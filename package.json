{
  "name": "christianmacion-portfolio",
  "type": "module",
  "version": "3.5.0",
  "private": true,
  "description": "Christian T. Macion — AI Engineer + Quantitative Researcher. Personal portfolio site.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "lint:md": "markdownlint-cli2 \"src/content/**/*.md\"",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{js,ts,tsx,jsx,astro,md,mdx,json,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,jsx,astro,md,mdx,json,css,yml,yaml}\"",
    "knip": "knip --no-progress",
    "prebuild": "node scripts/build-og-image.mjs && node scripts/optimize-assets.mjs",
    "build": "astro build",
    "postbuild": "node scripts/asset-audit.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "audit": "tsx src/utils/nda-audit.ts",
    "version:bump": "tsx scripts/bump-version.ts",
    "sitemap:check": "tsx scripts/validate-sitemap.ts",
    "typecheck": "astro check",
    "ci": "npm run lint:md && npm run lint && npm run format:check && npm run knip && npm run build && npm run audit && npm run sitemap:check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "astro": "^7.0.0",
    "astro-expressive-code": "^0.44.0",
    "astro-icon": "^1.1.5",
    "katex": "^0.17.0",
    "lightweight-charts": "^5.2.0",
    "lucide": "^1.23.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.33.5",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^15.0.0",
    "knip": "^6.25.0",
    "markdownlint-cli2": "^0.20.0",
    "prettier": "^3.9.0",
    "prettier-plugin-astro": "^0.14.0",
    "tsx": "^4.23.0",
    "typescript-eslint": "^8.63.0"
  }
}
