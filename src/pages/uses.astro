---
/**
 * uses.astro — v2.0 · polished /uses page (Werkzeug, Swyx, Bryan Cantrill school).
 *
 * Seven structured sections. Each row is `tool name` + `category tag` +
 * `why this and not that`. Updated 2026-07-09.
 *
 * Sections (left-to-right is "concrete → abstract"):
 *   1. Hardware
 *   2. Editor & OS
 *   3. Language toolchain
 *   4. Data vendors (free / open)
 *   5. Hosting & CDN
 *   6. Monitoring & analytics (none)
 *   7. MDX / Astro toolchain
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CTABanner from '@components/CTABanner.astro';
import { path } from '@utils/url';
import VoiceLine from '@components/VoiceLine.astro';

const lastUpdated = '2026-07-09';

interface UseRow {
  name: string;
  detail: string;
  tag: string;
  why: string;
}
interface UseSection {
  id: string;
  title: string;
  blurb?: string;
  items: UseRow[];
}

const sections: UseSection[] = [
  {
    id: 'hardware',
    title: 'Hardware',
    blurb: 'The metal. Two screens, one keyboard, one phone for comms only.',
    items: [
      {
        name: 'MacBook Pro 14" (M-series)',
        detail: 'Primary laptop',
        tag: 'compute',
        why: 'Apple silicon compiles Python + Astro + KaTeX in seconds; battery + instant resume are non-negotiable.',
      },
      {
        name: 'LG 27" 4K UltraFine',
        detail: 'External display',
        tag: 'display',
        why: 'Single-column reading at 1× and a multi-pane code/terminal at 2× — the only monitor spec that matters.',
      },
      {
        name: 'Standard Android',
        detail: 'Phone',
        tag: 'comms',
        why: 'Not on the engineering loop; a phone is a comms device, not a workstation.',
      },
    ],
  },
  {
    id: 'editor-os',
    title: 'Editor & OS',
    blurb: 'Modal editing, GPU terminal, themeable shell. Nothing in this section is new since 2024.',
    items: [
      {
        name: 'Neovim (LazyVim)',
        detail: 'Editor',
        tag: 'editor',
        why: 'LSP for Python / TypeScript / MDX, modal editing, and zero startup tax — the only editor that has never broken a flow.',
      },
      {
        name: 'Ghostty',
        detail: 'Terminal',
        tag: 'terminal',
        why: 'GPU-accelerated, low-latency, minimal chrome. iTerm2 was good until Ghostty was free.',
      },
      {
        name: 'zsh + oh-my-zsh + starship',
        detail: 'Shell + prompt',
        tag: 'shell',
        why: 'Portable across macOS sessions, themeable, and fast — the shell is upstream of the prompt.',
      },
      {
        name: 'git + gh + delta',
        detail: 'Version control CLI',
        tag: 'vcs',
        why: 'gh for GitHub-aware workflows (PRs, releases, issue triage); delta for diffs that are actually readable.',
      },
    ],
  },
  {
    id: 'language',
    title: 'Language toolchain',
    blurb: 'Python + TypeScript + SQL + Pine Script. No TA-Lib, no Lean, no backtrader — the point of the projects is shipping the engine from scratch.',
    items: [
      {
        name: 'Python',
        detail: 'numpy / pandas / matplotlib / scipy',
        tag: 'python',
        why: '~76.5k LOC of the public work. Pure stdlib math — no TA-Lib, no Lean, no backtrader.',
      },
      {
        name: 'TypeScript / JavaScript',
        detail: 'Astro / MDX / KaTeX',
        tag: 'typescript',
        why: 'This site. Astro static-first is the right tool for a content-heavy portfolio with no runtime needs.',
      },
      {
        name: 'SQL',
        detail: 'postgres + sqlite + DuckDB (parquet on-disk)',
        tag: 'sql',
        why: 'DuckDB increasingly replaces pandas for parquet-native analysis; sqlite remains the local default.',
      },
      {
        name: 'Pine Script',
        detail: 'TradingView',
        tag: 'dsl',
        why: 'For the charting side when working with non-Python researchers; not a research language, a sharing format.',
      },
    ],
  },
  {
    id: 'data',
    title: 'Data vendors (free / open)',
    blurb: 'Every artifact in /projects and /positions is reproducible from the sources below. No proprietary data.',
    items: [
      {
        name: 'Yahoo Finance (yfinance)',
        detail: 'Equities & ETFs',
        tag: 'equities',
        why: 'Free, point-in-time after revision-history check. Passes G22 of the eval stack with the embargo pattern.',
      },
      {
        name: 'CoinGecko / Binance public klines',
        detail: 'BTC/USDT 1d (and 18 altcoins)',
        tag: 'crypto',
        why: 'For the /positions paper-trade record. Public, no auth, deterministic on a symbol seed.',
      },
      {
        name: 'FRED (St. Louis Fed)',
        detail: 'Macro series',
        tag: 'macro',
        why: 'VIX percentile, fed funds, CPI — the macro overlay inputs. Free, public, revision-history-aware.',
      },
      {
        name: 'EDGAR / SEC filings',
        detail: 'Issuer fundamentals',
        tag: 'fundamentals',
        why: 'Primary-source fundamentals when the artifact needs them. XBRL is ugly; the truthfulness is the point.',
      },
      {
        name: 'Public CME / CBOE chains',
        detail: 'Options chains',
        tag: 'derivatives',
        why: 'Where options data is needed. Free, no auth, but chain histories are patchy — G22 gates it accordingly.',
      },
    ],
  },
  {
    id: 'hosting',
    title: 'Hosting & CDN',
    blurb: 'Free tier, fast, tied to the commit history. Custom domain planned.',
    items: [
      {
        name: 'Cloudflare Pages',
        detail: 'Primary hosting (CDN edge)',
        tag: 'hosting',
        why: 'Primary live URL is the Cloudflare Pages mirror; CDN edge is reliable in PH/sandbox where GH Pages is not.',
      },
      {
        name: 'GitHub Pages',
        detail: 'Secondary / fallback',
        tag: 'hosting',
        why: 'Kept as a fallback for redundancy; not the primary live URL after the regional edge incident.',
      },
      {
        name: 'GitHub Actions',
        detail: 'CI: build + deploy + NDA audit',
        tag: 'ci',
        why: 'Build-time NDA guardrail (`src/utils/nda-audit.ts`) fails the build on any violation — the guardrail is the CI step.',
      },
    ],
  },
  {
    id: 'monitoring',
    title: 'Monitoring & analytics',
    blurb: 'None. By design.',
    items: [
      {
        name: 'No third-party analytics',
        detail: 'No Google Analytics, no Plausible, no Fathom',
        tag: 'privacy',
        why: 'Privacy-by-default; the audience signal that matters (recruiter / founder email) is captured by direct contact, not by JS pixels.',
      },
      {
        name: 'No uptime monitor',
        detail: 'No external pinger',
        tag: 'privacy',
        why: 'Static site on a CDN edge — when it goes down, the CDN itself is the canary. Adding a third-party monitor would defeat the privacy posture.',
      },
      {
        name: 'No error tracking',
        detail: 'No Sentry, no LogRocket',
        tag: 'privacy',
        why: 'There is no client runtime to throw client errors. The only errors that matter are build-time and NDA-audit catches those.',
      },
    ],
  },
  {
    id: 'mdx-astro',
    title: 'MDX / Astro toolchain',
    blurb: 'The build pipeline for this site. Static-first; zero JS by default.',
    items: [
      {
        name: 'Astro 7',
        detail: 'Static site generator',
        tag: 'framework',
        why: 'Static-first, zero-JS by default, content-collections + MDX for the /projects corpus. The right tool for a content-heavy portfolio.',
      },
      {
        name: 'KaTeX',
        detail: 'Math typesetting (server + client)',
        tag: 'math',
        why: 'Server-side for /methodology, /projects, /now; client-side for inline use. Discord-style [ ] delimiters where MDX risks eating braces.',
      },
      {
        name: 'Inter + JetBrains Mono',
        detail: 'UI/body + data/math typefaces',
        tag: 'type',
        why: 'Inter for UI, JetBrains Mono for data and code. Two typefaces, two roles, no third family.',
      },
      {
        name: 'sharp + astro-expressive-code',
        detail: 'Asset pipeline + code blocks',
        tag: 'pipeline',
        why: 'sharp for image optimization; expressive-code for the syntax-highlighted code blocks in the /proof artifacts.',
      },
      {
        name: 'Vanilla CSS (tokens.css + global.css)',
        detail: 'No Tailwind, no CSS-in-JS',
        tag: 'styles',
        why: 'Design tokens are CSS custom properties; the dark-mode flip is a media query, not a JS library. Total CSS budget < 12KB.',
      },
    ],
  },
];---

<BaseLayout
  title="Uses"
  description="The hardware, software, and AI tooling used to ship the projects, methodology, and this site. Updated 2026-07-09."
  breadcrumbs={[{ name: "Home", href: "/" }, { name: "Uses", href: "/uses" }]}
>
  <header class="uses-head">
    <div class="container">
      <p class="section__eyebrow">
        <span class="mono">uses/</span> · last updated {lastUpdated}
      </p>
      <h1 class="uses-head__title">
        What I use to <span class="hl">do the work</span>.
      </h1>
      <VoiceLine class="uses-head__voice">
        A working researcher's stack — not a 2018-era ML engineer's. Updated quarterly.
      </VoiceLine>
      <p class="uses-head__sub">
        The /uses pattern — named, dated, no marketing. Recruiter signal: this is a working
        researcher's stack, not a 2018-era ML engineer's. Update cadence is quarterly or on
        tooling event. Every row is `tool name` · `category tag` · `why this and not that`.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      {/* Section TOC — quick jump to each section */}
      <nav class="uses-toc" aria-label="Uses sections">
        {
          sections.map((s) => (
            <a class="uses-toc__link mono" href={`#${s.id}`}>
              {s.title}
            </a>
          ))
        }
      </nav>

      {
        sections.map((s) => (
          <article id={s.id} class="uses-block">
            <header class="uses-block__head">
              <h2 class="uses-block__title">{s.title}</h2>
              {s.blurb && <p class="uses-block__blurb">{s.blurb}</p>}
            </header>
            <ul class="uses-list">
              {s.items.map((item) => (
                <li class="uses-row">
                  <div class="uses-row__name mono">{item.name}</div>
                  <div class="uses-row__tag">
                    <span class="pill pill--accent">{item.tag}</span>
                    <span class="uses-row__detail mono">{item.detail}</span>
                  </div>
                  <div class="uses-row__why">{item.why}</div>
                </li>
              ))}
            </ul>
          </article>
        ))
      }

      <div class="uses-foot mono">
        Inspired by the <a href="https://uses.tech" target="_blank" rel="noopener">/uses</a> tradition.
        Edit history:
        <a
          href="https://github.com/christianmacion26/portfolio/commits/main/src/pages/uses.astro"
          target="_blank"
          rel="noopener">github commits</a
        >.
      </div>
    </div>
  </section>

  <CTABanner
    title="Specific question about the stack?"
    sub="If a JD asks for a tool I use, I'll attach the relevant /uses entry plus a runnable reproduction."
    primaryLabel="Email me"
    secondaryLabel="Methodology"
    secondaryHref={path('/methodology')}
  />
</BaseLayout>

<style>
  .uses-head {
    padding-block: var(--sp-9) var(--sp-7);
    background:
      var(--c-bg);
    border-bottom: var(--border);
  }
  .uses-head__title {
    font-size: clamp(2.25rem, 5vw, 4rem);
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-block: var(--sp-4) var(--sp-5);
    max-width: 22ch;
  }
  .uses-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 60ch;
  }
  .uses-head__voice {
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
}
  /* === Section TOC === */
  .uses-toc {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-6);
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--c-rule-soft);
  }
  .uses-toc__link {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-primary-2-deep);
    padding: var(--sp-2) var(--sp-3);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-sm);
    text-decoration: none;
    background: var(--c-bg);
  }
  .uses-toc__link:hover {
    background: var(--c-amber-deep);
    color: var(--c-primary);
    border-color: var(--c-amber);
  }

  /* === Section block === */
  .uses-block {
    margin-bottom: var(--sp-6);
    padding: var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-left: 3px solid var(--c-primary);
    border-radius: var(--radius);
    scroll-margin-top: 80px;
  }
  .uses-block__head {
    margin-bottom: var(--sp-4);
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--c-rule-soft);
  }
  .uses-block__title {
    font-size: var(--fs-lg);
    color: var(--c-ink);
    margin: 0 0 var(--sp-1);
    letter-spacing: -0.01em;
  }
  .uses-block__blurb {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin: 0;
  }
  .uses-list {
    list-style: none;
    padding: 0;
  }
  .uses-row {
    display: grid;
    grid-template-columns: 200px 1fr 1.4fr;
    gap: var(--sp-4);
    padding: var(--sp-3) 0;
    border-bottom: 1px dashed var(--c-rule-soft);
    align-items: start;
  }
  .uses-row:last-child {
    border-bottom: none;
  }
  .uses-row__name {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--c-ink);
  }
  .uses-row__tag {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-2);
  }
  .uses-row__detail {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    letter-spacing: 0.04em;
  }
  .uses-row__why {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
  }

  .uses-foot {
    margin-top: var(--sp-6);
    padding: var(--sp-3) var(--sp-4);
    background: var(--c-paper);
    border: 1px dashed var(--c-rule);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    color: var(--c-ink-3);
  }
  .uses-foot a {
    color: var(--c-primary-2-deep);
    text-decoration: underline;
  }

  @media (max-width: 720px) {
    .uses-row {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
    }
  }
</style>
