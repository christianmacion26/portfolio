            href={c.href}
          />
        ))}
      </div>
    </div>
  </section>

  {/* =========================================================
      P.4 — Research artifacts (9 quant · 6 AI · 10 solutions)
      Filter bar: Topic × Type. Client-side, URL query sync.
      ========================================================= */}
  <section
    class="section"
    id="research"
    data-toc-id="research"
    data-toc-label="Research artifacts"
    data-reveal
    data-filter-host
    data-active-topic="all"
    data-active-type="all"
  >
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">P.4 · Research artifacts</p>
        <h2 class="section__title">
          9 quant · 6 AI · 10 solutions. <span class="mono">All public-data reproducible.</span>
        </h2>
        <p class="section__sub">
          Compact list rendering (AQR-Insights style). Each row links to the project or solution
          detail page; metrics come from the project frontmatter, not invented. Filter chips narrow
          the gallery by topic and asset type.
        </p>
      </header>

      {/* === Filter bar: Topic × Type === */}
      <div class="filter-bar" role="group" aria-label="Filter proof artifacts by topic and type">
        <div class="filter-bar__row">
          <span class="filter-bar__label mono">Topic</span>
          <div class="filter-bar__chips" data-filter-axis="topic">
            <button type="button" class="filter-chip mono is-active" data-filter-value="all" aria-pressed="true">All</button>
            <button type="button" class="filter-chip mono" data-filter-value="quant" aria-pressed="false">Quant</button>
            <button type="button" class="filter-chip mono" data-filter-value="ai" aria-pressed="false">AI</button>
            <button type="button" class="filter-chip mono" data-filter-value="oss" aria-pressed="false">OSS</button>
          </div>
        </div>
        <div class="filter-bar__row">
          <span class="filter-bar__label mono">Type</span>
          <div class="filter-bar__chips" data-filter-axis="type">
            <button type="button" class="filter-chip mono is-active" data-filter-value="all" aria-pressed="true">All</button>
            <button type="button" class="filter-chip mono" data-filter-value="code" aria-pressed="false">Code</button>
            <button type="button" class="filter-chip mono" data-filter-value="writeup" aria-pressed="false">Writeup</button>
            <button type="button" class="filter-chip mono" data-filter-value="talk" aria-pressed="false">Talk</button>
            <button type="button" class="filter-chip mono" data-filter-value="live-demo" aria-pressed="false">Live demo</button>
          </div>
        </div>
      </div>

      {/* Quant projects */}
      <h3 class="proof-list__heading">Quant projects — 9</h3>
      <ol
        class="proof-list proof-list--paged"
        aria-label="Quant research projects"
        data-paged-list
        data-page-size={PAGE_SIZE}
      >
        {
          paginate(quantProjects).map(({ item: p, page }) => {
            const m = formatProjectMetric(p);
            const date = p.data.date
              ? new Date(p.data.date).toLocaleDateString('en-US', {
                  month: 'short',
                  year: 'numeric',
                })
              : '';
            const dateIso = p.data.date
              ? new Date(p.data.date).toISOString().slice(0, 10)
              : '';
            const topic = projectTopic(p);
            const assetType = projectType(p);
            const isOss = p.data.status === 'open-source';
            const si = statusInfo(p.data.status);
            return (
              <li
                class="proof-list__row"
                data-page-index={page}
                data-topic={topic ?? 'oss'}
                data-oss={isOss ? 'true' : 'false'}
                data-assettype={assetType ?? 'writeup'}
              >
                <div class="proof-list__pills" aria-label="Project metadata">
                  {si && <span class:list={['pill', `pill--${si.tone}`]}>{si.label}</span>}
                  {dateIso && <span class="proof-list__pills-sep mono" aria-hidden="true">·</span>}
                  {dateIso && <span class="pill pill--mute mono">{dateIso}</span>}
