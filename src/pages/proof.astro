  <header class="proof-head" id="identity" data-toc-id="identity" data-toc-label="Identity" data-reveal>
    <div class="container container-narrow">
      <p class="section__eyebrow"><span class="mono">proof/</span> · show your work</p>
      <h1 class="proof-head__title">
        Proof. <span class="hl">Public or self-owned only</span>.
      </h1>
      <VoiceLine class="proof-head__voice">
        If it isn't reproducible from public data, it isn't here.
      </VoiceLine>

      {/* v6.3 polish — headline stats moved ABOVE the carousel + motif
         so all four numeric cells (22 / 9 / 6 / 10) are visible above
         the 800 px desktop fold. The audit's density check needs ≥ 4
         filled data cells; previously the stats sat below the fold
         because the carousel + brand-motif + paragraph together push
         ~700 px of decoration before the numbers arrive. Each stat
         still gets data-counter so the odometer fires on scroll-in. */}
      <ul class="proof-head__stats" aria-label="Proof-page at-a-glance counts">
        <li class="proof-head__stat">
          <span class="proof-head__stat-num tnum" data-counter="22">22</span>
          <span class="proof-head__stat-lbl mono">artifacts on this page</span>
        </li>
        <li class="proof-head__stat">
          <span class="proof-head__stat-num tnum" data-counter="9">9</span>
          <span class="proof-head__stat-lbl mono">quant projects</span>
        </li>
        <li class="proof-head__stat">
          <span class="proof-head__stat-num tnum" data-counter="6">6</span>
          <span class="proof-head__stat-lbl mono">AI projects</span>
        </li>
        <li class="proof-head__stat">
          <span class="proof-head__stat-num tnum" data-counter="10">10</span>
          <span class="proof-head__stat-lbl mono">case studies</span>
        </li>
      </ul>

      {/* === Proof discipline carousel — six core rules, rotating === */}
      <div class="proof-head__carousel">
        <StatementCarousel
          statements={[
            'Every cert links to its issuer. No exceptions.',
            'Every claim links to a public artifact or a self-owned file.',
            'Every project ships with the runnable code, not a slide deck.',
            'Every metric is real. Headline numbers come from disk.',
            'Every testimonial is an attestable paper trail, not a quote.',
            'Every NDA-protected engagement is closed past contract.',
          ]}
          label="Proof discipline — six rules, rotating"
          intervalMs={3000}
