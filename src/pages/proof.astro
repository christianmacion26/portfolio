      <div class="proof-head__motif">
        <BrandMotif width={320} caption="proof/ · G1–G31 gates emit the artefacts below" />
      </div>
      <p class="proof-head__sub">
        A gallery of public, NDA-clean artifacts — records, charts, co-signed certificates —
        that back up the claims on
        <a href={path('/experience')}>/experience</a>,
        <a href={path('/certifications')}>/certifications</a>,
        and <a href={path('/now')}>/now</a>. Thirty-one artifacts on disk, twenty-two surfaced below.
        Updated when something new ships; never deleted when something expires.
      </p>

      <p class="proof-head__ver mono">{proofVersion} · {buildStampUtc8()}</p>
