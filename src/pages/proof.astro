                </div>
                <a class="proof-list__title" href={path(`/projects/${p.id}`)}>
                  <span class="proof-list__kind mono">QUANT</span>
                  <span class="proof-list__name">{p.data.title}</span>
                  {m && (
                    <span class="proof-list__metric mono">
                      <span class="proof-list__metric-val">{m.value}</span>
                      <span class="proof-list__metric-lbl">{m.label}</span>
                    </span>
                  )}
                  <span class="proof-list__date mono">{date}</span>
                  <span class="proof-list__arrow mono" aria-hidden="true">→</span>
                </a>
                {p.data.summary && (
                  <p class="proof-list__summary">{p.data.summary}</p>
