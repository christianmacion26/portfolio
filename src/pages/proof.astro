/**
 * proof.astro — the proof spine. v5.3 six-section narrative.
 *
 * Order matters. Each section is a "tier" of proof depth:
 *   P.1 Identity              — who, on disk
 *   P.2 Flagship credentials  — Tier-1 cert flagships
 *   P.3 Shipped code          — the eval-first artifacts in code
 *   P.4 Research artifacts    — 9 quant + 6 AI + 10 solutions lists
 *   P.5 Public track record   — lectures, charts, RSS
 *   P.6 Disclosure + contact  — what's not here, and how to ask
 *
 * Data sources for sections P.4 below are loaded from content collections.
 * Sub-page routing anchors at #identity / #credentials / #code / #research / #track.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ProofCard from '@components/ProofCard.astro';
import CodeProofCard from '@components/CodeProofCard.astro';
import FlagshipCard from '@components/FlagshipCard.astro';
import BrandMotif from '@components/BrandMotif.astro';
import VideoEmbed from '@components/VideoEmbed.astro';
import CTABanner from '@components/CTABanner.astro';
import ReadMeta from '@components/ReadMeta.astro';
import TrustStrip from '@components/TrustStrip.astro';
import SectionTOC from '@components/SectionTOC.astro';
import VoiceLine from '@components/VoiceLine.astro';
import StatementCarousel from '@components/StatementCarousel.astro';
import { getCollection } from 'astro:content';
import { path } from '@utils/url';
import { profile } from '@utils/profile';
import { buildStampUtc8 } from '@utils/build-stamp';
import pkg from '../../package.json';
const proofVersion = `v${pkg.version}`;

// === Data: 4 flagship credentials (3 from certGroup.featured* + 1 standalone Bitget) ===
const certGroups = (await getCollection('certGroup')).sort((a, b) => a.data.order - b.data.order);
const flagshipCerts = certGroups
  .filter((g) => g.data.featuredImg)
  .map((g) => ({
    group: g.data.group,
    title: g.data.title,
    blurb: g.data.blurb,
    src: g.data.featuredImg!,
    alt: g.data.featuredAlt ?? `${g.data.title} flagship certificate`,
    caption: g.data.featuredCaption ?? g.data.blurb,
    href: g.data.featuredHref ?? path('/certifications'),
  }));

// === Data: 4 CodeProofCard entries (3 v3.5 + 1 eval-mcp-server) ===
const codeArtifacts = [
  {
    title: 'mcp-backtest-server',
    kind: 'MCP server' as const,
    tagline: 'IP-clean backtest tools over the Model Context Protocol. Three tools, four textbook strategies, zero market data.',
    metric: '100% offline · 4 strategies · 0 lines of proprietary data',
    preview: `$ uv run server.py
# FastMCP server listening on stdio
{"tools":["get_ohlcv","run_backtest","compute_metrics"]}`,
    outputLines: [
      'smoke · 262 bars returned',
      'sma_cross sharpe=0.471 cagr=0.079 max_dd=-0.21',
      'buy_and_hold sharpe=-0.490',
      'PASS · deterministic from symbol seed',
    ],
    repoPath: '~/portfolio_v2/mcp-backtest-server/',
    href: 'https://github.com/christianmacion26/portfolio_v2/tree/master/mcp-backtest-server',
  },
  {
    title: 'qfin-rag-harness',
    kind: 'Python package' as const,
    tagline: 'Citation-grounded retrieval harness over a curated corpus of 16 canonical q-fin papers. Pure-Python TF-IDF cosine, no LLM call.',
    metric: '16 papers · 0 API keys · 0 LLM dependency',
    preview: `$ python -m qfin_rag "How do I correct factor significance for data mining?"

# Citations for: How do I correct ...
## Harvey (2016) — And the Cross-Section ...
*Review of Financial Studies, 2016* (relevance: 0.173)`,
    outputLines: [
      'query → 16-paper curated corpus',
      'top-3 by TF-IDF cosine',
      'citation-grounded prompt template',
      'NO network calls',
    ],
    repoPath: '~/portfolio_v2/qfin-rag-harness/',
    href: 'https://github.com/christianmacion26/portfolio_v2/tree/master/qfin-rag-harness',
  },
  {
    title: 'numerical-faithfulness-eval',
    kind: 'Eval harness' as const,
    tagline: 'Verify LLM numerical claims against deterministic fixtures. Catches the most common LLM failure mode — wrong numbers — in under one second.',
    metric: '10 demo claims · 5 pass · 5 fail by design',
    preview: `$ python -m eval_harness
[FAIL] btc_2024_sma_cross_20_50 / sharpe: claimed=5.0,
       truth=0.4707, diff=4.5293 > tol 0.05
=== summary ===
  5/10 passed (50.0%)`,
    outputLines: [
      'fixtures computed deterministically from seeded backtest',
      'tolerances per metric (Sharpe atol=0.05, CAGR=0.02)',
      'per-claim reason + diff vs tolerance',
      'exit code = number of failed claims',
    ],
    repoPath: '~/portfolio_v2/numerical-faithfulness-eval/',
    href: 'https://github.com/christianmacion26/portfolio_v2/tree/master/numerical-faithfulness-eval',
  },
  {
    title: 'eval-mcp-server',
    kind: 'MCP server' as const,
    tagline: 'Slop-evaluation gate exposed as an MCP tool. Tools / Resources / Prompts — 20/20 conformance, 100% round-trip parity.',
    metric: 'MCP conformance 20/20 · round-trip parity 100% · primitives 3/3',
    preview: `$ uv run eval_mcp_server.py
# MCP server with the slop-evaluation gate
{"primitives":["tools","resources","prompts"],
 "tools":["evaluate_text","score_metrics","emit_report"]}`,
    outputLines: [
      '20/20 conformance cases pass',
      'round-trip parity across all 3 primitives',
      'Tools · Resources · Prompts all live',
      'PASS · slop score reproducible per call',
    ],
    repoPath: '~/portfolio_v2/eval-mcp-server/',
    href: 'https://github.com/christianmacion26/eval-mcp-server',
  },
];

// === Data: 9 quant + 6 AI projects + 10 solutions, surfaced as compact rows ===
const projects = (await getCollection('project')).sort((a, b) => a.data.order - b.data.order);
const quantProjects = projects.filter((p) => p.data.role === 'quant');
const aiProjects = projects.filter((p) => p.data.role === 'ai');
const solutions = (await getCollection('solution')).sort((a, b) => a.data.order - b.data.order);

const formatProjectMetric = (p: typeof projects[number]) => {
  if (!p.data.metrics?.length) return null;
  const first = p.data.metrics[0];
  return { label: first.label, value: first.value, sub: first.sub };
};

const formatSolutionMetric = (s: typeof solutions[number]) =>
  s.data.evidence?.[0] ?? s.data.outcome.slice(0, 80);

// === Status → tone + label mapping (for status pills) ===
// production → Live (green), open-source → Open Source (amber),
// internal → Internal (monochrome · F14 institutional), archived → Archived (gray).
type StatusTone = 'pass' | 'warn' | 'mute';
type StatusInfo = { label: string; tone: StatusTone };
const STATUS_MAP: Record<string, StatusInfo> = {
  production: { label: 'Live', tone: 'pass' },
  'open-source': { label: 'Open Source', tone: 'warn' },
  internal: { label: 'Internal', tone: 'mute' },
  archived: { label: 'Archived', tone: 'mute' },
};
const statusInfo = (s?: string): StatusInfo | null => (s && STATUS_MAP[s]) || null;

// === Filter attributes (Topic × Type) ===
// Topic: quant | ai | oss (solutions get topic from their lane)
// Type: code | writeup | talk | live-demo
const projectTopic = (p: typeof projects[number]) => p.data.topic ?? null;
const projectType = (p: typeof projects[number]) => p.data.assetType ?? null;
const solutionTopic = (s: typeof solutions[number]): 'quant' | 'ai' | 'oss' | null => {
  if (s.data.lane === 'quant' || s.data.lane === 'ai') return s.data.lane;
  // education / systems lanes are public writeups → OSS
  return 'oss';
};
const solutionType = (_s: typeof solutions[number]) => 'writeup' as const;

// === Per-list pagination: page size 6 ===
const PAGE_SIZE = 6;
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const paginate = (items: any[]) => {
  // pinned first, then in original order
  const sorted = [...items].sort((a, b) => {
    const ap = a.data.pinned ? 1 : 0;
    const bp = b.data.pinned ? 1 : 0;
    if (ap !== bp) return bp - ap;
    return a.data.order - b.data.order;
  });
  return sorted.map((item, idx) => {
    let page: number;
    if (idx < PAGE_SIZE) {
      // page 1 = pinned + first (PAGE_SIZE - pinnedCount) unpinned
      page = 1;
    } else {
      const offset = idx - PAGE_SIZE;
      page = 2 + Math.floor(offset / PAGE_SIZE);
    }
    return { item, page };
  });
};
