      <div class="proof-grid proof-grid--code">
        {codeArtifacts.map((c) => (
          <CodeProofCard
            title={c.title}
            kind={c.kind}
            tagline={c.tagline}
            metric={c.metric}
            preview={c.preview}
            outputLines={c.outputLines}
