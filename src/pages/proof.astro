    background: var(--c-bg-2);
  }
  .ptr__cell--platform {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--c-primary);
  }
  .ptr__cell--handle {
    font-size: var(--fs-sm);
    color: var(--c-primary-2-deep);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ptr__cell--empty {
    color: var(--c-ink-3);
    font-style: italic;
    font-size: var(--fs-xs);
  }
  .ptr__cell--metric {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ptr__cell--link {
    font-size: var(--fs-xs);
    text-align: right;
  }
  .ptr__link {
    color: var(--c-primary);
    text-decoration: underline;
    text-decoration-color: var(--c-rule-strong);
    text-underline-offset: 3px;
  }
  .ptr__link:hover {
    color: var(--c-primary-2-deep);
    text-decoration-color: var(--c-primary-2-deep);
  }

  /* === Responsive overrides === */
  @media (max-width: 720px) {
    .filter-bar__row {
      gap: var(--sp-2);
    }
    .filter-bar__label {
      min-width: 100%;
    }
    .ptr__row {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
      padding: var(--sp-3) 0;
    }
    .ptr__cell--platform {
      font-size: var(--fs-base);
    }
    .ptr__cell--link {
      text-align: left;
    }
  }
</style>

<script>
  /**
   * /proof client-side: Topic × Type filter chips and per-list pagination.
   * No URL routing on the page; the filter persists via ?topic= and ?type=.
   */
  (() => {
    const host = document.querySelector<HTMLElement>('[data-filter-host]');
    if (!host) return;

    // === Filter chips ===
    const params = new URLSearchParams(window.location.search);
    const validTopic = new Set(['all', 'quant', 'ai', 'oss']);
    const validType = new Set(['all', 'code', 'writeup', 'talk', 'live-demo']);
    const initialTopic = validTopic.has(params.get('topic') ?? '')
      ? (params.get('topic') as string)
      : 'all';
    const initialType = validType.has(params.get('type') ?? '')
      ? (params.get('type') as string)
      : 'all';

    const applyFilter = (axis: 'topic' | 'type', value: string) => {
      host.dataset[axis === 'topic' ? 'activeTopic' : 'activeType'] = value;
      // Update chip state.
      const axisHost = host.querySelector<HTMLElement>(
        `[data-filter-axis="${axis}"]`,
      );
      axisHost?.querySelectorAll<HTMLButtonElement>('.filter-chip').forEach((c) => {
        const active = c.dataset.filterValue === value;
        c.classList.toggle('is-active', active);
        c.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      // Update URL.
      const next = new URLSearchParams(window.location.search);
      if (value === 'all') next.delete(axis);
      else next.set(axis, value);
      const qs = next.toString();
      const url = window.location.pathname + (qs ? `?${qs}` : '') + window.location.hash;
      window.history.replaceState(null, '', url);
    };

    host.querySelectorAll<HTMLElement>('.filter-bar__chips').forEach((group) => {
      const axis = group.dataset.filterAxis as 'topic' | 'type' | undefined;
      if (!axis) return;
      group.querySelectorAll<HTMLButtonElement>('.filter-chip').forEach((chip) => {
        chip.addEventListener('click', () => {
          const v = chip.dataset.filterValue ?? 'all';
          applyFilter(axis, v);
          // After filter, re-paginate so the chips reflect the visible count.
          rehydratePagers();
        });
      });
    });

    // Apply initial filter (from URL query).
    applyFilter('topic', initialTopic);
    applyFilter('type', initialType);

    // === Per-list pagination ===
    type Pager = { list: HTMLElement; pager: HTMLElement; pageSize: number; current: number };
    const pagers: Pager[] = [];
    document.querySelectorAll<HTMLElement>('[data-paged-list]').forEach((list) => {
      const pager = list.parentElement?.querySelector<HTMLElement>('[data-pager]');
      if (!pager) return;
      const pageSize = Number(list.dataset.pageSize ?? 6);
      const rows = Array.from(list.querySelectorAll<HTMLElement>('.proof-list__row'));
      const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
      // If only one page, keep pager hidden.
      if (totalPages <= 1) {
        pager.hidden = true;
        return;
      }
      const pg: Pager = { list, pager, pageSize, current: 1 };
      pagers.push(pg);
      renderPager(pg, totalPages);
    });

    function renderPager(pg: Pager, totalPages: number) {
      pg.pager.innerHTML = '';
      const make = (label: string, page: number | null, opts: { active?: boolean; disabled?: boolean } = {}) => {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'proof-pager__chip mono' + (opts.active ? ' is-active' : '');
        b.textContent = label;
        if (opts.disabled || page === null) {
          b.setAttribute('disabled', 'true');
          b.setAttribute('aria-disabled', 'true');
        } else {
          b.addEventListener('click', () => {
            pg.current = page;
            showPage(pg);
            renderPager(pg, totalPages);
          });
        }
        if (opts.active) b.setAttribute('aria-current', 'page');
        return b;
      };
      for (let i = 1; i <= totalPages; i++) {
        pg.pager.appendChild(make(String(i), i, { active: i === pg.current }));
      }
      const next = pg.current < totalPages ? pg.current + 1 : null;
      pg.pager.appendChild(make('›', next, { disabled: next === null }));
      pg.pager.hidden = false;
    }

    function showPage(pg: Pager) {
      const rows = pg.list.querySelectorAll<HTMLElement>('.proof-list__row');
      rows.forEach((row) => {
        const idx = Number(row.dataset.pageIndex ?? 1);
        row.style.display = idx === pg.current ? '' : 'none';
      });
    }

    function rehydratePagers() {
      // After a filter change, the rows hidden by CSS are still in the DOM.
      // Re-compute which rows are visible (in DOM order) and assign fresh
      // page indices to those, then re-render the pagers.
      pagers.forEach((pg) => {
        const allRows = Array.from(pg.list.querySelectorAll<HTMLElement>('.proof-list__row'));
        const visible = allRows.filter((r) => {
          // CSS rule may hide; we re-evaluate by reading computed display.
          return window.getComputedStyle(r).display !== 'none';
        });
        const totalPages = Math.max(1, Math.ceil(visible.length / pg.pageSize));
        if (totalPages <= 1) {
          pg.pager.hidden = true;
          // Show all visible rows on the only page.
          allRows.forEach((r) => {
            r.style.display = window.getComputedStyle(r).display === 'none' && r.dataset._filterHidden
              ? 'none'
              : '';
          });
          return;
        }
        pg.pager.hidden = false;
        // Assign temporary data-page-index to visible rows for the showPage step.
        visible.forEach((r, i) => {
          let page: number;
          if (i < pg.pageSize) page = 1;
          else page = 2 + Math.floor((i - pg.pageSize) / pg.pageSize);
          r.dataset.pageIndex = String(page);
        });
        // Reset to page 1 on filter change.
        pg.current = 1;
        showPage(pg);
        renderPager(pg, totalPages);
      });
    }

    // Initial show: respect pre-baked data-page-index.
    pagers.forEach((pg) => {
      // Mark rows that the CSS filter has hidden, so rehydrate knows not to
      // un-hide them.
      const all = pg.list.querySelectorAll<HTMLElement>('.proof-list__row');
      all.forEach((r) => {
        if (window.getComputedStyle(r).display === 'none') {
          r.dataset._filterHidden = '1';
        }
      });
      showPage(pg);
    });
  })();
</script>
