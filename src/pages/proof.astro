        {
          paginate(aiProjects).map(({ item: p, page }) => {
            const m = formatProjectMetric(p);
            const date = p.data.date
              ? new Date(p.data.date).toLocaleDateString('en-US', {
                  month: 'short',
                  year: 'numeric',
                })
              : '';
            const dateIso = p.data.date
              ? new Date(p.data.date).toISOString().slice(0, 10)
              : '';
            const topic = projectTopic(p);
            const assetType = projectType(p);
            const isOss = p.data.status === 'open-source';
            const si = statusInfo(p.data.status);
            return (
              <li
                class="proof-list__row"
                data-page-index={page}
