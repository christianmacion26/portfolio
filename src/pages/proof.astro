  description="Decision-grade artefacts that back the claims on /experience, /certifications, and /now. Tier-1 credentials, 4 open-source artifacts, 9 quant projects, 6 AI projects, 10 case studies — all NDA-clean by construction."
  type="profile"
  breadcrumbs={[{ name: "Home", href: "/" }, { name: "Proof", href: "/proof" }]}
  extraJsonLd={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Christian T. Macion — Proof',
    description:
      'Six-tier proof spine: P.1 identity · P.2 flagship credentials · P.3 shipped code · P.4 research artifacts · P.5 public track record · P.6 NDA-positive disclosure.',
    isPartOf: {
      '@type': 'WebSite',
      name: 'Christian T. Macion — Portfolio',
      url: 'https://christianmacion-portfolio.pages.dev/',
    },
    hasPart: [
      { '@type': 'CreativeWork', name: 'Tier-1 credentials (CTA, Ateneo + US Embassy, BIDA × Meta, Bitget)', url: 'https://christianmacion-portfolio.pages.dev/proof#credentials' },
      { '@type': 'SoftwareSourceCode', name: 'Shipped code (mcp-backtest-server, qfin-rag-harness, numerical-faithfulness-eval, eval-mcp-server)', url: 'https://christianmacion-portfolio.pages.dev/proof#code' },
      { '@type': 'ItemList', name: '9 quant projects + 6 AI projects + 10 case studies', url: 'https://christianmacion-portfolio.pages.dev/proof#research' },
      { '@type': 'CreativeWork', name: 'Public track record (lectures, charts, Atom feeds)', url: 'https://christianmacion-portfolio.pages.dev/proof#track' },
      { '@type': 'CreativeWork', name: 'External accounts (Numerai, HuggingFace, GitHub, TradingView, Medium)', url: 'https://christianmacion-portfolio.pages.dev/proof#public-track' },
      { '@type': 'DisclosureDocument', name: 'NDA-positive disclosure', url: 'https://christianmacion-portfolio.pages.dev/proof#disclosure' },
    ],
  }}
