  <SectionTOC
    label="On this proof page"
    items={[
      { id: 'credentials', label: 'Flagship credentials' },
      { id: 'code', label: 'Shipped code' },
      { id: 'research', label: 'Research artifacts' },
      { id: 'track', label: 'Track record' },
