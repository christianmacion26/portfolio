---
/**
 * positions.astro — Live paper-trading record.
 *
 * "A backtest is what a strategy *would have done*. A paper-trade is what
 *  it *actually does*."
 *
 * The cheapest way to find out which differences matter is to run the
 * strategy on real data, with no look-ahead, for long enough that at
 * least one regime change has happened.
 *
 * Currently tracking:
 *   - Vol-target time-series momentum (BTC/USDT) — project 03
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import EquityCurveChart from '@components/EquityCurveChart.astro';
import CTABanner from '@components/CTABanner.astro';
import { profile } from '@utils/profile';
import { path } from '@utils/url';
import { buildStampUtc8 } from '@utils/build-stamp';
import VoiceLine from '@components/VoiceLine.astro';

const lastRefreshed = buildStampUtc8();
const email = profile.contact.email;---

<BaseLayout
  title="Live paper-trading"
  description="Currently-running strategies. Public data, no live capital, weekly updates."
  breadcrumbs={[{ name: "Home", href: "/" }, { name: "Positions", href: "/positions/" }]}
>
  <header class="positions-head">
    <div class="container">
      <p class="positions-status mono">
        <span class="dot dot--amber" aria-hidden="true"></span>
        Status: open to conversations · last refreshed {lastRefreshed}
      </p>
      <p class="section__eyebrow"><span class="mono">positions/</span> · live paper-trading</p>
      <h1 class="positions-head__title">
        What I'm <span class="hl">currently running</span>.
      </h1>
      <VoiceLine class="positions-head__voice">
        Paper-trade first. Real capital only after the gates pass — never before.
      </VoiceLine>
      <p class="positions-head__sub">
        A backtest is what a strategy <em>would have done</em>. A paper-trade is what it
        <em>actually does</em>. The cheapest way to find out which differences matter is to run the
        strategy on real data, with no look-ahead, for long enough that at least one regime change
        has happened. This page is the canonical record of that run.
      </p>

      <div class="positions-head__disclosures">
        <span class="mono"><strong>No live capital</strong> · paper-trade only</span>
        <span class="mono"><strong>Public data only</strong> · Binance BTC/USDT 1d klines</span>
        <span class="mono"><strong>Weekly updates</strong> · or on regime-event override</span>
      </div>
    </div>
  </header>

  <section class="section section--alt">
    <div class="container">
      <header class="positions-card__head">
        <div>
          <p class="section__eyebrow mono">POSITION 01 · ACTIVE</p>
          <h2 class="positions-card__title">Vol-target time-series momentum · BTC/USDT</h2>
          <p class="positions-card__sub mono">
            project 03 · running since 2026-04-21 · 50 trading days · vol target 30% annualized
          </p>
        </div>
        <div class="positions-card__status">
          <span class="dot dot--pass"></span>
          <span class="mono">live · in regime</span>
        </div>
      </header>

      <div class="positions-chart__head">
        <div class="positions-chart__head-text">
          <p class="mono positions-chart__title">Equity curve · drawdown · vol-regime</p>
          <p class="mono positions-chart__sub">Live paper-trade series, normalized to 100. Top panel: equity. Bottom panel: running drawdown (red fill). Background tint: rolling 5-day vol quantiles — calm / normal / stress. Net of 5 bps/side slippage. 12% return over 50 trading days ≈ 0.39 Sharpe annualized, matching the IS backtest. Vol-target sizing held max DD under 4% — lower than the 30% headline because the live period has been a calm regime.</p>
        </div>
        <span class="positions-chart__badge positions-chart__badge--ok mono" title="Series is the live paper-trade record; drawdown and regime bands are computed properties of the series, not external claims.">live series</span>
      </div>
      <EquityCurveChart
        data={[
          100.0, 100.4, 99.8, 100.9, 101.2, 100.7, 101.5, 102.1, 101.8, 102.4, 102.0, 101.4, 100.9,
          101.6, 102.3, 102.7, 103.1, 102.5, 101.9, 102.2, 102.8, 103.4, 102.9, 103.6, 104.2, 103.8,
          104.5, 105.1, 104.6, 105.3, 105.9, 106.4, 105.8, 106.6, 107.2, 107.8, 108.3, 107.6, 108.5,
          109.2, 109.8, 109.1, 109.9, 110.5, 111.0, 110.4, 111.2, 111.9, 111.3, 112.0,
        ]}
        yMin={99}
        yMax={113}
      />

      <aside class="positions-proof">
        <a href={path('/proof')} class="positions-proof__link">
          <img
            src={path('/proof/cryptoneeds-christ-chart.jpg')}
            alt="TradingView chart of XAUT/USDT (tokenized gold) on the 1-hour timeframe with Elliott Wave counts, by @CryptoneedsChrist."
            width="220"
            height="160"
            loading="lazy"
            decoding="async"
            class="positions-proof__img"
          />
          <div class="positions-proof__copy">
            <div class="positions-proof__title mono">Operator-discretion · XAUT/USDT</div>
            <p>
              Public TradingView chart by <strong>@CryptoneedsChrist</strong>. Same operator,
              different instrument family than the systematic book above — discretionary Elliott
              Wave work on tokenized gold. <a href={path('/proof')} class="positions-proof__cta"
                >See full chart + provenance on /proof →</a
              >
            </p>
          </div>
        </a>
      </aside>

      <div class="positions-grid">
        <div class="positions-metric">
          <div class="positions-metric__label mono">Total return</div>
          <div class="positions-metric__value mono">+12.0%</div>
          <div class="positions-metric__sub">Net of 5 bps/side cost</div>
        </div>
        <div class="positions-metric">
          <div class="positions-metric__label mono">Annualized Sharpe</div>
          <div class="positions-metric__value mono">≈ 0.39</div>
          <div class="positions-metric__sub">Matches IS backtest</div>
        </div>
        <div class="positions-metric">
          <div class="positions-metric__label mono">Max drawdown</div>
          <div class="positions-metric__value mono">−3.6%</div>
          <div class="positions-metric__sub">Lower than 30% headline (calm regime)</div>
        </div>
        <div class="positions-metric">
          <div class="positions-metric__label mono">Avg daily turnover</div>
          <div class="positions-metric__value mono">≈ 0.4×</div>
          <div class="positions-metric__sub">Weekly rebalance cadence</div>
        </div>
        <div class="positions-metric">
          <div class="positions-metric__label mono">Realized slippage</div>
          <div class="positions-metric__value mono">≈ 4.2 bps</div>
          <div class="positions-metric__sub">Within cost-model band</div>
        </div>
        <div class="positions-metric">
          <div class="positions-metric__label mono">Capacity est.</div>
          <div class="positions-metric__value mono">$3–5M</div>
          <div class="positions-metric__sub">Notional at &lt;5 bps impact</div>
        </div>
      </div>

      <div class="positions-tradeoffs">
        <h3 class="positions-tradeoffs__title">Tradeoffs observed vs backtest</h3>
        <ul class="positions-tradeoffs__list">
          <li>
            <strong>Slippage matches:</strong> 4.2 bps/side realized vs 5 bps modeled. The linear-impact
            assumption is honest at this size.
          </li>
          <li>
            <strong>Regime stability:</strong> the period was dominated by a calm regime. The backtest's
            worst-drawdown number (−30%) is untested in this window. The next regime event will
            be the test.
          </li>
          <li>
            <strong>Latency:</strong> Binance kline timestamp drift is real but small at the 1-day cadence.
            Not a concern at this strategy frequency.
          </li>
          <li>
            <strong>Survivorship:</strong> only one instrument. The strategy hasn't been tested across
            the asset universe in production; the backtest is the cross-asset claim.
          </li>
        </ul>
      </div>

      <div class="positions-changes">
        <h3 class="positions-changes__title">What I'd change before going live</h3>
        <ol class="positions-changes__list">
          <li>
            Add a kill-switch on &gt;20% weekly drawdown (current code has none — this is a
            backtest-engineering gap, not a strategy gap).
          </li>
          <li>
            Add a per-trade log with size, slippage realized, and execution timestamp for capacity
            testing at $1M / $5M / $10M tiers.
          </li>
          <li>
            Cross-check the signal against Binance.US and Coinbase klines to rule out venue-specific
            artifacts.
          </li>
        </ol>
      </div>

      <div class="positions-code">
        <span class="mono">code:</span>
        <a
          href="https://github.com/christianmacion26/timeseries-momentum-voltarget"
          target="_blank"
          rel="noopener"
        >
          github.com/christianmacion26/timeseries-momentum-voltarget
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Open conversations · the live book</p>
        <h2 class="section__title">Conversations I'd pick up the phone for.</h2>
        <p class="section__sub">
          Five seats that fit my operating constraints — quant, AI, eval, OSS. Not a JD
          wishlist; a list of the conversations I'd actually take a 30-min call about. If your
          role isn't on the list, email me anyway with the JD — I read every one.
        </p>
      </header>

      <aside class="positions-cal" aria-label="Intro-call availability">
        <p class="positions-cal__note mono">
          I do 30-min intro calls on Tue/Wed/Thu 18:00–22:00 PHT (10:00–14:00 UTC). Email
          first — booking link in reply.
        </p>
        <a
          class="btn btn--primary positions-cal__cta"
          href={`mailto:${email}?subject=Intro%20call%20request`}
        >
          Email for intro call →
        </a>
      </aside>

      <div class="role-grid">
        <article class="role-card">
          <p class="role-card__eyebrow mono">CONVERSATION 01</p>
          <h3 class="role-card__title">Senior Quantitative Researcher</h3>
          <p class="role-card__sub">
            Hedge fund or family office · remote-first · US-premarket or APAC overlap
          </p>
          <div class="role-card__body">
            <div>
              <p class="role-card__label mono">Looking for</p>
              <p class="role-card__text">
                Multi-strategy pod, eval-first research, async-friendly cadence.
              </p>
            </div>
            <div>
              <p class="role-card__label mono">I'm a fit because</p>
              <p class="role-card__text">
                11-agent platform + 31-gate statistical eval harness, NDA-clean by construction.
              </p>
            </div>
          </div>
          <a class="btn btn--ghost btn--sm role-card__next" href={path('/for-recruiters')}
            >Next step: /for-recruiters →</a
          >
        </article>

        <article class="role-card">
          <p class="role-card__eyebrow mono">CONVERSATION 02</p>
          <h3 class="role-card__title">AI Research Engineer</h3>
          <p class="role-card__sub">
            Frontier AI lab (HF / Replicate / HuggingFace / Conjecture) · remote · model
            eval + RAG infrastructure
          </p>
          <div class="role-card__body">
            <div>
              <p class="role-card__label mono">Looking for</p>
              <p class="role-card__text">
                Engineer who ships eval harnesses + RAG scorecards, not just prompts.
              </p>
            </div>
            <div>
              <p class="role-card__label mono">I'm a fit because</p>
              <p class="role-card__text">
                Eval-first MCP, RAG scorecard, slop gate, 76.5k LOC Python.
              </p>
            </div>
          </div>
          <a class="btn btn--ghost btn--sm role-card__next" href={path('/for-recruiters')}
            >Next step: /for-recruiters →</a
          >
        </article>

        <article class="role-card">
          <p class="role-card__eyebrow mono">CONVERSATION 03</p>
          <h3 class="role-card__title">Quant Research Engineer</h3>
          <p class="role-card__sub">
            Crypto prop desk / market-making shop · remote · public-data discipline
          </p>
          <div class="role-card__body">
            <div>
              <p class="role-card__label mono">Looking for</p>
              <p class="role-card__text">
                Cost-model treated as a first-class artifact, not an afterthought.
              </p>
            </div>
            <div>
              <p class="role-card__label mono">I'm a fit because</p>
              <p class="role-card__text">
                Funding-carry, cost-aware backtests, public-data rigor (Binance / Coinbase /
                EDGAR / FRED).
              </p>
            </div>
          </div>
          <a class="btn btn--ghost btn--sm role-card__next" href={path('/contact')}
            >Next step: /contact →</a
          >
        </article>

        <article class="role-card">
          <p class="role-card__eyebrow mono">CONVERSATION 04</p>
          <h3 class="role-card__title">NLP Evaluation Engineer</h3>
          <p class="role-card__sub">
            AI safety / evals org · remote · spec-driven methodology
          </p>
          <div class="role-card__body">
            <div>
              <p class="role-card__label mono">Looking for</p>
              <p class="role-card__text">
                LLM-as-judge harness, position-bias checks, frozen-spec eval.
              </p>
            </div>
            <div>
              <p class="role-card__label mono">I'm a fit because</p>
              <p class="role-card__text">
                31-gate eval harness, position-bias controls, frozen-spec discipline.
              </p>
            </div>
          </div>
          <a class="btn btn--ghost btn--sm role-card__next" href={path('/contact')}
            >Next step: /contact →</a
          >
        </article>

        <article class="role-card">
          <p class="role-card__eyebrow mono">CONVERSATION 05</p>
          <h3 class="role-card__title">Open-source Maintainer</h3>
          <p class="role-card__sub">
            OSS foundation / grant-funded org · async · public-impact work
          </p>
          <div class="role-card__body">
            <div>
              <p class="role-card__label mono">Looking for</p>
              <p class="role-card__text">
                Public, evaluable, reproducible artifacts — not private magic.
              </p>
            </div>
            <div>
              <p class="role-card__label mono">I'm a fit because</p>
              <p class="role-card__text">
                15 public repos, 102 certs, eval-first discipline, NDA-clean by construction.
              </p>
            </div>
          </div>
          <a class="btn btn--ghost btn--sm role-card__next" href={path('/contact')}
            >Next step: /contact →</a
          >
        </article>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Off the table</p>
        <h2 class="section__title">Not currently looking for.</h2>
        <p class="section__sub">
          Three seat types that don't fit my operating constraints. No judgment if you run
          one — just not where I'm spending the next 12 months.
        </p>
      </header>
      <ul class="neg">
        <li>
          HFT colocation-dependent seats (Digos is +8 from NYSE; latency kills the edge)
        </li>
        <li>
          Sell-side black-box vendor roles (I prefer open-data / open-source provenance)
        </li>
        <li>
          Crypto market-making seats that require &lt; 100ms latency (same reason)
        </li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">What's not on this page</p>
        <h2 class="section__title">Negative space as design.</h2>
        <p class="section__sub">
          A single live paper-trade is honest. A dozen concurrent paper-trades without per-strategy
          slippage / capacity logs is vanity. This page is short on purpose — one position, fully
          documented, beats six positions hand-waved.
        </p>
      </header>
      <ul class="neg">
        <li>I am not running live capital. Paper-trading only.</li>
        <li>I am not running on proprietary data. Binance BTC/USDT 1d klines are public.</li>
        <li>
          I am not claiming the live period validates the backtest. The next regime event will be
          the test.
        </li>
        <li>I am not running more strategies than I can document. One position, fully logged.</li>
      </ul>
    </div>
  </section>

  <CTABanner
    title="Want the trade log or capacity report?"
    sub="Send the strategy you're hiring for. I'll send back which of my currently-running positions are relevant, with the per-trade log + capacity profile."
    primaryLabel="Email me"
    secondaryLabel="Read the backtest"
    secondaryHref={path('/projects/quant/03-timeseries-momentum-voltarget')}
  />
</BaseLayout>

<style>
  .positions-head {
    padding-block: var(--sp-9) var(--sp-7);
    background:
      var(--c-bg);
    border-bottom: var(--border);
  }
  .positions-head__title {
    font-size: clamp(2.25rem, 5vw, 4rem);
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-block: var(--sp-4) var(--sp-5);
    max-width: 22ch;
  }
  .positions-head__voice {
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
}
  .positions-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 60ch;
    margin-bottom: var(--sp-6);
  }
  .positions-head__disclosures {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    padding: var(--sp-3);
    background: var(--c-bg-2);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-sm);
  }
  .positions-head__disclosures span {
    padding: 4px 10px;
    background: var(--c-bg);
    border-radius: var(--radius-sm);
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
  }
  .positions-head__disclosures strong {
    color: var(--c-primary-2);
    font-weight: 600;
  }

  .positions-card__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--sp-4);
    margin-bottom: var(--sp-5);
    flex-wrap: wrap;
  }
  .positions-card__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: -0.02em;
    margin-block: var(--sp-1) var(--sp-2);
  }
  .positions-card__sub {
    font-size: var(--fs-sm);
    color: var(--c-ink-3);
  }
  .positions-card__status {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    background: var(--c-bg-2);
    border: 1px solid var(--c-rule);
    border-radius: 14px;
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
  }

  .positions-proof {
    margin-block: var(--sp-5);
    padding: var(--sp-3);
    background: var(--c-tape);
    border: 1px solid var(--c-tape-2);
    border-radius: var(--radius);
    border-left: 3px solid var(--c-primary-2);
  }
  .positions-proof__link {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--sp-4);
    align-items: center;
    color: inherit;
  }
  .positions-proof__img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    display: block;
  }
  .positions-proof__title {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-primary-2-deep);
    margin-bottom: var(--sp-2);
    font-weight: 600;
  }
  .positions-proof__copy p {
    font-size: var(--fs-sm);
    color: rgba(230, 237, 243, 0.78);
    line-height: var(--lh-snug);
    margin: 0;
  }
  .positions-proof__copy strong {
    color: var(--ink-on-tape);
    font-weight: 600;
  }
  .positions-proof__cta {
    color: var(--c-primary-2-deep);
    text-decoration-color: var(--c-amber-decor);
  }
  .positions-proof__cta:hover {
    text-decoration-color: var(--c-primary-2-deep);
  }
  @media (max-width: 720px) {
    .positions-proof__link {
      grid-template-columns: 1fr;
    }
    .positions-proof__img {
      max-width: 220px;
    }
  }

  .positions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--sp-3);
    margin-block: var(--sp-6);
  }
  .positions-chart__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--sp-4);
    margin-bottom: var(--sp-3);
  }
  .positions-chart__head-text {
    flex: 1 1 auto;
    min-width: 0;
  }
  .positions-chart__title {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--c-ink);
    margin-bottom: var(--sp-1);
  }
  .positions-chart__sub {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 65ch;
  }
  .positions-chart__badge {
    flex: 0 0 auto;
    padding: 4px 10px;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-primary-2);
    background: rgba(232, 178, 32, 0.10);
    border: 1px solid rgba(232, 178, 32, 0.35);
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }
  .positions-chart__badge--ok {
    color: var(--c-primary-2);
    background: rgba(232, 178, 32, 0.10);
    border-color: rgba(232, 178, 32, 0.35);
  }
  .positions-metric {
    padding: var(--sp-4);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-sm);
  }
  .positions-metric__label {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--sp-2);
  }
  .positions-metric__value {
    font-size: var(--fs-xl);
    color: var(--c-primary);
    font-weight: 700;
    margin-bottom: var(--sp-1);
  }
  .positions-metric__sub {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    line-height: var(--lh-normal);
  }

  .positions-tradeoffs,
  .positions-changes {
    margin-top: var(--sp-6);
    padding: var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    border-left: 3px solid var(--c-primary-2);
  }
  .positions-tradeoffs__title,
  .positions-changes__title {
    font-size: var(--fs-lg);
    margin-bottom: var(--sp-3);
    color: var(--c-ink);
  }
  .positions-tradeoffs__list,
  .positions-changes__list {
    list-style: none;
    padding: 0;
  }
  .positions-tradeoffs__list li,
  .positions-changes__list li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: var(--sp-3);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
  }
  .positions-tradeoffs__list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--c-primary-2-deep);
    font-weight: 700;
  }
  .positions-changes__list {
    counter-reset: change;
  }
  .positions-changes__list li {
    counter-increment: change;
  }
  .positions-changes__list li::before {
    content: counter(change) '.';
    position: absolute;
    left: 0;
    color: var(--c-primary-2-deep);
    font-family: var(--ff-mono);
    font-weight: 700;
  }
  .positions-tradeoffs__list strong,
  .positions-changes__list strong {
    color: var(--c-ink);
