---
/**
 * publications.astro — research log: papers, workbooks, talks, videos, OSS projects.
 * Targeted at recruiters who want to see *what Christian has published publicly*.
 *
 * Delta 6 — AQR-style research archive:
 *   - Topic filter (papers / OSS / workbooks / press) via CSS-only radio
 *   - Year grouping for research papers and OSS projects
 *   - Venue/author metadata column on each row
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CTABanner from '@components/CTABanner.astro';
import ReadMeta from '@components/ReadMeta.astro';
import TrustStrip from '@components/TrustStrip.astro';
import { getCollection } from 'astro:content';
import { path } from '@utils/url';

const projects = (await getCollection('project')).sort((a, b) => a.data.order - b.data.order);
const aiPubs = projects.filter((p) => p.data.role === 'ai');
const quantPubs = projects.filter((p) => p.data.role === 'quant');

// Format a YYYY-MM-DD frontmatter date as "Mon YYYY"
function fmtDate(d?: Date | string): string {
  if (!d) return '';
  const date = typeof d === 'string' ? new Date(d) : d;
  if (isNaN(date.getTime())) return '';
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
function fmtYear(d?: Date | string): string {
  if (!d) return '';
  const date = typeof d === 'string' ? new Date(d) : d;
  if (isNaN(date.getTime())) return '';
  return String(date.getFullYear());
}

// Group pubs by year (descending) for the AQR-style year header
function groupByYear<T extends { data: { date?: Date | string } }>(items: T[]): [string, T[]][] {
  const map = new Map<string, T[]>();
  for (const item of items) {
    const y = fmtYear(item.data.date) || '—';
    if (!map.has(y)) map.set(y, []);
    map.get(y)!.push(item);
  }
  return Array.from(map.entries()).sort((a, b) => Number(b[0]) - Number(a[0]));
}

const quantByYear = groupByYear(quantPubs);
const aiByYear = groupByYear(aiPubs);

const workbooks = [
  {
    title: 'AI Architecture & Multi-Agent Systems Workbook',
    scope: '11-agent orchestrator, eval harness, MCP server, model routing',
    pages: '~80 pp',
    audience: 'AI engineers, agent architects, eval harness designers',
  },
  {
    title: 'Statistical Modeling for Systematic Trading Workbook',
    scope: 'multiple testing, walk-forward, block-bootstrap, deflated Sharpe, cost realism',
    pages: '~110 pp',
    audience: 'quant researchers, strategy developers, backtest engineers',
  },
  {
    title: 'STA Tier-1 CTA Curriculum Workbook',
    scope: 'technical analysis fundamentals through advanced pattern recognition',
    pages: '~150 pp',
    audience: 'technical analysts, finance students, CFA/CMT candidates',
  },
];

const press = [
  {
    date: '2024-09-15',
    year: 2024,
    title: 'PSHS-SMC alumni speaker — Philippine Science High School Southern Mindanao',
    venue: 'PSHS-SMC Alumni Talk Series',
    detail:
      'Talk on AI engineering and the educational path from PSHS to AI/quant careers. ~80 attendees (alumni + current students).',
  },
  {
    date: '2025-03-22',
    year: 2025,
    title: 'University guest lecturer — University of Southeastern Philippines (USeP)',
    venue: 'USeP College of Engineering',
    detail:
      'Guest lecture on systematic trading research and AI for engineering students. Course: CpE / EE 5th-year elective.',
  },
  {
    date: '2025-12-10',
    year: 2025,
    title: 'STA Tier-1 CTA Program completion — Society of Technical Analysts of the Philippines',
    venue: 'STA Philippines',
    detail:
      'Tier-1 Certified Technical Analyst program, completed Dec 2025. Final capstone: regime-classification case study on ASEAN equities.',
  },
  {
    date: '2025-11-21',
    year: 2025,
    title: 'BIDA × Meta AIccelerate 2025 — 5-day hybrid training, awarded Dec 17 2025',
    venue: 'BIDA × Bayan Academy × Meta',
    detail:
      'Selected for the BIDA × Bayan Academy × Meta AIccelerate 2025 cohort (Nov 12–21 2025). Five-day hybrid training on applied AI for MSMEs; co-signed certificate from BIDA, Bayan Academy, and Meta Philippines.',
    url: '/proof/bida-meta-aiccelerate-2025-11.jpg',
    kind: 'training',
  },
  {
    date: '2026-01-19',
    year: 2026,
    title: 'CTA program graduate — Society of Technical Analysts of the Philippines',
    venue: 'STA Philippines',
    detail:
      'Completed the STA Tier-1 Certified Technical Analyst program (Jan 19 2026, cert #260197). Photographic proof on the record — same image used in the hero signature strip.',
    url: '/proof/cta-cert-portrait-2026-01.jpg',
    kind: 'certification',
  },
];

const totalCount = quantPubs.length + aiPubs.length + workbooks.length + press.length;
---

<BaseLayout
  title="Publications"
  description="Public work — research projects, workbooks, talks, OSS repos, and press. All NDA-safe."
>
  {/* === CSS-only topic filter (no JS) === */}
  <input
    type="radio"
    name="topic"
    id="topic-all"
    class="topic-input topic-input--all"
    checked
    aria-hidden="true"
  />
  <input
    type="radio"
    name="topic"
    id="topic-papers"
    class="topic-input topic-input--papers"
    aria-hidden="true"
  />
  <input
    type="radio"
    name="topic"
    id="topic-oss"
    class="topic-input topic-input--oss"
    aria-hidden="true"
  />
  <input
    type="radio"
    name="topic"
    id="topic-workbooks"
    class="topic-input topic-input--workbooks"
    aria-hidden="true"
  />
  <input
    type="radio"
    name="topic"
    id="topic-press"
    class="topic-input topic-input--press"
    aria-hidden="true"
  />
  <header class="pub-head">
    <div class="container">
      <p class="section__eyebrow">
        <span class="mono">publications/</span> · public work log · {totalCount} artifacts
      </p>
      <h1 class="pub-head__title">
        Things I have <span class="hl">written, built, and said</span> in public.
      </h1>
      <p class="pub-head__sub">
        Every artifact below is either an OSS repo, a memo, a workbook, or a public talk. No
        proprietary data sources. No NDA-protected content.
      </p>

      {/* Topic filter labels — radio inputs above are hidden; these are the clickable labels */}
      <nav class="topic-filter" aria-label="Filter publications by topic">
        <label for="topic-all" class="topic-btn"
          ><span class="mono">all</span> <span class="topic-count">{totalCount}</span></label
        >
        <label for="topic-papers" class="topic-btn"
          ><span class="mono">papers</span>
          <span class="topic-count">{quantPubs.length}</span></label
        >
        <label for="topic-oss" class="topic-btn"
          ><span class="mono">oss</span> <span class="topic-count">{aiPubs.length}</span></label
        >
        <label for="topic-workbooks" class="topic-btn"
          ><span class="mono">workbooks</span>
          <span class="topic-count">{workbooks.length}</span></label
        >
        <label for="topic-press" class="topic-btn"
          ><span class="mono">press</span> <span class="topic-count">{press.length}</span></label
        >
      </nav>
    </div>
  </header>

  <TrustStrip variant="tape" />

  <div class="container">
    <ReadMeta minutes={7} updatedIso="2026-07-09" href={path('/proof')} />
  </div>

  <section class="section section--alt" data-topic="papers">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Research papers · {quantPubs.length} quant projects</p>
        <h2 class="section__title">Public-data systematic research.</h2>
      </header>
      {
        quantByYear.map(([year, pubs]) => (
          <div class="pub-year-group">
            <h3 class="pub-year mono">{year}</h3>
            <div class="pub-list" data-pub-list="quant">
              {pubs.map((p) => (
                <article class="pub">
                  <div class="pub__num mono" />
                  <div class="pub__body">
                    <h4 class="pub__title">
                      <a href={path(`/projects/${p.id}`)}>{p.data.title}</a>
                    </h4>
                    <p class="pub__summary">{p.data.summary}</p>
                    {p.data.metrics.length > 0 && (
                      <ul class="pub__metrics">
                        {p.data.metrics.map((m) => (
                          <li>
                            <span class="pub__metric-label">{m.label}</span>
                            <span class="pub__metric-value mono">{m.value}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                    <div class="pub__meta">
                      {p.data.stack.slice(0, 6).map((s) => (
                        <span class="pill">{s}</span>
                      ))}
                    </div>
                  </div>
                  <div class="pub__action">
                    <div class="pub__date mono">{fmtDate(p.data.date)}</div>
                    <a class="btn btn--ghost btn--sm" href={path(`/projects/${p.id}`)}>
                      Read →
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section" data-topic="oss">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">OSS projects · {aiPubs.length} AI builds</p>
        <h2 class="section__title">Multi-agent LLM systems with eval-first discipline.</h2>
      </header>
      {
        aiByYear.map(([year, pubs]) => (
          <div class="pub-year-group">
            <h3 class="pub-year mono">{year}</h3>
            <div class="pub-list" data-pub-list="ai">
              {pubs.map((p) => (
                <article class="pub">
                  <div class="pub__num mono" />
                  <div class="pub__body">
                    <h4 class="pub__title">
                      <a href={path(`/projects/${p.id}`)}>{p.data.title}</a>
                    </h4>
                    <p class="pub__summary">{p.data.summary}</p>
                    {p.data.metrics.length > 0 && (
                      <ul class="pub__metrics">
                        {p.data.metrics.map((m) => (
                          <li>
                            <span class="pub__metric-label">{m.label}</span>
                            <span class="pub__metric-value mono">{m.value}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                    <div class="pub__meta">
                      {p.data.stack.slice(0, 6).map((s) => (
                        <span class="pill">{s}</span>
                      ))}
                    </div>
                  </div>
                  <div class="pub__action">
                    <div class="pub__date mono">{fmtDate(p.data.date)}</div>
                    <a class="btn btn--ghost btn--sm" href={path(`/projects/${p.id}`)}>
                      Read →
                    </a>
                    {p.data.sourceLink && (
                      <a
                        class="btn btn--ghost btn--sm"
                        href={p.data.sourceLink}
                        target="_blank"
                        rel="noopener"
                      >
                        Repo ↗
                      </a>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section section--alt" data-topic="workbooks">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Workbooks · long-form</p>
        <h2 class="section__title">Three deep-dive workbooks (in progress).</h2>
        <p class="section__sub">
          Long-form workbooks that consolidate method, code, and exercises. Not yet published —
          drafts available on request.
        </p>
      </header>
      <div class="workbooks">
        {
          workbooks.map((w) => (
            <article class="wb">
              <h3 class="wb__title">{w.title}</h3>
              <div class="wb__scope">{w.scope}</div>
              <div class="wb__meta mono">
                <span>{w.pages}</span>
                <span aria-hidden="true">·</span>
                <span>{w.audience}</span>
              </div>
              <div class="wb__foot mono">
                <span class="wb__status">In progress</span> — early-reader draft; full PDF available
                on request (non-public, gated by topic)
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" data-topic="press">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Press & recognition</p>
        <h2 class="section__title">Public talks, lectures, and recognitions.</h2>
      </header>
      <ol class="press">
        {
          press.map((p) => (
            <li class="press__row">
              <div class="press__year mono">{p.year}</div>
              <div class="press__body">
                <h3 class="press__title">{p.title}</h3>
                <div class="press__venue mono">Venue: {p.venue}</div>
                <p class="press__detail">{p.detail}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <CTABanner
    title="Want a specific paper or talk?"
    sub="Email me the topic and I'll point you to the artifact (PDF, video, repo) within 24 hours."
    primaryLabel="Email me"
    secondaryLabel="See methodology"
    secondaryHref={path('/methodology')}
  />
</BaseLayout>

<style>
  /* === Topic filter (CSS-only, no JS) === */
  .topic-input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .topic-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-6);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--c-rule-soft);
  }
  .topic-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: 999px;
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    cursor: pointer;
    transition: all var(--transition);
    user-select: none;
  }
  .topic-btn:hover {
    border-color: var(--c-primary-2-deep);
    color: var(--c-primary);
  }
  .topic-count {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    padding: 0 var(--sp-2);
    border-radius: 999px;
    background: var(--c-bg-2);
  }
  /* Selected state */
  .topic-input--all:checked ~ * .topic-btn:has(input[disabled]),
  .topic-input--papers:checked ~ * [data-topic='papers'],
  .topic-input--oss:checked ~ * [data-topic='oss'],
  .topic-input--workbooks:checked ~ * [data-topic='workbooks'],
  .topic-input--press:checked ~ * [data-topic='press'] {
    /* not quite — use sibling cascade */
  }
  .topic-input--all:checked ~ * label[for='topic-all'] {
    background: var(--c-primary);
    color: #fff;
    border-color: var(--c-primary);
  }
  .topic-input--all:checked ~ * label[for='topic-all'] .topic-count {
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.1);
  }
  .topic-input--papers:checked ~ * label[for='topic-papers'] {
    background: var(--c-primary);
    color: #fff;
    border-color: var(--c-primary);
  }
  .topic-input--papers:checked ~ * label[for='topic-papers'] .topic-count {
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.1);
  }
  .topic-input--oss:checked ~ * label[for='topic-oss'] {
    background: var(--c-primary);
    color: #fff;
    border-color: var(--c-primary);
  }
  .topic-input--oss:checked ~ * label[for='topic-oss'] .topic-count {
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.1);
  }
  .topic-input--workbooks:checked ~ * label[for='topic-workbooks'] {
    background: var(--c-primary);
    color: #fff;
    border-color: var(--c-primary);
  }
  .topic-input--workbooks:checked ~ * label[for='topic-workbooks'] .topic-count {
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.1);
  }
  .topic-input--press:checked ~ * label[for='topic-press'] {
    background: var(--c-primary);
    color: #fff;
    border-color: var(--c-primary);
  }
  .topic-input--press:checked ~ * label[for='topic-press'] .topic-count {
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.1);
  }

  /* Hide sections by default; show based on filter */
  [data-topic='papers'],
  [data-topic='oss'],
  [data-topic='workbooks'],
  [data-topic='press'] {
    display: none;
  }
  .topic-input--all:checked ~ main [data-topic='papers'],
  .topic-input--all:checked ~ main [data-topic='oss'],
  .topic-input--all:checked ~ main [data-topic='workbooks'],
  .topic-input--all:checked ~ main [data-topic='press'],
  .topic-input--papers:checked ~ main [data-topic='papers'],
  .topic-input--oss:checked ~ main [data-topic='oss'],
  .topic-input--workbooks:checked ~ main [data-topic='workbooks'],
  .topic-input--press:checked ~ main [data-topic='press'] {
    display: block;
  }
  .topic-input--all:checked ~ main [data-topic='papers'] .pub-list,
  .topic-input--all:checked ~ main [data-topic='oss'] .pub-list,
  .topic-input--all:checked ~ main [data-topic='workbooks'] .workbooks,
  .topic-input--all:checked ~ main [data-topic='press'] .press {
    display: flex;
  }

  /* === Year groups (AQR-style) === */
  .pub-year-group {
    margin-bottom: var(--sp-6);
  }
  .pub-year {
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-primary-2-deep);
    font-weight: 700;
    margin: 0 0 var(--sp-3);
    padding-bottom: var(--sp-2);
    border-bottom: 1px solid var(--c-rule-soft);
  }

  .pub-head {
    padding-block: var(--sp-9) var(--sp-7);
    background:
      radial-gradient(1200px 600px at 80% 0%, rgba(11, 61, 92, 0.08), transparent 60%), var(--c-bg);
    border-bottom: var(--border);
  }
  .pub-head__title {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-block: var(--sp-4) var(--sp-5);
    max-width: 22ch;
  }
  .pub-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 60ch;
    margin-bottom: 0;
  }

  .pub-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    counter-reset: pub;
  }
  .pub {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: var(--sp-5);
    padding: var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    align-items: start;
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
  }
  .pub:hover {
    border-color: var(--c-primary);
    box-shadow: var(--shadow-sm);
  }
  .pub__num {
    font-size: var(--fs-lg);
    color: var(--c-primary);
    font-weight: 700;
    counter-increment: pub;
  }
  .pub__num::before {
    content: '[' counter(pub, decimal-leading-zero) ']';
  }
  .pub__title {
    font-size: var(--fs-lg);
    margin: 0 0 var(--sp-2);
  }
  .pub__title a {
    color: var(--c-ink);
  }
  .pub__title a:hover {
    color: var(--c-primary);
  }
  .pub__summary {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin: 0 0 var(--sp-3);
  }
  .pub__metrics {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin-bottom: var(--sp-3);
  }
  .pub__metrics li {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .pub__metric-label {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-3);
  }
  .pub__metric-value {
    font-size: var(--fs-base);
    color: var(--c-primary);
    font-weight: 700;
  }
  .pub__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .pub__action {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    align-items: flex-end;
  }
  .pub__date {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .workbooks {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--sp-4);
  }
  .wb {
    padding: var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .wb__title {
    font-size: var(--fs-lg);
    color: var(--c-ink);
    margin: 0;
  }
  .wb__scope {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
  }
  .wb__meta {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .wb__foot {
    margin-top: auto;
    padding-top: var(--sp-3);
    border-top: 1px dashed var(--c-rule-soft);
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
  }
  .wb__status {
    display: inline-block;
    padding: 0 6px;
    background: rgba(184, 134, 11, 0.12);
    color: var(--c-warn);
    border-radius: 3px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .press {
    list-style: none;
    padding: 0;
    max-width: 760px;
  }
  .press__row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--sp-4);
    padding-block: var(--sp-4);
    border-bottom: 1px solid var(--c-rule-soft);
  }
  .press__row:last-child {
    border-bottom: none;
  }
  .press__year {
    font-size: var(--fs-lg);
    color: var(--c-primary);
    font-weight: 700;
  }
  .press__title {
    font-size: var(--fs-base);
    margin: 0 0 var(--sp-1);
  }
  .press__venue {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    margin-bottom: var(--sp-2);
  }
  .press__detail {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin: 0;
  }

  @media (max-width: 720px) {
    .pub {
      grid-template-columns: 40px 1fr;
    }
    .pub__action {
      grid-column: 1 / -1;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .press__row {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
    }
  }
</style>
