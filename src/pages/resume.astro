---
/**
 * resume.astro — v2: 3 tailored resumes × 3 formats = 9 download targets.
 *
 * Hero equation: which resume = argmax over JD fit.
 *
 * Per variant, three download formats:
 *   - PDF   (visual, brand-faithful — for human reviewers)
 *   - MD    (Markdown     — for LLM-based recruiter agents, llms.txt ingesters)
 *   - TXT   (plain text   — for Workday classic, Greenhouse, Taleo ATS pipelines)
 *
 * Generated by:
 *   - scripts/build-resumes.mjs     → PDFs  (calls the OJP/Upwork python-docx builder)
 *   - scripts/build-resumes-md.mjs  → MD + TXT
 *
 * Both run on `npm run prebuild`, so every deploy ships all 9 artifacts.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Equation from '@components/Equation.astro';
import Stat from '@components/Stat.astro';
import { path } from '@utils/url';
import VoiceLine from '@components/VoiceLine.astro';

const resumes = [
  {
    label: 'Unified · AI Engineer + Quant Researcher',
    blurb:
      'The single-pane view: covers both lanes simultaneously. Best for recruiters hiring for a combined seat or undecided between the two.',
    primary: true,
    pages: '4 pages',
    slug: 'tailored',
    formats: [
      { kind: 'pdf', file: path('/resume-tailored.pdf'), label: 'PDF', note: 'visual · brand-faithful' },
      { kind: 'md', file: path('/resume-tailored.md'), label: 'MD', note: 'LLM-agent · llms.txt ingest' },
      { kind: 'txt', file: path('/resume-tailored.txt'), label: 'TXT', note: 'Workday · Greenhouse · Taleo' },
    ],
  },
  {
    label: 'AI Engineer Lane',
    blurb:
      'AI Engineer emphasis: multi-agent LLM systems, eval harnesses, MCP servers, and the projects that prove them.',
    pages: '4 pages',
    slug: 'ai-only',
    formats: [
      { kind: 'pdf', file: path('/resume-ai-only.pdf'), label: 'PDF', note: 'visual · brand-faithful' },
      { kind: 'md', file: path('/resume-ai-only.md'), label: 'MD', note: 'LLM-agent · llms.txt ingest' },
      { kind: 'txt', file: path('/resume-ai-only.txt'), label: 'TXT', note: 'Workday · Greenhouse · Taleo' },
    ],
  },
  {
    label: 'Quant Researcher Lane (one-pager)',
    blurb:
      'Quantitative Researcher emphasis: nine public-data projects with real headline metrics, plus the methodology that ties them together.',
    pages: '1 page',
    slug: 'quant-onepage',
    formats: [
      { kind: 'pdf', file: path('/resume-quant-onepage.pdf'), label: 'PDF', note: 'visual · brand-faithful' },
      { kind: 'md', file: path('/resume-quant-onepage.md'), label: 'MD', note: 'LLM-agent · llms.txt ingest' },
      { kind: 'txt', file: path('/resume-quant-onepage.txt'), label: 'TXT', note: 'Workday · Greenhouse · Taleo' },
    ],
  },
];---

<BaseLayout
  title="Resume"
  description="Three tailored resumes × 3 formats (PDF / Markdown / plain text). NDA-safe, public-data reproducible, ATS-friendly."
  breadcrumbs={[{ name: "Home", href: "/" }, { name: "Resume", href: "/resume" }]}
>
  <header class="page-head">
    <div class="container">
      <p class="section__eyebrow"><span class="mono">resume/</span> · 3 versions × 3 formats = 9 download targets</p>
      <h1 class="page-head__title">Three tailored resumes.</h1>
      <VoiceLine class="page-head__voice">
        Same person, three shapes. Pick the resume that fits the seat — then pick the format the system expects.
      </VoiceLine>
      <p class="page-head__sub">
        Pick the version that matches the role you're hiring for. Each version ships in three formats —
        PDF for human reviewers, Markdown for LLM-based recruiter agents, plain text for Workday-classic /
        Greenhouse / Taleo ATS pipelines. All three are NDA-safe, free of proprietary data sources, and
        reference only public-data methodology or open-source work.
      </p>

      <div class="head-eq">
        <Equation
          block
          latex={`\\text{resume}^{\\star} = \\arg\\max_{r \\in R} \\; \\text{fit}(r, \\text{JD}) \\quad \\text{where} \\quad R = \\{R_{\\text{unified}}, R_{\\text{AI}}, R_{\\text{Quant}}\\}`}
          size="md"
        />
      </div>

      <div class="head-stats">
        <Stat value="3" label="tailored" sub="resumes" />
        <Stat value="3" label="formats" sub="PDF · MD · TXT" />
        <Stat value="100%" label="NDA-safe" sub="by construction" />
        <Stat value="9" label="quant proj" sub="public-data" />
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="resume-grid">
        {
          resumes.map((r) => (
            <article class:list={['resume-card', { 'resume-card--primary': r.primary }]}>
              <div class="resume-card__head">
                <div class="resume-card__label">{r.label}</div>
                <span class="pill pill--brand">{r.pages}</span>
              </div>
              <div class="resume-card__blurb">{r.blurb}</div>
              <ul class="resume-card__formats">
                {r.formats.map((f) => (
                  <li class="format">
                    <a class="format__link" href={f.file} download>
                      <span class="format__kind">{f.label}</span>
                      <span class="format__note">{f.note}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>

      <aside class="resume-note">
        <h3 class="resume-note__title">If you'd rather a different shape</h3>
        <p>
          I keep a <strong>bullet-bank resume materials</strong> package (~80 bullet variants) for tailored
          one-pagers per JD. Email me the JD and I'll send back a tailored version within 24 hours.
        </p>
        <p class="resume-note__mono">
          Built with the same HIRED-FlowCV builder used for OnlineJobs.ph and Upwork applications —
          ATS-safe, single-column, no tables-for-layout. Source JSONs live in
          <code>scripts/resumes/</code>; PDFs regenerate via <code>npm run resumes:build</code>,
          MD + TXT via <code>npm run resumes:build:md</code>.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: var(--sp-9) var(--sp-7);
    background:
      radial-gradient(1200px 600px at 80% -100px, rgba(212, 160, 23, 0.08), transparent 60%),
      var(--c-paper);
    border-bottom: var(--border);
  }
  .page-head__title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .page-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 64ch;
    margin-bottom: var(--sp-6);
  }
  .page-head__voice {
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
}
  .head-eq {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    margin-bottom: var(--sp-5);
    overflow-x: auto;
  }
  .head-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-3);
  }
  .resume-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--sp-5);
    margin-bottom: var(--sp-7);
  }
  .resume-card {
    display: flex;
    flex-direction: column;
    padding: var(--sp-5);
    background: var(--c-bg);
    border: var(--border);
    border-radius: var(--radius);
    color: var(--c-ink);
    transition:
      border-color var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }
  .resume-card:hover {
    border-color: var(--c-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .resume-card--primary {
    border-color: var(--c-primary);
    background: linear-gradient(180deg, rgba(212, 160, 23, 0.04), var(--c-bg));
  }
  .resume-card__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }
  .resume-card__label {
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--c-primary);
    line-height: 1.3;
  }
  .resume-card__blurb {
    color: var(--c-ink-2);
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
    margin-bottom: var(--sp-4);
    flex: 1;
  }
  .resume-card__formats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--sp-2);
    border-top: 1px solid var(--c-rule-soft);
    padding-top: var(--sp-3);
  }
  .format__link {
    display: grid;
    grid-template-columns: 56px 1fr;
    align-items: baseline;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    background: var(--c-bg-2);
    border: 1px solid var(--c-rule-soft);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--c-ink);
    transition:
      border-color var(--transition),
      background var(--transition);
  }
  .format__link:hover {
    border-color: var(--c-primary);
    background: var(--c-bg);
    color: var(--c-ink);
  }
  .format__kind {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--c-primary);
    letter-spacing: 0.04em;
  }
  .format__note {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: 1.4;
  }
  .resume-note {
    padding: var(--sp-5);
    background: var(--c-bg-2);
    border-left: 3px solid var(--c-primary-2);
    border-radius: 0 var(--radius) var(--radius) 0;
    max-width: 760px;
  }
  .resume-note__title {
    font-size: var(--fs-lg);
    color: var(--c-primary);
    margin-bottom: var(--sp-2);
  }
  .resume-note p {
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
  }
  .resume-note p + p {
    margin-top: var(--sp-3);
  }
  .resume-note__mono {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
  }
  .resume-note__mono code {
    font-family: var(--font-mono);
    background: var(--c-bg-2);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--c-primary);
  }
  .resume-note strong {
    color: var(--c-ink);
    font-weight: 600;
  }

  @media (max-width: 880px) {
    .head-stats {
      grid-template-columns: 1fr 1fr;
    }
    .resume-card__head {
      flex-direction: column;
      align-items: flex-start;
    }
    .format__link {
      grid-template-columns: 48px 1fr;
    }
  }
</style>