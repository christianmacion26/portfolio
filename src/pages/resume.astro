---
/**
 * resume.astro — v2: 3 tailored resumes + math/quant aesthetic.
 *
 * Hero equation: which resume = argmax over JD fit.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Equation from '@components/Equation.astro';
import Stat from '@components/Stat.astro';
import { path } from '@utils/url';

const resumes = [
  {
    label: 'Unified · AI Engineer + Quant Researcher',
    file: path('/resume-tailored.pdf'),
    blurb:
      'The single-pane view: covers both lanes simultaneously. Best for recruiters hiring for a combined seat or undecided between the two.',
    primary: true,
    pages: '4 pages',
  },
  {
    label: 'AI Engineer Lane',
    file: path('/resume-ai-only.pdf'),
    blurb:
      'AI Engineer emphasis: multi-agent LLM systems, eval harnesses, MCP servers, and the projects that prove them.',
    pages: '4 pages',
  },
  {
    label: 'Quant Researcher Lane (one-pager)',
    file: path('/resume-quant-onepage.pdf'),
    blurb:
      'Quantitative Researcher emphasis: nine public-data projects with real headline metrics, plus the methodology that ties them together.',
    pages: '1 page',
  },
];
---

<BaseLayout
  title="Resume"
  description="Three tailored resumes — unified, AI-only, and Quant one-pager. NDA-safe, public-data reproducible."
>
  <header class="page-head">
    <div class="container">
      <p class="section__eyebrow"><span class="mono">resume/</span> · 3 tailored versions</p>
      <h1 class="page-head__title">Three tailored resumes.</h1>
      <p class="page-head__sub">
        Pick the version that matches the role you're hiring for. All three are NDA-safe, free of
        proprietary data sources, and reference only public-data methodology or open-source work.
      </p>

      <div class="head-eq">
        <Equation
          block
          latex={`\\text{resume}^{\\star} = \\arg\\max_{r \\in R} \\; \\text{fit}(r, \\text{JD}) \\quad \\text{where} \\quad R = \\{R_{\\text{unified}}, R_{\\text{AI}}, R_{\\text{Quant}}\\}`}
          size="md"
        />
      </div>

      <div class="head-stats">
        <Stat value="3" label="tailored" sub="resumes" formula="|R|" />
        <Stat value="100%" label="NDA-safe" sub="by construction" formula="\neg N" />
        <Stat value="9" label="quant proj" sub="public-data" formula="|P_q|" />
        <Stat value="6" label="AI proj" sub="OSS runnable" formula="|P_a|" />
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="resume-grid">
        {
          resumes.map((r) => (
            <a
              class:list={['resume-card', { 'resume-card--primary': r.primary }]}
              href={r.file}
              download
            >
              <div class="resume-card__label">{r.label}</div>
              <div class="resume-card__blurb">{r.blurb}</div>
              <div class="resume-card__foot">
                <span class="pill pill--brand">{r.pages}</span>
                <span class="resume-card__dl">Download PDF ↓</span>
              </div>
            </a>
          ))
        }
      </div>

      <aside class="resume-note">
        <h3 class="resume-note__title">If you'd rather a different shape</h3>
        <p>
          I keep a <strong>bullet-bank resume materials</strong> package (~80 bullet variants) for tailored
          one-pagers per JD. Email me the JD and I'll send back a tailored version within 24 hours.
        </p>
        <p class="resume-note__mono">
          Built with the same HIRED-FlowCV builder used for OnlineJobs.ph and Upwork applications —
          ATS-safe, single-column, no tables-for-layout. Source JSONs live in
          <code>scripts/resumes/</code>; PDFs regenerate via <code>npm run resumes:build</code>.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: var(--sp-9) var(--sp-7);
    background:
      radial-gradient(1200px 600px at 80% -100px, rgba(11, 61, 92, 0.1), transparent 60%),
      var(--c-paper);
    border-bottom: var(--border);
  }
  .page-head__title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .page-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 64ch;
    margin-bottom: var(--sp-6);
  }
  .head-eq {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    margin-bottom: var(--sp-5);
    overflow-x: auto;
  }
  .head-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-3);
  }
  .resume-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--sp-5);
    margin-bottom: var(--sp-7);
  }
  .resume-card {
    display: flex;
    flex-direction: column;
    padding: var(--sp-5);
    background: var(--c-bg);
    border: var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--c-ink);
    transition:
      border-color var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }
  .resume-card:hover {
    border-color: var(--c-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    color: var(--c-ink);
  }
  .resume-card--primary {
    border-color: var(--c-primary);
    background: linear-gradient(180deg, rgba(11, 61, 92, 0.04), var(--c-bg));
  }
  .resume-card__label {
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--c-primary);
    margin-bottom: var(--sp-3);
  }
  .resume-card__blurb {
    color: var(--c-ink-2);
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
    margin-bottom: var(--sp-4);
    flex: 1;
  }
  .resume-card__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--sp-3);
    border-top: 1px solid var(--c-rule-soft);
  }
  .resume-card__dl {
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--c-primary);
  }
  .resume-note {
    padding: var(--sp-5);
    background: var(--c-bg-2);
    border-left: 3px solid var(--c-primary-2);
    border-radius: 0 var(--radius) var(--radius) 0;
    max-width: 760px;
  }
  .resume-note__title {
    font-size: var(--fs-lg);
    color: var(--c-primary);
    margin-bottom: var(--sp-2);
  }
  .resume-note p {
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
  }
  .resume-note p + p {
    margin-top: var(--sp-3);
  }
  .resume-note__mono {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
  }
  .resume-note__mono code {
    font-family: var(--font-mono);
    background: var(--c-bg-2);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--c-primary);
  }
  .resume-note strong {
    color: var(--c-ink);
    font-weight: 600;
  }

  @media (max-width: 880px) {
    .head-stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
