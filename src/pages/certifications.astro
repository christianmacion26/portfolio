---
/**
 * certifications.astro — v2: curated certs + math/quant aesthetic.
 *
 * Hero equation: cert density over time → {{claimedTotal}} certs / {{ageMonths}} months.
 * Both inputs read from `profile.certCount` and `profile.ageMonths` so the
 * rendered equation tracks profile updates without manual sync.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Equation from '@components/Equation.astro';
import Stat from '@components/Stat.astro';
import ProofCard from '@components/ProofCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { path } from '@utils/url';
import { profile } from '@utils/profile';
import VoiceLine from '@components/VoiceLine.astro';

// Read the authoritative "claimed total" from profile (single source of truth).
// The on-disk curated set is a subset; this is the headline number used across
// the site (humans.md, home description, JSON-LD awards).
const claimedTotal = Number(profile.stats.certCount);

type CertGroupEntry = CollectionEntry<'certGroup'>;
const allCertGroups: CertGroupEntry[] = await getCollection('certGroup');
const groups = allCertGroups.sort((a, b) => a.data.order - b.data.order);

const totalCount = groups.reduce((sum, g) => sum + g.data.items.length, 0);
const flagshipCount = groups.reduce(
  (sum: number, g: CertGroupEntry) =>
    sum + g.data.items.filter((c: CertGroupEntry['data']['items'][number]) => c.flagship).length,
  0,
);
const tier1Count = groups.reduce(
  (sum: number, g: CertGroupEntry) =>
    sum + g.data.items.filter((c: CertGroupEntry['data']['items'][number]) => c.tier === 1).length,
  0,
);
// v6.11.22 — derive certification window from curated items' years
// (was hardcoded "(Nov 2022 → May 2026)" — actually Nov 2022 → May 2026,
// but the month-spans are fabricated). Years are honest; months derived
// from earliest/latest cert year (Nov is the Nov of the year indicated;
// May = month awarded for Tier-1 STA Jan 2026 ceremony).
type CertItem = CertGroupEntry['data']['items'][number];
const allItems: CertItem[] = groups.flatMap((g) => g.data.items);
const yearsArr = allItems.map((c) => Number(c.year)).filter((n) => Number.isFinite(n));
const earliestYear = yearsArr.length ? Math.min(...yearsArr) : null;
const latestYear = yearsArr.length ? Math.max(...yearsArr) : null;
const certWindow =
  earliestYear !== null && latestYear !== null
    ? earliestYear === latestYear
      ? `${earliestYear}`
      : `${earliestYear} → ${latestYear}`
    : '';
// Cert span in months — derived from earliest/latest year (Jan → Dec).
// This is the honest denominator for cert-density: same units, same window.
const certSpanMonths =
  earliestYear !== null && latestYear !== null
    ? (latestYear - earliestYear + 1) * 12
    : Number(profile.stats.ageMonths);
---

<BaseLayout
  title="Certifications"
  description={`Curated ${totalCount}+ of ${claimedTotal} professional certifications, grouped by domain and Tier-1 issuer.`}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Certifications', href: '/certifications' },
  ]}
>
  <header class="page-head">
    <div class="container">
      <p class="section__eyebrow">
        <span class="mono">certs/</span> · {claimedTotal} total, curated below
      </p>
      <h1 class="page-head__title">
        <span class="mono">{totalCount}+ of {claimedTotal}</span> certifications, four domains.
      </h1>
      <VoiceLine class="page-head__voice">
        Every cert links to its issuer's public registry — or it doesn't ship on this page.
      </VoiceLine>
      <p class="page-head__sub">
        {claimedTotal} professional certifications across AI, finance, math/statistics, and event flagships
        — collected over {certSpanMonths} months ({certWindow}). Curated below by domain; Tier-1
        issuers flagged.
      </p>

      <div class="head-eq">
        <Equation
          block
          latex={`\\text{cert\\_density} = \\frac{c(t)}{t} = \\frac{${claimedTotal} \\text{ certs}}{${certSpanMonths} \\text{ months}} \\approx ${(claimedTotal / certSpanMonths).toFixed(1)} \\text{ certs/month}`}
          size="md"
        />
      </div>

      <div class="head-stats">
        <Stat value={String(totalCount)} label="curated" sub="below" />
        <Stat value={String(claimedTotal)} label="total" sub="all-time" trend="up" />
        <Stat value={String(flagshipCount)} label="flagships" sub="NASA · Meta · IBM · IMC" />
        <Stat value={String(tier1Count)} label="tier-1" sub="STA · SEC · BSP" />
      </div>
    </div>
  </header>

  {
    groups.map((group, idx) => (
      <section class:list={['section', { 'section--alt': idx % 2 === 1 }]}>
        <div class="container">
          <header class="section__head">
            <p class="section__eyebrow">Domain {idx + 1}</p>
            <h2 class="section__title">{group.data.title}</h2>
            <p class="section__sub">{group.data.blurb}</p>
          </header>
          {group.data.featuredImg && (
            <div class="cert-featured">
              <ProofCard
                src={path(group.data.featuredImg)}
                alt={group.data.featuredAlt ?? ''}
                caption={group.data.featuredCaption ?? ''}
                href={group.data.featuredHref ? path(group.data.featuredHref) : undefined}
                aspect="3/2"
              />
            </div>
          )}
          <ul class="certs">
            {group.data.items.map((item: CertGroupEntry['data']['items'][number]) => (
              <li
                class:list={[
                  'cert',
                  { 'cert--tier1': item.tier === 1, 'cert--flagship': item.flagship },
                ]}
              >
                <div class="cert__name">{item.name}</div>
                <div class="cert__issuer">{item.issuer}</div>
                <div class="cert__year mono">{item.year ?? ''}</div>
                {item.flagship && <span class="pill pill--gold cert__tag">Flagship</span>}
                {item.tier === 1 && !item.flagship && <span class="pill cert__tag">Tier 1</span>}
              </li>
            ))}
          </ul>
        </div>
      </section>
    ))
  }

  <section class="section section--tight">
    <div class="container container-narrow">
      <p class="footnote">
        <strong>Full list:</strong> the curated {totalCount} above is the highlight reel. The complete
        list of {claimedTotal} (issuer + date + verifiable credential ID where applicable) lives in the
        <a href={path('/resume')}> tailored resume package</a>. Government certs include CSC Career
        Service Professional Eligibility, BSP financial planning, SEC Philippines capital market and
        financial reporting, and Basel Institute on Governance STR analysis.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: var(--sp-9) var(--sp-7);
    background: var(--c-paper);
    border-bottom: var(--border);
  }
  .page-head__title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .page-head__voice {
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
  }
  .page-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 64ch;
    margin-bottom: var(--sp-6);
  }
  .head-eq {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    margin-bottom: var(--sp-5);
    overflow-x: auto;
  }
  .head-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-3);
  }
  .cert-featured {
    margin-bottom: var(--sp-6);
    max-width: 760px;
  }
  .certs {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--sp-3);
  }
  .cert {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0 var(--sp-3);
    padding: var(--sp-4);
    background: var(--c-bg);
    border: var(--border);
    border-radius: var(--radius-sm);
    position: relative;
    transition: border-color var(--transition);
  }
  .cert:hover {
    border-color: var(--c-ink-3);
  }
  .cert__name {
    font-weight: 600;
    color: var(--c-ink);
    grid-column: 1;
  }
  .cert__issuer {
    grid-column: 1;
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
  }
  .cert__year {
    grid-column: 2;
    grid-row: 1;
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    text-align: right;
  }
  .cert__tag {
    grid-column: 2;
    grid-row: 2;
    align-self: end;
    justify-self: end;
    margin-top: var(--sp-2);
  }
  /* v6.10.33 — institutional: drop the F13-era amber gradient (rgba 212,160,23 stale).
     Lift via --c-bg-2 token; amber-deep border is enough chrome signal. */
  .cert--flagship {
    border-color: var(--c-amber-deep);
    background: var(--c-bg-2);
  }
  .footnote {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    padding: var(--sp-5);
    background: var(--c-bg-2);
    border-left: 3px solid var(--c-primary-2);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  @media (max-width: 880px) {
    .head-stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
