  /* F14 — institutional: monochrome work-card tag (no per-variant color). */
  .work-card__tag {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }
  .work-card--ai .work-card__tag { color: var(--c-ink-3); }
  .work-card__title {
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--c-ink);
    line-height: 1.25;
    letter-spacing: -0.012em;
  }
  .work-card__copy {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: 1.55;
    flex: 1;
  }
  .work-card__link {
    font-size: var(--fs-xs);
    font-family: var(--ff-mono);
    color: var(--c-primary-2);
    letter-spacing: 0.04em;
    transition: color var(--transition);
  }
  .work-card__link:hover {
    color: var(--c-primary-2-light);
  }

  @media (max-width: 880px) {
    .work__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 540px) {
    .work__grid { grid-template-columns: 1fr; }
  }

  /* ============================================================
     v6.7 — SELECTED WORK TIMELINE (5 rows)
     Vertical-timeline layout replacing the prior 3×2 card grid.
     Each row = 220px-wide year rail (left) + 1px vertical hairline
     connector (amber dot at midpoint) + flexible content area with
     a 3-bar before/after metric strip. The CSS for this was scaffolded
     in v6.6 but never written — so the section rendered as a plain
     markdown list. Fixed.
     ============================================================ */
  .work__timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 1px solid var(--c-rule);
    margin-left: 100px;
  }
  .work__row {
    position: relative;
    margin: 0;
    padding: 0;
  }
  .work__row-link {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--sp-5);
    padding: var(--sp-4) 0 var(--sp-4) var(--sp-6);
    color: var(--c-ink);
    text-decoration: none;
    align-items: start;
    border-bottom: 1px solid var(--c-rule);
    transition: background 120ms ease-out;
  }
  .work__row:last-child .work__row-link { border-bottom: 0; }
  .work__row-link:hover {
    background: rgba(232, 178, 32, 0.04);
  }
  .work__rail {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  /* F23 — institutional: timeline rail dot. No halo. Solid amber dot,
     tick mark reads as data-point on a rail (Bloomberg research-report
     style). */
  .work__rail::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--sp-6) - 4px);
    top: 6px;
    width: 8px;
    height: 8px;
    background: var(--c-amber);
    border-radius: 50%;
  }
  .work__year {
    font-family: var(--ff-mono);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--c-amber);
    letter-spacing: 0.02em;
  }
  .work__node { display: none; }
  .work__content {
    min-width: 0;
  }
  .work__line {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
    flex-wrap: wrap;
  }
  /* F14 — institutional: monochrome tags, no traffic-light pills.
     Man Group / AQR / Bridgewater use plain text category labels with
     a hairline border (not multi-color backgrounds). All tag variants
     collapse to the same ink-3 hairline-bordered chip. */
  .work__tag {
    display: inline-block;
    padding: 2px 8px;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    font-weight: 600;
    border-radius: 2px;
    background: transparent;
    border: 1px solid var(--c-rule);
    color: var(--c-ink-3);
  }
  .work__tag--ai { border-color: var(--c-rule); color: var(--c-ink-3); }
  .work__tag--research { border-color: var(--c-rule); color: var(--c-ink-3); }
  .work__tag--markets { border-color: var(--c-rule); color: var(--c-ink-3); }
  .work__tag--prediction { border-color: rgba(232, 178, 32, 0.45); color: var(--c-primary-2); }
  .work__title {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--c-ink);
    flex: 1;
    min-width: 200px;
  }
  .work__subtitle {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--c-ink-2);
  }
  .work__bars {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .work__bar {
    display: grid;
    grid-template-columns: 90px 1fr 60px 16px 1fr 60px;
    gap: var(--sp-2);
    align-items: center;
  }
  .work__bar-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-2);
  }
  .work__bar-track {
    position: relative;
    height: 10px;
    background: var(--c-tape);
    border: 1px solid var(--c-rule);
    border-radius: 1px;
    overflow: hidden;
  }
  .work__bar-fill {
    display: block;
    height: 100%;
    background: var(--c-ink-3);
    transition: width 200ms ease-out;
  }
  .work__bar-fill--after.is-pos { background: var(--c-data-positive); }
  .work__bar-fill--after.is-neg { background: var(--c-data-negative); }
  .work__bar-val {
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    color: var(--c-ink);
    text-align: right;
  }
  .work__bar-val--after.is-pos { color: var(--c-data-positive); }
  .work__bar-val--after.is-neg { color: var(--c-data-negative); }
  .work__bar-pipe {
    text-align: center;
    color: var(--c-ink-3);
    font-size: 0.75rem;
  }
  .work__bar-pipe.is-pos { color: var(--c-data-positive); }
  .work__bar-pipe.is-neg { color: var(--c-data-negative); }

  @media (max-width: 720px) {
    .work__timeline { margin-left: 60px; }
    .work__row-link { grid-template-columns: 1fr; gap: var(--sp-2); }
    .work__bar { grid-template-columns: 70px 1fr 50px 12px 1fr 50px; }
  }

  /* ============================================================
     THE NUMBERS — 2 rows × 4 cells of stat tiles. v6.7 had a
     class mismatch (.numbers__row vs .metric-row) that left the
     label/value/delta stacked on one line. F10 fix.
     ============================================================ */
  .metric-strip {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--c-rule);
  }
  .metric-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
    padding: var(--sp-4) 0;
    border-bottom: 1px solid var(--c-rule);
  }
  .metric-row--second {
    border-bottom: 0;
  }
  .metric {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 4px;
    min-width: 0;
  }
  .metric__label {
    font-size: 9.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-ink-3);
    line-height: 1;
    font-weight: 600;
  }
  .metric__num {
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    font-weight: 500;
    color: var(--c-ink);
    letter-spacing: -0.015em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .metric__delta {
    font-size: 0.66rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--c-ink-2);
    line-height: 1;
  }
  .metric__delta--up { color: var(--c-data-positive); }
  .metric__delta--down { color: var(--c-data-negative); }
  .metric__delta--flat { color: var(--c-ink-2); }

  /* Legacy .numbers__row kept for any back-compat consumer */
  .numbers__row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
    border-top: 1px solid var(--c-rule);
  }
  .number {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .number__fig {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    color: var(--c-ink);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .number__unit {
    font-size: 0.6em;
    color: var(--c-ink-2);
    margin-left: 0.05em;
  }
  .number__lbl {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 880px) {
    .numbers__row,
    .metric-row { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .numbers__row,
    .metric-row { grid-template-columns: 1fr 1fr; gap: var(--sp-4); }
    .number__fig { font-size: 1.85rem; }
  }

  /* ============================================================
     CREDENTIALS — chip ribbon (12 names)
     F14 institutional: monochrome ink-2 + 1 amber accent only
     ============================================================ */
  .creds__ribbon {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: center;
  }
  .creds__chip {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border: 1px solid var(--c-rule);
    background: transparent;
    font-size: var(--fs-xs);
    line-height: 1.3;
    transition: border-color var(--transition);
  }
  .creds__chip:hover {
    border-color: var(--c-primary-2);
  }
  .creds__chip-mono {
    font-family: var(--ff-mono);
    font-weight: 700;
    color: var(--c-primary-2-deep);
    font-size: var(--fs-2xs);
    letter-spacing: 0.05em;
  }
  .creds__chip-label {
    color: var(--c-ink-2);
    font-size: var(--fs-xs);
    letter-spacing: 0.04em;
  }
  .creds__chip-rule {
    display: none;
  }

  /* Legacy list (older markup, retained for safety) */
  .creds__list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--c-rule);
  }
  .creds__row {
    display: grid;
    grid-template-columns: 1.4fr 1.5fr auto;
    gap: var(--sp-5);
    padding: var(--sp-4) 0;
    border-bottom: 1px solid var(--c-rule);
    align-items: baseline;
  }
  .creds__name {
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--c-ink);
  }
  .creds__name sup {
    color: var(--c-primary-2-deep);
    font-size: 0.7em;
  }
  .creds__org {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
  }
  .creds__date {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .creds__row {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
      padding: var(--sp-4) 0;
    }
    .creds__date { margin-top: var(--sp-1); }
  }

  /* ============================================================
     Section head tweaks
     ============================================================ */
  .section__eyebrow {
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-primary-2-deep);
    margin-bottom: var(--sp-3);
    font-weight: 600;
  }
  .section__title {
    font-size: clamp(1.6rem, 3.4vw, 2.4rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .section__sub {
    font-size: var(--fs-base);
    color: var(--c-ink-2);
    line-height: 1.6;
    max-width: 100%;
    min-width: 0;
    overflow-wrap: break-word;
  }
  .section__foot {
    display: flex;
    justify-content: center;
    gap: var(--sp-4);
    margin-top: var(--sp-5);
  }
  /* v6.7.1 — beefed-up CTA rail below the Five Proofs timeline.
     The previous "All 15 projects →" text link read as dead. */
  .projects-cta {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--sp-4);
    width: 100%;
    max-width: 720px;
    padding: var(--sp-3) var(--sp-5);
    background: rgba(232, 178, 32, 0.04);
    border: 1px solid rgba(232, 178, 32, 0.35);
    border-radius: var(--radius);
    color: var(--c-ink);
    text-decoration: none;
    transition: background 120ms ease-out, border-color 120ms ease-out, transform 120ms ease-out;
  }
  .projects-cta:hover {
    background: rgba(232, 178, 32, 0.10);
    border-color: rgba(232, 178, 32, 0.55);
  }
  .projects-cta__eyebrow {
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--c-amber);
    font-weight: 600;
  }
  .projects-cta__main {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--c-ink);
    letter-spacing: -0.01em;
  }
  .projects-cta__arrow {
    font-size: 1.125rem;
    color: var(--c-amber);
    font-weight: 600;
  }

  /* ============================================================
     v6.1.0 — DARK ALT-SECTION OVERRIDES
     .section--alt is now institutional-tape. Override child element
     colors so titles, eyebrows, and cards render correctly on dark.
     ============================================================ */
  .section--alt .section__title { color: var(--c-primary); }
  .section--alt .section__sub { color: rgba(230, 237, 243, 0.7); }
  .section--alt .section__sub a { color: var(--c-primary-2-light); }
  .section--alt .section__eyebrow { color: var(--c-primary-2); }
  .section--alt .number__fig { color: var(--c-primary); }
  .section--alt .number__lbl { color: rgba(230, 237, 243, 0.6); }
  .section--alt .work-card {
    background: var(--c-tape-2);
    border-color: rgba(255, 255, 255, 0.08);
    color: var(--c-primary);
  }
  .section--alt .work-card:hover {
    border-color: var(--c-primary-2);
  }
  .section--alt .work-card__title { color: var(--c-primary); }
  .section--alt .work-card__copy { color: rgba(230, 237, 243, 0.7); }
  .section--alt .work-card__link { color: var(--c-primary-2-light); }
  .section--alt .what-cell {
    background: var(--c-tape-2);
    border-color: rgba(255, 255, 255, 0.08);
  }
  .section--alt .creds__row,
  .section--alt .numbers__row { border-color: rgba(255, 255, 255, 0.08); }
  .section--alt .creds__name { color: var(--c-primary); }
  .section--alt .creds__chip {
    border-color: rgba(255, 255, 255, 0.16);
  }
  .section--alt .creds__chip-label { color: rgba(230, 237, 243, 0.78); }
  .section--alt .creds__chip-mono { color: var(--c-amber-light); }
  .section--alt .creds__org { color: rgba(230, 237, 243, 0.7); }
  .section--alt .creds__date { color: rgba(230, 237, 243, 0.5); }
  .section--alt .section__foot .hero__link { color: var(--c-primary-2-light); }

  /* ============================================================
     MOBILE SAFETY NET — prevent any hero/section content from
     forcing horizontal scroll on narrow viewports.
     ============================================================ */
  @media (max-width: 880px) {
    .hero__top {
      grid-template-columns: 1fr;
      gap: var(--sp-5);
    }
    .hero__id {
      max-width: 320px;
      margin: 0 auto;
    }
  }
  @media (max-width: 600px) {
    .hero__title { font-size: clamp(1.65rem, 8.5vw, 2.1rem); }
    .hero__voice {
      font-size: 1.05rem;
}
    .hero__sub { font-size: var(--fs-xs); }
    .hero__sep { display: inline; margin: 0 0.3em; }
    .hero__actions { gap: var(--sp-3) var(--sp-4); }
    .section__title { font-size: 1.5rem; }
  }

  /* ============================================================
     v6.2 — WORLD EVENT MAP SECTION
     Sits between the ticker and the value props. Dark editorial
     band so the SVG continent dots read clearly. Voice line uses
     the shared VoiceLine component (curly quotes + amber rail).
     ============================================================ */
  .world-events {
    background: var(--c-tape);
    color: var(--ink-on-tape);
    border-block: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: var(--sp-8);
  }
  .world-events__head { margin-bottom: var(--sp-6); }
  .world-events .section__title {
    color: var(--c-primary);
    max-width: 28ch;
    letter-spacing: -0.02em;
  }
  .world-events .voice-line--cmd {
    color: rgba(230, 237, 243, 0.78);
    max-width: 72ch;
  }
  /* v6.4 — `.world-events__stage` is the relative-positioned wrapper
     that hosts <EarthGlobe /> + the absolutely-positioned <EarthPulse />
     overlay. Both children share the same aspect-ratio square. */
  .world-events__stage {
    position: relative;
    width: 100%;
    margin-bottom: var(--sp-5);
  }
  .world-events__stage .earth-pulse {
    width: 100% !important;
    height: 100% !important;
  }
  /* EarthDrawer is fixed-position, but the page reserves right-edge
     scrollbar gutter on desktop so the world-events content doesn't
     sit beneath the drawer when it's open. The drawer itself slides
     in via the `:has(details[open])` parent selector — see
     EarthDrawer.astro. */
  @media (min-width: 901px) {
    .world-events { padding-right: 0; }
  }
  @media (max-width: 720px) {
    .world-events .section__title { max-width: 100%; }
  }
  @media (prefers-reduced-motion: reduce) {
    /* The EventPin's own reduced-motion rule handles the pin animation;
       the section itself has no entrance animation. Keep this block as
       a documentation-grade placeholder so future contributors know
       the section honors the user preference at the component level. */
  }

  /* ============================================================
     v6.2 (Mission Q + R) — AMBIENT WORKSPACE BAND
     Two-row container: the ambient video strip on top, the four-lane
     world feed below. Both live on tape-dark so they read as one
     desk; the entry-point strip below is tape-2 (slightly lifted)
     and a 1px hairline separates them.
     ============================================================ */
  .workspace {
    background: var(--c-tape);
    color: var(--ink-on-tape);
    position: relative;
    border-block: 1px solid rgba(255, 255, 255, 0.06);
  }
  .workspace__ambient {
    position: relative;
    height: 72px;
    overflow: hidden;
    background: var(--c-tape);
    isolation: isolate;
  }
  /* The ambient band needs the HeroVideo overlay anchored to ITS
     height, not to the whole .workspace wrapper. The component
     already uses position:absolute; inset:0, so the parent needs
     `position: relative` (set on .workspace__ambient above) — no
     additional anchor CSS required. */
  .workspace__feed {
    background: var(--c-tape);
  }

  /* ============================================================
     v6.6.1 — WORKSPACE RESEARCH-COVERAGE + VELOCITY
     Two visual blocks sandwiched between HeroVideo and WorldFeed:
       (1) 6-axis radar (BACKTEST/SIGNALS/RISK/EXEC/EVAL/AGENTS)
           seeded from seedFromString(buildSeed() + '::radar')
       (2) 4×6 velocity heatmap of last 24 weeks
           seeded from seedFromString(buildSeed() + '::velocity')
     Both sit on a slightly lifted tape-2 surface to read as
     "data panel" between the ambient hero video and the live
     world-event feed.
     ============================================================ */
  .workspace__viz {
    background: var(--c-tape-2, var(--c-tape));
    color: var(--ink-on-tape);
    padding: clamp(20px, 2.4vw, 32px) clamp(16px, 2vw, 28px);
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(20px, 2.4vw, 32px);
    border-block: 1px solid rgba(255, 255, 255, 0.06);
  }
  @media (max-width: 720px) {
    .workspace__viz {
      grid-template-columns: 1fr;
    }
  }

  .workspace__viz-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--ff-mono);
    font-size: var(--fs-3xs, 9px);
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(230, 237, 243, 0.65);
    margin: 0 0 12px;
  }
  .workspace__viz-rule {
    display: inline-block;
    width: 18px;
    height: 1px;
    background: var(--c-amber);
    flex: 0 0 auto;
  }

  .workspace__radar {
    margin: 0;
    padding: 12px;
    background: rgba(255, 255, 255, 0.015);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 2px;
  }
  .workspace__radar-svg {
    display: block;
    width: 100%;
    height: auto;
    max-width: 360px;
    margin: 0 auto;
  }
  /* v6.7 — radar reads as institutional: outer hex rings at solid
     0.16 opacity (not dashed), axes at solid 0.20, filled polygon at
     0.32 with bright stroke. Labels in tabular mono at the perimeter
     with a numeric value next to each axis for instant readability. */
  .radar-grid {
    fill: none;
    stroke: rgba(255, 255, 255, 0.16);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .radar-axis {
    stroke: rgba(255, 255, 255, 0.22);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .radar-polygon {
    fill: var(--c-amber);
    fill-opacity: 0.32;
    stroke: var(--c-amber);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .radar-label {
    font-family: var(--ff-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    fill: rgba(230, 237, 243, 0.95);
    font-weight: 600;
  }
  .radar-value {
    font-family: var(--ff-mono);
    font-size: 8px;
    letter-spacing: 0.04em;
    fill: var(--c-amber);
    font-weight: 600;
  }
  .radar-vertex {
    fill: var(--c-amber);
    stroke: var(--c-bg);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }

  .workspace__velocity {
    margin: 0;
    padding: 12px;
    background: rgba(255, 255, 255, 0.015);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
  }
  /* F13.1 — burndown matrix: 1 header row (column labels W/P/H/F/M/R)
     + 4 data rows (week windows W18-W23, W12-W17, W06-W11, W00-W05).
     Row labels are in the gutter; cells carry the stage letter +
     intensity bar. Reads as a project pipeline heatmap, not piano keys. */
  .velocity__grid {
    display: grid;
    grid-template-columns: 64px repeat(6, 1fr);
    gap: 4px;
    flex: 1 1 auto;
    align-content: start;
  }
  .velocity-row {
    display: contents;
  }
  .velocity-row--header {
    /* Header row: column labels W/P/H/F/M/R */
  }
  .velocity-rowlabel {
    font-family: var(--ff-mono);
    font-size: 8.5px;
    line-height: 1;
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    align-self: center;
    text-align: right;
    padding-right: 8px;
  }
  .velocity-rowlabel--head {
    color: var(--c-ink-3);
    font-size: 8px;
    letter-spacing: 0.12em;
    opacity: 0.7;
  }
  .velocity-colhead {
    font-family: var(--ff-mono);
    font-size: 10px;
    line-height: 1;
    color: var(--c-amber);
    text-transform: uppercase;
