---
/**
 * index.astro — Home page. Hero with dual hat, featured projects, CTA.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import CTABanner from '@components/CTABanner.astro';
import { getCollection } from 'astro:content';
import { profile } from '@utils/profile';
import { path } from '@utils/url';

const projects = (await getCollection('project'))
  .sort((a, b) => a.data.order - b.data.order);
const aiFeatured = projects.filter(p => p.data.role === 'ai').slice(0, 3);
const quantFeatured = projects.filter(p => p.data.role === 'quant').slice(0, 3);
---
<BaseLayout title={profile.titles.primary} description={profile.titles.secondary}>

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__eyebrow">
        <span class="pill pill--brand">AI Engineer</span>
        <span class="pill pill--accent">Quantitative Researcher</span>
        <span class="pill">Multi-Agent · Statistical Modeling</span>
      </div>
      <h1 class="hero__title">
        Two hats, one method.<br />
        <span class="hero__accent">Eval-first discipline.</span>
      </h1>
      <p class="hero__sub">
        I build <strong>multi-agent LLM systems</strong> and <strong>systematic trading strategies</strong> on the same engineering principle:
        a quality gate before shipping. Eleven-agent orchestrator. 31-gate statistical eval harness. Pre-registered research.
        Public-data reproducibility. Headline metrics you can verify.
      </p>
      <div class="hero__stats">
        <div class="hero__stat">
          <div class="hero__stat-val mono">{profile.stats.aiAgentCount}</div>
          <div class="hero__stat-lbl">orchestrator + workers</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-val mono">{profile.stats.evalGates}</div>
          <div class="hero__stat-lbl">-gate eval harness</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-val mono">{profile.stats.locPython}</div>
          <div class="hero__stat-lbl">LOC light-dep Python</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-val mono">{profile.stats.certCount}</div>
          <div class="hero__stat-lbl">professional certs</div>
        </div>
      </div>
      <div class="hero__actions">
        <a href={path('/projects')} class="btn btn--primary">View all projects</a>
        <a href={path('/resume')} class="btn btn--ghost">Download resume ↓</a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Lane 1 · AI Engineer</p>
        <h2 class="section__title">Multi-agent LLM systems, eval-first.</h2>
        <p class="section__sub">
          Production-grade AI engineering: from agent charters to mechanical validators to MCP servers.
          Every project ships with a measurable scorecard, not a prompt demo.
        </p>
      </header>
      <div class="grid grid-3">
        {aiFeatured.map(p => (
          <ProjectCard
            href={path(`/projects/${p.id}`)}
            title={p.data.title}
            summary={p.data.summary}
            metrics={p.data.metrics}
            lane="ai"
            order={p.data.order}
            status={p.data.status === 'open-source' ? 'open source' : p.data.status}
          />
        ))}
      </div>
      <div class="section__foot">
        <a href={path('/projects')} class="btn btn--ghost">All AI projects →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Lane 2 · Quantitative Researcher</p>
        <h2 class="section__title">Systematic strategies, multiple-testing-aware.</h2>
        <p class="section__sub">
          Nine reproducible public-data research projects. Multiple-testing discipline, look-ahead-bias audits,
          cost-aware backtests, and honest OOS windows.
        </p>
      </header>
      <div class="grid grid-3">
        {quantFeatured.map(p => (
          <ProjectCard
            href={path(`/projects/${p.id}`)}
            title={p.data.title}
            summary={p.data.summary}
            metrics={p.data.metrics}
            lane="quant"
            order={p.data.order}
            status="public-data reproducible"
          />
        ))}
      </div>
      <div class="section__foot">
        <a href={path('/projects')} class="btn btn--ghost">All quant projects →</a>
      </div>
    </div>
  </section>

  <CTABanner
    title="Hiring for an AI Engineer or Quant Researcher seat?"
    sub="Public-data reproducible projects, runnable eval harnesses, and a 31-gate statistical validation stack. Let's talk."
    primaryLabel="Download resume ↓"
    secondaryLabel="Get in touch"
  />

</BaseLayout>

<style>
  .hero {
    padding-block: var(--sp-9);
    background:
      radial-gradient(1200px 600px at 80% -100px, rgba(44, 122, 123, 0.12), transparent 60%),
      radial-gradient(900px 500px at 0% 0%, rgba(11, 61, 92, 0.08), transparent 60%),
      var(--c-bg);
    border-bottom: var(--border);
  }
  .hero__inner {
    max-width: 880px;
  }
  .hero__eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-5);
  }
  .hero__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--sp-5);
  }
  .hero__accent { color: var(--c-primary); }
  .hero__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 68ch;
    margin-bottom: var(--sp-7);
  }
  .hero__sub strong { color: var(--c-ink); font-weight: 600; }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
    padding: var(--sp-5);
    background: var(--c-bg);
    border: var(--border);
    border-radius: var(--radius);
    margin-bottom: var(--sp-7);
  }
  .hero__stat {
    text-align: center;
    border-right: 1px solid var(--c-rule-soft);
    padding-right: var(--sp-4);
  }
  .hero__stat:last-child { border-right: none; padding-right: 0; }
  .hero__stat-val {
    font-size: var(--fs-2xl);
    font-weight: 700;
    color: var(--c-primary);
    line-height: 1;
  }
  .hero__stat-lbl {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    margin-top: var(--sp-2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .hero__actions { display: flex; gap: var(--sp-3); flex-wrap: wrap; }

  .section__foot {
    margin-top: var(--sp-6);
    display: flex;
    justify-content: center;
  }

  @media (max-width: 720px) {
    .hero__stats { grid-template-columns: 1fr 1fr; }
    .hero__stat:nth-child(2) { border-right: none; padding-right: 0; }
    .hero__stat:nth-child(1), .hero__stat:nth-child(2) {
      border-bottom: 1px solid var(--c-rule-soft);
      padding-bottom: var(--sp-3);
    }
  }
</style>