---
/**
 * index.astro — Home page. v6.1.0 (t-digital rebuild)
 *
 * Editorial single-column. No math on home. No jargon dump.
 * Structure: identity strip · what I do · selected work · the numbers · credentials · contact.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import CTABanner from '@components/CTABanner.astro';
import Ticker from '@components/Ticker.astro';
import StatementCarousel from '@components/StatementCarousel.astro';
import { getCollection } from 'astro:content';
import { profile } from '@utils/profile';
import { path } from '@utils/url';

const projects = (await getCollection('project')).sort((a, b) => a.data.order - b.data.order);
const aiFeatured = projects.filter((p) => p.data.role === 'ai').slice(0, 3);
const quantFeatured = projects.filter((p) => p.data.role === 'quant').slice(0, 3);
---

<BaseLayout title={profile.titles.primary} description={profile.titles.secondary}>
  {/* ============================================================
       HERO — dark editorial, single-column, identity-first.
       T-Digital pattern: full-bleed dark canvas, single H1 sentence,
       one italic voice line, restrained spacing, no math, no jargon.
       ============================================================ */}
  <section class="hero">
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="hero__grid" aria-hidden="true"></div>
    <div class="container hero__inner">
      <p class="hero__eyebrow">
        Open to remote roles · UTC+8
      </p>

      <h1 class="hero__title">
        Quant research <span class="hero__amp">&amp;</span> AI engineering,
        <br />shipped with the eval harness<span class="hero__period">.</span>
      </h1>

      <p class="hero__voice">
        I build research systems, and I ship the evals that prove they work.
      </p>

      <p class="hero__sub">
        Christian T. Macion, CTA<sup>®</sup> · based in Digos City, Philippines
        <span class="hero__sep" aria-hidden="true">·</span>
        remote-first, available 30 hrs/wk
      </p>

      <div class="hero__actions">
        <a href={path('/contact')} class="btn btn--primary">Get in touch →</a>
        <a href={path('/projects')} class="hero__link">Selected work</a>
        <a href={path('/resume')} class="hero__link">Resume</a>
      </div>
    </div>
  </section>

  {/* ============================================================
       TICKER — institutional marquee of methodology signals.
       Sits between the hero and the value props, acting as a
       status bar (the institutional "we are rigorous" indicator).
       ============================================================ */}
  <Ticker />

  {/* ============================================================
       WHAT I DO — four numbered value props, t-digital style.
       Each tile is a single sentence: what I do, in plain language.
       ============================================================ */}
  <section class="section what">
    <div class="container">
      <header class="section__head what__head">
        <p class="section__eyebrow">What I do</p>
        <h2 class="section__title">Four things, one discipline.</h2>
        <p class="section__sub">
          A senior quant and an AI engineer can share a desk only if both
          write the eval harness. That's the only output that survives the next
          data drift, the next regime shift, the next model swap.
        </p>
      </header>

      <ol class="what__list">
        <li class="what__row">
          <div class="what__num mono">01</div>
          <div class="what__body">
            <h3 class="what__title">Systematic strategies, multiple-testing-aware</h3>
            <p class="what__copy">
              I design, backtest, and validate systematic strategies on
              public data. Every published number survives deflated Sharpe,
              walk-forward, and frozen-spec evaluation before it goes on
              the page.
            </p>
          </div>
        </li>
        <li class="what__row">
          <div class="what__num mono">02</div>
          <div class="what__body">
            <h3 class="what__title">Multi-agent LLM systems, eval-first</h3>
            <p class="what__copy">
              I build agent systems with explicit charters, MCP tool
              contracts, and a runnable eval harness. The same gate stack
              used for systematic strategies gates LLM outputs.
            </p>
          </div>
        </li>
        <li class="what__row">
          <div class="what__num mono">03</div>
          <div class="what__body">
            <h3 class="what__title">Public-data reproducibility, end to end</h3>
            <p class="what__copy">
              Every project on this site is reproducible from public data.
              No proprietary feeds, no NDA-protected inputs. The codebase,
              the eval harness, and the scorecard ship together.
            </p>
          </div>
        </li>
        <li class="what__row">
          <div class="what__num mono">04</div>
          <div class="what__body">
            <h3 class="what__title">NDA-clean by construction</h3>
            <p class="what__copy">
              Past contract work (closed engagements, 2025–2026) is
              disclosed. Nothing on this site references a current or
              active employer's systems, code, or data.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  {/* ============================================================
       SELECTED WORK — small grid, t-digital restraint.
       3 quant + 3 AI. Compact. No big stat bars, no equations.
       Each card is title + 1-line summary + 1 chip.
       ============================================================ */}
  <section class="section section--alt work">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Selected work</p>
        <h2 class="section__title">Fifteen projects, two lanes, public data.</h2>
        <p class="section__sub">
          Nine systematic-strategy projects and six multi-agent LLM projects.
          Each one ships with a reproducible pipeline, an eval harness, and a
          scorecard.
        </p>
      </header>

      <div class="work__grid">
        {
          quantFeatured.map((p) => (
            <a href={path(`/projects/${p.id}`)} class="work-card">
              <div class="work-card__tag mono">QUANT</div>
              <h3 class="work-card__title">{p.data.title}</h3>
              <p class="work-card__copy">{p.data.summary}</p>
              <span class="work-card__link">Read case study →</span>
            </a>
          ))
        }
        {
          aiFeatured.map((p) => (
            <a href={path(`/projects/${p.id}`)} class="work-card work-card--ai">
              <div class="work-card__tag mono">AI</div>
              <h3 class="work-card__title">{p.data.title}</h3>
              <p class="work-card__copy">{p.data.summary}</p>
              <span class="work-card__link">Read case study →</span>
            </a>
          ))
        }
      </div>

      <div class="section__foot">
        <a href={path('/projects')} class="hero__link">All 15 projects →</a>
      </div>
    </div>
  </section>

  {/* ============================================================
       THE NUMBERS — single row, t-digital restraint.
       One line of stat tiles, no sparklines, no equations.
       ============================================================ */}
  <section class="section numbers">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">The numbers</p>
        <h2 class="section__title">What eleven months of build looks like.</h2>
      </header>

      <div class="numbers__row">
        <div class="number">
          <div class="number__fig mono tnum">{profile.stats.evalGates}</div>
          <div class="number__lbl">eval gates, G1–G31</div>
        </div>
        <div class="number">
          <div class="number__fig mono tnum">{profile.stats.aiAgentCount}</div>
          <div class="number__lbl">AI agents, orchestrator + workers</div>
        </div>
        <div class="number">
          <div class="number__fig mono tnum">{profile.stats.locPython}<span class="number__unit">k</span></div>
          <div class="number__lbl">lines of Python, on the desk</div>
        </div>
        <div class="number">
          <div class="number__fig mono tnum">{profile.stats.certCount}</div>
          <div class="number__lbl">certifications, 2024 → 2026</div>
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================
       STATEMENT CAROUSEL — editorial rotating sentences.
       Auto-advances every 5s, pauses on hover. The Anthropic /
       Schonfeld institutional signature: one rotating thought
       that re-anchors the page between the proof band and the
       credentials list.
       ============================================================ */}
  <StatementCarousel />

  {/* ============================================================
       CREDENTIALS — 4 flagship certs, plain text list.
       t-digital style: small list, no images here, just the names
       and the dates. Save the visuals for /certifications.
       ============================================================ */}
  <section class="section section--alt creds">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Credentials</p>
        <h2 class="section__title">A short list, in plain language.</h2>
        <p class="section__sub">
          The full credential library (102 certificates, four groups) is on
          the <a href={path('/certifications')}>certifications page</a>. The
          four below are the headlines.
        </p>
      </header>

      <ul class="creds__list">
        <li class="creds__row">
          <div class="creds__name">Certified Technical Analyst<sup>®</sup></div>
          <div class="creds__org">Society of Technical Analysts</div>
          <div class="creds__date mono">Jan 2026</div>
        </li>
        <li class="creds__row">
          <div class="creds__name">AI for the Modern Workforce</div>
          <div class="creds__org">Ateneo de Davao · US Embassy</div>
          <div class="creds__date mono">Nov 2025</div>
        </li>
        <li class="creds__row">
          <div class="creds__name">AIccelerate 2025</div>
          <div class="creds__org">BIDA · Bayan Academy · Meta</div>
          <div class="creds__date mono">Dec 2025</div>
        </li>
        <li class="creds__row">
          <div class="creds__name">Blockchain4Youth B4Y</div>
          <div class="creds__org">Bitget</div>
          <div class="creds__date mono">2026</div>
        </li>
      </ul>
    </div>
  </section>

  <CTABanner
    title="Hiring a Quant Researcher or AI Engineer?"
    sub="Public-data reproducible work. Runnable eval harnesses. NDA-clean by construction. Remote-first, available 30 hrs/wk."
    primaryLabel="Get in touch"
    primaryHref={path('/contact')}
    secondaryLabel="Read methodology"
    secondaryHref={path('/methodology')}
  />
</BaseLayout>

<style>
  /* ============================================================
     HERO — t-digital pattern. Dark canvas, single sentence, sparse.
     ============================================================ */
  .hero {
    position: relative;
    padding-block: clamp(var(--sp-7), 14vh, 11rem) clamp(var(--sp-7), 12vh, 9rem);
    background: var(--c-tape);
    color: var(--ink-on-tape);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
    min-width: 0;
  }
  /* v6.1.0 — Atmospheric dark hero. Soft amber glow + cool counter-glow +
     subtle grid. The two decorative divs are positioned absolutely so
     they never break the layout. */
  .hero__glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(900px 600px at 88% 8%, rgba(232, 178, 32, 0.18), transparent 65%),
      radial-gradient(700px 500px at 8% 95%, rgba(11, 61, 92, 0.25), transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 80px 80px;
    pointer-events: none;
    z-index: 0;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
    min-width: 0;
  }
  .hero__eyebrow {
    display: inline-block;
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-primary-2);
    font-weight: 600;
    margin-bottom: var(--sp-5);
  }

  .hero__title {
    font-size: clamp(2rem, 5.5vw, 4.2rem);
    line-height: 1.04;
    letter-spacing: -0.028em;
    color: #fafafa;
    font-weight: 600;
    margin-bottom: var(--sp-5);
    max-width: 100%;
    min-width: 0;
    overflow-wrap: break-word;
    text-wrap: balance;
  }
  .hero__amp {
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 400;
    color: var(--c-primary-2);
    padding: 0 0.05em;
  }
  .hero__period {
    color: var(--c-primary-2);
  }

  .hero__voice {
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.1rem, 2.4vw, 1.6rem);
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.78);
    max-width: 100%;
    margin-bottom: var(--sp-6);
    letter-spacing: -0.005em;
    min-width: 0;
  }

  .hero__sub {
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.62);
    line-height: 1.6;
    margin-bottom: var(--sp-7);
    max-width: 100%;
    min-width: 0;
  }
  .hero__sub sup {
    color: var(--c-primary-2);
    font-size: 0.7em;
  }
  .hero__sep {
    margin: 0 0.5em;
    color: rgba(255, 255, 255, 0.3);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-4) var(--sp-5);
    min-width: 0;
  }
  .hero__actions .btn--primary {
    background: var(--c-primary-2);
    color: #0a0a0a;
    border-color: var(--c-primary-2);
    padding: 0.7rem 1.3rem;
    font-weight: 600;
  }
  .hero__actions .btn--primary:hover {
    background: #f5b94a;
    border-color: #f5b94a;
  }
  .hero__link {
    color: var(--c-primary-2);
    text-decoration: underline;
    text-decoration-color: rgba(212, 160, 23, 0.4);
    text-underline-offset: 4px;
    font-weight: 500;
    font-size: var(--fs-base);
    transition:
      color var(--transition),
      text-decoration-color var(--transition);
  }
  .hero__link:hover {
    color: #f5b94a;
    text-decoration-color: #f5b94a;
  }

  /* ============================================================
     WHAT I DO — 4-row editorial list, t-digital quant-factory style.
     ============================================================ */
  .what__head { margin-bottom: var(--sp-7); }

  .what__list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--c-rule);
  }
  .what__row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--sp-5);
    padding: var(--sp-6) 0;
    border-bottom: 1px solid var(--c-rule);
    align-items: start;
  }
  .what__num {
    font-size: var(--fs-sm);
    color: var(--c-primary);
    font-weight: 700;
    letter-spacing: 0.05em;
    padding-top: 0.25rem;
  }
  .what__title {
    font-size: var(--fs-xl);
    font-weight: 600;
    color: var(--c-ink);
    margin-bottom: var(--sp-2);
    letter-spacing: -0.015em;
    line-height: 1.25;
  }
  .what__copy {
    font-size: var(--fs-base);
    color: var(--c-ink-2);
    line-height: 1.6;
    max-width: 100%;
    min-width: 0;
    overflow-wrap: break-word;
  }

  @media (max-width: 720px) {
    .what__row {
      grid-template-columns: 56px 1fr;
      gap: var(--sp-3);
    }
    .what__title { font-size: var(--fs-lg); }
  }

  /* ============================================================
     SELECTED WORK — 6 cards, 3-col grid on desktop.
     ============================================================ */
  .work__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }
  .work-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    color: var(--c-ink);
    text-decoration: none;
    transition:
      border-color var(--transition),
      transform var(--transition);
  }
  .work-card:hover {
    border-color: var(--c-primary);
    transform: translateY(-2px);
  }
  .work-card__tag {
    font-size: var(--fs-xs);
    color: var(--c-primary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
  }
  .work-card--ai .work-card__tag { color: var(--c-primary-3); }
  .work-card__title {
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--c-ink);
    line-height: 1.25;
    letter-spacing: -0.012em;
  }
  .work-card__copy {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: 1.55;
    flex: 1;
  }
  .work-card__link {
    font-size: var(--fs-xs);
    font-family: var(--ff-mono);
    color: var(--c-primary-2);
    letter-spacing: 0.04em;
    transition: color var(--transition);
  }
  .work-card__link:hover {
    color: var(--c-primary-2-light);
  }

  @media (max-width: 880px) {
    .work__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 540px) {
    .work__grid { grid-template-columns: 1fr; }
  }

  /* ============================================================
     THE NUMBERS — single row of 4 stat tiles, restrained.
     ============================================================ */
  .numbers__row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
    border-top: 1px solid var(--c-rule);
    padding-top: var(--sp-6);
  }
  .number {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .number__fig {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    color: var(--c-ink);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .number__unit {
    font-size: 0.6em;
    color: var(--c-ink-2);
    margin-left: 0.05em;
  }
  .number__lbl {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 880px) {
    .numbers__row { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .numbers__row { grid-template-columns: 1fr 1fr; gap: var(--sp-4); }
    .number__fig { font-size: 1.85rem; }
  }

  /* ============================================================
     CREDENTIALS — list of 4, plain table-like.
     ============================================================ */
  .creds__list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--c-rule);
  }
  .creds__row {
    display: grid;
    grid-template-columns: 1.4fr 1.5fr auto;
    gap: var(--sp-5);
    padding: var(--sp-4) 0;
    border-bottom: 1px solid var(--c-rule);
    align-items: baseline;
  }
  .creds__name {
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--c-ink);
  }
  .creds__name sup {
    color: var(--c-primary-2-deep);
    font-size: 0.7em;
  }
  .creds__org {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
  }
  .creds__date {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .creds__row {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
      padding: var(--sp-4) 0;
    }
    .creds__date { margin-top: var(--sp-1); }
  }

  /* ============================================================
     Section head tweaks
     ============================================================ */
  .section__eyebrow {
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-primary-2-deep);
    margin-bottom: var(--sp-3);
    font-weight: 600;
  }
  .section__title {
    font-size: clamp(1.6rem, 3.4vw, 2.4rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .section__sub {
    font-size: var(--fs-base);
    color: var(--c-ink-2);
    line-height: 1.6;
    max-width: 100%;
    min-width: 0;
    overflow-wrap: break-word;
  }
  .section__foot {
    display: flex;
    justify-content: center;
    gap: var(--sp-4);
    margin-top: var(--sp-4);
  }

  /* ============================================================
     v6.1.0 — DARK ALT-SECTION OVERRIDES
     .section--alt is now institutional-tape. Override child element
     colors so titles, eyebrows, and cards render correctly on dark.
     ============================================================ */
  .section--alt .section__title { color: #fafafa; }
  .section--alt .section__sub { color: rgba(230, 237, 243, 0.7); }
  .section--alt .section__sub a { color: var(--c-primary-2-light); }
  .section--alt .section__eyebrow { color: var(--c-primary-2); }
  .section--alt .number__fig { color: #fafafa; }
  .section--alt .number__lbl { color: rgba(230, 237, 243, 0.6); }
  .section--alt .work-card {
    background: var(--c-tape-2);
    border-color: rgba(255, 255, 255, 0.08);
    color: #fafafa;
  }
  .section--alt .work-card:hover {
    border-color: var(--c-primary-2);
  }
  .section--alt .work-card__title { color: #fafafa; }
  .section--alt .work-card__copy { color: rgba(230, 237, 243, 0.7); }
  .section--alt .work-card__link { color: var(--c-primary-2-light); }
  .section--alt .what__row,
  .section--alt .creds__row,
  .section--alt .numbers__row { border-color: rgba(255, 255, 255, 0.08); }
  .section--alt .what__title,
  .section--alt .creds__name { color: #fafafa; }
  .section--alt .what__copy,
  .section--alt .creds__org { color: rgba(230, 237, 243, 0.7); }
  .section--alt .creds__date { color: rgba(230, 237, 243, 0.5); }
  .section--alt .section__foot .hero__link { color: var(--c-primary-2-light); }

  /* ============================================================
     MOBILE SAFETY NET — prevent any hero/section content from
     forcing horizontal scroll on narrow viewports.
     ============================================================ */
  @media (max-width: 600px) {
    .hero__title { font-size: clamp(1.85rem, 9vw, 2.4rem); }
    .hero__voice { font-size: 1.05rem; }
    .hero__sub { font-size: var(--fs-xs); }
    .hero__sep { display: block; margin: 0.4em 0 0; }
    .hero__actions { gap: var(--sp-3) var(--sp-4); }
    .section__title { font-size: 1.5rem; }
    .what__title { font-size: 1.1rem; }
  }
</style>
