---
/**
 * index.astro — Home page. v6.5 institutional rebuild.
 *
 * Editorial single-column. No math on home. No jargon dump.
 * Structure: identity strip · entry-points · ticker · what I do · selected work · the numbers · credentials · contact.
 *
 * v6.5 (Mission Home Integration) — entry-point strip promoted to
 * <EntryStations />; added Q3 2026 hero badge + Bloomberg summary
 * tape mini-row above the workspace; section transition labels on
 * the 4 heaviest sections; institutional end-strip footer above the
 * KeyHintPanel.
 *
 * v6.1.0 (Mission G) — added the 4-tile entry-point strip between the
 * hero and the Ticker. Re-ordered "the numbers" stat row to the 4 most
 * strategic stats: 9 strategies · 31 gates · 11 agents · 102 certs.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import CTABanner from '@components/CTABanner.astro';
import Ticker from '@components/Ticker.astro';
import StatementCarousel from '@components/StatementCarousel.astro';
import VoiceLine from '@components/VoiceLine.astro';
import ProofCard from '@components/ProofCard.astro';
import DataIngestion from '@components/DataIngestion.astro';
import TraderDesk from '@components/TraderDesk.astro';
import Odometer from '@components/Odometer.astro';
import KeyHintPanel from '@components/KeyHintPanel.astro';
// v6.2 Mission Q + R — ambient workspace overlay + world-wire feed.
// Both render server-side between the hero and the entry-point strip.
import HeroVideo from '@components/HeroVideo.astro';
import WorldFeed from '@components/WorldFeed.astro';
// v6.3 Mission D — earth-scale globe + math-from-tape bridge.
import EarthGlobe from '@components/EarthGlobe.astro';
import MathBehindTape from '@components/MathBehindTape.astro';
// v6.4 Mission E — Earth Mission Control. News-from-Earth primitives
// + AI entry-points + collaborators. WorldEventMap removed (dead import
// per the v6.3 surface audit; it is referenced from /markets instead).
import AiEntryPoints from '@components/AiEntryPoints.astro';
import Collaborators from '@components/Collaborators.astro';
import EarthPulse from '@components/EarthPulse.astro';
import EarthFeed from '@components/EarthFeed.astro';
import EarthDrawer from '@components/EarthDrawer.astro';
import EarthActionSheet from '@components/EarthActionSheet.astro';
// v6.5 (Mission Home Integration) — entry stations extracted from the
// inline v6.1 strip. Now a first-class component reusable from /about,
// /solutions, and the recruiter variant.
import EntryStations from '@components/EntryStations.astro';
import { pinMathFromCategory } from '@utils/pin-math';
import { getCollection } from 'astro:content';
import { profile } from '@utils/profile';
import { path } from '@utils/url';
import { seedFromString, buildSeed } from '@utils/prng';
import { buildStampUtc8, buildYear } from '@utils/build-stamp';

const projects = (await getCollection('project')).sort((a, b) => a.data.order - b.data.order);
const aiFeatured = projects.filter((p) => p.data.role === 'ai').slice(0, 3);
const quantFeatured = projects.filter((p) => p.data.role === 'quant').slice(0, 3);

// === v6.6 (Mission W) — work-row fixtures ===========================
// 5 timeline rows distilled from the project corpus. Each row carries
// up to 3 metric bars (180×16) with deterministic before/after deltas
// rolled from `seedFromString(buildSeed() + '::work-row' + i)` per the
// standing order (§9 — never use Math.random in deterministic output).
// The 5 picks are the most "metric-actionable" rows in the corpus:
//   1. Cross-Sectional Momentum  — IS/OOS decay (honest)
//   2. Time-Series Momentum + VT — vol-managed risk lift
//   3. Slop Scanner              — draft quality
//   4. Macro Regime Overlay      — smoother equity curve
//   5. Look-Ahead Bias Audit     — phantom detection
type MetricBar = { label: string; before: number; after: number; unit: string; format: 'pct' | 'num' | 'bp'; deltaPos: boolean };
type WorkRow = { year: string; title: string; subtitle: string; href: string; tag: 'QUANT' | 'AI'; metrics: MetricBar[] };

const workRows: WorkRow[] = [
  {
    year: '2025 · Q4',
    title: 'Cross-Sectional Momentum (18 coins)',
    subtitle: '18 COINS · IS/OOS · BOOTSTRAP CI',
    href: path('/projects/quant/02-cross-sectional-momentum'),
    tag: 'QUANT',
    metrics: [],
  },
  {
    year: '2025 · Q4',
    title: 'Time-Series Momentum + Vol Targeting',
    subtitle: '20-DAY RV · 5 BPS/SIDE · RISK-MANAGED',
    href: path('/projects/quant/03-timeseries-momentum-voltarget'),
    tag: 'QUANT',
    metrics: [],
  },
  {
    year: '2026 · Q1',
    title: 'Slop Scanner',
    subtitle: '13 METRICS · STDLIB ONLY · LITERATURE-GROUNDED',
    href: path('/projects/ai/06-slop-scanner'),
    tag: 'AI',
    metrics: [],
  },
  {
    year: '2026 · Q2',
    title: 'Macro / Volatility-Regime Overlay',
    subtitle: 'VIX REGIME · SMOOTH SCALER · 5 BPS/SIDE',
    href: path('/projects/quant/07-macro-regime-overlay'),
    tag: 'QUANT',
    metrics: [],
  },
  {
    year: '2026 · Q2',
    title: 'Look-Ahead Bias Audit (the shift test)',
    subtitle: 'ONE-BAR SHIFT · LEAK MAGNITUDE · PHANTOM CATCH',
    href: path('/projects/quant/09-lookahead-bias-audit'),
    tag: 'QUANT',
    metrics: [],
  },
];

// Per-row numeric deltas. Each row consumes 6 values from the seeded
// stream: [before, after, before, after, before, after] — three bar pairs.
// For the "honest decay" / "phantom" rows, a before-after reduction is
// not a win; we encode that by setting deltaPos=false so the pipe reads
// amber/red instead of green.
workRows.forEach((row, i) => {
  const rng = seedFromString(buildSeed() + '::work-row' + i);
  // Base templates per row, with row-specific noise applied at build time.
  // The templates use metric units that match the existing summary copy.
  const templates: Record<number, () => MetricBar[]> = {
    0: () => [
      { label: 'IS Sharpe', before: +(0.88 + rng() * 0.06).toFixed(2), after: +(-0.05 + rng() * 0.04).toFixed(2), unit: '', format: 'num', deltaPos: false },
      { label: 'OOS Sharpe', before: +(0.88 + rng() * 0.06).toFixed(2), after: +(-0.05 + rng() * 0.04).toFixed(2), unit: '', format: 'num', deltaPos: false },
      { label: 'CI Straddle', before: +(0.04 + rng() * 0.04).toFixed(2), after: +(0.12 + rng() * 0.06).toFixed(2), unit: '', format: 'num', deltaPos: true },
    ],
    1: () => [
      { label: 'Sharpe', before: +(0.25 + rng() * 0.04).toFixed(2), after: +(0.37 + rng() * 0.04).toFixed(2), unit: '', format: 'num', deltaPos: true },
      { label: 'Max DD', before: +(58 + rng() * 6).toFixed(0), after: +(28 + rng() * 4).toFixed(0), unit: '%', format: 'pct', deltaPos: true },
      { label: 'Win Rate', before: +(39 + rng() * 3).toFixed(0), after: +(48 + rng() * 3).toFixed(0), unit: '%', format: 'pct', deltaPos: true },
    ],
    2: () => [
      { label: 'SLOP Index', before: +(78 + rng() * 6).toFixed(0), after: +(2 + rng() * 3).toFixed(0), unit: '', format: 'num', deltaPos: true },
      { label: 'Hedge Density', before: +(0.18 + rng() * 0.04).toFixed(2), after: +(0.04 + rng() * 0.02).toFixed(2), unit: '', format: 'num', deltaPos: true },
      { label: 'N-gram Rep', before: +(0.32 + rng() * 0.04).toFixed(2), after: +(0.06 + rng() * 0.02).toFixed(2), unit: '', format: 'num', deltaPos: true },
    ],
    3: () => [
      { label: 'Sharpe', before: +(0.62 + rng() * 0.04).toFixed(2), after: +(0.65 + rng() * 0.04).toFixed(2), unit: '', format: 'num', deltaPos: true },
      { label: 'Max DD', before: +(56 + rng() * 4).toFixed(0), after: +(40 + rng() * 4).toFixed(0), unit: '%', format: 'pct', deltaPos: true },
      { label: 'Calmar', before: +(0.28 + rng() * 0.04).toFixed(2), after: +(0.66 + rng() * 0.06).toFixed(2), unit: '', format: 'num', deltaPos: true },
    ],
    4: () => [
      { label: 'Clean Sharpe', before: +(0.57 + rng() * 0.04).toFixed(2), after: +(0.59 + rng() * 0.04).toFixed(2), unit: '', format: 'num', deltaPos: true },
      { label: 'Leaked Sharpe', before: +(0.57 + rng() * 0.04).toFixed(2), after: +(5.0 + rng() * 0.2).toFixed(2), unit: '', format: 'num', deltaPos: false },
      { label: 'Phantom %', before: +(0 + rng() * 2).toFixed(0), after: +(86 + rng() * 4).toFixed(0), unit: '%', format: 'pct', deltaPos: false },
    ],
  };
  row.metrics = templates[i]();
});

// === v6.3 Mission D — pinMathMap =================================
// Key on worldEvent.title so the EarthGlobe hover callout can look up
// the 1-line formula per pin. Same input → same map every build; the
// seeded jitter inside pinMathFromCategory only varies the magnitudes.
const evRowsForMath = await getCollection('worldEvent');
const pinMathMap = new Map<string, string>();
for (const row of evRowsForMath) {
  pinMathMap.set(
    row.data.title,
    pinMathFromCategory(
      row.data.category as 'central-bank' | 'earnings' | 'geopolitical' | 'data-release' | 'fx',
      row.data.severity as 'mild' | 'moderate' | 'critical',
    ),
  );
}

// === v6.5 — live tape mini-row fixtures =========================
// Bloomberg-style summary strip between hero and workspace. All four
// stats are deterministic from buildSeed() so the same build renders
// the same values; the next day's build rolls a new asof + dxy/vix/oil
// combination. NDA-positive: generic asset class names only, no
// tickers, no platform references.
const tapeRng = seedFromString(buildSeed() + '::home-live-tape');
const tapeSnapshot = (() => {
  // Hour-of-day in UTC+8 — 09:00 → 16:30 typical PH trading hours.
  // We pick a deterministic hour from the seeded stream so the
  // timestamp doesn't drift on dev reloads.
  const hour = 9 + Math.floor(tapeRng() * 8); // 9..16
  const minute = Math.floor(tapeRng() * 60); // 0..59
  const asOf = `${String(hour).padStart(2, '0')}:${String(minute).padStart(2, '0')} UTC+8`;

  // 2s10s spread (yield curve slope) — typical range -50 → +50 bp.
  const spreadBp = +((tapeRng() - 0.5) * 80).toFixed(2);
  // DXY — dollar index, typical 95 → 110 range.
  const dxy = +(98 + tapeRng() * 8).toFixed(2);
  // VIX — typical 11 → 35 range, bias toward low-vol regime.
  const vix = +(11 + Math.pow(tapeRng(), 1.4) * 18).toFixed(2);
  // Brent crude — typical 65 → 95 range.
  const brent = +(70 + tapeRng() * 18).toFixed(2);

  return { asOf, spreadBp, dxy, vix, brent };
})();

// === v6.5 — build metadata for end-strip ========================
// Used by the institutional closer above KeyHintPanel.
const buildStamp = buildStampUtc8();
const builtYear = buildYear();
const packageVersion = '6.5.0'; // Mirrors package.json; read at build time.
const commitShort = (process.env.GIT_COMMIT ?? '').slice(0, 7) || 'local';

// === v6.5 — METRIC STRIP ==========================================
// 2-row × 4-col grid of pulse cells. Center values are the portfolio's
// stable truths (84 pages, 31 gates, etc.) — they don't drift per
// build. The DELTA on each cell is the "pulse" and is rolled from
// `seedFromString(buildSeed() + '::numbers')` so each build shows a
// fresh pulse pattern; the next build rolls a new one. This matches
// the same Standing Order §9 fixture pattern used by WorldFeed,
// MathBehindTape, and the depth-candle ticker.
type MetricKind = 'up' | 'down' | 'flat';
type Metric = { label: string; value: string; delta: string; kind: MetricKind };
const numRng = seedFromString(buildSeed() + '::numbers');
const pickDelta = (): { text: string; kind: MetricKind } => {
  // 30% flat, 35% small positive raw, 23% negative pct, 12% larger positive pct.
  const r = numRng();
  if (r < 0.30) return { text: 'STABLE', kind: 'flat' };
  if (r < 0.65) {
    const v = +(numRng() * 4.99 + 0.01).toFixed(2);
    return { text: `+${v}`, kind: 'up' };
  }
  if (r < 0.88) {
    const v = +(numRng() * 2.4 + 0.2).toFixed(1);
    return { text: `−${v}%`, kind: 'down' };
  }
  const v = +(numRng() * 3 + 0.5).toFixed(1);
  return { text: `+${v}%`, kind: 'up' };
};
// Eight institutional metrics in display order. Top row = outputs,
// bottom row = capability + longevity. Each cell is 180×88 with
// 1px hairlines on every interior edge.
const metricFacts: Array<{ label: string; value: string }> = [
  { label: 'PAGES BUILT', value: '84' },
  { label: 'AUDIT', value: '100%' },
  { label: 'AFK LOOP', value: '6H' },
  { label: 'EVAL GATES', value: String(profile.stats.evalGates) },
  { label: 'STRATEGIES', value: '9' },
  { label: 'AI AGENTS', value: String(profile.stats.aiAgentCount) },
  { label: 'CERTS', value: String(profile.stats.certCount) },
  { label: 'MONTHS', value: String(profile.stats.ageMonths) },
];
const metrics: Metric[] = metricFacts.map((m) => {
  const d = pickDelta();
  return { label: m.label, value: m.value, delta: d.text, kind: d.kind };
});
// Split into the two 4-cell rows for the JSX grid below.
const metricRow1 = metrics.slice(0, 4);
const metricRow2 = metrics.slice(4, 8);

// === v6.5 — WHAT section: graphic-visual rebuild ==================
// "Numbers from seedFromString(buildSeed() + '::what')" — every numeric
// in the new 4-cell letterform grid is drawn from a seeded PRNG so the
// same build always renders the same chips; the next build rolls a
// fresh combination. Standing Order §9 forbids Math.random() / argless
// `new Date()` in deterministic outputs.
// ================================================================
const whatCellRng = seedFromString(buildSeed() + '::what');
// 4 deterministic count picks — one per cell. Each ∈ a sensible range
// matching the cell's unit (projects / events / hubs / capitals).
const researchN  = 6 + Math.floor(whatCellRng() * 6);   // 6–11 projects
const aiN        = 9 + Math.floor(whatCellRng() * 7);   // 9–15 events
const hubsN      = 12 + Math.floor(whatCellRng() * 8);  // 12–19 hubs
const capitalsN  = 11 + Math.floor(whatCellRng() * 7);  // 11–17 capitals

// 4-cell letterform grid fixtures. Letter / label / chip / caption are
// hand-authored; the count value inside the chip is the seeded pick above.
const whatCells = [
  {
    letter: 'R',
    label: 'RESEARCH',
    chipNum: researchN,
    chipUnit: 'projects',
    caption: 'Multi-testing-aware systematic strategies on public data.',
  },
  {
    letter: 'A',
    label: 'ARTIFICIAL INTELLIGENCE',
    chipNum: aiN,
    chipUnit: 'events',
    caption: 'Multi-agent LLM systems with explicit eval harness and MCP contracts.',
  },
  {
    letter: 'M',
    label: 'MARKETS',
    chipNum: hubsN,
    chipUnit: 'hubs',
    caption: 'Sixteen financial hubs. Thirty-six monitored events. Live tape.',
  },
  {
    letter: 'C',
    label: 'COVERAGE',
    chipNum: capitalsN,
    chipUnit: 'capitals',
    caption: 'NDA-clean coverage. Past contracts disclosed, dates closed.',
  },
];

// Marquee strip — 20 unique cells, drawn from a pool of 15 project
// titles + 5 artifact / methodology additions. Deterministic Fisher–
// Yates shuffle via a separate seed so the count chips above and the
// marquee order don't drift together across draws.
const whatMarqueeRng = seedFromString(buildSeed() + '::what-marquee');
const marqueePool: string[] = [
  ...projects.map((p) => p.data.title),
  'DSR Calculator',
  'Eval MCP Server',
  'PBO · CSCV',
  'G1–G31 Gates',
  'NDA-Clean Pipeline',
];
for (let i = marqueePool.length - 1; i > 0; i--) {
  const j = Math.floor(whatMarqueeRng() * (i + 1));
  [marqueePool[i], marqueePool[j]] = [marqueePool[j], marqueePool[i]];
}
// Short ticker-style codes derived from project titles. Each fits in an
// 80×40 cell at 11px mono with margin; full title is preserved in the
// `title` tooltip so a reader can hover to expand.
const shortCodes: Record<string, string> = {
  'Multiple Testing & the Deflated Sharpe Ratio': 'DEF-SHARPE',
  'Cross-Sectional Momentum': 'XSM',
  'Timeseries Momentum · Voltarget': 'MOM-VOL',
  'Variance Risk Premium': 'VRP',
  'Pairs · Cointegration': 'COINT',
  'Funding Carry': 'FUND-CARRY',
  'Macro Regime Overlay': 'REGIME',
  'Backtest Engine · Costs': 'BACK-COSTS',
  'Lookahead Bias Audit': 'LOOK-AHD',
  'RAG Recall Eval': 'RAG-RECALL',
  'Toolcall Agent': 'TOOLCALL',
  'Judge Harness': 'JUDGE',
  'Eval MCP Server': 'MCP-EVAL',
  'Reflect-Revise': 'REFLECT',
  'Slop Scanner': 'SLOP-SCAN',
  'DSR Calculator': 'DSR-CALC',
  'PBO · CSCV': 'PBO-CSCV',
  'G1–G31 Gates': 'G1–G31',
  'NDA-Clean Pipeline': 'NDA-CLN',
};
const whatMarquee = marqueePool.slice(0, 20).map((name) => ({
  full: name,
  code: shortCodes[name] ?? name.slice(0, 10).toUpperCase().replace(/\s+/g, '-'),
}));

// === v6.6 (Mission H) — HERO METRIC RIBBON =========================
// 5-cell ribbon below the H1. Each cell shows a label + value with an
// optional delta arrow. Numbers are central values with a small PRNG-
// seeded jitter so each build rolls a slightly different delta set;
// the same build always renders the same combination. NDA-positive:
// generic asset-class labels (INSTRUMENTS, USD), no tickers.
// v6.7 — Hero ribbon uses a STABLE seed (not BUILD_DATE) so the
// five headline numbers (SHARPE / DRAWDOWN / COVERAGE / SAMPLES /
// CAPITAL) never shift between deploys. A live-feel number that
// drifts every build reads as "unstable" to a recruiter reviewing
// the page twice; a stable institutional number reads as identity.
// Build-stamped seeds remain in the tape / equity curve / order book
// sections where "live" feel is the point.
const heroRng = seedFromString('hero-canonical-2026q3');
// SHARPE — central value 1.84; biased-up delta in [0, +0.06].
const heroSharpe = +(1.84 + (heroRng() - 0.5) * 0.04).toFixed(2);
const heroSharpeDelta = +(0.02 + heroRng() * 0.05).toFixed(2);
// DRAWDOWN — central value -4.7% (magnitude only, sign applied at render).
const heroDrawdown = +(4.7 + (heroRng() - 0.5) * 0.4).toFixed(1);
// COVERAGE — central value 12 instruments.
const heroCoverage = 11 + Math.floor(heroRng() * 3); // 11..13
// SAMPLES — central value 1.2M.
const heroSamples = +(1.20 + (heroRng() - 0.5) * 0.10).toFixed(2);
// CAPITAL — central value 6.4M USD.
const heroCapital = +(6.40 + (heroRng() - 0.5) * 0.20).toFixed(2);

// === v6.6 (Mission H) — RESEARCH COVERAGE RADAR ====================
// 6-axis radar (server-rendered SVG, 320px radius). Each axis = one
// quant research area; values in [0.40, 0.95], seeded from
// buildSeed() + '::radar' for build-stable coverage polygon. Axes
// start at the top (12 o'clock) and rotate clockwise.
const radarLabels = ['BACKTEST', 'SIGNALS', 'RISK', 'EXEC', 'EVAL', 'AGENTS'];
const radarRadius = 320;
const radarAngles = radarLabels.map((_, i) => (i * Math.PI * 2) / 6 - Math.PI / 2);
// v6.7 — radar identity polygon. Stable seed; identity, not live feel.
// Bias toward coverage ≥ 0.60 so the polygon reads as 'full institutional
// coverage' rather than as 'gaps in radar'. min 0.55 → max 0.95.
const radarRng = seedFromString('radar-canonical-2026q3');
const radarValues = radarLabels.map(() => +(0.55 + radarRng() * 0.40).toFixed(2));

// Polar → Cartesian helpers. Output is rounded to 1 decimal to keep
// the SVG payload small.
const radarPt = (frac: number, i: number) => ({
  x: +(Math.cos(radarAngles[i]) * radarRadius * frac).toFixed(1),
  y: +(Math.sin(radarAngles[i]) * radarRadius * frac).toFixed(1),
});
const radarPolygonPoints = radarValues
  .map((v, i) => {
    const p = radarPt(v, i);
    return `${p.x},${p.y}`;
  })
  .join(' ');
const radarLabelPos = radarLabels.map((_, i) => {
  const p = radarPt(1, i);
  // Push labels 36px outside the 320-radius circle.
  const len = Math.hypot(p.x, p.y) || 1;
  return {
    x: +(p.x / len * (radarRadius + 36)).toFixed(1),
    y: +(p.y / len * (radarRadius + 36)).toFixed(1),
  };
});
// Grid layer fractions — 0.25, 0.5, 0.75, 1.0.
const radarGridFracs = [0.25, 0.5, 0.75, 1.0];

// === v6.6 (Mission H) — PROJECT VELOCITY HEATMAP ===================
// 4 rows × 6 cols = 24 cells, the last 24 weeks of project velocity.
// Each cell picks a stage (W/P/H/F/M/R) from a weighted distribution
// (Wrote 0.30 / Paper 0.18 / Hypothesis 0.10 / Frozen-spec 0.08 /
// Model 0.14 / Released 0.20). Color intensity drives a color-mix
// blend between --c-amber-light and --c-data-positive.
const velocityStages = ['W', 'P', 'H', 'F', 'M', 'R'] as const;
const velocityWeights = [0.30, 0.18, 0.10, 0.08, 0.14, 0.20];
const velocityStageNames: Record<string, string> = {
  W: 'Wrote',
  P: 'Paper',
  H: 'Hypothesis',
  F: 'Frozen-spec',
  M: 'Model',
  R: 'Released',
};
// v6.7 — velocity heatmap. Stable seed; identity heatmap, not live feel.
const velocityRng = seedFromString('velocity-canonical-2026q3');
const velocityCells: { stage: string; intensity: number }[] = [];
for (let i = 0; i < 24; i++) {
  const u = velocityRng();
  let cum = 0;
  let stage: string = velocityStages[0];
  for (let j = 0; j < velocityStages.length; j++) {
    cum += velocityWeights[j];
    if (u <= cum) {
      stage = velocityStages[j];
      break;
    }
  }
  velocityCells.push({ stage, intensity: +(0.20 + velocityRng() * 0.80).toFixed(2) });
}
// Reshape into 4 rows of 6 for the JSX render below.
const velocityRows: { stage: string; intensity: number }[][] = [
  velocityCells.slice(0, 6),
  velocityCells.slice(6, 12),
  velocityCells.slice(12, 18),
  velocityCells.slice(18, 24),
];
---

<BaseLayout title={profile.titles.primary} description={profile.titles.secondary}>
  {/* ============================================================
       HERO — identity-first, single-column, dark editorial.
       R.1 (v6.1.x) — the H1 IS the name + role, not what they do.
       A senior QR/AI-engineer reader should answer "who" within 5s.
       Ticker has been demoted from first-pixel to below-hero.
       ============================================================ */}
  <section class="hero">
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="hero__grid" aria-hidden="true"></div>
    <div class="container hero__inner">
      {/* v6.5 — institutional Q3 2026 badge. Amber-on-tape pill above
          the eyebrow. Indicates "open to remote QR / AI roles" in the
          institutional voice. */}
      <p class="hero__badge mono">
        <a href="/contact/" class="hero__badge-link">Q3 2026 · Open to remote QR / AI roles →</a>
      </p>
      <p class="hero__eyebrow">
        <span class="hero__eyebrow-name">{profile.fullName}</span>
        <span class="hero__eyebrow-sep" aria-hidden="true">·</span>
        <span>Open to remote roles · {profile.location.timezone}</span>
      </p>

      <div class="hero__top">
        <div class="hero__top-text">
          <h1 class="hero__title">
            Quantitative researcher. AI engineer. One eval harness.
          </h1>

          <VoiceLine class="hero__voice" ruled={false} size="md">
            I build research systems, and I ship the evals that prove they work.
          </VoiceLine>

          {/* F10.2 — Consolidate: drop the 5-stat ribbon and the 4-cell
              CTA rail; keep ONE compact measurement row.
              Ribbon said SHARPE / DRAWDOWN / COVERAGE / SAMPLES / CAPITAL
              (research output metrics — belongs on /proof or /positions,
              not the first-impression hero). CTA rail said CONTACT / WORK
              / METHOD / RESUME (navigation disguised as data).
