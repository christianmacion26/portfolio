          {/* Data rows: 4 windows × 6 weeks each. Top = oldest, bottom = newest. */}
          {velocityRows.map((row, ri) => {
            // Window label: ri=0 → W18–W23 (oldest), ri=3 → W00–W05 (newest)
            const highWeek = (3 - ri) * 6 + 5;
            const lowWeek = (3 - ri) * 6;
            const label = `W${String(lowWeek).padStart(2, '0')}–W${String(highWeek).padStart(2, '0')}`;
            return (
              <div class="velocity-row" role="row">
                <span class="velocity-rowlabel mono" role="rowheader" aria-hidden="true">{label}</span>
                {row.map((cell, ci) => (
                  <div
                    class:list={['velocity-cell', `velocity-cell--${cell.stage.toLowerCase()}`]}
