  /* ============================================================
     WHAT I DO — v6.5 graphic-visual rebuild.
     4-cell letterform grid (240×180) + 20-cell marquee strip.
     Pure styled DOM, no client JS. Honors prefers-reduced-motion.
     ============================================================ */
  .what__head { margin-bottom: var(--sp-6); }

  /* === 4-cell letterform grid === */
  .what__cells {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
    margin-bottom: var(--sp-5);
  }

  .what-cell {
    position: relative;
    min-height: 200px;
    padding: var(--sp-3) var(--sp-3) var(--sp-3);
    background: var(--c-tape-2);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    overflow: hidden;
    isolation: isolate;
  }

  /* Top-right count chip — 11px mono tabular-nums with a leading amber dot */
  .what-cell__chip {
    position: absolute;
    top: 10px;
    right: 10px;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.6875rem; /* 11px */
    line-height: 1;
    color: var(--ink-on-tape);
    background: rgba(232, 178, 32, 0.08);
    border: 1px solid rgba(232, 178, 32, 0.30);
    border-radius: var(--radius-sm);
    padding: 0.32rem 0.55rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
    z-index: 2;
    white-space: nowrap;
  }
  .what-cell__chip-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--c-amber-light);
    flex-shrink: 0;
  }

  /* Giant sans-serif letter — 96px amber, flat (no offset shadow — institutional). */
  .what-cell__letter {
    position: relative;
    margin-top: var(--sp-3);
    font-family: var(--ff-sans);
    font-size: 96px;
    font-weight: 600;
    line-height: 0.85;
    letter-spacing: -0.045em;
    color: var(--c-amber-light);
    z-index: 1;
  }

  /* 14px tracked mono label below the letter */
  .what-cell__label {
    margin-top: var(--sp-2);
    font-size: 0.875rem; /* 14px */
    line-height: 1;
    letter-spacing: 0.12em;
    color: var(--c-ink);
    font-weight: 600;
    text-transform: uppercase;
  }

  /* 1-line caption — 10px ink-2, ≤ 80 char (enforced by data fixture). */
  .what-cell__caption {
    position: absolute;
    left: var(--sp-3);
    right: var(--sp-3);
    bottom: var(--sp-3);
    margin: 0;
    font-size: 0.625rem; /* 10px */
    line-height: 1.4;
    color: var(--c-ink-2);
    max-width: 224px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Mobile: collapse to 2×2 grid then single column */
  @media (max-width: 1040px) {
    .what__cells {
      grid-template-columns: repeat(2, 240px);
    }
  }
  @media (max-width: 540px) {
    .what__cells {
      grid-template-columns: 1fr;
    }
    .what-cell {
      width: 100%;
    }
  }

  /* === 20-cell marquee strip === */
  .what__marquee {
    position: relative;
    height: 40px;
    background: var(--c-tape);
    border-block: 1px solid var(--c-rule);
    overflow: hidden;
    user-select: none;
    margin-top: var(--sp-2);
  }
  /* Soft amber fade on the edges so cells fade in/out gracefully. */
  .what__marquee::before,
  .what__marquee::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 60px;
    z-index: 2;
    pointer-events: none;
  }
  .what__marquee::before {
    left: 0;
    background: linear-gradient(90deg, var(--c-tape), transparent);
  }
  .what__marquee::after {
    right: 0;
    background: linear-gradient(-90deg, var(--c-tape), transparent);
  }

  .what__marquee-track {
    display: flex;
    height: 100%;
    width: max-content;
    align-items: stretch;
    /* 30s cycle = 28s slide + 2s end-of-cycle pause. The 93.33% keyframe
       lands at translateX(-50%) — i.e. exactly one full copy of the
       20 cells — and the hold continues to 100% for the 2s pause. */
    animation: what-marquee-scroll 30s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    will-change: transform;
  }

  /* Each cell — 80×40 — short ticker-style code centered. Full name
     lives in the `title` tooltip on hover. */
  .what__marquee-cell {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 40px;
    flex: 0 0 80px;
    font-size: 0.625rem; /* 10px */
    line-height: 1;
    color: var(--ink-on-tape-2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-right: 1px solid var(--c-rule);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    padding-inline: 0.35rem;
    font-variant-numeric: tabular-nums;
  }
  /* Slight amber accent on every 5th cell — adds rhythm to the scroll
     without introducing extra motion. Pure decoration. */
  .what__marquee-cell:nth-child(5n) {
    color: var(--c-amber-light);
    background: rgba(232, 178, 32, 0.04);
  }

  /* Pause on hover — institutional "you can read it" affordance. */
  .what__marquee:hover .what__marquee-track {
    animation-play-state: paused;
  }

  @keyframes what-marquee-scroll {
    0% {
      transform: translateX(0);
    }
    93.33% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .what__marquee-track {
      animation: none !important;
    }
  }

  /* ============================================================
     SELECTED WORK — 6 cards, 3-col grid on desktop.
     ============================================================ */
  .work__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }
  .work-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
