---
/**
 * index.astro — Home page. v2 (math/quant aesthetic).
 *
 * Hero:   dual-hat headline + equation motif + 4 stat tiles with sparklines
 * Lane 1: 3 featured AI projects (with Quant Researcher secondary positioning)
 * Lane 2: 3 featured quant projects
 * Method: 3 highlight gates from G1–G31 (the eval-first signal)
 * Math:   3 "type signatures" of the method (DSR, multi-agent, walk-forward)
 * Resume: 3 tailored PDFs
 * CTA:    contact + download
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import CTABanner from '@components/CTABanner.astro';
import ProcessStrip from '@components/ProcessStrip.astro';
import TrustStrip from '@components/TrustStrip.astro';
import ProofCard from '@components/ProofCard.astro';
import BrandMotif from '@components/BrandMotif.astro';

const nowDate = new Date();
const nowLabel = `NOW · ${nowDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).replace(' ', '-')}`;
import Equation from '@components/Equation.astro';
import Stat from '@components/Stat.astro';
import Ticker from '@components/Ticker.astro';
import { getCollection } from 'astro:content';
import { profile } from '@utils/profile';
import { path } from '@utils/url';

const projects = (await getCollection('project')).sort((a, b) => a.data.order - b.data.order);
const aiFeatured = projects.filter((p) => p.data.role === 'ai').slice(0, 3);
const quantFeatured = projects.filter((p) => p.data.role === 'quant').slice(0, 3);

// Synthetic but realistic-looking sparkline data points (just shapes — honest framing in caption)
const sparkCap = [3, 4, 6, 8, 11, 13, 16, 18, 22, 26, 31]; // gates added month by month
---

<BaseLayout title={profile.titles.primary} description={profile.titles.secondary}>
  <Ticker />

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__eyebrow">
        <span class="pill pill--brand">Quant Researcher · AI Engineer</span>
        <span class="pill">Eval-first · NDA-clean · Public-data reproducible</span>
      </div>

      <h1 class="hero__title">
        Quant Researcher.<br />
        <span class="hl">Two hats.</span>
        <span class="hero__accent">One method.</span>
      </h1>

      <div class="hero__motif">
        <BrandMotif width={360} caption="G1–G31 · ship(x) = 1 ⇔ ∀ gates pass" />
      </div>

      <p class="hero__sub">
        Systematic strategies that survive <strong>multiple-testing correction</strong>. Multi-agent
        LLM systems that ship with a <strong>runnable eval harness</strong>. Same gate stack for
        both — declared before any number is published.
      </p>

      <div class="hero__eq-row">
        <div class="hero__eq-cell">
          <div class="hero__eq-label mono">deflated Sharpe</div>
          <Equation
            latex={`\\mathrm{DSR} = \\frac{\\widehat{\\mathrm{SR}} - \\mathrm{SR}_0}{\\sigma_{\\hat{SR}}} \\cdot \\left[1 - \\gamma_3 \\cdot \\widehat{\\mathrm{SR}} + \\gamma_4 \\cdot \\frac{\\widehat{\\mathrm{SR}}^2 - 1}{4}\\right]`}
          />
        </div>
        <div class="hero__eq-cell hero__eq-cell--right">
          <div class="hero__eq-label mono">multi-agent cost</div>
          <Equation
            tone="tape"
            latex={`\\mathrm{cost} = \\sum_{a \\in \\mathcal{A}} t(a) \\cdot p(\\mathrm{tier}(a))`}
          />
        </div>
      </div>

      {/* === R — Result: single big numerical proof + T — Tooltip === */}
      <div class="hero__result" tabindex="0" aria-describedby="hero-result-tooltip">
        <div class="hero__result-num mono">
          <span class="hero__result-eyebrow">statistical eval gates, declared up front</span>
          <span class="hero__result-figure">31</span>
          <span class="hero__result-cap">
            covering mechanical validity, statistical nulls, walk-forward OOS, multiple testing,
            look-ahead discipline, and economic realism
          </span>
        </div>
        <div class="hero__tooltip" id="hero-result-tooltip" role="tooltip">
          <div class="hero__tooltip-title mono">G1–G31 · six families</div>
          <ul class="hero__tooltip-list mono">
            <li><b>G1–G5</b> mechanical validity (schema, exit-0, JSON strict, byte budget)</li>
            <li>
              <b>G6–G10</b> statistical nulls (block-bootstrap CIs, random-timing, regime shuffle)
            </li>
            <li>
              <b>G11–G15</b> walk-forward / OOS (locked windows, 5-era stability, embargoed test)
            </li>
            <li>
              <b>G16–G20</b> multiple testing (deflated Sharpe, CSCV-PBO, MinBTL, Bonferroni–Holm)
            </li>
            <li><b>G21–G25</b> look-ahead discipline (point-in-time, survivorship, frozen-spec)</li>
            <li>
              <b>G26–G31</b> economic realism (spread/slippage, capacity, funding-carry, regime overlay)
            </li>
          </ul>
          <a class="hero__tooltip-link" href={path('/methodology')}>Read full methodology →</a>
        </div>
      </div>

      <div class="hero__actions">
        <a href={path('/solutions')} class="btn btn--primary">Read solutions</a>
        <a href={path('/methodology')} class="btn btn--ghost">Methodology (G1–G31)</a>
        <a href={path('/resume')} class="btn btn--ghost">Download resume ↓</a>
      </div>

      <div class="hero__proof-row">
        <span class="dot dot--pass"></span>
        <span class="mono hero__proof-text"
          >all 31 gates declared before any number is published · no proprietary data sources · see
          /experience for past engagements · all 9 quant projects reproducible end-to-end from
          public data</span
        >
      </div>
    </div>

    <aside class="hero__signature" aria-label="Featured proof — CTA cert portrait">
      <ProofCard
        src={path('/proof/cta-cert-portrait-2026-01.jpg')}
        alt="Christian T. Macion holding the Society of Technical Analysts Certified Technical Analyst® (CTA) certificate, certificate number 260197, awarded January 2026. Photographic proof of the Tier-1 CTA designation."
        caption="Sitting with the Tier-1 Certified Technical Analyst® certificate (Jan 2026) — certification number 260197. Visual proof, on the record."
        credit="STA · certificate #260197 · Jan 2026"
        aspect="auto"
        href={path('/certifications')}
      />
    </aside>
  </section>

  <TrustStrip
    buildSha={import.meta.env.PUBLIC_BUILD_SHA}
    lastVerifiedIso={import.meta.env.PUBLIC_LAST_VERIFIED ?? new Date().toISOString()}
  />

  <section class="stat-row">
    <div class="container">
      <div class="stat-row__inner">
        <Stat
          value="9"
          label="quant projects"
          sub="public-data reproducible"
          formula="|P_q|"
          size="lg"
          trend="up"
        />
        <Stat
          value={profile.stats.evalGates}
          label="eval gates"
          sub="G1–G31 statistical"
          spark={sparkCap}
          formula="g"
          size="lg"
          trend="up"
        />
        <Stat
          value="5"
          label="asset classes"
          sub="equity · crypto · vol"
          formula="\mathcal{U}"
          size="lg"
        />
        <Stat value="100%" label="NDA-clean" sub="public-data only" formula="\neg p" size="lg" />
      </div>
    </div>
  </section>

  <ProcessStrip
    title="How the AI lane ships."
    subtitle="Same five-step loop for every multi-agent build. The eval harness at the end is what keeps the other four honest."
    steps={[
      {
        num: '1',
        title: 'Intent',
        desc: 'Write the agent charter and acceptance criteria before any model is called. Output contract: JSON Schema strict.',
      },
      {
        num: '2',
        title: 'Architecture',
        desc: 'Orchestrator-worker topology. Eleven agents. Each with explicit inputs, outputs, and failure modes.',
      },
      {
        num: '3',
        title: 'Tools',
        desc: 'MCP for structured calls (backtests, file I/O, retriever). No tool calls without a logged schema.',
      },
      {
        num: '4',
        title: 'Eval gates',
        desc: 'G1–G31 mechanical validity + statistical nulls + LLM-as-judge on samples. Frozen spec, no mid-run edits.',
      },
      {
        num: '5',
        title: 'Deliverable',
        desc: 'Runnable repo + readme + memo + eval-harness output. Scorecard attached, not promised.',
      },
    ]}
  />

  <section class="now-strip">
    <div class="container">
      <div class="now-strip__inner">
        <div class="now-strip__cell">
          <div class="now-strip__label mono">
            {nowLabel} · <a href={path('/now')} class="now-strip__link">/now →</a>
          </div>
          <div class="now-strip__val">
            <strong>Open to:</strong> Quant Researcher (QR / QR-rotational), Quantitative Research Engineer,
            or Research Engineer seat · remote · UTC+8
          </div>
          <div class="now-strip__meta">
            <span class="mono">30 hrs/wk</span> · contract or part-time · immediate start
          </div>
        </div>
        <div class="now-strip__cell now-strip__cell--narrow">
          <div class="now-strip__label mono">LATEST</div>
          <div class="now-strip__val">DSR calculator shipped (signature interactive)</div>
        </div>
        <div class="now-strip__cell now-strip__cell--narrow">
          <div class="now-strip__label mono">NEXT</div>
          <div class="now-strip__val">
            <a href={path('/positions')} class="now-strip__link"
              >Live paper-trade log · project 03</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">
          Lane 1 · Quant Researcher <span class="mono">⟵ primary</span>
        </p>
        <h2 class="section__title">Systematic strategies, multiple-testing-aware.</h2>
        <p class="section__sub">
          Nine reproducible public-data research projects. Each candidate survives deflated Sharpe,
          CSCV-based PBO, walk-forward, and frozen-spec evaluation before the number is published.
        </p>
      </header>
      <div class="grid grid-3">
        {
          quantFeatured.map((p) => (
            <ProjectCard
              href={path(`/projects/${p.id}`)}
              title={p.data.title}
              summary={p.data.summary}
              metrics={p.data.metrics}
              lane="quant"
              order={p.data.order}
              status="public-data reproducible"
            />
          ))
        }
      </div>
      <div class="section__foot">
        <a href={path('/projects')} class="btn btn--ghost">All quant projects →</a>
        <a href={path('/publications')} class="btn btn--ghost">Publications log →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Lane 2 · AI Engineer <span class="mono">⟵ secondary</span></p>
        <h2 class="section__title">Multi-agent LLM systems, eval-first.</h2>
        <p class="section__sub">
          Six OSS projects. Agent charters, MCP servers, eval harnesses, and LLM-as-judge gates —
          everything that says "shipped" also has a scorecard attached.
        </p>
      </header>
      <div class="grid grid-3">
        {
          aiFeatured.map((p) => (
            <ProjectCard
              href={path(`/projects/${p.id}`)}
              title={p.data.title}
              summary={p.data.summary}
              metrics={p.data.metrics}
              lane="ai"
              order={p.data.order}
              status="open source"
            />
          ))
        }
      </div>
      <div class="section__foot">
        <a href={path('/projects')} class="btn btn--ghost">All AI projects →</a>
        <a href={path('/solutions')} class="btn btn--ghost">Solutions library →</a>
      </div>

      <aside class="ai-secondary">
        <div class="ai-secondary__title mono">AI · SECONDARY — what this lane is and isn't</div>
        <p class="ai-secondary__note">
          The AI lane ships work, not previews. It is the same eval-first discipline applied
          to LLM outputs: agent charters, MCP servers, scorecards, and frozen-spec evaluation. The primary
          seat target is Quant Researcher; the AI lane is what makes me useful inside a quant team that
          ships with LLM tooling. See <a href={path('/solutions')}>the solutions library</a> for the problem
          → approach → evidence → outcome → proof pattern, and
          <a href={path('/mistakes')}>postmortems</a> for the failure modes the eval stack is built to
          catch.
        </p>
      </aside>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">The method · G1–G31</p>
        <h2 class="section__title">One gate stack. Two lanes.</h2>
        <p class="section__sub">
          The same gate stack gates LLM outputs and systematic strategies. Six families, 31 gates,
          one contract. See the full gate taxonomy on the <a href={path('/methodology')}
            >methodology page</a
          >.
        </p>
      </header>

      <div class="gates-preview">
        <div class="gate-tile">
          <div class="gate-tile__range mono">G1–G5</div>
          <div class="gate-tile__name">Mechanical validity</div>
          <ul class="gate-tile__list mono">
            <li>schema conformance</li>
            <li>exit-0 contract</li>
            <li>JSON Schema strict</li>
            <li>byte-length budget</li>
          </ul>
        </div>
        <div class="gate-tile">
          <div class="gate-tile__range mono">G6–G10</div>
          <div class="gate-tile__name">Statistical nulls</div>
          <ul class="gate-tile__list mono">
            <li>block-bootstrap CIs</li>
            <li>random-timing nulls</li>
            <li>regime shuffle</li>
            <li>parameter-prior sensitivity</li>
          </ul>
        </div>
        <div class="gate-tile">
          <div class="gate-tile__range mono">G11–G15</div>
          <div class="gate-tile__name">Walk-forward & OOS</div>
          <ul class="gate-tile__list mono">
            <li>locked OOS windows</li>
            <li>5-era stability</li>
            <li>expanding/rolling</li>
            <li>embargoed test set</li>
          </ul>
        </div>
        <div class="gate-tile">
          <div class="gate-tile__range mono">G16–G20</div>
          <div class="gate-tile__name">Multiple testing</div>
          <ul class="gate-tile__list mono">
            <li>deflated Sharpe</li>
            <li>CSCV-based PBO</li>
            <li>MinBTL</li>
            <li>Bonferroni–Holm</li>
          </ul>
        </div>
        <div class="gate-tile">
          <div class="gate-tile__range mono">G21–G25</div>
          <div class="gate-tile__name">Look-ahead discipline</div>
          <ul class="gate-tile__list mono">
            <li>point-in-time data</li>
            <li>survivorship check</li>
            <li>timing consistency</li>
            <li>frozen-spec</li>
          </ul>
        </div>
        <div class="gate-tile">
          <div class="gate-tile__range mono">G26–G31</div>
          <div class="gate-tile__name">Economic realism</div>
          <ul class="gate-tile__list mono">
            <li>spread/slippage/latency</li>
            <li>capacity constraint</li>
            <li>funding-carry</li>
            <li>regime overlay</li>
          </ul>
        </div>
      </div>

      <div class="section__foot">
        <a href={path('/methodology')} class="btn btn--primary">Read full methodology →</a>
      </div>
    </div>
  </section>

  <CTABanner
    title="Hiring a Quant Researcher or AI Engineer?"
    sub="Public-data reproducible projects. Runnable eval harnesses. A 31-gate statistical validation stack. NDA-clean by construction."
    primaryLabel="Read solutions"
    secondaryLabel="Get in touch"
    secondaryHref={path('/contact')}
  />
</BaseLayout>

<style>
  .hero {
    padding-block: var(--sp-9);
    background:
      radial-gradient(1200px 600px at 80% -100px, rgba(212, 160, 23, 0.14), transparent 60%),
      radial-gradient(900px 500px at 0% 0%, rgba(11, 61, 92, 0.1), transparent 60%), var(--c-paper);
    border-bottom: var(--border);
  }
  .hero__inner {
    max-width: 980px;
  }
  .hero__eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-5);
  }
  .hero__title {
    font-size: clamp(1.875rem, 5.6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.035em;
    margin-bottom: var(--sp-5);
  }
  .hero__accent {
    color: var(--c-primary);
  }
  .hero__motif {
    display: flex;
    justify-content: flex-start;
    margin: 0 0 var(--sp-5);
  }
  .hero__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 72ch;
    margin-bottom: var(--sp-7);
  }
  .hero__sub strong {
    color: var(--c-ink);
    font-weight: 600;
  }

  .hero__eq-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--sp-5);
    margin-bottom: var(--sp-7);
  }
  .hero__eq-cell {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    overflow-x: auto;
  }
  .hero__eq-cell--right {
    background: var(--c-tape);
    color: var(--ink-on-tape);
    border-color: var(--c-tape-2);
  }
  .hero__eq-cell--right .hero__eq-label {
    color: #d29922;
  }
  .hero__eq-label {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-primary-2-deep);
    margin-bottom: var(--sp-2);
    font-weight: 600;
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-3);
    margin-bottom: var(--sp-7);
  }

  /* === Hero R — Result + T — Tooltip (Delta 3 HRT) === */
  .hero__result {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: var(--sp-6);
    align-items: center;
    padding: var(--sp-5) var(--sp-6);
    margin-bottom: var(--sp-7);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-left: 3px solid var(--c-primary-2-deep);
    border-radius: var(--radius);
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
  }
  .hero__result:hover,
  .hero__result:focus-within {
    border-color: var(--c-primary);
    border-left-color: var(--c-primary-2-deep);
    box-shadow: var(--shadow-sm);
  }
  .hero__result-num {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .hero__result-eyebrow {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-primary-2-deep);
    font-weight: 600;
  }
  .hero__result-figure {
    font-size: clamp(5rem, 14vw, 9rem);
    font-weight: 800;
    line-height: 0.9;
    color: var(--c-primary);
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
  }
  .hero__result-cap {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-normal);
    max-width: 38ch;
  }
  .hero__tooltip {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg-2);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
  }
  .hero__tooltip-title {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-primary-2-deep);
    margin-bottom: var(--sp-3);
    font-weight: 700;
  }
  .hero__tooltip-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--sp-3) 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .hero__tooltip-list li {
    color: var(--c-ink-2);
    line-height: var(--lh-snug);
  }
  .hero__tooltip-list li b {
    color: var(--c-primary);
    font-weight: 700;
    margin-right: var(--sp-2);
  }
  .hero__tooltip-link {
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    color: var(--c-primary-2-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* === Stat row (Delta 4) === */
  .stat-row {
    padding-block: var(--sp-7);
    background: var(--c-bg-2);
    border-bottom: var(--border);
  }
  .stat-row__inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
  }

  @media (max-width: 880px) {
    .hero__result {
      grid-template-columns: 1fr;
    }
    .hero__result-figure {
      font-size: clamp(4rem, 18vw, 6rem);
    }
    .stat-row__inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 540px) {
    .stat-row__inner {
      grid-template-columns: 1fr;
    }
  }

  .hero__actions {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    margin-bottom: var(--sp-7);
  }

  .hero__proof-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    background: rgba(22, 163, 74, 0.06);
    border-left: 3px solid var(--c-pass);
    border-radius: var(--radius-sm);
  }
  .hero__proof-text {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
  }
  .hero__signature {
    margin-top: var(--sp-7);
    max-width: 920px;
    margin-left: auto;
    margin-right: auto;
  }

  /* === Gate preview tiles === */
  .gates-preview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--sp-3);
  }
  .gate-tile {
    padding: var(--sp-4);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-left: 3px solid var(--c-primary);
    border-radius: var(--radius);
    transition: border-color var(--transition);
  }
  .gate-tile:hover {
    border-color: var(--c-primary);
    border-left-color: var(--c-primary-2-deep);
  }
  .gate-tile__range {
    font-size: var(--fs-sm);
    color: var(--c-primary);
    font-weight: 700;
    margin-bottom: var(--sp-1);
  }
  .gate-tile__name {
    font-size: var(--fs-base);
    color: var(--c-ink);
    margin-bottom: var(--sp-2);
    font-weight: 600;
  }
  .gate-tile__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .gate-tile__list li {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    line-height: 1.5;
  }

  .section__foot {
    margin-top: var(--sp-6);
    display: flex;
    justify-content: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  @media (max-width: 880px) {
    .hero__eq-row {
      grid-template-columns: 1fr;
    }
  }

  /* === Now strip === */
  .now-strip {
    background: var(--c-tape);
    color: var(--ink-on-tape);
