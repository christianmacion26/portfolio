---
/**
 * experience.astro — timeline view.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import TimelineEntry from '@components/TimelineEntry.astro';
import CTABanner from '@components/CTABanner.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('experience'))
  .sort((a, b) => a.data.order - b.data.order);

// Pre-render each entry's content
const rendered = await Promise.all(
  entries.map(async e => {
    const { Content } = await render(e);
    return { entry: e, Content };
  })
);
---
<BaseLayout
  title="Experience"
  description="Operator and researcher experience across multi-agent AI platforms, venture incubation, content automation, and systematic trading research."
>

  <header class="page-head">
    <div class="container">
      <p class="section__eyebrow">Experience</p>
      <h1 class="page-head__title">Where the work happened.</h1>
      <p class="page-head__sub">
        {entries.length} engagements, current and past. The 19V Capital role is a <strong>closed past contract</strong>
        (03/2026 – 06/2026); all references are NDA-safe and free of proprietary data sources.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container container-narrow">
      <div class="timeline">
        {rendered.map(({ entry, Content }) => (
          <TimelineEntry
            title={entry.data.title}
            company={entry.data.company}
            location={entry.data.location}
            startDate={entry.data.startDate}
            endDate={entry.data.endDate}
            isCurrent={entry.data.isCurrent}
            summary={entry.data.summary}
          >
            <Content />
          </TimelineEntry>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    title="Need a deeper reference list?"
    sub="Contact me and I'll share a tailored reference pack — name, role, brief context — within 24 hours."
  />

</BaseLayout>

<style>
  .page-head {
    padding-block: var(--sp-9) var(--sp-6);
    background:
      radial-gradient(800px 400px at 80% 0%, rgba(11, 61, 92, 0.08), transparent 60%),
      var(--c-bg);
    border-bottom: var(--border);
  }
  .page-head__title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .page-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    max-width: 64ch;
  }
  .timeline { padding-block: var(--sp-5); }
</style>