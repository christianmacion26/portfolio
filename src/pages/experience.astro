---
/**
 * experience.astro — v2: timeline + math/quant aesthetic.
 *
 * Hero equation: where proof / work / time = per-engagement contribution density.
 * Stats panel: total engagements, total months, total proofs declared.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import TimelineEntry from '@components/TimelineEntry.astro';
import Stat from '@components/Stat.astro';
import Equation from '@components/Equation.astro';
import CTABanner from '@components/CTABanner.astro';
import ReadMeta from '@components/ReadMeta.astro';
import TrustStrip from '@components/TrustStrip.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { path } from '@utils/url';
import VoiceLine from '@components/VoiceLine.astro';

const allEntries: CollectionEntry<'experience'>[] = await getCollection('experience');
const entries = allEntries.sort((a, b) => a.data.order - b.data.order);

// Pre-render each entry's content
const rendered = await Promise.all(
  entries.map(async (e) => {
    const { Content } = await render(e);
    return { entry: e, Content };
  }),
);

// Aggregate metrics across all experiences (NDA-safe — only counts and labels)
const totalContributions = rendered.reduce(
  (sum, { entry }) => sum + (entry.data.contributions?.length ?? 0),
  0,
);
const totalProofs = rendered.reduce((sum, { entry }) => sum + (entry.data.proofs?.length ?? 0), 0);
const totalEntries = rendered.length;

// v6.11.19 — totalMonths derived from frontmatter (was hardcoded 25 with
// a stale comment "2024-12 → 2026-05 = ~25 months" — that span is
// actually 17 months, not 25). Union of months across all entries is
// the honest unique-months span of the experience column. `today`
// freezes at build time per deploy, so the chrome stays roughly
// current between commits.
function parseExpDate(s: string): Date {
  const today = new Date();
  if (s === 'present') return today;
  const [y, m] = s.split('-').map(Number);
  return new Date(Date.UTC(y, (m ?? 1) - 1, 1));
}
const monthKeys = new Set<string>();
for (const { entry } of rendered) {
  const start = parseExpDate(entry.data.startDate);
  const end = parseExpDate(entry.data.endDate ?? 'present');
  const cursor = new Date(start);
  while (cursor <= end) {
    monthKeys.add(`${cursor.getUTCFullYear()}-${String(cursor.getUTCMonth() + 1).padStart(2, '0')}`);
    cursor.setUTCMonth(cursor.getUTCMonth() + 1);
  }
}
const totalMonths = monthKeys.size;
// Earliest + latest months across all rendered entries — shown in the
// chrome as the experience window so the date stamps reflect real data.
const sortedMonths = [...monthKeys].sort();
const expWindowEarliest = sortedMonths[0] ?? '';
const expWindowLatest = sortedMonths[sortedMonths.length - 1] ?? '';
const expWindow = `${expWindowEarliest} → ${expWindowLatest}`;
---

<BaseLayout
  title="Experience"
  description="Operator and researcher experience across multi-agent AI platforms, venture incubation, content automation, and systematic trading research."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Experience', href: '/experience' },
  ]}
>
  <header class="page-head">
    <div class="container">
      <p class="section__eyebrow"><span class="mono">experience/</span> · engagements + proofs</p>
      <h1 class="page-head__title">
        Where the work happened — and how to <span class="hl">verify</span> it.
      </h1>
      <VoiceLine class="page-head__voice">
        Each engagement ships with proof. If the proof isn't public, the entry isn't here.
      </VoiceLine>
      <p class="page-head__sub">
        {entries.length} engagements. Each entry lists the contributions made and points to public artifacts
        that prove them. The systematic-strategy desk role is a <strong>closed past contract</strong
        >
        (03/2026 – 06/2026); all references are NDA-safe and free of proprietary data sources.
      </p>

      <div class="nda-callout" role="note">
        <span class="dot dot--amber" aria-hidden="true"></span>
        <div>
          <strong>NDA-safe by construction.</strong> Every entry on this page was written from publicly-attributable
          signals (public repos, public talks, public-data backtests) plus the contributions I have explicit
          permission to disclose. <strong
            >systematic-strategy desk (NDA-protected; closed past contract 03/2026 – 06/2026)</strong
          >
          is a <strong>closed past contract</strong>; PM of record with publicly attributable
          initials
          <span class="mono">(NDA-protected desk)</span>. No proprietary data sources, strategy
          internals, or desk PnL are referenced anywhere on this site. If the proof you need is
          missing, email me and if it's public, NDA-clean, and I have it on disk, I'll send it
          within 24 hours.
        </div>
      </div>

      <div class="head-eq">
        <Equation
          block
          latex={`\\text{contribution\\_density} = \\frac{\\sum_{e \\in E} \\text{proofs}(e)}{\\text{months}(\\Delta E)}`}
          size="md"
        />
      </div>

      <div class="head-stats">
        <Stat value={String(totalEntries)} label="engagements" sub="multi-hat" formula="|E|" />
        <Stat
          value={String(totalContributions)}
          label="contributions"
          sub="declared"
          formula="\sum c_e"
          trend="up"
        />
        <Stat
          value={String(totalProofs)}
          label="proof pointers"
          sub="public artifacts"
          formula="\sum p_e"
          trend="up"
        />
        <Stat value={`${totalMonths}`} label="months" sub={expWindow} formula="\Delta t" />
      </div>
    </div>
  </header>

  <TrustStrip variant="tape" />

  <div class="container container-narrow">
    <ReadMeta minutes={8} href={path('/proof')} />
  </div>

  <section class="section">
    <div class="container container-narrow">
      <div class="timeline">
        {
          rendered.map(({ entry, Content }) => (
            <TimelineEntry
              title={entry.data.title}
              company={entry.data.company}
              location={entry.data.location}
              startDate={entry.data.startDate}
              endDate={entry.data.endDate}
              isCurrent={entry.data.isCurrent}
              summary={entry.data.summary}
              contributions={entry.data.contributions}
              proofs={entry.data.proofs}
            >
              <Content />
            </TimelineEntry>
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner
    title="Need a deeper reference list?"
    sub="Contact me and I'll share a tailored reference pack — name, role, brief context — within 24 hours."
  />
</BaseLayout>

<style>
  .page-head {
    padding-block: var(--sp-9) var(--sp-7);
    background: var(--c-paper);
    border-bottom: var(--border);
  }
  .page-head__title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .page-head__voice {
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
  }
  .page-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 64ch;
    margin-bottom: var(--sp-6);
  }
  .page-head__sub strong {
    color: var(--c-ink);
    font-weight: 600;
  }
  .head-eq {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    margin-bottom: var(--sp-5);
    overflow-x: auto;
  }
  .head-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-3);
  }
  .timeline {
    padding-block: var(--sp-5);
  }

  @media (max-width: 880px) {
    .head-stats {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* === NDA-safe disclosure callout (Delta 8) === */
  .nda-callout {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    margin-top: var(--sp-5);
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-amberl-faint);
    border: 1px solid var(--c-amberl-strong);
    border-left: 3px solid var(--c-primary-2);
    border-radius: var(--radius);
    font-size: var(--fs-sm);
    color: var(--c-ink);
    line-height: var(--lh-loose);
  }
  .nda-callout strong {
    color: var(--c-primary);
    font-weight: 600;
  }
  .nda-callout .mono {
    font-size: 0.92em;
    color: var(--c-primary-2-deep);
  }
</style>
