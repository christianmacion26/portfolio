---
/**
 * contact.astro — v2: full contact directory with all channels and "use this for X" guidance.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Equation from '@components/Equation.astro';
import Avatar from '@components/Avatar.astro';
import { profile } from '@utils/profile';
import VoiceLine from '@components/VoiceLine.astro';

const channels = [
  {
    label: 'Open roles · JDs',
    sub: 'Email with the JD attached',
    value: profile.contact.email,
    href: `mailto:${profile.contact.email}?subject=JD%20%E2%80%94%20%5Brole%5D`,
    primary: true,
    use: 'I reply within 24h with: problem → approach → evidence → outcome → proof.',
  },
  {
    label: 'Casual · paper-trail',
    sub: 'LinkedIn DM',
    value: 'linkedin.com/in/christianmacion',
    href: profile.contact.linkedin,
    external: true,
    use: 'DMs open · recruiter-friendly.',
  },
  {
    label: 'Public work · proof',
    sub: 'GitHub',
    value: 'github.com/christianmacion26',
    href: profile.contact.github,
    external: true,
    use: '24 repos · runnable scorecards · reproducible methodology.',
  },
  {
    label: 'Writing · long-form',
    sub: 'Medium · twice monthly',
    value: 'medium.com/@christianmacion',
    href: profile.contact.medium,
    external: true,
    use: 'Quant research notes, multi-agent build logs, eval-harness write-ups. 2 posts / month.',
  },
  {
    label: 'Phone · WhatsApp · Viber',
    sub: 'Sync, after email',
    value: profile.contact.phoneDisplay,
    href: `tel:${profile.contact.phone}`,
    use: 'UTC+8 · best 9 AM – 6 PM PHT.',
  },
];

const platforms = [
  {
    label: 'OnlineJobs.ph',
    value: 'v2.onlinejobs.ph/jobseekers/info/4760383',
    href: profile.contact.ojp,
    use: 'Filipino remote roles · OJP applications.',
  },
  {
    label: 'Upwork',
    value: 'upwork.com/freelancers/~01785a76c001e4acd8',
    href: profile.contact.upwork,
    use: 'Contract engagements · hourly or fixed-price.',
  },
];---

<BaseLayout
  title="Contact"
  description={`Email ${profile.contact.email} with a JD, or reach me via LinkedIn, GitHub, or phone. Reply within 24h on weekdays.`}
  breadcrumbs={[{ name: "Home", href: "/" }, { name: "Contact", href: "/contact" }]}
>
  <header class="contact-head">
    <div class="container">
      <div class="contact-head__top">
        <div class="contact-head__copy">
          <p class="section__eyebrow"><span class="mono">contact/</span> · 24h reply · NDA-safe</p>
          <h1 class="contact-head__title">Five channels. Pick the one that fits.</h1>
          <VoiceLine class="contact-head__voice">
        Email-with-JD gets the richest reply. LinkedIn DM is fine for casual. Phone after email — never first.
      </VoiceLine>
          <p class="contact-head__sub">
            Each tile names the job it does, not the platform. For open roles, the email-with-JD
            path gets the richest reply (problem → approach → evidence → outcome → proof).
          </p>
        </div>
        <div class="contact-head__avatar">
          <Avatar
            alt={profile.headshot.alt}
            size={120}
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>

      <div class="contact-head__eq">
        <Equation
          latex={`\\text{response\\_time} \\leq 24 \\text{h} \\quad \\text{given} \\quad \\text{JD attached}`}
          size="md"
        />
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        {
          channels.map((c) => (
            <a
              class:list={['contact-card', { 'contact-card--primary': c.primary }]}
              href={c.href}
              target={c.external ? '_blank' : undefined}
              rel={c.external ? 'noopener' : undefined}
            >
              <div class="contact-card__label">
                {c.label}
                {c.external && (
                  <span class="contact-card__ext" aria-hidden="true">
                    ↗
                  </span>
                )}
              </div>
              <div class="contact-card__sub">{c.sub}</div>
              <div class="contact-card__value mono">{c.value}</div>
              <div class="contact-card__hint">{c.use}</div>
            </a>
          ))
        }
      </div>

      <aside class="loc-card">
        <h2 class="loc-card__title">Location & availability</h2>
        <ul class="mono">
          <li><strong>Based in</strong> {profile.location.display}</li>
          <li>
            <strong>Availability</strong>
            {profile.availability.mode} · {profile.availability.hours}
          </li>
          <li>
            <strong>Open to</strong> AI Engineer · Quantitative Researcher · Quant Developer · Trading
            Research Assistant roles
          </li>
          <li>
            <strong>Overlap with</strong> US East (UTC-5) = 21:00 – 02:00 PHT · EU (UTC+1) = 15:00 – 23:00
            PHT · APAC (UTC+9) = 09:00 – 18:00 PHT
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Freelance platforms</p>
        <h2 class="section__title">If you're sourcing on a marketplace.</h2>
        <p class="section__sub">
          These stay useful for Filipino-remote and short-engagement sourcing, but the channels
          above are the primary path. I treat OJP/Upwork as supplementary, not as the first stop.
        </p>
      </header>
      <div class="platforms-grid">
        {
          platforms.map((p) => (
            <a class="platform-card" href={p.href} target="_blank" rel="noopener">
              <div class="platform-card__label mono">{p.label}</div>
              <div class="platform-card__value mono">{p.value}</div>
              <div class="platform-card__hint">{p.use}</div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">How I respond</p>
        <h2 class="section__title">What to expect in a reply.</h2>
      </header>
      <ol class="how-i-reply">
        <li>
          <div class="how-i-reply__num mono">01</div>
          <div class="how-i-reply__body">
            <h3>Acknowledge within 24h</h3>
            <p>Short reply confirming I received the message and when to expect a real response.</p>
          </div>
        </li>
        <li>
          <div class="how-i-reply__num mono">02</div>
          <div class="how-i-reply__body">
            <h3>Read the JD fully</h3>
            <p>
              If a JD is attached, I'll read it end-to-end before replying. I'll surface the gates
              from G1–G31 that already apply to your stack.
            </p>
          </div>
        </li>
        <li>
          <div class="how-i-reply__num mono">03</div>
          <div class="how-i-reply__body">
            <h3>Solution sketch</h3>
            <p>
              You'll get a structured response: problem → approach → evidence → outcome → proof
              pointer. Same shape as the solutions page.
            </p>
          </div>
        </li>
        <li>
          <div class="how-i-reply__num mono">04</div>
          <div class="how-i-reply__body">
            <h3>Tailored resume if appropriate</h3>
            <p>
              For open roles, I'll send a tailored PDF within 24h. Three resume shapes already exist
              (unified / AI-only / Quant one-pager).
            </p>
          </div>
        </li>
        <li>
          <div class="how-i-reply__num mono">05</div>
          <div class="how-i-reply__body">
            <h3>AI architecture audit (on request)</h3>
            <p>
              Read your stack end-to-end and surface the gates from G1–G31 that already apply, plus
              the ones it doesn't yet cover. Same lens I apply to my own multi-agent builds.
            </p>
          </div>
        </li>
        <li>
          <div class="how-i-reply__num mono">06</div>
          <div class="how-i-reply__body">
            <h3>Business OSINT pass (on request)</h3>
            <p>
              Open-source intelligence on your business before we talk — public filings, posts,
              product surface, team footprint. So the first call starts with context, not discovery.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-head {
    padding-block: var(--sp-9) var(--sp-7);
    background:
      var(--c-paper);
    border-bottom: var(--border);
  }
  .contact-head__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--sp-5);
  }
  .contact-head__copy {
    flex: 1 1 auto;
    min-width: 0;
  }
  .contact-head__avatar {
    flex-shrink: 0;
    align-self: flex-start;
    position: relative;
    top: 8px;
  }
  .contact-head__avatar :global(.avatar) {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    border-width: 1px;
  }
  @media (max-width: 640px) {
    .contact-head__top {
      flex-direction: column-reverse;
      align-items: flex-start;
    }
    .contact-head__avatar :global(.avatar) {
      width: 96px !important;
      height: 96px !important;
    }
  }
  .contact-head__title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-block: var(--sp-4) var(--sp-5);
  }
  .contact-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 60ch;
    margin-bottom: var(--sp-6);
  }
  .contact-head__voice {
    margin: 0 0 var(--sp-4);
    max-width: 60ch;
}
  .contact-head__eq {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    display: inline-block;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }
  .contact-card {
    display: block;
    padding: var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    color: var(--c-ink);
    text-decoration: none;
    transition:
      border-color var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }
  .contact-card:hover {
    border-color: var(--c-primary);
    box-shadow: var(--shadow-md);
    color: var(--c-ink);
  }
  /* v6.10.33 — institutional: drop the F13-era amber gradient (rgba 212,160,23 stale).
     Lift via --c-bg-2 token; primary border remains to signal the hero variant. */
  .contact-card--primary {
    border-color: var(--c-primary);
    background: var(--c-bg-2);
  }
  .contact-card__label {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-2);
    margin-bottom: var(--sp-2);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .contact-card__ext {
    color: var(--c-primary-2-deep);
    font-family: var(--ff-mono);
    font-size: var(--fs-sm);
  }
  .contact-card__value {
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--c-primary);
    margin-bottom: var(--sp-2);
    word-break: break-word;
    overflow-wrap: break-word;
    line-height: 1.3;
  }
  .contact-card__sub {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--sp-1);
  }
  .contact-card__hint {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
  }

  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--sp-3);
  }
  .platform-card {
    display: block;
    padding: var(--sp-4);
    background: var(--c-bg);
    border: 1px solid var(--c-rule-soft);
    border-radius: var(--radius-sm);
    color: var(--c-ink);
    text-decoration: none;
    transition: border-color var(--transition);
  }
  .platform-card:hover {
    border-color: var(--c-ink-3);
    color: var(--c-ink);
  }
  .platform-card__label {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--sp-2);
  }
  .platform-card__value {
    font-size: var(--fs-sm);
    color: var(--c-primary-2-deep);
    margin-bottom: var(--sp-2);
    word-break: break-all;
  }
  .platform-card__hint {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
  }

  .loc-card {
    padding: var(--sp-5);
    background: var(--c-tape);
    border: 1px solid var(--c-tape-2);
    border-radius: var(--radius);
    color: rgba(230, 237, 243, 0.85);
  }
  .loc-card__title {
    font-size: var(--fs-lg);
    margin-bottom: var(--sp-3);
    color: var(--c-primary);
  }
  .loc-card ul {
    list-style: none;
    padding: 0;
  }
  .loc-card li {
    padding-block: var(--sp-2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    line-height: var(--lh-loose);
    font-size: var(--fs-sm);
  }
  .loc-card li:last-child {
    border-bottom: none;
  }
  .loc-card strong {
    color: var(--c-primary);
    font-weight: 600;
    margin-right: var(--sp-2);
  }

  .how-i-reply {
    list-style: none;
    padding: 0;
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .how-i-reply li {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--sp-5);
    padding: var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-left: 3px solid var(--c-primary);
    border-radius: var(--radius);
  }
  .how-i-reply__num {
    font-size: var(--fs-3xl);
    color: var(--c-primary);
    font-weight: 500;
    line-height: 1;
  }
  .how-i-reply__body h3 {
    font-size: var(--fs-base);
    margin-bottom: var(--sp-1);
  }
  .how-i-reply__body p {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin: 0;
  }

  @media (max-width: 720px) {
    .how-i-reply li {
      grid-template-columns: 1fr;
      gap: var(--sp-2);
    }
  }
</style>
