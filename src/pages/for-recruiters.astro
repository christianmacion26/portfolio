---
/**
 * for-recruiters.astro — v6.0 · one-pager for HR / hiring managers.
 *
 * 60-second skim page for recruiters who don't yet know the body of
 * the site. Answers the six institutional questions directly:
 * 1) Who, 2) Status, 3) Seniority + target seats, 4) Location +
 * authorization, 5) Resume PDF + plain-text, 6) Fastest contact.
 * Plus an FAQPage JSON-LD so recruiters' search boxes surface the
 * canonical answers.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CTABanner from '@components/CTABanner.astro';
import { profile } from '@utils/profile';
import { path } from '@utils/url';
import VoiceLine from '@components/VoiceLine.astro';

const fullName = profile.fullName;
const loc = profile.location;
const email = profile.contact.email;
const phoneDisplay = profile.contact.phoneDisplay;
const linkedin = profile.contact.linkedin;
const NGATE = `${profile.stats.evalGates}-gate`;

// v6.12 — cold-email template. The {placeholder} tokens must appear as
// literal text (the recruiter is supposed to copy-paste then fill them),
// not as JSX expressions. Stored as a string in the frontmatter and
// rendered via <pre>{...}</pre> so Astro doesn't try to evaluate them.
const emailTemplate = `Subject: [{role-tag}] {seniority} · JD attached — {company}

Hi Christian —

I’m a {your-role} at {company}, sourcing for a {role} seat.
The JD is attached. Highlights:
  - {JD bullet 1}
  - {JD bullet 2}
  - {JD bullet 3}

If you’re open, I’d like a 30-min screening this {Tue|Wed|Thu}
between 18:00–22:00 PHT (UTC+8). Full agenda: christianmacion-portfolio.pages.dev/screening-call
If not, who do you recommend?

— {name}`;

// Same template, ASCII-punctuated, for the mailto body. Slightly different
// (— → -, ’ → ') so it survives ASCII-only transport cleanly.
const emailBody = `Hi Christian —\n\nI'm a {your-role} at {company}, sourcing for a {role} seat.\nThe JD is attached. Highlights:\n  - {JD bullet 1}\n  - {JD bullet 2}\n  - {JD bullet 3}\n\nIf you're open, I'd like a 30-min screening this {Tue|Wed|Thu} between 18:00-22:00 PHT (UTC+8).\nFull agenda: https://christianmacion-portfolio.pages.dev/screening-call\n\nIf not, who do you recommend?\n\n— {name}`;

const faqs = [
  {
    q: 'Who is this candidate?',
    a: `${fullName} — a quantitative researcher and AI engineer based in ${loc.display}. ${profile.stats.aiAgentCount}-agent research platform, ${profile.stats.evalGates}-gate statistical eval harness, ${profile.stats.locPython} LOC Python, ${profile.stats.certCount} professional certifications across AI, finance, math, and events.`,
  },
  {
    q: 'What is their current availability?',
    a: `Open to remote Quant Researcher, QR-rotational, Quantitative Research Engineer, or Research Engineer seats with US-premarket or APAC overlap. Approximately ${profile.availability.hours} capacity, immediate start.`,
  },
  {
    q: 'What seniority level are they targeting?',
    a: 'Senior / staff Quant Researcher or Research Engineer. Primary seat: Quant Researcher (with QR-rotational considered). Secondary: AI Engineer inside a quant team that ships LLM tooling.',
  },
  {
    q: 'Where are they based, and what is their work authorization?',
    a: `Based in ${loc.display}. Filipino citizen, Philippine passport. Fully remote, all hours delivered over internet. Familiar with US pre-market (UTC-5 to UTC-8) and APAC overlap windows; primary working hours anchored at UTC+8.`,
  },
  {
    q: 'Do they have a one-page resume PDF?',
    a: `Yes. ${profile.stats.resumeCount} tailored one-page resumes are linked at /resume — Quant (one-page), AI-only, and Unified. Each lists the same identity block and ${NGATE} methodology but weights different evidence.`,
  },
  {
    q: 'Is the work NDA-clean by construction?',
    a: 'Yes. Every published research artifact uses only public-data sources (Yahoo Finance, CoinGecko, FRED, EDGAR, SEC filings, public CME/CBOE chains). No proprietary datasets, no non-public signals. The nda-audit script in /proof enforces this guarantee automatically on every build.',
  },
  {
    q: 'How fast can they respond?',
    a: 'Replies to recruiter emails within four business hours during UTC+8 day. Cold DMs slower. Direct phone for qualified screening calls only.',
  },
  {
    q: 'Do they require sponsorship?',
    a: 'No sponsorship is required for remote engagements; the candidate works as an independent contractor from the Philippines. For full-time W-2 roles, visa sponsorship is the employer-side question — the candidate holds a Philippine passport and is open to globally remote (EOR) arrangements.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="For recruiters"
  description="The 60-second candidate one-pager: availability, location, target seats, resume PDFs, and direct contact for hiring managers."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'For recruiters', href: '/for-recruiters' },
  ]}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <section class="hero">
    <div class="container container--narrow">
      <p class="eyebrow mono">
        <span>FOR HIRING MANAGERS</span>
        <span aria-hidden="true">·</span>
        <span>60-SECOND SKIM</span>
        <span aria-hidden="true">·</span>
        <span>NDA-CLEAN</span>
      </p>
      <h1 class="hero__title">{fullName}</h1>
      <VoiceLine class="hero__voice">
        60-second skim. NDA-clean. Built so a hiring manager can decide in one read.
      </VoiceLine>
      <p class="hero__sub">
        Quantitative researcher and AI engineer. {loc.display}.<br />
        Open to remote QR, QR-rotational, or research-engineer seats with US-premarket or APAC overlap.
      </p>

      <table class="kv">
        <tbody>
          <tr>
            <th scope="row">Status</th>
            <td>Open · immediate start · {profile.availability.hours}</td>
          </tr>
          <tr>
            <th scope="row">Target seats</th>
            <td
              >Quant Researcher (primary) · QR-Rotational · Quant Research Engineer · Research
              Engineer</td
            >
          </tr>
          <tr>
            <th scope="row">Location</th>
            <td>{loc.display} · working UTC+8 · remote-first</td>
          </tr>
          <tr>
            <th scope="row">Work authorization</th>
            <td
              >Filipino citizen · independent contractor · globally remote (EOR) · no sponsorship
              required</td
            >
          </tr>
          <tr>
            <th scope="row">Stack</th>
            <td
              >Python ({profile.stats.locPython} LOC) · {profile.stats.aiAgentCount} agents · {
                profile.stats.evalGates
              }-gate eval harness · MCP · multi-agent LLM · RAG · frozen-spec evals</td
            >
          </tr>
          <tr>
            <th scope="row">Resume PDF</th>
            <td>
              <a href={path('/resume')}>Tailored resumes →</a> ·
              <a href={path('/resume-tailored.pdf')} download>Quant (1-pg) ↓</a> ·
              <a href={path('/resume-ai-only.pdf')} download>AI-only ↓</a> ·
              <a href={path('/resume-quant-onepage.pdf')} download>Unified ↓</a>
            </td>
          </tr>
          <tr>
            <th scope="row">Contact</th>
            <td>
              <a href={`mailto:${email}?subject=Inquiry%20%E2%80%94%20Christian%20Macion`}
                >{email}</a
              >
              · {phoneDisplay} · <a href={linkedin} rel="noopener noreferrer" target="_blank"
                >LinkedIn</a
              >
            </td>
          </tr>
        </tbody>
      </table>

      <div class="hero__actions">
        <a
          class="btn btn--primary"
          href={`mailto:${email}?subject=Inquiry%20%E2%80%94%20Christian%20Macion`}
          >Email {fullName.split(',')[0]} →</a
        >
        <a class="btn btn--ghost" href={path('/resume')}>View resumes →</a>
        <a class="btn btn--ghost" href={path('/proof')}>See proof →</a>
        <a class="btn btn--ghost" href="#cold-email-template">Cold-email template ↓</a>
      </div>
    </div>
  </section>

  <section id="cold-email-template" class="section">
    <div class="container container--narrow">
      <header class="section__head">
        <p class="section__eyebrow mono">intro/</p>
        <h2 class="section__title">Cold-email template — paste, fill, send.</h2>
        <p class="section__sub">
          Copy the block below. Two mailto links pre-fill subject + body. Reply SLA: 4 business
          hours during UTC+8 day.
        </p>
      </header>

      <div class="intro-template">
        <pre class="intro-template__body mono">{emailTemplate}</pre>
        <ul class="intro-template__links">
          <li>
            <a
              class="btn btn--primary"
              href={`mailto:${email}?subject=${encodeURIComponent('[QR] Senior · JD attached — {role}')}&body=${encodeURIComponent(emailBody)}`}
            >
              Email [QR] track →
            </a>
          </li>
          <li>
            <a
              class="btn btn--ghost"
              href={`mailto:${email}?subject=${encodeURIComponent('[AI] Eval-first · JD attached — {role}')}&body=${encodeURIComponent(emailBody)}`}
            >
              Email [AI] track →
            </a>
          </li>
          <li class="intro-template__meta">
            Reply SLA · 4 business hours during UTC+8 day. Cold DMs: 24h SLA.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <header class="section__head">
        <p class="section__eyebrow mono">paths/</p>
        <h2 class="section__title">Reading paths — choose by role.</h2>
        <p class="section__sub">Two ways to skim. Same site. Same eval gates. Different subset.</p>
      </header>

      <div class="persona-grid">
        <article class="persona-card">
          <h3 class="persona-card__title">If you’re hiring an AI engineer</h3>
          <p class="persona-card__sub">
            Eval-first engineer. MCP server. RAG pipeline. Multi-agent harness.
          </p>
          <ul class="persona-card__links">
            <li>
              <a href={path('/methodology')}>
                {`G6, G7, G8, G11: frozen-spec eval · N-of-M · look-ahead bias`}
              </a>
            </li>
            <li>
              <a href={path('/projects')}>Projects → AI tooling lane</a>
            </li>
            <li>
              <a href={path('/resume-ai-only.pdf')} download>AI resume (4-pg) ↓</a>
            </li>
            <li>
              <a href={path('/proof')}>
                Proof → mcp-backtest-server · qfin-rag-harness · numerical-faithfulness-eval
              </a>
            </li>
          </ul>
        </article>

        <article class="persona-card">
          <h3 class="persona-card__title">If you’re hiring a Quant researcher</h3>
          <p class="persona-card__sub">
            QR or QR-rotational. Deflated Sharpe. Look-ahead audit. Strategy research.
          </p>
          <ul class="persona-card__links">
            <li>
              <a href={path('/methodology')}>
                {`G1–G4: regime · PSL · p-hacking · deflated Sharpe`}
              </a>
            </li>
            <li>
              <a href={path('/projects')}>Projects → Quant research lane</a>
            </li>
            <li>
              <a href={path('/resume-tailored.pdf')} download>Quant resume (4-pg) ↓</a>
            </li>
            <li>
              <a href={path('/research')}>
                {`Research → ${profile.stats.strategyCount} strategies · 12 sources`}
              </a>
            </li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <header class="section__head">
        <h2 class="section__title">FAQ — what hiring managers usually ask</h2>
        <p class="section__sub">
          {faqs.length} canonical questions. Each answer is short, factual, and verifiable from the rest
          of the site.
        </p>
      </header>

      <ol class="faq">
        {
          faqs.map((f, i) => (
            <li class="faq__item">
              <details>
                <summary>
                  <span class="faq__num mono">{String(i + 1).padStart(2, '0')}</span>
                  <span class="faq__q">{f.q}</span>
                </summary>
                <p class="faq__a">{f.a}</p>
              </details>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <CTABanner
    title="Skim the proof, not just the resume."
    sub="Every claim on this page is backed by a public-data reproducible artifact. See /proof for the full inventory of certifications, lectures, charts, OSS repos, and solutions."
    primaryLabel="Go to /proof"
    secondaryLabel="Browse /solutions"
    secondaryHref={path('/solutions')}
  />
</BaseLayout>

<style>
  .hero {
    padding-block: var(--sp-9) var(--sp-7);
    background: var(--c-paper);
    border-bottom: var(--border);
  }
  .eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-primary-2-deep);
    font-weight: 600;
    margin-bottom: var(--sp-5);
  }
  .hero__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: var(--sp-4);
    color: var(--c-ink);
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .hero__sub {
    font-size: clamp(1rem, 2vw, var(--fs-lg));
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin-bottom: var(--sp-7);
    max-width: 60ch;
  }
  .hero__voice {
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
  }
  .kv {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--sp-7);
    border-top: var(--border);
    border-bottom: var(--border);
  }
  .kv th,
  .kv td {
    text-align: left;
    padding: var(--sp-3) var(--sp-4);
    border-bottom: 1px solid var(--c-rule-soft);
    vertical-align: top;
  }
  .kv tr:last-child th,
  .kv tr:last-child td {
    border-bottom: none;
  }
  .kv th {
    width: 30%;
    color: var(--c-ink-3);
    font-weight: 600;
    text-transform: uppercase;
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    font-family: var(--ff-mono);
  }
  .kv td {
    color: var(--c-ink);
  }
  .kv a {
    color: var(--c-primary);
    text-decoration: underline;
    text-decoration-color: var(--c-amber-decor);
    text-underline-offset: 3px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: center;
  }

  .section {
    padding-block: var(--sp-9);
  }
  .section__head {
    margin-bottom: var(--sp-6);
  }
  .section__title {
    font-size: clamp(1.5rem, 3.5vw, var(--fs-2xl));
    margin-bottom: var(--sp-3);
    color: var(--c-ink);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .section__sub {
    color: var(--c-ink-2);
    font-size: var(--fs-base);
    line-height: var(--lh-loose);
    max-width: 60ch;
  }

  .faq {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: var(--border);
  }
  .faq__item {
    border-bottom: var(--border);
  }
  .faq__item details {
    padding: var(--sp-4) 0;
  }
  .faq__item summary {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
    cursor: pointer;
    font-weight: 600;
    color: var(--c-ink);
    font-size: var(--fs-lg);
    list-style: none;
    padding-right: var(--sp-7);
    position: relative;
  }
  .faq__item summary::-webkit-details-marker {
    display: none;
  }
  .faq__item summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 0;
    color: var(--c-primary-2-deep);
    font-size: 1.5rem;
    line-height: 1;
    font-weight: 400;
    transition: transform var(--transition);
  }
  /* v6.9.16 — drop the translateY(-2px) decorative shift. Used line-height
     + 1.5rem font for natural glyph centering instead. */
  .faq__item details[open] summary::after {
    content: '−';
    line-height: 0.85;
    display: inline-block;
  }
  .faq__num {
    color: var(--c-primary-2-deep);
    font-size: var(--fs-sm);
    flex-shrink: 0;
    width: 2.5ch;
    letter-spacing: 0.05em;
  }
  .faq__q {
    flex: 1;
  }
  .faq__a {
    margin: var(--sp-4) 0 0 calc(2.5ch + var(--sp-4));
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    font-size: var(--fs-base);
  }

  @media (max-width: 600px) {
    .kv th {
      width: 38%;
    }
    .kv td {
      overflow-wrap: anywhere;
      max-width: 60vw;
      font-size: var(--fs-sm);
      line-height: 1.4;
    }
  }

  /* v6.12 — cold-email template block. Two-column on desktop, stacked on
     mobile. Mailto deep-links pre-fill subject + body via encodeURIComponent. */
  .intro-template {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--sp-5);
    align-items: start;
  }
  .intro-template__body {
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    padding: var(--sp-5);
    font-size: var(--fs-sm);
    line-height: 1.55;
    color: var(--c-ink);
    white-space: pre-wrap;
    word-break: break-word;
    overflow-x: auto;
    margin: 0;
  }
  .intro-template__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .intro-template__links li {
    margin: 0;
  }
  .intro-template__links .btn {
    width: 100%;
    justify-content: center;
  }
  .intro-template__meta {
    color: var(--c-ink-3);
    font-size: var(--fs-xs);
    font-family: var(--ff-mono);
    line-height: var(--lh-loose);
    padding-top: var(--sp-2);
    border-top: 1px solid var(--c-rule-soft);
  }

  @media (max-width: 720px) {
    .intro-template {
      grid-template-columns: 1fr;
    }
  }

  /* v6.12 — persona split. 2-pane reading-path grid; single column on
     narrow viewports. Derived from /methodology gate numbers + the
     3 resume PDF variants; no hardcoded chrome. */
  .persona-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }
  .persona-card {
    padding: var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-left: 3px solid var(--c-primary);
    border-radius: var(--radius);
  }
  .persona-card__title {
    font-size: var(--fs-lg);
    color: var(--c-ink);
    margin-bottom: var(--sp-2);
    font-weight: 600;
    line-height: 1.2;
  }
  .persona-card__sub {
    color: var(--c-ink-2);
    font-size: var(--fs-sm);
    line-height: var(--lh-loose);
    margin-bottom: var(--sp-4);
  }
  .persona-card__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .persona-card__links li {
    padding-block: var(--sp-2);
    border-bottom: 1px solid var(--c-rule-soft);
  }
  .persona-card__links li:last-child {
    border-bottom: none;
  }
  .persona-card__links a {
    color: var(--c-primary);
    font-size: var(--fs-sm);
    text-decoration: underline;
    text-decoration-color: var(--c-amber-decor);
    text-underline-offset: 3px;
    line-height: var(--lh-loose);
  }

  @media (max-width: 800px) {
    .persona-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
