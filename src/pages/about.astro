---
/**
 * about.astro — v4.0 proof-first.
 *
 * IA: hero (avatar + equations + stats) → proof strip (3 strongest solutions)
 *   → methodology teaser → quant teaser → bio (4 prose paragraphs) →
 *   education (1 prose paragraph) → disclosure (1 prose paragraph) → CTA banner.
 *
 * Why proof-first: 20+ quant firm references (Jane Street blog, Two Sigma
 * /insights, D.E. Shaw, Vatic Labs) all lead the bio artefact: proof
 * strips sit above the human paragraph; bio is the closer, not the opener.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Stat from '@components/Stat.astro';
import Equation from '@components/Equation.astro';
import CTABanner from '@components/CTABanner.astro';
import Avatar from '@components/Avatar.astro';
import { profile } from '@utils/profile';
import { path } from '@utils/url';
import { getCollection, type CollectionEntry } from 'astro:content';
import VoiceLine from '@components/VoiceLine.astro';

type SolutionEntry = CollectionEntry<'solution'>;
type ProjectEntry = CollectionEntry<'project'>;

// Top 3 AI-lane solutions for the proof strip. Filter by data.lane
// and sort by data.order rather than relying on collection entry ids
// (glob-loader ids vary across Astro versions).
const allSolutions: SolutionEntry[] = await getCollection('solution');
const proofStrip: SolutionEntry[] = allSolutions
  .filter((s) => s.data.lane === 'ai')
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

// v6.10.31 — derive project count from collection (quant lane = public-data reproducible)
const allProjectsForCount: ProjectEntry[] = await getCollection('project');
const quantProjectCount = allProjectsForCount.filter((p) => p.data.role === 'quant').length;

// v6.10.47 — derive gate-count chrome from profile.stats.evalGates.
const NGATE = `${profile.stats.evalGates}-gate`;
---

<BaseLayout
  title="About"
  description="Operator + researcher building eval-first multi-agent AI systems and systematic trading research."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'About', href: '/about' },
  ]}
>
  <header class="page-head">
    <div class="container container-narrow">
      <Avatar alt={profile.headshot.alt} size={200} />
      <p class="section__eyebrow"><span class="mono">about/</span> · operator + researcher</p>
      <h1 class="page-head__title">
        One method. <span class="hl">Two hats</span>.
      </h1>
      <VoiceLine class="page-head__voice">
        I build the eval harness first. Then I build the work that has to pass it.
      </VoiceLine>

      <div class="head-eq">
        <Equation
          block
          latex={`\\mathrm{ship}(x) = \\begin{cases} 1 & \\text{if } x \\text{ passes G1--G${profile.stats.evalGates}} \\\\ 0 & \\text{otherwise} \\end{cases}`}
          size="md"
        />
      </div>

      <div class="head-stats">
        <Stat
          value={profile.stats.certCount}
          label="certs"
          sub={`${profile.stats.ageMonths}-month arc`}
        />
        <Stat value={profile.stats.evalGates} label="gates" sub="G1–G31" />
        <Stat value={profile.stats.aiAgentCount} label="agents" sub="orch + workers" />
        <Stat value={profile.stats.locPython} label="LOC" sub="light-dep" />
      </div>
    </div>
  </header>

  {
    /*
    PROOF STRIP — proof-first, not bio-first.
    The top three solutions: strongest signal of shipped work. A recruiter's
    first glance is here, not the bio.
  */
  }
  <section class="section section--proof">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Proof</p>
        <h2 class="section__title">
          What I built and shipped<span class="muted"> — not what I am.</span>
        </h2>
        <p class="section__lede">
          Three decision-grade artefacts from the long record. Each one links to a public-data
          reproduction or a documented engagement summary.
        </p>
      </header>

      <div class="proof-grid">
        {
          proofStrip.map((s: SolutionEntry) => (
            <article class="proof-card">
              <header class="proof-card__head">
                <span class="proof-card__ord mono">#{String(s.data.order).padStart(2, '0')}</span>
                <span class="pill pill--brand">AI</span>
              </header>
              <h3 class="proof-card__title">{s.data.title}</h3>
              <div class="proof-card__client mono">{s.data.client}</div>
              <div class="proof-card__row">
                <div class="proof-card__row-label">Evidence</div>
                <ul class="proof-card__list mono">
                  {s.data.evidence.slice(0, 3).map((e: string) => (
                    <li>{e}</li>
                  ))}
                </ul>
              </div>
              <div class="proof-card__row">
                <div class="proof-card__row-label">Outcome</div>
                <p class="proof-card__row-body">{s.data.outcome}</p>
              </div>
              <a class="proof-card__more mono" href={path('/solutions')}>
                Read on /solutions ↗
              </a>
            </article>
          ))
        }
      </div>

      <p class="proof-strip__foot mono">
        Full record at <a href={path('/solutions')}>{path('/solutions')}</a> · engagements at <a
          href={path('/experience')}>{path('/experience')}</a
        > · methodology at <a href={path('/methodology')}>{path('/methodology')}</a>
      </p>
    </div>
  </section>

  {
    /*
    METHODOLOGY TEASER — Gates {GATE_RANGE}, DSR, PBO, MinBTL.
    A single inline equation + 3-stat row mirrors /methodology without
    duplicating it; the link does the heavy lifting.
  */
  }
  <section class="section section--alt">
    <div class="container container-narrow">
      <header class="section__head">
        <p class="section__eyebrow">Method</p>
        <h2 class="section__title">{NGATE} before a number ships.</h2>
      </header>

      <div class="method-ribbon">
        <div class="method-ribbon__eq">
          <Equation
            latex={`\\mathrm{DSR}(\\hat{\\sigma}) \\;=\\; \\frac{\\mathbb{E}\\!\\left[\\hat{\\mu}\\right] - r_f}{\\sqrt{V\\!\\left[\\hat{\\mu}\\right] + V\\!\\left[\\hat{\\sigma}^2\\right] / 2}} \\cdot \\gamma_1`}
            size="md"
          />
        </div>
        <ul class="method-ribbon__list mono">
          <li><strong>G1–G12</strong> · single-strategy guardrails</li>
          <li><strong>G16–G20</strong> · multiple-testing layer</li>
          <li><strong>{`G23–G${profile.stats.evalGates}`}</strong> · LLM-output validation</li>
        </ul>
      </div>

      <p class="section__foot mono">
        Full method at <a href={path('/methodology')}>{path('/methodology')}</a> · live calculator at
        <a href={path('/methodology')} #calculator>DSR calculator →</a>
      </p>
    </div>
  </section>

  {
    /*
    QUANT SIDE TEASER — single equation + quant-specific stat row.
    Mirrors the canonical quant research discipline the user cares about.
  */
  }
  <section class="section">
    <div class="container container-narrow">
      <header class="section__head">
        <p class="section__eyebrow">Quant side</p>
        <h2 class="section__title">{quantProjectCount} projects, public-data reproducible.</h2>
      </header>

      <div class="method-ribbon">
        <div class="method-ribbon__eq">
          <Equation
            latex={`\\mathrm{PBO}_{\\mathrm{CSCV}} \\;=\\; \\mathbb{P}\\!\\left[\\lambda^* \\in \\mathcal{F} \\;\\big|\\; \\text{training} \\in \\mathcal{S}\\right]`}
            size="md"
          />
        </div>
        <ul class="method-ribbon__list mono">
          <li><strong>{quantProjectCount}</strong> public-data projects shipped</li>
          <li><strong>5</strong> asset classes covered</li>
          <li><strong>3</strong> strategy families validated end-to-end</li>
        </ul>
      </div>

      <p class="section__foot mono">
        Reading log at <a href={path('/publications')}>{path('/publications')}</a> · engagements at <a
          href={path('/experience')}>{path('/experience')}</a
        >
      </p>
    </div>
  </section>

  {
    /*
    BIO — kept short, moved below the proof surface.
    Four flowing paragraphs in the HIRED voice.
  */
  }
  <section class="section section--bio">
    <div class="container container-narrow">
      <header class="section__head">
        <p class="section__eyebrow">Background</p>
        <h2 class="section__title">A research-desk operator with one method.</h2>
      </header>

      <div class="bio-prose">
        <p class="bio-prose__lead">
          I work at the intersection of <strong>multi-agent LLM systems</strong> and
          <strong>systematic trading research</strong>. The through-line is a single engineering
          principle: <strong>don't ship what hasn't passed a measurable quality gate.</strong>
          {profile.stats.aiAgentCount} agents in an orchestrator-worker topology. A {NGATE} statistical
          evaluation harness. Pre-registered research windows. Public-data reproducibility. Headline metrics
          you can verify.
        </p>

        <p>
          I was previously the AI Systems Engineer / Quantitative Researcher on the
          <strong
            >systematic-strategy desk (NDA-protected; closed past contract 03/2026 – 06/2026)</strong
          >
          under a PM with publicly attributable initials (closed past contract), where the same eval harness
          served both LLM outputs and systematic trading strategies. Before that I shipped a 7-agent venture-incubation
          pipeline under Macion Ventures, an 8-agent content-production pipeline for editorial automation,
          and a portfolio of runnable AI projects (RAG scorecard, ReAct tool-calling agent, MCP eval server,
          LLM-as-judge harness, reflection agent, AI-slop evaluation gate).
        </p>

        <p>
          On the quant side I design and backtest systematic strategies on crypto and equities — {
            quantProjectCount
          } reproducible public-data projects spanning multiple-testing (Deflated Sharpe), cross-sectional
          and time-series alpha, volatility carry, cointegration, funding-carry, regime overlays, transaction-cost
          realism, and look-ahead-bias audits. Every project ships with the standard senior-research discipline:
          locked OOS windows, block-bootstrap CIs, and the methodology stated up-front, not bolted on
          at the end.
        </p>

        <p>
          I'm based in Digos City, Davao del Sur, Philippines (UTC+8), available {
            profile.availability.hours
          }
          remote. I hold {profile.stats.certCount} professional certifications across AI, finance, math/statistics,
          and event flagships, built up in {profile.stats.ageMonths} months. I write about what I'm learning
          and ship the things I'm building.
        </p>
      </div>
    </div>
  </section>

  {
    /*
    EDUCATION — flowing prose, not a list.
    Genre rule: quant and AI references keep education as one paragraph
    (Eva Miller, Gwern, Percy Liang pattern), not as a structured card list.
  */
  }
  <section class="section section--alt">
    <div class="container container-narrow">
      <header class="section__head">
        <p class="section__eyebrow">Education</p>
        <h2 class="section__title">The arc, in one sentence.</h2>
      </header>

      <p class="long-form-prose">
        Graduate of the Philippine Science High School — Southern Mindanao Campus (2022, national
        competitive exam). Engineering units at the University of Southeastern Philippines
        (2022–2024, did not complete). Currently enrolled in Financial Management at the University
        of Mindanao (1st Semester, AY 2026–27). Completed the Certified Technical Analyst Program at
        the Society of Technical Analysts of the Philippines (Tier-1, December 2025).
      </p>
    </div>
  </section>

  {
    /*
    DISCLOSURE POSTURE — flowing prose, not an X-list.
    Genre rule: quants don't disclose NDA posture with red X marks;
    they declare it as a prose paragraph (D.E. Shaw / RenTec / Jane Street style).
  */
  }
  <section class="section">
    <div class="container container-narrow">
      <header class="section__head">
        <p class="section__eyebrow">Disclosure posture</p>
        <h2 class="section__title">How to read the numbers on this site.</h2>
      </header>

      <p class="long-form-prose">
        All work shown here is NDA-safe. The systematic-strategy desk role is a closed past contract
        (03/2026 – 06/2026) under a PM with publicly attributable initials. I do not reference
        per-strategy t-stats, bps figures, live Sharpe numbers, proprietary data sources,
        fund-renames, or any desk-internal terms. Headline metrics cite public-data work or
        open-source runnable projects. If a proof you need is missing, email me the JD and I'll send
        back a tailored version within 24 hours.
      </p>
    </div>
  </section>

  <CTABanner
    title="Hiring for an AI Engineer or Quant Researcher seat?"
    sub={`Email me at ${profile.contact.email} with the JD — tailored resume within 24 hours. Or grab the matching PDF below.`}
    primaryLabel="Get in touch"
    primaryHref={`mailto:${profile.contact.email}?subject=Role%20inquiry%20—%20%5Btailored%20resume%5D`}
    secondaryLabel="Download resume ↓"
    secondaryHref={path('/resume')}
  />
</BaseLayout>

<style>
  /* === Hero === */
  .page-head {
    padding-block: var(--sp-9) var(--sp-7);
    background: var(--c-paper);
    border-bottom: var(--border);
  }
  .page-head__title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .page-head__voice {
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
  }
  @media (max-width: 480px) {
    .avatar-img,
    .avatar {
      width: 140px !important;
      height: 140px !important;
    }
  }
  .head-eq {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    margin-bottom: var(--sp-5);
    overflow-x: auto;
  }
  .head-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-3);
  }

  /* === Section header shared === */
  .section__head {
    margin-bottom: var(--sp-5);
  }
  .section__title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-block: var(--sp-3) var(--sp-3);
  }
  .section__title .muted {
    color: var(--c-ink-3);
    font-weight: 400;
  }
  .section__lede {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 60ch;
  }
  .section__foot {
    margin-top: var(--sp-5);
    font-size: var(--fs-sm);
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .section__foot a {
    color: var(--c-primary-2-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* === Proof strip === */
  .section--proof {
    padding-block: var(--sp-8);
  }
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
  }
  .proof-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-left: 3px solid var(--c-primary);
    border-radius: var(--radius);
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
  }
  .proof-card:hover {
    border-color: var(--c-primary);
    box-shadow: var(--shadow-md);
  }
  .proof-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
  }
  .proof-card__ord {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
  }
  .proof-card__title {
    font-size: var(--fs-xl);
    line-height: 1.2;
    color: var(--c-ink);
    margin: 0;
  }
  .proof-card__client {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    padding-bottom: var(--sp-3);
    border-bottom: 1px dashed var(--c-rule-soft);
    margin-bottom: var(--sp-2);
  }
  .proof-card__row {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .proof-card__row-label {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-primary);
    font-weight: 600;
  }
  .proof-card__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    margin: 0;
  }
  .proof-card__list li {
    font-size: var(--fs-sm);
    color: var(--c-ink);
    line-height: var(--lh-normal);
    padding-left: 1.25rem;
    position: relative;
  }
  .proof-card__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--c-amber);
  }
  .proof-card__row-body {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin: 0;
  }
  .proof-card__more {
    margin-top: auto;
    padding-top: var(--sp-3);
    border-top: 1px solid var(--c-rule-soft);
    font-size: var(--fs-sm);
    color: var(--c-primary-2-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .proof-strip__foot {
    margin-top: var(--sp-6);
    text-align: center;
    font-size: var(--fs-sm);
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .proof-strip__foot a {
    color: var(--c-primary-2-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* === Methodology / Quant ribbons === */
  .method-ribbon {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--sp-6);
    align-items: center;
    padding: var(--sp-5) var(--sp-6);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-left: 4px solid var(--c-primary);
    border-radius: var(--radius);
    margin-block: var(--sp-5);
  }
  .method-ribbon__eq {
    text-align: center;
    min-width: 0;
  }
  .method-ribbon__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
    color: var(--c-ink);
  }
  .method-ribbon__list strong {
    color: var(--c-primary);
    font-weight: 600;
  }

  /* === Bio === */
  .section--bio {
    padding-block: var(--sp-8);
  }
  .bio-prose p {
    margin-bottom: var(--sp-5);
    font-size: var(--fs-lg);
    line-height: var(--lh-loose);
    color: var(--c-ink);
  }
  .bio-prose .bio-prose__lead {
    font-size: var(--fs-xl);
    color: var(--c-ink);
  }
  .bio-prose strong {
    color: var(--c-primary);
    font-weight: 600;
  }

  /* === Long-form prose (Education + Disclosure) === */
  .long-form-prose {
    font-size: var(--fs-lg);
    line-height: var(--lh-loose);
    color: var(--c-ink);
    max-width: 64ch;
    margin: 0;
  }

  @media (max-width: 880px) {
    .head-stats {
      grid-template-columns: 1fr 1fr;
    }
    .proof-grid {
      grid-template-columns: 1fr;
    }
    .method-ribbon {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 720px) {
    .head-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
