---
/**
 * 404.astro — v2: math/quant aesthetic.
 *
 * Equation: ∄ x ∈ site : URL(x) = requested. Try one of these.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Equation from '@components/Equation.astro';
import { path } from '@utils/url';

const links = [
  { href: path('/'), label: 'Home' },
  { href: path('/projects'), label: 'Projects' },
  { href: path('/experience'), label: 'Experience' },
  { href: path('/skills'), label: 'Skills' },
  { href: path('/certifications'), label: 'Certifications' },
  { href: path('/contact'), label: 'Contact' },
];
---

<BaseLayout title="404 — Page not found" description="The page you're looking for isn't here.">
  <section class="not-found">
    <div class="container container-narrow not-found__inner">
      <p class="section__eyebrow mono">404 · off the path</p>
      <h1 class="not-found__title">Off the path.</h1>
      <p class="not-found__sub">
        The page you were looking for isn't here — or the URL changed. Try one of the routes below,
        or jump back to <a href={path('/')}>home</a>.
      </p>

      <div class="not-found__eq">
        <Equation
          block
          latex={`\\nexists\\, x \\in \\mathcal{S} \\;:\\; \\text{url}(x) = \\text{requested} \\quad \\Longrightarrow \\quad \\text{try one of:}`}
          size="md"
        />
      </div>

      <nav class="not-found__nav" aria-label="404 navigation">
        {
          links.map((l) => (
            <a href={l.href} class="btn btn--ghost">
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding-block: var(--sp-9);
    min-height: 60vh;
    display: flex;
    align-items: center;
    background:
      radial-gradient(800px 400px at 50% 0%, rgba(212, 160, 23, 0.1), transparent 60%),
      var(--c-paper);
  }
  .not-found__inner {
    text-align: center;
  }
  .not-found__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    letter-spacing: -0.03em;
    margin-bottom: var(--sp-3);
  }
  .not-found__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin-bottom: var(--sp-6);
    max-width: 56ch;
    margin-inline: auto;
  }
  .not-found__eq {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    margin-bottom: var(--sp-6);
    overflow-x: auto;
    display: inline-block;
  }
  .not-found__nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: center;
  }
</style>
