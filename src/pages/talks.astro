---
/**
 * talks.astro — v1.0 · public talks, lectures, and recorded walkthroughs.
 *
 * Two sections:
 *   1) Public lectures — VideoEmbed cards, 2-up, sourced from /public/proof.
 *   2) Conference & meetup appearances — tight list of public-facing events.
 *
 * Every artifact below is either a video on disk or a named event with a
 * public attestation (image, certificate, or institutional record). No
 * NDA-protected content; no proprietary data.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import VideoEmbed from '@components/VideoEmbed.astro';
import CTABanner from '@components/CTABanner.astro';
import { profile } from '@utils/profile';
import { path } from '@utils/url';
import VoiceLine from '@components/VoiceLine.astro';

const fullName = profile.fullName.split(',')[0];
const NGATE = `${profile.stats.evalGates}-gate`;

// === Public lectures (VideoEmbed, 2-up) =====================================
const lectures = [
  {
    title: 'USeP EGE 313 Manobo lecture — live presenter view',
    date: '2024-09-13',
    audience: 'USeP · College of Engineering · EGE 313',
    description:
      'Live Presenter-view delivery for the EGE 313 cohort. Webcam lower-right; deck filename visible in the PPT Edit-mode frame.',
    src: path('/proof/usep-lecture.mp4'),
    poster: path('/proof/usep-lecture.jpg'),
    duration: 55,
  },
  {
    title: 'AI workflow — same lecture, drafted via ChatGPT-assisted authoring',
    date: '2024-08-22',
    audience: 'USeP · EGE 313 (deck precursor)',
    description: `Three weeks before the lecture: same deck, drafted end-to-end via a single ChatGPT session. The precursor pattern to the current ${NGATE} authoring harness.`,
    src: path('/proof/ai-workflow.mp4'),
    poster: path('/proof/ai-workflow.jpg'),
    duration: 55,
  },
];

// === Conference & meetup appearances (tight list) ===========================
interface Appearance {
  date: string;
  dateLabel: string;
  title: string;
  audience: string;
  description: string;
  link?: { label: string; href: string };
}

const appearances: Appearance[] = [
  {
    date: '2024-10-05',
    dateLabel: 'Oct 5 2024',
    title: 'NASA Space Apps Challenge 2024 — Galactic Problem Solver',
    audience: 'NASA Space Apps · Zurich global cohort',
    description:
      'Forty-eight-hour global hackathon; awarded the Galactic Problem Solver distinction for the open-data space-physics challenge track.',
    link: { label: 'Proof photo', href: path('/proof') },
  },
  {
    date: '2024-09-15',
    dateLabel: 'Sep 15 2024',
    title: 'PSHS-SMC alumni speaker — AI engineering and the PSHS → quant path',
    audience: 'Philippine Science High School — Southern Mindanao Campus',
    description:
      'Alumni talk on AI engineering, the math curriculum, and the educational path from PSHS-SMC to AI and quant careers. ~80 attendees, alumni and current students.',
  },
  {
    date: '2025-03-22',
    dateLabel: 'Mar 22 2025',
    title: 'USeP guest lecture — systematic trading research and AI for engineers',
    audience: 'University of Southeastern Philippines · College of Engineering',
    description:
      'Guest lecture on systematic trading research, multiple-testing discipline, and applied AI for engineering students. CpE / EE 5th-year elective cohort.',
  },
  {
    date: '2025-11-08',
    dateLabel: 'Nov 8 2025',
    title: 'AI for the Modern Workforce — Ateneo de Davao × US Embassy',
    audience: 'Ateneo de Davao University · US Embassy Manila',
    description:
      'Selected cohort for the AI for the Modern Workforce program; co-hosted by Ateneo de Davao and the US Embassy. AI-literacy curriculum for working professionals.',
    link: { label: 'Cert image', href: path('/proof/ateneo-american-corner-2025-11.jpg') },
  },
  {
    date: '2025-11-12',
    dateLabel: 'Nov 12–21 2025',
    title: 'BIDA × Bayan Academy × Meta AIccelerate 2025',
    audience: 'Board of Investments × Bayan Academy × Meta Philippines',
    description:
      'Five-day hybrid training on applied AI for Philippine MSMEs; co-signed certificate from BIDA, Bayan Academy, and Meta Philippines. Awarded Dec 17 2025.',
    link: { label: 'Cert image', href: path('/proof/bida-meta-aiccelerate-2025-11.jpg') },
  },
  {
    date: '2026-01-19',
    dateLabel: 'Jan 19 2026',
    title: 'CTA program graduate — Society of Technical Analysts of the Philippines',
    audience: 'STA Philippines · Tier-1 CTA program',
    description:
      'Tier-1 Certified Technical Analyst program, completed Jan 19 2026 (cert #260197). Final capstone: regime-classification case study on ASEAN equities.',
    link: { label: 'Cert image', href: path('/proof/cta-cert-portrait-2026-01.jpg') },
  },
];
---

<BaseLayout
  title="Talks"
  description="Public lectures, conference appearances, and meetup talks — sourced from the /proof archive. NDA-safe."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Talks', href: '/talks' },
  ]}
>
  <header class="talks-head">
    <div class="container">
      <p class="section__eyebrow">
        <span class="mono">talks/</span> · public-facing speaking record
      </p>
      <h1 class="talks-head__title">Talks, lectures, and recorded walkthroughs.</h1>
      <VoiceLine class="talks-head__voice">
        Every entry is on disk, named to the event, and linkable to the organizer.
      </VoiceLine>
      <p class="talks-head__sub">
        Every entry below is a public artifact — a video on disk, a named event with an
        institutional record, or a co-signed certificate. The two video lectures are surfaced from <a
          href={path('/proof')}>/proof</a
        >; the conference and meetup list names the rest.
      </p>
    </div>
  </header>

  {
    /* =========================================================
      Section 1 — Public lectures (VideoEmbed, 2-up)
      ========================================================= */
  }
  <section class="section" data-reveal>
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Section 1 · Public lectures</p>
        <h2 class="section__title">{lectures.length} recorded lectures on disk.</h2>
        <p class="section__sub">
          Both files are the canonical USeP EGE 313 delivery from late 2024. The second is the
          deck-authoring session three weeks prior — the precursor pattern to the current {NGATE} authoring
          harness.
        </p>
      </header>

      <div class="talks-grid">
        {
          lectures.map((lec) => (
            <article class="talks-card">
              <VideoEmbed
                src={lec.src}
                poster={lec.poster}
                title={lec.title}
                duration={lec.duration}
                caption={lec.description}
                mode="gallery"
              />
              <div class="talks-card__meta">
                <span class="talks-card__date mono">{lec.date}</span>
                <span class="talks-card__audience mono">{lec.audience}</span>
              </div>
              <h3 class="talks-card__title">{lec.title}</h3>
              <p class="talks-card__desc">{lec.description}</p>
              <a
                class="talks-card__link"
                href={lec.src}
                download
                aria-label={`Download ${lec.title}`}
              >
                Download video ↓
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {
    /* =========================================================
      Section 2 — Conference & meetup appearances (tight list)
      ========================================================= */
  }
  <section class="section section--alt" data-reveal>
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Section 2 · Conference & meetup appearances</p>
        <h2 class="section__title">Public events, awards, and recognitions.</h2>
        <p class="section__sub">
          A tight list of named public events. Most carry an institutional co-signer (NASA, Ateneo,
          US Embassy, BIDA, Meta, STA) and a date-stamped record.
        </p>
      </header>

      <ol class="talks-list">
        {
          appearances.map((a) => (
            <li class="talks-row">
              <div class="talks-row__date mono">{a.dateLabel}</div>
              <div class="talks-row__body">
                <h3 class="talks-row__title">{a.title}</h3>
                <div class="talks-row__audience mono">{a.audience}</div>
                <p class="talks-row__desc">{a.description}</p>
                {a.link && (
                  <a class="talks-row__link" href={a.link.href} rel="noopener noreferrer">
                    {a.link.label} →
                  </a>
                )}
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <CTABanner
    title="Want a specific talk in person?"
    sub="Open to invited lectures on systematic-trading research, AI-evaluation discipline, and the multi-agent LLM stack. Email with date, audience size, and venue."
    primaryLabel={`Email ${fullName}`}
    secondaryLabel="See methodology"
    secondaryHref={path('/methodology')}
  />
</BaseLayout>

<style>
  .talks-head {
    padding-block: var(--sp-9) var(--sp-7);
    background: var(--c-paper);
    border-bottom: var(--border);
  }
  .talks-head__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: var(--sp-4);
    color: var(--c-ink);
    font-weight: 600;
    letter-spacing: -0.02em;
    max-width: 22ch;
  }
  .talks-head__sub {
    font-size: clamp(1rem, 2vw, var(--fs-lg));
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin-bottom: 0;
    max-width: 60ch;
  }
  .talks-head__voice {
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
  }
  .talks-head__sub a {
    color: var(--c-primary-2-deep);
    text-decoration: underline;
    text-decoration-color: var(--c-amber-decor);
    text-underline-offset: 3px;
  }

  /* === Lectures grid (2-up) === */
  .talks-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--sp-5);
  }
  .talks-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    border-left: 3px solid var(--c-primary);
  }
  .talks-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-primary-2-deep);
  }
  .talks-card__title {
    font-size: var(--fs-lg);
    margin: 0;
    color: var(--c-ink);
    line-height: var(--lh-snug);
  }
  .talks-card__desc {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin: 0;
  }
  .talks-card__link {
    margin-top: auto;
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    color: var(--c-primary-2-deep);
    text-decoration: underline;
    text-decoration-color: var(--c-amber-deep-decor);
    text-underline-offset: 3px;
    align-self: flex-start;
  }

  /* === Tight appearances list === */
  .talks-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: var(--border);
  }
  .talks-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--sp-5);
    padding-block: var(--sp-5);
    border-bottom: var(--border);
    align-items: start;
  }
  .talks-row__date {
    font-size: var(--fs-sm);
    color: var(--c-primary-2-deep);
    font-weight: 600;
    letter-spacing: 0.04em;
    padding-top: 2px;
  }
  .talks-row__title {
    font-size: var(--fs-lg);
    margin: 0 0 var(--sp-1);
    color: var(--c-ink);
    line-height: var(--lh-snug);
  }
  .talks-row__audience {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--sp-2);
  }
  .talks-row__desc {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin: 0 0 var(--sp-2);
  }
  .talks-row__link {
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    color: var(--c-primary-2-deep);
    text-decoration: underline;
    text-decoration-color: var(--c-amber-deep-decor);
    text-underline-offset: 3px;
  }

  /* === Responsive === */
  @media (max-width: 720px) {
    .talks-grid {
      grid-template-columns: 1fr;
    }
    .talks-row {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
    }
  }
</style>
