---
/**
 * projects/[...slug].astro — single project detail page.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import MetricPill from '@components/MetricPill.astro';
import CTABanner from '@components/CTABanner.astro';
import { getCollection, render } from 'astro:content';
import { path } from '@utils/url';
import VoiceLine from '@components/VoiceLine.astro';

export async function getStaticPaths() {
  const projects = await getCollection('project');
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const {
  title,
  summary,
  summary_long,
  stack,
  metrics,
  sourceLink,
  tags,
  status,
  role,
  hero,
} = project.data;
const laneLabel = role === 'ai' ? 'AI Engineer' : 'Quantitative Researcher';
const laneClass = role === 'ai' ? 'pill--brand' : 'pill--accent';---

<BaseLayout title={title} description={summary_long ?? summary} type="article">
  <article class="proj">
    <header class="proj__head">
      <div class="container container-narrow">
        <p class="proj__crumb">
          <a href={path('/projects')}>← Projects</a>
          <span class="proj__crumb-sep">·</span>
          <span class:list={['pill', laneClass]}>{laneLabel}</span>
        </p>

        {
          hero && (
            <figure class="proj__hero-figure">
              <img
                src={path(hero.src)}
                alt={hero.alt}
                width="1280"
                height="720"
                class={`proj__hero-img proj__hero-img--${hero.fit}`}
                loading="eager"
                decoding="async"
              />
            </figure>
          )
        }

        <h1 class="proj__title">{title}</h1>
        {summary_long && <VoiceLine class="proj__voice">
        {summary_long}
      </VoiceLine>}

        {
          metrics.length > 0 && (
            <div class="proj__metrics">
              {metrics.map((m) => (
                <MetricPill
                  label={m.label}
                  value={m.value}
                  sub={m.sub}
                  tone={role === 'ai' ? 'brand' : 'accent'}
                />
              ))}
            </div>
          )
        }

        <div class="proj__meta">
          {
            status && (
              <div>
                <div class="proj__meta-label">Status</div>
                <div class="proj__meta-value">{status}</div>
              </div>
            )
          }
          {
            sourceLink && (
              <div>
                <div class="proj__meta-label">Repo</div>
                <div class="proj__meta-value">
                  <a href={sourceLink} target="_blank" rel="noopener">
                    GitHub ↗
                  </a>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </header>

    <div class="proj__body container container-narrow">
      <div class="proj__prose">
        <Content />
      </div>

      {
        stack.length > 0 && (
          <aside class="proj__sidebar">
            <section class="proj__panel">
              <h3 class="proj__panel-title">Stack</h3>
              <ul class="proj__stack">
                {stack.map((s) => (
                  <li>{s}</li>
                ))}
              </ul>
            </section>
            {tags.length > 0 && (
              <section class="proj__panel">
                <h3 class="proj__panel-title">Topics</h3>
                <div class="proj__tags">
                  {tags.map((t) => (
                    <span class="pill">{t}</span>
                  ))}
                </div>
              </section>
            )}
          </aside>
        )
      }
    </div>
  </article>

  <CTABanner
    title="Want to see this project in your stack?"
    sub="Every project is runnable in one command. The scorecard is the contract."
  />
</BaseLayout>

<style>
  .proj__head {
    padding-block: var(--sp-8) var(--sp-6);
    background:
      radial-gradient(800px 400px at 80% 0%, rgba(212, 160, 23, 0.1), transparent 60%), var(--c-bg);
    border-bottom: var(--border);
  }
  .proj__crumb {
    display: flex;
    gap: var(--sp-2);
    align-items: center;
    color: var(--c-ink-2);
    font-size: var(--fs-sm);
    margin-bottom: var(--sp-4);
  }
  .proj__crumb-sep {
    color: var(--c-ink-3);
  }
  .proj__hero-figure {
    margin: 0 auto var(--sp-5);
    max-width: 880px;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--c-amber-deep);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--c-bg-2);
  }
  /* v6.10.6 — removed decorative drop-shadow + inset amber ring.
     Flat border is the institutional chrome pattern. */
  .proj__hero-img {
    display: block;
    width: 100%;
    height: 100%;
  }
  .proj__hero-img--cover {
    object-fit: cover;
  }
  .proj__hero-img--contain {
    object-fit: contain;
  }
  .proj__title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .proj__voice {
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
}
  .proj__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin-bottom: var(--sp-6);
  }
  .proj__metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--sp-3);
    margin-bottom: var(--sp-6);
  }
  .proj__meta {
    display: flex;
    gap: var(--sp-6);
    flex-wrap: wrap;
    padding-top: var(--sp-4);
    border-top: 1px solid var(--c-rule-soft);
  }
  .proj__meta-label {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-ink-2);
    margin-bottom: 0.25rem;
  }
  .proj__meta-value {
    font-size: var(--fs-sm);
    color: var(--c-ink);
  }
  .proj__body {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--sp-6);
    padding-block: var(--sp-7);
  }
  .proj__prose :global(h2) {
    margin-top: var(--sp-6);
    margin-bottom: var(--sp-3);
    font-size: var(--fs-2xl);
  }
  .proj__prose :global(h3) {
    margin-top: var(--sp-5);
    margin-bottom: var(--sp-2);
    font-size: var(--fs-xl);
  }
  .proj__prose :global(p) {
    color: var(--c-ink);
    line-height: var(--lh-loose);
    margin-bottom: var(--sp-4);
  }
  .proj__prose :global(strong) {
    color: var(--c-primary);
    font-weight: 600;
  }
  .proj__prose :global(blockquote) {
    border-left: 3px solid var(--c-primary);
    padding: var(--sp-3) var(--sp-5);
    margin: var(--sp-5) 0;
    color: var(--c-ink-2);
    background: var(--c-bg-2);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-style: italic;
  }
  .proj__prose :global(code) {
    background: var(--c-bg-3);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.92em;
  }
  .proj__prose :global(pre) {
    background: var(--c-primary-deep);
    color: #e0e6ed;
    padding: var(--sp-4);
    border-radius: var(--radius);
    overflow-x: auto;
    margin-block: var(--sp-4);
  }
  .proj__prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }
  .proj__prose :global(ul) {
    margin-bottom: var(--sp-4);
  }
  .proj__prose :global(li) {
    margin-bottom: var(--sp-2);
    line-height: var(--lh-loose);
  }
  @media (min-width: 960px) {
    .proj__body {
      grid-template-columns: minmax(0, 1fr) 260px;
    }
  }
  .proj__sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .proj__panel {
    padding: var(--sp-5);
    background: var(--c-bg-2);
    border: var(--border);
    border-radius: var(--radius);
  }
  .proj__panel-title {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-2);
    margin-bottom: var(--sp-3);
  }
  .proj__stack {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .proj__stack li {
    font-size: var(--fs-sm);
    color: var(--c-ink);
    line-height: 1.5;
    padding-left: 1rem;
    position: relative;
  }
  .proj__stack li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--c-amber);
  }
  .proj__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
</style>
