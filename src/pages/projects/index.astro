---
/**
 * projects/index.astro — full project index, filter chips.
 *
 * v6.4 — adds `?tag=quant` and `?tag=ai` URL-param filtering via a
 * tiny inline `<script is:inline>` at the bottom of the file. This is
 * not a `client:*` directive — Astro's framework-hydration directives
 * are unrelated to plain inline scripts, which Astro compiles to a
 * single per-page bundle. The script degrades gracefully: if JS is
 * disabled, all projects stay visible (the default state, matching
 * the unfiltered URL).
 *
 * Lane sections that match the active tag are shown; non-matching
 * sections are hidden via a `[hidden]` attribute toggled by the script
 * on `DOMContentLoaded`. The script also activates the matching
 * filter chip (`[data-filter][aria-pressed]`).
 *
 * Canonical entry-point for the home page `OPEN NOTEBOOKS` chip is
 * `/projects/?tag=quant` — this lands users directly on the lane-2
 * section, with the AI lane hidden until they clear the filter.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { path } from '@utils/url';
import { projectListJsonLd } from '@utils/seo';
import VoiceLine from '@components/VoiceLine.astro';

const projects = (await getCollection('project')).sort((a, b) => a.data.order - b.data.order);
const aiProjects = projects.filter((p) => p.data.role === 'ai');
const quantProjects = projects.filter((p) => p.data.role === 'quant');
const ossProjects = projects.filter((p) => p.data.sourceLink);

const itemListJsonLd = projectListJsonLd(
  projects.map((p) => ({
    slug: p.id,
    title: p.data.title,
    summary: p.data.summary,
    role: p.data.role,
    sourceLink: p.data.sourceLink,
    date: p.data.date,
  })),
);---

<BaseLayout
  title="Projects"
  description="AI engineering projects (multi-agent, eval, MCP) and quantitative research projects (multiple-testing, cross-sectional alpha, volatility, cointegration)."
  extraJsonLd={itemListJsonLd}
  breadcrumbs={[{ name: "Home", href: "/" }, { name: "Projects", href: "/projects" }]}
>
  <header class="page-head">
    <div class="container">
      <p class="section__eyebrow">Portfolio</p>
      <h1 class="page-head__title">{projects.length} projects, two lanes.</h1>
      <VoiceLine class="page-head__voice">
        Every metric below is real, every method is documented, every line of code is on disk.
      </VoiceLine>
      <p class="page-head__sub">
        Every project is reproducible, headline metrics are real, and the methodology is documented.
        Filter by lane to focus on the work most relevant to the role you're hiring for.
      </p>

      {/* === Headline stats — two-lane split at a glance === */}
      <div class="page-head__stats">
        <div class="page-head__stat">
          <span class="page-head__stat-num tnum">{projects.length}</span>
          <span class="page-head__stat-lbl">projects shipped</span>
        </div>
        <div class="page-head__stat">
          <span class="page-head__stat-num tnum">{aiProjects.length}</span>
          <span class="page-head__stat-lbl">AI engineer projects</span>
        </div>
        <div class="page-head__stat">
          <span class="page-head__stat-num tnum">{quantProjects.length}</span>
          <span class="page-head__stat-lbl">quant research projects</span>
        </div>
        <div class="page-head__stat">
          <span class="page-head__stat-num tnum">{ossProjects.length}</span>
          <span class="page-head__stat-lbl">open-source repos</span>
        </div>
      </div>

      {/* v6.4 — Lane filter chips (URL-param-driven, no client:*). */}
      <div class="lane-filter" role="group" aria-label="Filter projects by lane">
        <a
          class="lane-filter__chip"
          href="/projects/"
          data-filter="all"
          aria-pressed={true}
        >
          All <span class="lane-filter__count mono">{projects.length}</span>
        </a>
        <a
          class="lane-filter__chip"
          href="/projects/?tag=ai"
          data-filter="ai"
          aria-pressed={false}
        >
          AI Engineer <span class="lane-filter__count mono">{aiProjects.length}</span>
        </a>
        <a
          class="lane-filter__chip"
          href="/projects/?tag=quant"
          data-filter="quant"
          aria-pressed={false}
        >
          Quant Researcher <span class="lane-filter__count mono">{quantProjects.length}</span>
        </a>
      </div>
    </div>
  </header>

  <section class="section" data-lane="ai" id="lane-ai">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Lane 1 · AI Engineer</p>
        <h2 class="section__title">Multi-agent LLM systems & eval</h2>
        <p class="section__sub">
          {aiProjects.length} projects spanning RAG scorecards, ReAct tool-calling, MCP servers, LLM-as-judge
          validation, reflection loops, and AI-output quality gates.
        </p>
      </header>
      <div class="grid grid-3">
        {
          aiProjects.map((p) => (
            <ProjectCard
              href={path(`/projects/${p.id}`)}
              title={p.data.title}
              summary={p.data.summary}
              metrics={p.data.metrics}
              lane="ai"
              order={p.data.order}
              status="open source"
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--alt" data-lane="quant" id="lane-quant">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Lane 2 · Quantitative Researcher</p>
        <h2 class="section__title">Systematic strategies & statistical validation</h2>
        <p class="section__sub">
          {quantProjects.length} projects across multiple-testing, cross-sectional and time-series alpha,
          volatility, cointegration, funding-carry, and bias control.
        </p>
      </header>
      <div class="grid grid-3">
        {
          quantProjects.map((p) => (
            <ProjectCard
              href={path(`/projects/${p.id}`)}
              title={p.data.title}
              summary={p.data.summary}
              metrics={p.data.metrics}
              lane="quant"
              order={p.data.order}
              status="public-data reproducible"
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--alt book-analysis">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Combined-book analysis · cross-project</p>
        <h2 class="section__title">What {quantProjects.length} projects tell you about a research book</h2>
        <p class="section__sub">
          None of these projects stand alone. The signal, cost, regime, and bias-control layers are
          designed to compose — a single vol-targeted carry trade (03 + 06) carries different risk
          than a cointegration pair (05) carrying regime-aware sizing (07). The shared methodology
          across all nine is what makes the book interpretable to a risk manager, not just an
          alpha-hunter.
        </p>
      </header>

      <div class="book-grid">
        <article class="book-card">
          <div class="book-card__layer">Layer A — Signal</div>
          <h3 class="book-card__title">Alpha sources</h3>
          <ul class="book-card__list">
            <li>
              <strong>Cross-sectional:</strong> project 02 (failed OOS, as the test predicted)
            </li>
            <li><strong>Time-series:</strong> projects 03 (vol-targeted), 04 (VRP)</li>
            <li><strong>Carry / funding:</strong> project 06 (OOS Sharpe decayed post-2023)</li>
            <li><strong>Cointegration / stat-arb:</strong> project 05 (rejected by ADF)</li>
          </ul>
        </article>

        <article class="book-card">
          <div class="book-card__layer">Layer B — Risk</div>
          <h3 class="book-card__title">Risk-management overlays</h3>
          <ul class="book-card__list">
            <li><strong>Vol targeting (20-day):</strong> project 03 (Sharpe 0.27 → 0.39)</li>
            <li><strong>Regime overlay (smoothed VIX):</strong> project 07 (DD −58% → −42%)</li>
            <li><strong>Cost-aware sizing:</strong> project 08 (break-even turnaround scan)</li>
            <li>
              <strong>Look-ahead audit:</strong> project 09 (one-line shift test, every book run)
            </li>
          </ul>
        </article>

        <article class="book-card">
          <div class="book-card__layer">Layer C — Validation</div>
          <h3 class="book-card__title">Statistical gating</h3>
          <ul class="book-card__list">
            <li><strong>Multiple-testing:</strong> project 01 (Deflated Sharpe, 160-trial null)</li>
            <li>
              <strong>Pre-registration:</strong> project 06 (OOS window locked before data touched)
            </li>
            <li><strong>HAC inference:</strong> project 04 (Newey-West t = +6.5)</li>
            <li>
              <strong>Honest nulls:</strong> projects 02 + 05 (rejected, shipped as rejections)
            </li>
          </ul>
        </article>
      </div>

      <p class="book-note">
        The book is not nine winning trades. It is one pipeline with three orthogonal layers and a
        layered validation discipline that catches the failure modes that eat naive books alive. A
        risk manager reading these nine projects sees the same engineering discipline applied
        end-to-end — that is what is hireable.
      </p>
    </div>
  </section>

  {/* v6.4 — Lane filter script (no `client:*`). Reads `?tag=` from
      the URL and toggles `[hidden]` on the matching lane sections.
      Degrades to "all lanes visible" if JS is off. The same script
      also activates the matching chip via `aria-pressed`. */}
  <script is:inline>
    (function () {
      try {
        var params = new URLSearchParams(window.location.search);
        var tag = (params.get('tag') || 'all').toLowerCase();
        var validTags = { all: 1, ai: 1, quant: 1 };
        if (!validTags[tag]) tag = 'all';

        document.querySelectorAll('[data-lane]').forEach(function (el) {
          var lane = el.getAttribute('data-lane');
          if (tag === 'all' || lane === tag) {
            el.removeAttribute('hidden');
          } else {
            el.setAttribute('hidden', '');
          }
        });

        document.querySelectorAll('[data-filter]').forEach(function (chip) {
          if (chip.getAttribute('data-filter') === tag) {
            chip.setAttribute('aria-pressed', 'true');
          } else {
            chip.setAttribute('aria-pressed', 'false');
          }
        });
      } catch (e) {
        // Soft-fail: leave the default state (all visible).
      }
    })();
  </script>
</BaseLayout>

<style>
  .page-head {
    padding-block: var(--sp-9) var(--sp-6);
    background: var(--c-bg);
    border-bottom: var(--border);
  }
  .page-head__title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .page-head__voice {
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
}
  .page-head__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
    margin-block: var(--sp-5) var(--sp-4);
    padding-block: var(--sp-4);
    border-top: 1px solid var(--c-rule);
    border-bottom: 1px solid var(--c-rule);
  }
  .page-head__stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .page-head__stat-num {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--c-primary);
    font-variant-numeric: tabular-nums;
  }
  .page-head__stat-lbl {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink-3);
    line-height: 1.3;
  }
  @media (max-width: 640px) {
    .page-head__stats {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--sp-3);
    }
  }
  .page-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    max-width: 64ch;
  }

  /* Combined-book analysis */
  .book-analysis {
    border-top: var(--border);
  }

  /* v6.4 — Lane filter chips (URL-param-driven, no client:*). */
  .lane-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-5);
  }
  .lane-filter__chip {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    min-height: 44px;
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    background: var(--c-bg);
    color: var(--c-ink-2);
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition:
      border-color var(--transition),
      background var(--transition),
      color var(--transition);
  }
  .lane-filter__chip:hover {
    border-color: var(--c-primary-2);
    color: var(--c-ink);
  }
  .lane-filter__chip[aria-pressed='true'] {
    background: var(--c-primary-2);
    border-color: var(--c-primary-2);
    color: var(--c-tape);
  }
  .lane-filter__count {
    font-size: 0.7rem;
    opacity: 0.75;
  }
  .book-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }
  @media (max-width: 880px) {
    .book-grid {
      grid-template-columns: 1fr;
    }
  }
  .book-card {
    background: var(--c-bg-2);
    border: var(--border);
    border-radius: var(--radius);
    padding: var(--sp-5);
    transition: border-color 120ms ease;
  }
  .book-card:hover {
    border-color: var(--c-primary-2-deep);
  }
  .book-card__layer {
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    color: var(--c-primary-2-deep);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: var(--sp-2);
  }
  .book-card__title {
    font-size: var(--fs-lg);
    margin-bottom: var(--sp-3);
    color: var(--c-ink);
  }
  .book-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
  }
  .book-card__list li {
    padding: var(--sp-1) 0;
    border-bottom: 1px dashed var(--c-rule);
  }
  .book-card__list li:last-child {
    border-bottom: none;
  }
  .book-card__list strong {
    color: var(--c-ink);
    font-weight: 600;
  }
  .book-note {
    font-size: var(--fs-base);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 72ch;
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border-left: 3px solid var(--c-primary-2);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
</style>
