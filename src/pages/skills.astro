---
/**
 * skills.astro — v2: domain-grouped skill matrix + math/quant aesthetic.
 *
 * Hero equation: skill_stack = build + validate + ship (one stack across two lanes).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Equation from '@components/Equation.astro';
import Stat from '@components/Stat.astro';
import { getCollection } from 'astro:content';

const groups = (await getCollection('skillGroup'))
  .sort((a, b) => a.data.order - b.data.order);

const totalSkills = groups.reduce((sum, g) => sum + g.data.items.length, 0);
---
<BaseLayout
  title="Skills"
  description="Domain-grouped skill matrix: AI & multi-agent systems, quantitative research & statistics, and engineering tools."
>

  <header class="page-head">
    <div class="container">
      <p class="section__eyebrow"><span class="mono">skills/</span> · three domains, one stack</p>
      <h1 class="page-head__title">Three domains. <span class="hl">One stack.</span></h1>
      <p class="page-head__sub">
        Skills grouped the way a hiring manager reads them: what I build, how I validate it, and what
        I ship it with. Each skill is paired with the discipline it represents.
      </p>

      <div class="head-eq">
        <Equation
          block
          latex={`\\mathrm{stack} \\;=\\; \\mathrm{build} \\;\\cdot\\; \\mathrm{validate}\\;\\cdot\\;\\mathrm{ship} \\qquad \\text{where}\\quad \\mathrm{validate} = \\mathrm{G1\\;..\\;G31}`}
          size="md"
        />
      </div>

      <div class="head-stats">
        <Stat value={String(groups.length)} label="domains" sub="three" formula="|D|" />
        <Stat value={String(totalSkills)} label="skills" sub="in stack" formula="|\mathcal{S}|" />
        <Stat value="0" label="proprietary" sub="data sources" formula="\neg p" />
        <Stat value="6" label="OSS repos" sub="runnable" formula="|R|" trend="up" />
      </div>
    </div>
  </header>

  {groups.map((group, idx) => (
    <section class:list={["section", { "section--alt": idx % 2 === 1 }]}>
      <div class="container">
        <header class="section__head">
          <p class="section__eyebrow">Domain {idx + 1}</p>
          <h2 class="section__title">{group.data.title}</h2>
          <p class="section__sub">{group.data.blurb}</p>
        </header>
        <div class="skills">
          {group.data.items.map(item => (
            <div class="skill">
              <div class="skill__label">{item.label}</div>
              {item.sub && <div class="skill__sub muted">{item.sub}</div>}
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

</BaseLayout>

<style>
  .page-head {
    padding-block: var(--sp-9) var(--sp-7);
    background:
      radial-gradient(1200px 600px at 80% -100px, rgba(11, 61, 92, 0.10), transparent 60%),
      var(--c-paper);
    border-bottom: var(--border);
  }
  .page-head__title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: var(--sp-3);
  }
  .page-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 64ch;
    margin-bottom: var(--sp-6);
  }
  .head-eq {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    margin-bottom: var(--sp-5);
    overflow-x: auto;
  }
  .head-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-3);
  }
  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--sp-4);
  }
  .skill {
    padding: var(--sp-4);
    background: var(--c-bg);
    border: var(--border);
    border-radius: var(--radius-sm);
    transition: border-color var(--transition), transform var(--transition);
  }
  .skill:hover {
    border-color: var(--c-ink-3);
    transform: translateY(-1px);
  }
  .skill__label {
    font-weight: 600;
    color: var(--c-ink);
    margin-bottom: 0.25rem;
  }
  .skill__sub {
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
  }

  @media (max-width: 880px) {
    .head-stats { grid-template-columns: 1fr 1fr; }
  }
</style>