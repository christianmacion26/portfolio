---
/**
 * methodology.astro — the eval-first philosophy, G1–G31 gate stack, model-routing policy,
 * agent charter pattern. Spell out the *method*, not just the outputs.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Equation from '@components/Equation.astro';
import CTABanner from '@components/CTABanner.astro';
import DSRCalculator from '@components/DSRCalculator.astro';
import ReadMeta from '@components/ReadMeta.astro';
import TrustStrip from '@components/TrustStrip.astro';
import SectionTOC from '@components/SectionTOC.astro';
import PipelineDiagram from '@components/PipelineDiagram.astro';
import StatementCarousel from '@components/StatementCarousel.astro';
import { path } from '@utils/url';

const gates = [
  {
    range: 'G1–G5',
    name: 'Mechanical validity',
    desc: 'Schema conformance, exit-0 contract, structured output parse, JSON Schema strict-mode, byte-length budget.',
  },
  {
    range: 'G6–G10',
    name: 'Statistical nulls',
    desc: '<a href={path("/glossary/block-bootstrap")}>block-bootstrap</a> CIs, random-timing nulls, <a href={path("/glossary/regime")}>regime</a>-shuffle, parameter-prior sensitivity, Monte-Carlo coverage.',
  },
  {
    range: 'G11–G15',
    name: 'Walk-forward & OOS',
    desc: 'Locked <a href={path("/glossary/oos")}>OOS</a> windows, 5-era stability, expanding/rolling <a href={path("/glossary/walk-forward")}>walk-forward</a> windows, frozen-spec evaluation, <a href={path("/glossary/embargo")}>embargoed</a> test set.',
  },
  {
    range: 'G16–G20',
    name: 'Multiple testing',
    desc: '<a href={path("/glossary/deflated-sharpe")}>Deflated Sharpe Ratio</a> (DSR), <a href={path("/glossary/cscv-pbo")}>CSCV-based Probability of Backtest Overfit</a> (PBO), <a href={path("/glossary/minbtl")}>Minimum Backtest Length</a> (MinBTL), <a href={path("/glossary/bonferroni-holm")}>Bonferroni–Holm</a>, BH-FDR.',
  },
  {
    range: 'G21–G25',
    name: 'Look-ahead discipline',
    desc: 'Point-in-time dataset verification, <a href={path("/glossary/survivorship-bias")}>survivorship-bias</a> check, rebalance-vs-signal timing, frozen-spec, no-leakage to scoring.',
  },
  {
    range: 'G26–G31',
    name: 'Economic & cost realism',
    desc: 'Spread/<a href={path("/glossary/slippage")}>slippage</a>/latency per asset class, capacity-constraint report, funding-carry, borrow cost, vol-targeted sizing, <a href={path("/glossary/regime")}>regime</a> overlay.',
  },
];

const routing = [
  {
    tier: 'Opus',
    role: 'judgment / hardest autonomous decisions',
    ratio: '~1 dispatch per analysis chain',
  },
  { tier: 'Sonnet', role: 'assembly / structured generation', ratio: '~3–5 dispatches per chain' },
  {
    tier: 'Haiku',
    role: 'mechanical / fast deterministic steps',
    ratio: '~10–30 dispatches per chain',
  },
  { tier: 'Fable', role: 'long-horizon autonomous research', ratio: 'one off, overnight' },
];

const charter = [
  { tag: 'role', value: 'A specific function, never generic "AI assistant"' },
  { tag: 'inputs', value: 'Typed input contract (JSON Schema, fail-closed)' },
  { tag: 'outputs', value: 'Typed output contract with strict validation' },
  { tag: 'handoffs', value: 'What this agent must NOT do (anti-charter)' },
  { tag: 'gates', value: 'Which of G1–G31 apply, with exit codes' },
  { tag: 'evidence', value: 'What the agent must attach as proof' },
];
---

<BaseLayout
  title="Methodology"
  description="The eval-first discipline. G1–G31 statistical gate stack. Model-routing policy. Agent charter pattern."
  breadcrumbs={[{ name: "Home", href: "/" }, { name: "Methodology", href: "/methodology" }]}
>
  <header class="method-head">
    <div class="container">
      <p class="section__eyebrow"><span class="mono">methodology/</span> · eval-first discipline</p>
      <h1 class="method-head__title">
        Don’t ship what hasn’t passed a <span class="hl">measurable gate</span>.
      </h1>
      <p class="method-head__voice voice-line">
        If it isn't measured, it isn't built.
      </p>

      <div class="method-head__carousel">
        <StatementCarousel
          statements={[
            'Gate before ship. Always.',
            'PBO-tested. CSCV-based. Walk-forward.',
            'Block-bootstrap CIs. Random-timing nulls.',
            'Deflated Sharpe. Multiple-testing aware.',
            'Frozen-spec eval. No live tuning.',
            'Five-era stability. One regime is anecdote.',
          ]}
          label="Methodology discipline — six rules, rotating"
          intervalMs={5500}
        />
      </div>

      <p class="method-head__sub">
        One engineering principle. Applied to LLM outputs and to systematic trading strategies with
        the same gate stack. The method is what scales; the tools change.
      </p>

      <div class="method-head__eq-block">
        <Equation
          block
          size="lg"
          latex={`\\Pr(\\text{ship}) \\;=\\; \\Pr(\\text{ship} \\mid \\text{passes G1--G31}) \\cdot \\prod_{i=1}^{31} \\Pr(G_i \\mid \\text{evidence}_i)`}
        />
      </div>

      {/* === Headline stats — gate lattice at a glance === */}
      <div class="method-head__stats">
        <div class="method-head__stat">
          <span class="method-head__stat-num tnum">31</span>
          <span class="method-head__stat-lbl">statistical gates</span>
        </div>
        <div class="method-head__stat">
          <span class="method-head__stat-num tnum">6</span>
          <span class="method-head__stat-lbl">gate families</span>
        </div>
        <div class="method-head__stat">
          <span class="method-head__stat-num tnum">11</span>
          <span class="method-head__stat-lbl">agents on the same method</span>
        </div>
        <div class="method-head__stat">
          <span class="method-head__stat-num tnum">0</span>
          <span class="method-head__stat-lbl">rollbacks on shipped work</span>
        </div>
      </div>
    </div>
  </header>

  <TrustStrip variant="tape" />

  <div class="container container-narrow">
    <ReadMeta minutes={11} updatedIso="2026-07-09" href={path('/proof')} />
  </div>

  <SectionTOC
    label="On this methodology page"
    items={[
      { id: 'gates', label: 'G1–G31 gate stack' },
      { id: 'routing', label: 'Model routing' },
      { id: 'dsr', label: 'DSR calculator' },
      { id: 'charter', label: 'Agent charter' },
      { id: 'neg', label: 'Negative space' },
      { id: 'hire', label: 'If you hired me' },
    ]}
  />

  <section class="section" data-toc-id="gates" data-toc-label="G1–G31 gate stack">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">The gate stack</p>
        <h2 class="section__title" id="gates">G1–G31. Six families. One contract.</h2>
        <p class="section__sub">
          Every candidate — LLM output, systematic strategy, content artifact — passes through the
          same gate stack. Gates are mechanical (exit-0 contract), not opinionated. A pass means the
          candidate is allowed to surface; a fail means it isn't.
        </p>
      </header>

      <div class="gates">
        {
          gates.map((g, i) => (
            <article class="gate" id={`family-${i + 1}`}>
              <header class="gate__head">
                <span class="gate__range mono">{g.range}</span>
                <h3 class="gate__name">{g.name}</h3>
              </header>
              <p class="gate__desc">{g.desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--alt" data-toc-id="routing" data-toc-label="Model routing">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Model routing</p>
        <h2 class="section__title" id="routing">Tiered dispatch, not single-agent.</h2>
        <p class="section__sub">
          A multi-agent system runs at ~15× the token cost of a single agent. The cost is real — the
          answer is to route by what the step actually needs to compute, not by default. Every
          dispatch has a per-step budget.
        </p>
      </header>

      <div class="routing">
        {
          routing.map((r) => (
            <div class="route">
              <div class="route__tier mono">{r.tier}</div>
              <div class="route__role">{r.role}</div>
              <div class="route__ratio mono">{r.ratio}</div>
            </div>
          ))
        }
      </div>

      <div class="routing-eq">
        <Equation
          latex={`\\text{cost} = \\sum_{i} \\text{tokens}(i) \\cdot \\text{price}(\\text{tier}(i)) \\quad \\text{where} \\quad \\text{tier} : \\mathcal{A} \\to \\{\\text{Opus, Sonnet, Haiku, Fable}\\}`}
        />
      </div>

      <div class="routing-pipeline" aria-label="End-to-end pipeline from intent to deliverable with feedback loop">
        <p class="routing-pipeline__cap mono">end-to-end pipeline · every project</p>
        <PipelineDiagram
          tone="paper"
          steps={[
            { num: '01', title: 'Intent', desc: 'problem statement + success metric + NDA audit' },
            { num: '02', title: 'Frame', desc: 'frozen spec · eval harness drafted before code' },
            { num: '03', title: 'Build', desc: 'tier-routed agents · cost-capped per step' },
            { num: '04', title: 'Verify', desc: 'gate stack G1–G31 · exit-0 contract' },
            { num: '05', title: 'Deliver', desc: 'public repo or live paper-trade · published only if all pass' },
          ]}
        />
      </div>
    </div>
  </section>

  <section class="section" data-toc-id="dsr" data-toc-label="DSR calculator">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Interactive · G16</p>
        <h2 class="section__title" id="dsr">Try the <a href={path("/glossary/deflated-sharpe")}>deflated Sharpe</a> calculator.</h2>
        <p class="section__sub">
          See how the same in-sample <a href={path("/glossary/sharpe")}>Sharpe</a> can pass or fail G16 depending on how many strategies
          you actually tried. This is the gate that turns "1.14 looks great" into <a href={path("/glossary/deflated-sharpe")}>"DSR 0.70 — fail."</a>
        </p>
      </header>

      <DSRCalculator />
    </div>
  </section>

  <section class="section" data-toc-id="charter" data-toc-label="Agent charter">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">Agent charter</p>
        <h2 class="section__title" id="charter">Six required fields per agent.</h2>
        <p class="section__sub">
          A charter is a contract, not a prompt. Every agent has the same six fields, with the same
          semantics. No exceptions.
        </p>
      </header>

      <div class="charter">
        {
          charter.map((c) => (
            <div class="charter__row">
              <div class="charter__tag mono">{c.tag}</div>
              <div class="charter__val">{c.value}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--alt" data-toc-id="neg" data-toc-label="Negative space">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">What I will not do</p>
        <h2 class="section__title" id="neg">Negative-space as design.</h2>
      </header>
      <ul class="neg">
        <li>
          I will not claim current employment at any NDA-protected firm. The systematic-strategy desk engagement
          is a <strong>closed past contract</strong> (03/2026 – 06/2026).
        </li>
        <li>
          I will not reference proprietary data sources, fund renames, or per-strategy t-stats from
          any NDA-protected desk.
        </li>
        <li>
          I will not share a <a href={path("/glossary/sharpe")}>"Sharpe = X.X"</a> number without showing the gate stack that produced it.
        </li>
        <li>I will not ship an agent without an exit-0 mechanical-validator contract.</li>
        <li>I will not present a backtest without capacity, <a href={path("/glossary/slippage")}>slippage</a>, and a locked <a href={path("/glossary/oos")}>OOS</a> window.</li>
      </ul>
    </div>
  </section>

  <section class="section section--alt" data-toc-id="hire" data-toc-label="If you hired me">
    <div class="container">
      <header class="section__head">
        <p class="section__eyebrow">What I'd build first</p>
        <h2 class="section__title" id="hire">If you hired me onto a quant desk.</h2>
        <p class="section__sub">
          These are the first 90 days, ordered by leverage. A new QR on a 2–5 person pod doesn't
          start with alpha — they start by making the existing book defensible to a risk manager and
          a PM. The discipline compounds; the alpha is downstream.
        </p>
      </header>
      <ol class="plan">
        <li class="plan__row">
          <div class="plan__week mono">WK 1–2</div>
          <div class="plan__body">
            <h3 class="plan__title">Backtest-engine audit + look-ahead scan</h3>
            <p class="plan__body-p">
              Run the one-bar shift test (project 09) on every strategy in the book. Quantify the
              phantom-Sharpe gap. This is the gate that catches the most expensive error class
              first.
            </p>
            <div class="plan__gates mono">G21–G25 · look-ahead discipline</div>
          </div>
        </li>
        <li class="plan__row">
          <div class="plan__week mono">WK 3–4</div>
          <div class="plan__body">
            <h3 class="plan__title">Cost-model calibration + break-even turnaround</h3>
            <p class="plan__body-p">
              Per-strategy <a href={path("/glossary/slippage")}>slippage</a> / impact / spread estimate. For every strategy, ship the
              break-even turnaround cost (project 08). Strategies that win gross and lose net come
              off the book.
            </p>
            <div class="plan__gates mono">G26–G31 · economic & cost realism</div>
          </div>
        </li>
        <li class="plan__row">
          <div class="plan__week mono">WK 5–8</div>
          <div class="plan__body">
            <h3 class="plan__title">Multiple-testing correction across the book</h3>
            <p class="plan__body-p">
              Re-rank every strategy by <a href={path("/glossary/deflated-sharpe")}>DSR</a> (project 01), not raw <a href={path("/glossary/sharpe")}>Sharpe</a>. Re-rank by <a href={path("/glossary/cscv-pbo")}>CSCV-based PBO</a>
              (prob. of backtest overfit). The book's "best strategy" is rarely the strategy with
              the highest raw Sharpe.
            </p>
            <div class="plan__gates mono">G16–G20 · multiple testing</div>
          </div>
        </li>
        <li class="plan__row">
          <div class="plan__week mono">WK 9–12</div>
          <div class="plan__body">
            <h3 class="plan__title">Walk-forward OOS window standardization</h3>
            <p class="plan__body-p">
              Locked, <a href={path("/glossary/embargo")}>embargoed</a> <a href={path("/glossary/oos")}>OOS</a> windows (project 06 pattern) across the book. Frozen-spec
              evaluation. <a href={path("/glossary/walk-forward")}>Walk-forward</a> standardization. The book becomes reproducible from cold start.
            </p>
            <div class="plan__gates mono">G11–G15 · walk-forward & OOS</div>
          </div>
        </li>
      </ol>

      <div class="plan__note">
        <strong>The pattern:</strong> defenses before alpha. A QR who can defend the book is hireable;
        a QR who can find alpha is hireable-and-defensible. The first 90 days establish the defense.
      </div>
    </div>
  </section>

  <CTABanner
    title="Method under-spec? Send the JD."
    sub="If your role has a written spec, send it. I'll respond with which gates from G1–G31 already apply to your stack, and which I'd build."
    primaryLabel="Email me"
    secondaryLabel="View solutions"
    secondaryHref={path('/solutions')}
  />
</BaseLayout>

<style>
  .method-head {
    padding-block: var(--sp-9) var(--sp-7);
    background:
      radial-gradient(1200px 600px at 80% 0%, rgba(11, 61, 92, 0.1), transparent 60%), var(--c-bg);
    border-bottom: var(--border);
  }
  .method-head__title {
    font-size: clamp(1.75rem, 5vw, 4rem);
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-block: var(--sp-4) var(--sp-5);
    max-width: 22ch;
  }
  .method-head__voice {
    margin: 0 0 var(--sp-5);
    padding-left: var(--sp-3);
    border-left: 2px solid var(--c-primary-2);
    font-style: italic;
    font-family: var(--serif-display);
    font-size: clamp(1.15rem, 2.4vw, 1.65rem);
    line-height: 1.4;
    color: var(--c-ink-2);
    max-width: 60ch;
  }
  .method-head__voice::before {
    content: '\201C';
    color: var(--c-primary-2);
    font-style: normal;
    margin-right: 0.1em;
  }
  .method-head__voice::after {
    content: '\201D';
    color: var(--c-primary-2);
    font-style: normal;
    margin-left: 0.1em;
  }
  .method-head__sub {
    font-size: var(--fs-lg);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 60ch;
    margin-bottom: var(--sp-7);
  }
  .method-head__eq-block {
    padding: var(--sp-6) var(--sp-5);
    background: var(--c-paper);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    overflow-x: auto;
  }
  .method-head__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
    margin-block: var(--sp-6) var(--sp-4);
    padding-block: var(--sp-4);
    border-top: 1px solid var(--c-rule);
    border-bottom: 1px solid var(--c-rule);
  }
  .method-head__stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .method-head__stat-num {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--c-primary);
    font-variant-numeric: tabular-nums;
  }
  .method-head__stat-lbl {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink-3);
    line-height: 1.3;
  }
  @media (max-width: 640px) {
    .method-head__stats {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--sp-3);
    }
  }

  .gates {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--sp-4);
  }
  .gate {
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-left: 3px solid var(--c-primary);
    border-radius: var(--radius);
    transition: border-color var(--transition);
  }
  .gate:hover {
    border-color: var(--c-primary);
    border-left-color: var(--c-primary-2-deep);
  }
  .gate__head {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    margin-bottom: var(--sp-2);
  }
  .gate__range {
    font-size: var(--fs-sm);
    color: var(--c-primary);
    font-weight: 700;
  }
  .gate__name {
    font-size: var(--fs-base);
    margin: 0;
  }
  .gate__desc {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin: 0;
  }

  .routing {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--sp-3);
    margin-bottom: var(--sp-5);
  }
  .route {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-4);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
  }
  .route__tier {
    font-size: var(--fs-base);
    color: var(--c-primary);
    font-weight: 700;
  }
  .route__role {
    font-size: var(--fs-sm);
    color: var(--c-ink);
    line-height: var(--lh-normal);
  }
  .route__ratio {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    margin-top: var(--sp-1);
  }

  .routing-eq {
    padding: var(--sp-5);
    background: var(--c-paper);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    overflow-x: auto;
  }

  .charter {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .charter__row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--sp-4);
    padding: var(--sp-3) var(--sp-5);
    border-bottom: 1px solid var(--c-rule-soft);
    align-items: center;
  }
  .charter__row:last-child {
    border-bottom: none;
  }
  .charter__tag {
    color: var(--c-primary);
    font-weight: 600;
    text-transform: uppercase;
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
  }
  .charter__val {
    color: var(--c-ink);
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
  }

  .neg {
    list-style: none;
    padding: 0;
    max-width: 760px;
  }
  .neg li {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: var(--sp-3);
    line-height: var(--lh-loose);
    color: var(--c-ink-2);
    font-size: var(--fs-base);
  }
  .neg li::before {
    content: '✕';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--c-fail);
    font-weight: 600;
    font-family: var(--ff-mono);
  }
  .neg strong {
    color: var(--c-ink);
    font-weight: 600;
  }

  @media (max-width: 720px) {
    .charter__row {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
    }
  }

  /* === WHAT I'D BUILD FIRST === */
  .plan {
    list-style: none;
    padding: 0;
    counter-reset: plan;
    max-width: 880px;
  }
  .plan__row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: var(--sp-4);
    padding: var(--sp-5);
    background: var(--c-bg);
    border: 1px solid var(--c-rule);
    border-left: 3px solid var(--c-primary-2);
    border-radius: var(--radius);
    margin-bottom: var(--sp-3);
    counter-increment: plan;
  }
  .plan__week {
    font-size: var(--fs-sm);
    color: var(--c-primary-2-deep);
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .plan__title {
    font-size: var(--fs-lg);
    margin: 0 0 var(--sp-2);
    color: var(--c-ink);
  }
  .plan__body-p {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    margin-bottom: var(--sp-3);
  }
  .plan__gates {
    display: inline-block;
    padding: 4px 10px;
    background: var(--c-bg-2);
    border: 1px solid var(--c-rule);
    border-radius: 12px;
    font-size: var(--fs-xs);
