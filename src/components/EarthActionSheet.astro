---
/**
 * EarthActionSheet.astro — v6.4 "Earth Mission Control" — "what a desk
 * does with this event" overlay. One rendered per city cluster; shows
 * 1-3 rows of (event-category | desk-action 1-liner) for the events
 * currently firing in that city.
 *
 * Source data:
 *   - Pulls events from `getCollection('worldEvent')`.
 *   - Filters to events whose `data.city` matches the prop.
 *   - If the city has zero events in the fixture set, falls back to
 *     the first event of the collection so the sheet always renders
 *     at least one action (decoration-not-information fallback).
 *
 * Determinism:
 *   - Desk actions come from `@utils/desk-actions.deskActionFor(category,
 *     buildDateIso?)` — the same function EarthDrawer uses for its
 *     per-event desk-action column. Same build → same action; next-day
 *     build → fresh action. Single seed-threading site = single source
 *     of truth.
 *
 * Honored constraints:
 *   - No `client:*`, no `Math.random()`, no `Date.now()`.
 *   - Palette tokens only.
 *   - `prefers-reduced-motion`: no animations on this component;
 *     nothing to disable.
 */
import { getCollection } from 'astro:content';
import { deskActionFor } from '@utils/desk-actions';

interface RawWorldEvent {
  data: {
    title: string;
    category:
      | 'central-bank'
      | 'earnings'
      | 'geopolitical'
      | 'data-release'
      | 'fx';
    severity: 'mild' | 'moderate' | 'critical';
    lat: number;
    lon: number;
    city: string;
    source: string;
    order: number;
  };
}

interface Props {
  /** City to render the action sheet for. Required. */
  city: string;
  /** Optional build-stamp for deterministic desk-action selection. */
  buildDateIso?: string;
  /** Optional max rows to render (default 3). */
  maxRows?: number;
}

const { city, buildDateIso, maxRows = 3 } = Astro.props;

const allEvents = await getCollection('worldEvent');
const cityEvents = allEvents
  .filter((e: RawWorldEvent) => e.data.city === city)
  .sort(
    (a: RawWorldEvent, b: RawWorldEvent) => a.data.order - b.data.order,
  );

// Fallback: if the city has zero fixture events, render the first event
// of the collection so the sheet always has at least one row to show.
const slice = cityEvents.length > 0 ? cityEvents : allEvents.slice(0, 1);

interface ActionRow {
  category: string;
  title: string;
  action: string;
}

const rows: ActionRow[] = slice.slice(0, maxRows).map((e: RawWorldEvent) => ({
  category: e.data.category,
  title: e.data.title,
  action: deskActionFor(e.data.category, buildDateIso),
}));
---

<section
  class="earth-action-sheet"
  aria-label={`What a desk does in ${city}`}
>
  <header class="earth-action-sheet__head">
    <span class="earth-action-sheet__city">{city}</span>
    <span class="earth-action-sheet__label">· desk action</span>
    <span class="earth-action-sheet__count">{rows.length}</span>
  </header>
  <ol class="earth-action-sheet__list">
    {
      rows.map((r) => (
        <li class="earth-action-sheet__item">
          <span class="earth-action-sheet__cat">{r.category}</span>
          <span class="earth-action-sheet__action">{r.action}</span>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .earth-action-sheet {
    border: 1px solid var(--c-rule);
    background: var(--c-tape-2);
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--radius);
  }
  .earth-action-sheet__head {
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
    margin-bottom: var(--sp-2);
    border-bottom: 1px solid var(--c-rule-soft);
    padding-bottom: var(--sp-2);
    font-family: var(--ff-mono, monospace);
  }
  .earth-action-sheet__city {
    color: var(--c-amber-light);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.7rem;
  }
  .earth-action-sheet__label {
    color: var(--c-ink-3);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
  }
  .earth-action-sheet__count {
    color: var(--c-ink-2);
    font-size: 0.66rem;
    margin-left: auto;
  }

  .earth-action-sheet__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .earth-action-sheet__item {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: var(--sp-3);
    padding: var(--sp-2) 0;
    border-bottom: 1px dashed var(--c-rule-soft);
    font-size: var(--fs-sm);
    align-items: baseline;
  }
  .earth-action-sheet__item:last-child {
    border-bottom: 0;
  }
  .earth-action-sheet__cat {
    color: var(--c-ink-2);
    font-family: var(--ff-mono, monospace);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .earth-action-sheet__action {
    color: var(--c-ink);
  }

  @media (max-width: 720px) {
    .earth-action-sheet__item {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
    }
  }
</style>
