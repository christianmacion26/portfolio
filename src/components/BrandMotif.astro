---
/**
 * BrandMotif.astro — the 33-cell micro-lattice.
 *
 * One reusable geometric SVG that visually encodes the G1–G31 evaluation
 * stack: 31 gates grouped into 6 families + 1 amber-lit "ship" indicator
 * + 1 outlined "block" indicator. The aesthetic reference is Jane Street's
 * six-exchange honeycomb, Akuna's engineer-first terminal glyph, and the
 * Vatic Labs wordmark — a single geometric mark used sparingly across the IA,
 * never wallpapered.
 *
 * SEMANTIC UPGRADE (v5.0 D.1): each of the 31 gate cells is now a clickable
 * link to /methodology#family-{N} with a native <title> tooltip showing the
 * family range + name. The 2 indicator cells (ship, block) stay inert.
 *
 * Wired into the IA at three places only:
 *   - The `/` hero, beside the H1 fragment.
 *   - The `/proof` page head decoration.
 *   - The footer, beside the brand wordmark.
 *
 * Usage:
 *   <BrandMotif width={420} caption="G1–G31 · ship(x) = 1 ⇔ ∀ gates pass" />
 */
interface Props {
  /** Rendered width in px. Default 240. */
  width?: number;
  /** Rendered height (auto-derived from width when omitted). */
  height?: number;
  /** Optional mono caption rendered under the lattice. */
  caption?: string;
  /** If true (default) the SVG is decorative (aria-hidden). Set false when
   * the caption is the load-bearing context and you want screen readers
   * to reach it. */
  decorative?: boolean;
}

const {
  width = 240,
  height,
  caption,
  decorative = true,
} = Astro.props;

const N = 33;
const VIEW_W = 240;
const VIEW_H = 60;
// 33 circles across VIEW_W → step ~7.0
const stepX = VIEW_W / (N + 1); // leaves a half-cell of margin on each side
const radius = 2.4;
const cy = 22;
const captionY = 50;

// Choose one cell to be the bright "ship" gate (position 16 = G16) and one
// outlined "block" indicator at position 27. Both stay inert (no link).
const shipIndex = 16;
const blockIndex = 27;

// Gate families — source of truth lives at /methodology. Each family anchors
// a contiguous run of cells in the lattice (5 + 5 + 5 + 5 + 5 + 6 = 31).
// The 33 cells = 31 family cells + ship + block; family cells 0..4 = G1–G5,
// cells 5..9 = G6–G10, ..., cells 25..30 = G26–G31. Cells 31 (ship) and 32
// (block) are reserved indicator positions.
const families = [
  { cells: [0, 1, 2, 3, 4], range: 'G1–G5', name: 'Mechanical validity', href: '/methodology#family-1' },
  { cells: [5, 6, 7, 8, 9], range: 'G6–G10', name: 'Statistical nulls', href: '/methodology#family-2' },
  { cells: [10, 11, 12, 13, 14], range: 'G11–G15', name: 'Walk-forward & OOS', href: '/methodology#family-3' },
  { cells: [15, 17, 18, 19, 20], range: 'G16–G20', name: 'Multiple testing', href: '/methodology#family-4' }, // skip shipIndex=16
  { cells: [21, 22, 23, 24, 25], range: 'G21–G25', name: 'Look-ahead discipline', href: '/methodology#family-5' },
  { cells: [26, 28, 29, 30, 31, 32], range: 'G26–G31', name: 'Economic & cost realism', href: '/methodology#family-6' }, // skip blockIndex=27
];

// Flat lookup: cell index → family info (or null for ship/block indicators).
const cellToFamily: Map<number, (typeof families)[number]> = new Map();
for (const f of families) {
  for (const c of f.cells) {
    cellToFamily.set(c, f);
  }
}
---

<figure class="brand-motif" style={`--brand-w:${width}px;${height ? `--brand-h:${height}px;` : ''}`}>
  {/* v6.3 polish — wrap the motif in a single 44×44+ anchor to
     /methodology instead of 31 individual per-cell `<a>` tags.
     The audit was flagging every cell anchor as a 26×26 SVG link
     (insufficient tap target even with the 44-unit hit rect).
     Now the motif has ONE link to the methodology page; the
     native `<title>` tooltips on each cell still announce the
     gate family on hover/long-press. */}
  <a
    href="/methodology/"
    class="brand-motif__link"
    aria-label="See the full G1–G31 evaluation stack on /methodology"
  >
    <svg
      viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
      width={width}
      height={height}
      role={decorative ? 'presentation' : 'img'}
      aria-hidden={decorative ? 'true' : 'false'}
      focusable="false"
      preserveAspectRatio="xMidYMid meet"
    >
      <title>Validation gate lattice — G1–G31 across 6 families</title>
      <desc>
        Thirty-three cells representing the G1–G31 statistical eval stack. Cells
        16 and 27 are reserved indicator positions (ship, block). Hover any cell
        to read its family.
      </desc>
      <g class="brand-motif__row">
        {
          Array.from({ length: N }).map((_, i) => {
            const cx = stepX * (i + 1);
            if (i === shipIndex) {
              return (
                <g class="brand-motif__cell brand-motif__cell--ship">
                  <circle cx={cx} cy={cy} r={radius + 1.6} fill="var(--c-primary-2)" opacity="0.18" />
                  <circle cx={cx} cy={cy} r={radius} fill="var(--c-primary-2)" />
                </g>
              );
            }
            if (i === blockIndex) {
              return (
                <circle
                  class="brand-motif__cell brand-motif__cell--block"
                  cx={cx}
                  cy={cy}
                  r={radius}
                  fill="none"
                  stroke="var(--c-primary-2-deep)"
                  stroke-width="1.2"
                />
              );
            }
            const family = cellToFamily.get(i);
            if (!family) {
              return (
                <circle
                  class="brand-motif__cell"
                  cx={cx}
                  cy={cy}
                  r={radius}
                  fill="var(--c-ink-3)"
                  opacity="0.55"
                />
              );
            }
            return (
              <g class="brand-motif__cell brand-motif__cell--gate">
                <title>{family.range} · {family.name}</title>
                <circle
                  cx={cx}
                  cy={cy}
                  r={radius}
                  fill="var(--c-ink-3)"
                  opacity="0.55"
                />
              </g>
            );
          })
        }
      </g>
      {caption && (
        <text
          class="brand-motif__caption"
          x={VIEW_W / 2}
          y={captionY}
          text-anchor="middle"
          font-family="var(--ff-mono)"
          font-size="7"
          fill="var(--c-ink-3)"
          letter-spacing="0.08em"
        >
          {caption}
        </text>
      )}
    </svg>
  </a>
</figure>

<style>
  .brand-motif {
    display: inline-block;
    margin: 0;
    padding: 0;
    line-height: 0;
    max-width: 100%;
  }
  /* v6.3 polish — the wrapping <a> is inline-block so it sizes to the
     SVG bounding box, then receives a safe ≥ 44 px tap target via
     min-height (the visible lattice is already ≥ 240×60 px on desktop
     and scales proportionally on mobile, so min-height only widens the
     hit box, never the visible glyph). display on the link is critical
     because the SVG inside is inline by default. */
  .brand-motif__link {
    display: inline-block;
    min-height: 44px;
    line-height: 0;
    text-decoration: none;
    color: inherit;
  }
  .brand-motif svg {
    display: block;
    max-width: 100%;
    height: auto;
  }
  /* Subtle pulse on the ship indicator — restraint: opacity, no motion. */
  @media (prefers-reduced-motion: no-preference) {
    .brand-motif__cell--ship > circle:nth-child(2) {
      animation: brand-motif-breathe 5.5s ease-in-out infinite;
    }
  }
  @keyframes brand-motif-breathe {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.72;
    }
  }

  /* Gate cells: hover lifts opacity; focus shows a 1px ring. */
  .brand-motif__cell--gate {
    cursor: pointer;
    transition: opacity 0.15s ease;
  }
  .brand-motif__cell--gate:hover circle {
    opacity: 0.9;
    fill: var(--c-primary-2);
  }
  .brand-motif__cell--gate:focus {
    outline: none;
  }
  .brand-motif__cell--gate:focus-visible circle {
    stroke: var(--c-primary-2-deep);
    stroke-width: 0.8;
  }
</style>
