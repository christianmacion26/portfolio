---
/**
 * Equation.astro — server-side rendered KaTeX block.
 *
 * Usage:
 *   <Equation latex="P(A \mid B) = \frac{P(B \mid A) P(A)}{P(B)}" />
 *   <Equation latex="\sigma^2 = E[(X - \mu)^2]" block label="(1)" />
 *
 * Props:
 *   latex  — KaTeX-compatible LaTeX string
 *   block  — render as display block (default: false, inline)
 *   label  — optional equation label, e.g. "(1)"
 *   size   — 'sm' | 'md' | 'lg' | 'xl' (default 'md')
 *   tone   — 'paper' (default, near-black ink on light bg)
 *         | 'tape' (light ink on dark `--c-tape` bg)
 *   className — extra classes
 */
import katex from 'katex';

interface Props {
  latex: string;
  block?: boolean;
  label?: string;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  tone?: 'paper' | 'tape';
  className?: string;
}

const { latex, block = false, label, size = 'md', tone = 'paper', className } = Astro.props;
const html = katex.renderToString(latex, {
  displayMode: block,
  throwOnError: false,
  output: 'html',
  strict: 'ignore',
  trust: false,
});
const sizeClass = size !== 'md' ? `eq--${size}` : '';
const toneClass = tone === 'tape' ? 'eq--tape' : '';
---

<span
  class:list={['eq', sizeClass, toneClass, className, { 'eq--block': block }]}
  data-latex={latex}
>
  <Fragment set:html={html} />
  {
    label && (
      <span class="eq__label" aria-hidden="true">
        {label}
      </span>
    )
  }
</span>

<style>
  .eq {
    display: inline-block;
    font-family: var(--ff-math);
    color: var(--c-eq);
    line-height: 1.4;
    vertical-align: baseline;
    /* KaTeX HTML output is math-styled; preserve its baseline math */
  }
  /* 'tape' tone — light ink on dark `--c-tape` background. */
  /* Reassign every KaTeX class the engine uses for math text so glyphs */
  /* stay legible against dark cells; without this, .mord/.mathnormal */
  /* inherit from --c-eq (near-black) and disappear into --c-tape. */
  .eq--tape,
  .eq--tape :global(.mord),
  .eq--tape :global(.mathnormal),
  .eq--tape :global(.mathit),
  .eq--tape :global(.mathrm),
  .eq--tape :global(.mathbf),
  .eq--tape :global(.mathsf),
  .eq--tape :global(.mathtt),
  .eq--tape :global(.mbin),
  .eq--tape :global(.mrel),
  .eq--tape :global(.mopen),
  .eq--tape :global(.mclose),
  .eq--tape :global(.mpunct),
  .eq--tape :global(.minner),
  .eq--tape :global(.mop),
  .eq--tape :global(.accent),
  .eq--tape :global(.op-symbol),
  .eq--tape :global(.delimsizing),
  .eq--tape :global(.delimcenter),
  .eq--tape :global(.delimcenter span),
  .eq--tape :global(.sqrt),
  .eq--tape :global(.sqrt > .root),
  .eq--tape :global(.sqrt > .sqrt-sign),
  .eq--tape :global(.frac-line),
  .eq--tape :global(.sizing),
  .eq--tape :global(.reset-size1),
  .eq--tape :global(.reset-size2),
  .eq--tape :global(.reset-size3),
  .eq--tape :global(.reset-size4),
  .eq--tape :global(.reset-size5),
  .eq--tape :global(.reset-size6),
  .eq--tape :global(.reset-size7),
  .eq--tape :global(.reset-size8),
  .eq--tape :global(.reset-size9),
  .eq--tape :global(.reset-size10),
  .eq--tape :global(.reset-size11),
  .eq--tape :global(.size1),
  .eq--tape :global(.size2),
  .eq--tape :global(.size3),
  .eq--tape :global(.size4),
  .eq--tape :global(.size5),
  .eq--tape :global(.size6),
  .eq--tape :global(.size7),
  .eq--tape :global(.size8),
  .eq--tape :global(.size9),
  .eq--tape :global(.size10),
  .eq--tape :global(.size11) {
    color: var(--ink-on-tape);
  }
  /* Accent tokens stay readable: Φ gold, σ amber (F14 institutional) */
  .eq--tape :global(.accent .mord),
  .eq--tape :global(.mathbb) {
    color: var(--c-primary-2-deep);
  }
  .eq--block {
    display: block;
    margin: var(--sp-5) 0;
    text-align: center;
    position: relative;
  }
  .eq--block :global(.katex-display) {
    margin: 0;
  }
  .eq__label {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--ff-mono);
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
  }
  .eq--tape .eq__label {
    color: var(--c-ink-faint);
  }
  .eq--block .eq__label {
    top: auto;
    bottom: -0.5em;
    right: 0;
    transform: none;
  }
</style>
