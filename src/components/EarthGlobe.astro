---
/**
 * EarthGlobe.astro — v6.5 rotating orthographic globe with mission-control chrome.
 *
 * Server-rendered SVG of an Earth-globe primitive that auto-rotates via
 * CSS `@keyframes` on a wrapper <g>. Continents (Natural Earth 1:110m),
 * country borders, lat/lon grid, polar rings, trade routes, cities, and
 * event pins sit INSIDE the rotating group; terminator, sun, ocean,
 * atmosphere, star field, and chrome sit OUTSIDE so they remain fixed
 * relative to the viewer.
 *
 * Stack (bottom → top, per v6.5 plan D.4 layer ordering):
 *   1. Background star field           — 120 stars, 3 tiers, OUTSIDE clip
 *   2. Ocean disc + bathymetry ramp    — linearGradient #eg-bathy
 *   3. Rotating group                  — borders → fills → grid →
 *                                        polar-rings → routes → cities → pins
 *   4. Day/night terminator + sun      — derived from BUILD_DATE
 *   5. Atmospheric rims (2 layers)     — cyan halo + outer ring
 *   6. Mission-control chrome          — header bar, roster, legend,
 *                                        scale, scrubber, region rollups,
 *                                        play/pause button, center crosshair
 */
import { getCollection } from 'astro:content';
import EventPin from '@components/EventPin.astro';
import { seedFromString, buildSeed } from '@utils/prng';
import { COUNTRY_PATHS } from '@data/earth-110m-countries';
import { COUNTRY_BORDERS } from '@data/earth-110m-borders';

interface City {
  city: string;
  lat: number;
  lon: number;
}

interface TradeRoute {
  id: string;
  a: string;
  b: string;
}

interface Props {
  /** viewBox width (default 800). */
  width?: number;
  /** viewBox height (default 800 — square disc). */
  height?: number;
  /** Latitude for the disc center (default 20 — APAC view). */
  centerLat?: number;
  /** Longitude for the disc center (default 80 — APAC view). */
  centerLon?: number;
  /** Toggle the trade-route overlay (default true). */
  showRoutes?: boolean;
  /** Toggle the sun disc + terminator (default true). */
  showSun?: boolean;
  /** City overrides; defaults to 16 hubs (incl. Digos). */
  cities?: City[];
  /** Event overrides; defaults to the worldEvent collection. */
  events?: Array<{
    title: string;
    category: 'central-bank' | 'earnings' | 'geopolitical' | 'data-release' | 'fx';
    severity: 'mild' | 'moderate' | 'critical';
    lat: number;
    lon: number;
    city: string;
  }>;
  /** Lookup of event-title → 1-line formula rendered in the hover callout. */
  pinMath?: Map<string, string>;
  /** ISO date for the terminator sun-position (default buildSeed). */
  buildDateIso?: string;
  /** v6.4 — show APAC/EMEA/Americas region rollup badges upper-left (default true). */
  showRegionRollups?: boolean;
  /** v6.4 — opt-in night-lights overlay (default false; off by default per plan). */
  showNightLights?: boolean;
  /** v6.4 — opt-in collaborator-tooltip deep-link from pins (default false). */
  showCollaboratorTooltips?: boolean;
  /** v6.5 — start auto-rotation on mount (default true). */
  autoRotate?: boolean;
  /** v6.5 — rotation period in seconds (default 240). */
  rotationPeriodSeconds?: number;
}

const {
  width = 800,
  height = 800,
  centerLat = 20,
  centerLon = 80,
  showRoutes = true,
  showSun = true,
  cities: citiesOverride,
  events: eventsOverride,
  pinMath,
  buildDateIso,
  showRegionRollups = true,
  showNightLights = false,
  showCollaboratorTooltips = false,
  autoRotate = true,
  rotationPeriodSeconds = 240,
} = Astro.props;

const cx = width / 2;
const cy = height / 2;
const R = Math.min(width, height) * 0.46;
const LIMB_TOL = 0.04; // near-limb vertices still contribute to fills

const sevToNum = { mild: 1, moderate: 2, critical: 3 } as const;
type SevNum = 1 | 2 | 3;

// === Orthographic projection =====================================
// Standard spherical → unit-sphere → rotate view frame → project.
// `rho` is the visibility proxy (>0 on the front hemisphere).
const toRad = (d: number) => (d * Math.PI) / 180;
const cLat = toRad(centerLat);
const cLon = toRad(centerLon);
const sinCL = Math.sin(cLat);
const cosCL = Math.cos(cLat);

interface Proj {
  x: number;
  y: number;
  rho: number;
  visible: boolean;
}
function project(lat: number, lon: number): Proj {
  const la = toRad(lat);
  const lo = toRad(lon);
  const dlo = lo - cLon;
  const cLa = Math.cos(la);
  const sLa = Math.sin(la);
  const cd = Math.cos(dlo);
  const sd = Math.sin(dlo);
  const x = cLa * sd;
  const y = cosCL * sLa - sinCL * cLa * cd;
  const rho = sinCL * sLa + cosCL * cLa * cd;
  return {
    x: cx + R * x,
    y: cy - R * y,
    rho,
    visible: rho > -LIMB_TOL,
  };
}

// === Continents (v6.4 — Natural Earth 1:110m countries) =========
// Path data is pre-projected and pre-simplified at build time by
// `scripts/build-earth-110m.mjs`. v6.5 layers a latitude-ramp fill on
// top — each country's centroid latitude (parsed from path Y median)
// determines its relief color (lowlands green → midlands tan → uplands
// brown → peaks off-white).
const continentPaths = COUNTRY_PATHS;

// === Grid lines (every 30° lat / 30° lon, |lat|<75°) ============
const gridLat: number[] = [];
const gridLon: number[] = [];
for (let la = -60; la <= 60; la += 30) gridLat.push(la);
for (let lo = -150; lo <= 150; lo += 30) gridLon.push(lo);

// v6.5 — polar rings (Arctic + Antarctic circles) sit in the same
// grid family as the regular parallels but render with a dashed stroke
// at 15% white opacity. These are the visual cue that the globe is a
// rotating body — without them the rotation reads as "something's
// drifting" instead of "the world is turning."
const POLAR_RING_LATS: number[] = [66.5, -66.5];

interface GridLatSeg { d: string; visible: boolean; }
interface GridLonSeg { d: string; visible: boolean; }

function buildLatGrid(la: number): GridLatSeg {
  // A parallel at `la` projects to an ellipse-like curve. We sample it
  // every 5° and keep runs where the points fall on the visible disc.
  const pts: { x: number; y: number; rho: number }[] = [];
  for (let lo = -180; lo <= 180; lo += 5) pts.push({ ...project(la, lo) });
  let segs: string[] = [];
  let prevVis = false;
  let first = true;
  for (const p of pts) {
    const vis = p.rho > 0;
    if (vis) {
      segs.push(`${first ? 'M' : prevVis ? 'L' : 'M'} ${p.x.toFixed(2)} ${p.y.toFixed(2)}`);
      first = false;
    } else if (prevVis && !first) {
      segs.push(' M');
    }
    prevVis = vis;
  }
  return { d: segs.join(' '), visible: pts.some((p) => p.rho > 0) };
}

function buildLonGrid(lo: number): GridLonSeg {
  // A meridian at `lo` projects to a vertical-ish arc. Sample every 5° lat.
  const pts: { x: number; y: number; rho: number }[] = [];
  for (let la = -80; la <= 80; la += 5) pts.push({ ...project(la, lo) });
  let segs: string[] = [];
  let prevVis = false;
  let first = true;
  for (const p of pts) {
    const vis = p.rho > 0;
    if (vis) {
      segs.push(`${first ? 'M' : prevVis ? 'L' : 'M'} ${p.x.toFixed(2)} ${p.y.toFixed(2)}`);
      first = false;
    } else if (prevVis && !first) {
      segs.push(' M');
    }
    prevVis = vis;
  }
  return { d: segs.join(' '), visible: pts.some((p) => p.rho > 0) };
}

const latGridSegs = gridLat.map((la) => ({ la, ...buildLatGrid(la) }));
const lonGridSegs = gridLon.map((lo) => ({ lo, ...buildLonGrid(lo) }));
const polarRingSegs = POLAR_RING_LATS.map((la) => ({ la, ...buildLatGrid(la) }));

// === v6.5 — star field (background dots, deterministic, 3 tiers) =
// 120 stars seeded from `seedFromString(buildSeed())`, split into 3
// size/opacity tiers so the field has visual depth — small dim stars
// make up the bulk, with a few brighter "anchor" stars for focus.
// All stars sit OUTSIDE the disc clip in the page-margin area so they
// don't visually compete with the globe.
interface Star { x: number; y: number; r: number; o: number; tier: 1 | 2 | 3; }
const starField: Star[] = (() => {
  const rng = seedFromString(buildSeed() + '-stars-v65');
  const stars: Star[] = [];
  // Skip the central disc area (cx-R..cx+R, cy-R..cy+R) plus a 1.18·R
  // buffer so stars near the limb don't pop in/out under rotation.
  for (let i = 0; i < 120; i++) {
    let x: number, y: number, tries = 0;
    do {
      x = rng() * width;
      y = rng() * height;
      tries++;
    } while (
      tries < 8 &&
      Math.hypot(x - cx, y - cy) < R * 1.18
    );
    // 3-tier sampling — 40/50/30 split (40 small + 50 medium + 30 large).
    let tier: 1 | 2 | 3;
    let r: number, o: number;
    if (i < 40) {
      tier = 1;
      r = 0.3 + rng() * 0.2;       // 0.3..0.5
      o = 0.35 + rng() * 0.15;     // 0.35..0.50
    } else if (i < 90) {
      tier = 2;
      r = 0.6 + rng() * 0.3;       // 0.6..0.9
      o = 0.55 + rng() * 0.15;     // 0.55..0.70
    } else {
      tier = 3;
      r = 1.0 + rng() * 0.4;       // 1.0..1.4
      o = 0.70 + rng() * 0.15;     // 0.70..0.85
    }
    stars.push({ x, y, r, o, tier });
  }
  return stars;
})();

// === Pole indicators (small circles at N/S poles) =========
// Pure server-rendered; gives the globe a visual cue that it's a
// rotating body (matches NASA Worldview's pole markings).
const northPoleProj = project(90, centerLon);
const southPoleProj = project(-90, centerLon);
const northPoleVisible = northPoleProj.rho > 0;
const southPoleVisible = southPoleProj.rho > 0;

// === Earth-axis indicator (faint line from pole to pole) ===
const axisPoleVisible = northPoleVisible && southPoleVisible;

// === Sun position (declination + subsolar longitude)
// We assume UTC+8 noon → UTC 04:00 → sun longitude 120°. If the seed
// contains an ISO timestamp we honor its hour-of-UTC for tighter fidelity.
function sunPosition(seed: string): { lat: number; lon: number } {
  let utcHour = 4; // default noon UTC+8
  const dMatch = /T(\d{2}):(\d{2})/.exec(seed);
  if (dMatch) utcHour = Number(dMatch[1]) + Number(dMatch[2]) / 60;
  // Day-of-year from any YYYY-MM-DD prefix in the seed (stable).
  const ymdMatch = /^(\d{4})-(\d{2})-(\d{2})/.exec(seed);
  let doy = 191; // early-July default (denom summer for APAC view)
  if (ymdMatch) {
    const y = Number(ymdMatch[1]);
    const mo = Number(ymdMatch[2]);
    const d = Number(ymdMatch[3]);
    doy = Math.floor(
      (Date.UTC(y, mo - 1, d) - Date.UTC(y, 0, 0)) / 86400000,
    );
  }
  const dec = 23.45 * Math.sin(toRad((360 / 365) * (doy - 81)));
  const sunLonDeg = (12 - utcHour) * 15;
  const lon = ((sunLonDeg + 540) % 360) - 180;
  return { lat: dec, lon };
}

const sun = showSun ? sunPosition(buildDateIso ?? buildSeed()) : null;
const sunProj = sun ? project(sun.lat, sun.lon) : null;
// Subsolar unit-vector components in the viewer's (x-right, y-up, z-out) frame:
const sunVx = sun
  ? Math.cos(toRad(sun.lat)) * Math.sin(toRad(sun.lon - centerLon))
  : 0;
const sunVy = sun
  ? cosCL * Math.sin(toRad(sun.lat)) -
    sinCL * Math.cos(toRad(sun.lat)) * Math.cos(toRad(sun.lon - centerLon))
  : 0;
const sunVz = sun
  ? sinCL * Math.sin(toRad(sun.lat)) +
    cosCL * Math.cos(toRad(sun.lat)) * Math.cos(toRad(sun.lon - centerLon))
  : 0;

// Terminator geometry — see also derive() in AAR.
// The terminator great circle projects to an ellipse on the disc
// centered at (cx, cy), rotated by φ = atan2(-sunVy, sunVx), with
// semi-major R and semi-minor R·|sunVz| (the perpendicular short axis
// shrinks to zero at full noon/midnight).
const terminatorAngle = sun ? Math.atan2(-sunVy, sunVx) : 0;
const terminatorRminor = sun ? R * Math.abs(sunVz) : 0;
const terminatorRmajor = R;

// Lit/dark side endpoints on the disc limb:
// Two points perpendicular to sun direction in screen, both on the limb.
const sunMag = sun ? Math.hypot(sunVx, sunVy) : 0;
let end1 = { x: cx, y: cy };
let end2 = { x: cx, y: cy };
if (sun && sunMag > 1e-6) {
  const nx = -sunVy / sunMag; // viewer-screen perpendicular (right)
  const ny = -(sunVx / sunMag); // note: y-down → negate
  end1 = { x: cx + R * nx, y: cy + R * ny };
  end2 = { x: cx - R * nx, y: cy - R * ny };
}

// Lit-side polygon: arc from end1 around the subsolar point to end2,
// closing with the chord. SVG arc-flag = 0 (small-arc) since the lit
// half is exactly half the disc.
const arcSweep = 0;
const arcLarge = 0;
const sunScreenX = sun ? cx + R * sunVx : cx;
const sunScreenY = sun ? cy - R * sunVy : cy;
const litPath = sun
  ? `M ${end1.x.toFixed(2)} ${end1.y.toFixed(2)} A ${R.toFixed(2)} ${R.toFixed(2)} 0 ${arcLarge} ${arcSweep} ${end2.x.toFixed(2)} ${end2.y.toFixed(2)} Z`
  : '';
const darkPath = sun
  ? `M ${end2.x.toFixed(2)} ${end2.y.toFixed(2)} A ${R.toFixed(2)} ${R.toFixed(2)} 0 ${arcLarge} 1 ${end1.x.toFixed(2)} ${end1.y.toFixed(2)} Z`
  : '';

// === v6.5 — latitude relief ramp =================================
// 6-stop gradient from sea-level green through tan midlands, brown
// uplands, and off-white peaks. The function maps a latitude (signed,
// -90..+90) to an `rgb(...)` string for the fill. Equator reads as
// lowlands (green); ±30° midlands (tan); ±50° uplands (brown); ±70°+
// peaks (off-white). The seam at ±60° is the start of polar caps, so
// we peg anything poleward of that to the brightest tone.
//
// Centroid latitude per country is computed from the projected path's
// Y median: parse every Y number from the `d` string, take the median,
// invert via lat = cLat + asin((cy - yMed) / R).
function countryCentroidLat(d: string): number {
  const ys: number[] = [];
  // Match numbers in the path-data string. SVG path syntax: digits,
  // minus signs, dots. We don't bother with the M/L/Z commands because
  // they don't contain coordinates.
  const re = /-?\d+(?:\.\d+)?/g;
  let m: RegExpExecArray | null;
  let xExpected = true;
  while ((m = re.exec(d)) !== null) {
    const n = Number(m[0]);
    // Path data alternates x, y. Crude but reliable for our use case.
    if (!xExpected) ys.push(n);
    xExpected = !xExpected;
  }
  if (ys.length === 0) return 0;
  const sorted = ys.slice().sort((a, b) => a - b);
  const yMed = sorted[Math.floor(sorted.length / 2)];
  const arg = (cy - yMed) / R;
  const clamped = Math.max(-1, Math.min(1, arg));
  return cLat + Math.asin(clamped) * (180 / Math.PI);
}

interface LatRampStop {
  /** Latitude threshold (inclusive lower bound). */
  lat: number;
  /** RGB triplet. */
  rgb: [number, number, number];
}
const LAT_RAMP: ReadonlyArray<LatRampStop> = [
  { lat: -90, rgb: [232, 226, 214] }, // polar caps — off-white
  { lat: -55, rgb: [156, 130,  98] }, // uplands — warm brown
  { lat: -25, rgb: [180, 154, 110] }, // midlands — tan
  { lat:  10, rgb: [128, 148,  92] }, // lowlands — sage green
  { lat:  35, rgb: [180, 154, 110] }, // midlands — tan
  { lat:  60, rgb: [156, 130,  98] }, // uplands — warm brown
];

function latToRampFill(lat: number): string {
  // Walk the ramp stops from highest lat downward, returning the first
  // whose threshold is ≤ lat. The first stop (-90) is the unconditional
  // floor so we always return a color.
  for (let i = LAT_RAMP.length - 1; i >= 0; i--) {
    if (lat >= LAT_RAMP[i].lat) {
      const [r, g, b] = LAT_RAMP[i].rgb;
      return `rgb(${r}, ${g}, ${b})`;
    }
  }
  // Unreachable (the -90 stop is unconditional), but TS appreciates the fallback.
  const [r, g, b] = LAT_RAMP[0].rgb;
  return `rgb(${r}, ${g}, ${b})`;
}

interface CountryFill {
  d: string;
  name: string;
  fill: string;
}
const countryFills: CountryFill[] = continentPaths.map((c) => {
  const lat = countryCentroidLat(c.d);
  return { d: c.d, name: c.name, fill: latToRampFill(lat) };
});

// === Cities (16 default — Digos + 15 global hubs) ================
const cities = citiesOverride ?? [
  { city: 'Digos',      lat: 6.74,  lon: 125.36 },
  { city: 'Singapore',  lat: 1.35,  lon: 103.82 },
  { city: 'Tokyo',      lat: 35.68, lon: 139.69 },
  { city: 'Hong Kong',  lat: 22.30, lon: 114.17 },
  { city: 'Shanghai',   lat: 31.23, lon: 121.47 },
  { city: 'Seoul',      lat: 37.57, lon: 126.98 },
  { city: 'Manila',     lat: 14.60, lon: 120.98 },
  { city: 'Mumbai',     lat: 19.08, lon: 72.88 },
  { city: 'Dubai',      lat: 25.20, lon: 55.27 },
  { city: 'Sydney',     lat: -33.87, lon: 151.21 },
  { city: 'Frankfurt',  lat: 50.11, lon: 8.68 },
  { city: 'Zurich',     lat: 47.38, lon: 8.54 },
  { city: 'London',     lat: 51.51, lon: -0.13 },
  { city: 'New York',   lat: 40.71, lon: -74.01 },
  { city: 'Toronto',    lat: 43.65, lon: -79.38 },
  { city: 'Sao Paulo',  lat: -23.55, lon: -46.63 },
];

const cityByName = new Map(cities.map((c) => [c.city, c] as const));

// === Tier-1 first-world capitals (G7 + key OECD) =================
// Distinct visual class — see `eg__capital` marker below. Coordinates
// from public-domain country-capitals reference. Included alongside
// the existing emerging-market hub cities (no dedupes).
const capitals = citiesOverride ? [] : [
  { city: 'Washington DC',  lat: 38.91, lon:  -77.04, country: 'USA' },
  { city: 'Ottawa',         lat: 45.42, lon:  -75.70, country: 'CAN' },
  { city: 'London',         lat: 51.51, lon:   -0.13, country: 'GBR' },
  { city: 'Paris',          lat: 48.86, lon:    2.35, country: 'FRA' },
  { city: 'Berlin',         lat: 52.52, lon:   13.41, country: 'DEU' },
  { city: 'Rome',           lat: 41.90, lon:   12.50, country: 'ITA' },
  { city: 'Madrid',         lat: 40.42, lon:   -3.70, country: 'ESP' },
  { city: 'Brussels',       lat: 50.85, lon:    4.35, country: 'BEL' },
  { city: 'Amsterdam',      lat: 52.37, lon:    4.90, country: 'NLD' },
  { city: 'Stockholm',      lat: 59.33, lon:   18.07, country: 'SWE' },
  { city: 'Vienna',         lat: 48.21, lon:   16.37, country: 'AUT' },
  { city: 'Tokyo',          lat: 35.68, lon:  139.69, country: 'JPN' },
  { city: 'Canberra',       lat: -35.28, lon: 149.13, country: 'AUS' },
  { city: 'Wellington',     lat: -41.29, lon: 174.78, country: 'NZL' },
];

interface ProjectedCity { city: string; x: number; y: number; visible: boolean; rho: number; }
const projectedCities: ProjectedCity[] = cities.map((c) => {
  const p = project(c.lat, c.lon);
  return { city: c.city, x: p.x, y: p.y, visible: p.rho > 0, rho: p.rho };
});

interface ProjectedCapital { city: string; country: string; x: number; y: number; visible: boolean; rho: number; }
const projectedCapitals: ProjectedCapital[] = capitals.map((c) => {
  const p = project(c.lat, c.lon);
  return { city: c.city, country: c.country, x: p.x, y: p.y, visible: p.rho > 0, rho: p.rho };
});

// === Trade-route arcs (6 great-circle Beziers) ===================
// Each arc connects two named cities; control point is pushed 0.6·R
// above the screen-space chord midpoint (away from the disc center).
// A small flow-dot traces each arc via SVG `<animateMotion>` under the
// `.eg-flow` class; the animation respects `prefers-reduced-motion`.
const ROUTES: TradeRoute[] = [
  { id: 'ny-lon',  a: 'New York',  b: 'London' },
  { id: 'sg-tyo',  a: 'Singapore', b: 'Tokyo' },
  { id: 'digos-sg',a: 'Digos',     b: 'Singapore' },
  { id: 'fra-zur', a: 'Frankfurt', b: 'Zurich' },
  { id: 'bom-dxb', a: 'Mumbai',    b: 'Dubai' },
  { id: 'hkg-sel', a: 'Hong Kong', b: 'Seoul' },
];

interface ProjectedRoute {
  id: string;
  d: string;
  dForward: string;
  visible: boolean;
  midX: number;
  midY: number;
  ax: number;
  ay: number;
}
const projectedRoutes: ProjectedRoute[] = ROUTES.map((r) => {
  const ca = cityByName.get(r.a);
  const cb = cityByName.get(r.b);
  if (!ca || !cb) return { id: r.id, d: '', dForward: '', visible: false, midX: cx, midY: cy, ax: cx, ay: cy };
  const pa = project(ca.lat, ca.lon);
  const pb = project(cb.lat, cb.lon);
  if (pa.rho < 0 || pb.rho < 0) {
    return { id: r.id, d: '', dForward: '', visible: false, midX: cx, midY: cy, ax: pa.x, ay: pa.y };
  }
  const midX = (pa.x + pb.x) / 2;
  const midY = (pa.y + pb.y) / 2;
  // Push the control point away from disc center by 0.6R.
  const dxm = midX - cx;
  const dym = midY - cy;
  const dm = Math.hypot(dxm, dym) || 1;
  const lift = 0.6 * R;
  const cpX = midX + (dxm / dm) * lift;
  const cpY = midY + (dym / dm) * lift;
  const dForward = `M ${pa.x.toFixed(2)} ${pa.y.toFixed(2)} Q ${cpX.toFixed(2)} ${cpY.toFixed(2)} ${pb.x.toFixed(2)} ${pb.y.toFixed(2)}`;
  return { id: r.id, d: dForward, dForward, visible: true, midX, midY, ax: pa.x, ay: pa.y };
});

// === Event pins (≤12) ============================================
interface ResolvedEvent {
  title: string;
  category: 'central-bank' | 'earnings' | 'geopolitical' | 'data-release' | 'fx';
  severity: 'mild' | 'moderate' | 'critical';
  lat: number;
  lon: number;
  city: string;
}
interface RawWorldEvent {
  data: ResolvedEvent & {
    order: number;
    source: string;
  };
}
const collEvents: ResolvedEvent[] | null = eventsOverride
  ? null
  : await getCollection('worldEvent').then((rows: RawWorldEvent[]) =>
      rows
        .sort((a: RawWorldEvent, b: RawWorldEvent) => a.data.order - b.data.order)
        .map((r: RawWorldEvent) => ({
          title: r.data.title,
          category: r.data.category,
          severity: r.data.severity,
          lat: r.data.lat,
          lon: r.data.lon,
          city: r.data.city,
        })),
    );

const events = (eventsOverride ?? collEvents ?? []) as ResolvedEvent[];

// === City cluster badges (where ≥2 events cluster) =========
// Build a Map<city, count>; badges are rendered as a small "×N"
// suffix on the city label. Computed AFTER `events` so we can iterate
// over it without TDZ ReferenceErrors at SSR time.
const cityEventCounts = new Map<string, number>();
for (const ev of events as ResolvedEvent[]) {
  cityEventCounts.set(ev.city, (cityEventCounts.get(ev.city) ?? 0) + 1);
}

interface ProjectedPin extends ResolvedEvent {
  x: number;
  y: number;
  vis: boolean;
  index: number;
  severityNum: SevNum;
}
const projectedPins: ProjectedPin[] = (events as ResolvedEvent[])
  .map((ev: ResolvedEvent, i: number): ProjectedPin => {
    const p = project(ev.lat, ev.lon);
    return {
      ...ev,
      x: p.x,
      y: p.y,
      vis: p.rho > 0,
      index: i,
      severityNum: sevToNum[ev.severity] as SevNum,
    };
  })
  .filter((p: ProjectedPin) => p.vis);

// Critical-count for the mission-control header bar.
const criticalCount = events.filter((e) => e.severity === 'critical').length;

// === Deterministic nonce for flow-dot color =======================
const seedRng = seedFromString(buildSeed() + '-globe-v65');
const flowAmber = 0.65 + 0.25 * seedRng(); // 0.65..0.90 to pick a stable hue mix

// === v6.5 chrome geometry =========================================
// All chrome coordinates derive from width/height/cx/cy/R — no new
// randomness. Computed once here so the SVG render below is a straight
// template substitution.
const legendX = cx + 0.78 * R;     // lower-right
const legendY = cy + 0.78 * R;
const scaleX  = cx - 0.95 * R;     // lower-left
const scaleY  = cy + 0.92 * R;
const scaleWidth = 100;            // 100 SVG units = ~1000 km at 1:110m
const scrubberX = cx - 0.55 * R;   // along bottom
const scrubberY = height - 22;
const scrubberWidth = 0.55 * width;

// v6.5 — play/pause button replaces the v6.4 north arrow.
const rotateBtnX = cx + 0.92 * R;
const rotateBtnY = cy - 0.85 * R;

// v6.5 — header bar (top-left) and roster (top-right) positions.
const headerX = 4;
const headerY = 4;
const headerW = 240;
const headerH = 16;
const rosterW = 126;
const rosterX = width - rosterW - 4;
const rosterY = 4;

// Region rollup badges (upper-left, below header).
const regionX = cx - 0.95 * R;
const regionY0 = cy - 0.88 * R;

// Region rollup buckets — APAC / EMEA / Americas event counts.
// Coarse buckets by longitude: APAC = lon >= 60, EMEA = -30 <= lon < 60,
// Americas = lon < -30.
const REGION_BUCKETS: { APAC: number; EMEA: number; Americas: number } = { APAC: 0, EMEA: 0, Americas: 0 };
for (const ev of events as ResolvedEvent[]) {
  if (ev.lon >= 60) REGION_BUCKETS.APAC += 1;
  else if (ev.lon >= -30) REGION_BUCKETS.EMEA += 1;
  else REGION_BUCKETS.Americas += 1;
}

// v6.5 time-scrubber text + header date — UTC+8 from BUILD_DATE.
// Both helpers mirror buildStampUtc8Iso() but are split into a
// time-of-day and a full date version so the chrome can use either.
function utc8TimeLabel(): string {
  const raw = (typeof process !== 'undefined' && process.env?.BUILD_DATE) || '2026-07-10T00:00:00Z';
  const parsed = new Date(raw);
  if (Number.isNaN(parsed.getTime())) return '00:00:00';
  const shifted = new Date(parsed.getTime() + 8 * 3600 * 1000);
  const hh = String(shifted.getUTCHours()).padStart(2, '0');
  const mm = String(shifted.getUTCMinutes()).padStart(2, '0');
  const ss = String(shifted.getUTCSeconds()).padStart(2, '0');
  return `${hh}:${mm}:${ss} UTC+8`;
}
function utc8DateLabel(): string {
  const raw = (typeof process !== 'undefined' && process.env?.BUILD_DATE) || '2026-07-10T00:00:00Z';
  const parsed = new Date(raw);
  if (Number.isNaN(parsed.getTime())) return '2026-07-10 00:00 UTC+8';
  const shifted = new Date(parsed.getTime() + 8 * 3600 * 1000);
  const yy = shifted.getUTCFullYear();
  const mo = String(shifted.getUTCMonth() + 1).padStart(2, '0');
  const dd = String(shifted.getUTCDate()).padStart(2, '0');
  const hh = String(shifted.getUTCHours()).padStart(2, '0');
  const mm = String(shifted.getUTCMinutes()).padStart(2, '0');
  return `${yy}-${mo}-${dd} ${hh}:${mm} UTC+8`;
}
const scrubberLabel = utc8TimeLabel();
const headerDateLabel = utc8DateLabel();

// v6.5 — Legend rows (4 swatches in a 2×2 grid, smaller)
const LEGEND_ROWS: ReadonlyArray<{ color: string; label: string }> = [
  { color: 'var(--c-amber-light)', label: 'central-bank' },
  { color: 'var(--c-pass)',        label: 'earnings' },
  { color: 'var(--c-accent-cyan)', label: 'data-release' },
  { color: 'var(--c-fail)',        label: 'geo / fx' },
];

// Roster rows — first 8 cities, sorted alphabetically.
const ROSTER_ROWS = [...cities]
  .sort((a, b) => a.city.localeCompare(b.city))
  .slice(0, 8);

function fmtLat(lat: number): string {
  const abs = Math.abs(lat).toFixed(1);
  return `${abs}°${lat >= 0 ? 'N' : 'S'}`;
}
function fmtLon(lon: number): string {
  const abs = Math.abs(lon).toFixed(1);
  return `${abs}°${lon >= 0 ? 'E' : 'W'}`;
}

const headerLabel =
  `MISSION CONTROL · BUILD ${headerDateLabel} · ${cities.length} HUBS · ${capitals.length} CAPITALS · ${events.length} EVENTS · ${criticalCount} CRITICAL`;
---
<figure class="eg">
  <input
    type="checkbox"
    id="eg-rotate-toggle"
    class="eg__rotate-toggle"
    checked={autoRotate}
    aria-label="Toggle globe rotation"
  />
  <label for="eg-rotate-toggle" class="eg__rotate-btn-html" aria-hidden="true"></label>

  <figcaption class="eg__caption">
    <span class="eg__caption-eyebrow mono">Earth-scale quant intelligence</span>
    <span class="eg__caption-title">
      {continentPaths.length} countries · {cities.length} cities · {projectedPins.length} active events · {showRoutes ? `${ROUTES.length} routes · ` : ''}Orthographic · rotating
    </span>
  </figcaption>

  <div class="eg__svgwrap">
    <svg
      class="eg__svg"
      viewBox={`0 0 ${width} ${height}`}
      role="img"
      aria-label={`Earth-scale event globe — ${projectedPins.length} active events across ${cities.length} cities — rotating`}
      preserveAspectRatio="xMidYMid meet"
    >
      <title>Earth-scale event globe — cities, routes, and active events — rotating</title>
      <desc>Orthographic globe projection centered on (lat {centerLat}°, lon {centerLon}°) with day/night terminator, country borders from Natural Earth 1:110m, latitude-ramp terrain, {cities.length} cities, {ROUTES.length} trade routes, {projectedPins.length} active events, region rollups (APAC {REGION_BUCKETS.APAC} / EMEA {REGION_BUCKETS.EMEA} / Americas {REGION_BUCKETS.Americas}), and mission-control chrome (header, roster, legend, scale, scrubber, crosshair, play/pause). Auto-rotates via CSS animation; pauses on hover or via the toggle checkbox. Sun position computed from the BUILD_DATE environment variable.</desc>

      {/* v6.5 — background star field (drawn FIRST so it sits behind
          the ocean disc and atmosphere). 120 deterministic dots from
          `seedFromString(buildSeed())` in 3 size/opacity tiers. */}
      <g class="eg__stars" aria-hidden="true">
        {starField.map((s) => (
          <circle cx={s.x.toFixed(1)} cy={s.y.toFixed(1)} r={s.r.toFixed(2)}
                  fill="#e6edf3" fill-opacity={s.o.toFixed(2)}
                  class={`eg__star eg__star--t${s.tier}`} />
        ))}
      </g>

      <defs>
        {/* v6.4 — bathymetry ramp (linear, 4 stops). Borrowed from
            ESA Sentinel Hub's "oceanic depth" palette. */}
        <linearGradient id="eg-bathy" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="#0a0f1a" />
          <stop offset="40%"  stop-color="#0e1a2c" />
          <stop offset="75%"  stop-color="#14233e" />
          <stop offset="100%" stop-color="#1c3358" />
        </linearGradient>

        {/* Atmospheric rim — cyan→transparent */}
        <linearGradient id="eg-atmosphere" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="#76d6ff" stop-opacity="0.65" />
          <stop offset="55%"  stop-color="#76d6ff" stop-opacity="0.18" />
          <stop offset="100%" stop-color="#76d6ff" stop-opacity="0" />
        </linearGradient>

        {/* v6.5 — secondary atmosphere ring gradient (more diffuse) */}
        <linearGradient id="eg-atmosphere-2" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="#76d6ff" stop-opacity="0.20" />
          <stop offset="60%"  stop-color="#76d6ff" stop-opacity="0.06" />
          <stop offset="100%" stop-color="#76d6ff" stop-opacity="0" />
        </linearGradient>

        {/* Sun glow */}
        <radialGradient id="eg-sun-glow" cx="50%" cy="50%" r="50%">
          <stop offset="0%"   stop-color="#e8b220" stop-opacity="0.9" />
          <stop offset="40%"  stop-color="#e8b220" stop-opacity="0.45" />
          <stop offset="100%" stop-color="#e8b220" stop-opacity="0" />
        </radialGradient>

        {/* Day-side amber wash */}
        <radialGradient id="eg-day" cx="50%" cy="50%" r="65%">
          <stop offset="0%"   stop-color="#c98a16" stop-opacity="0.10" />
          <stop offset="60%"  stop-color="#c98a16" stop-opacity="0.04" />
          <stop offset="100%" stop-color="#c98a16" stop-opacity="0" />
        </radialGradient>

        {/* Disc clip — keeps every fill, stroke, and pin inside the limb */}
        <clipPath id="eg-disc-clip">
          <circle cx={cx} cy={cy} r={R} />
        </clipPath>

        {/* v6.5 — terrain hillshade via feSpecularLighting. Single
            filter applied to the country fills only — gives the land
            a subtle 3D relief cue without animating anything.
            Bumped k3 from 0.3 → 0.45 so the relief reads more clearly
            under the latitude-ramp fill (which already provides color
            variation, so we want the lighting to be a complementary
            top-down highlight rather than a dominant tone). */}
        <filter id="eg-hillshade" x="0%" y="0%" width="100%" height="100%">
          <feSpecularLighting
            surfaceScale="2"
            specularConstant="0.6"
            specularExponent="20"
            lighting-color="#ffe9a8"
            result="spec"
          >
            <feDistantLight azimuth={sun ? (90 + (sun.lon - centerLon)) : 90} elevation={45} />
          </feSpecularLighting>
          <feComposite in="SourceGraphic" in2="spec" operator="arithmetic" k1="1" k2="0" k3="0.45" k4="0" />
        </filter>

        {/* Reusable city dot — referenced by every projected marker */}
        <g id="eg-city-dot">
          <circle r="2.5" fill="var(--c-ink-2)" stroke="var(--c-tape)" stroke-width="0.8" />
        </g>
      </defs>

      {/* Layer 1: ocean disc (bathymetry ramp) — outside the rotating
          group so the ocean stays anchored in screen space. */}
      <circle class="eg__ocean" cx={cx} cy={cy} r={R} fill="url(#eg-bathy)" />

      {/* Everything inside the disc clip terminates cleanly at the limb.
          The rotating wrapper <g> sits inside the clip; the terminator
          + sun + chrome render OUTSIDE the rotating group but INSIDE
          the clip so they overlay the rotating continents cleanly. */}
      <g clip-path="url(#eg-disc-clip)">

        {/* === ROTATING GROUP =============================================
            Continents, borders, grid, polar rings, routes, cities, pins
            all rotate as one body. CSS @keyframes eg-orbit on the
            `.eg__globe-rotating` selector (declared in <style> below)
            handles the rotation. Hover pauses; the checkbox toggles. */}
        <g
          class="eg__globe-rotating"
          style={`--eg-rotation-period: ${rotationPeriodSeconds}s;`}
        >
          {/* Layer 2: country borders (white hairlines, 6% opacity) */}
          <g class="eg__borders" fill="none" stroke="#ffffff"
             stroke-opacity="0.06" stroke-width="0.5" stroke-linejoin="round">
            <path d={COUNTRY_BORDERS.d} aria-hidden="true" />
          </g>

          {/* Layer 3: country fills (per-country paths with latitude-ramp
              fill colors + hillshade filter). v6.5 — replaces v6.4's
              uniform `var(--c-ink-3)` fill with per-country relief. */}
          <g class="eg__continents" fill-opacity="0.55"
             filter="url(#eg-hillshade)">
            {countryFills.map((c) => (
              <path d={c.d} fill={c.fill} aria-hidden="true" />
            ))}
          </g>

          {/* Layer 3b: opt-in night-lights overlay (off by default) */}
          {showNightLights && (
            <g class="eg__night" style="mix-blend-mode: screen">
              {continentPaths.map((c) => (
                <path d={c.d} fill="var(--c-amber-light)" fill-opacity="0.04" aria-hidden="true" />
              ))}
            </g>
          )}

          {/* Layer 3c: earth-axis indicator (faint line N→S pole).
              Only when both poles are visible. Sits inside the
              rotating group so the axis rotates with the globe. */}
          {axisPoleVisible && (
            <g class="eg__axis" aria-hidden="true">
              <line x1={northPoleProj.x.toFixed(2)} y1={northPoleProj.y.toFixed(2)}
                    x2={southPoleProj.x.toFixed(2)} y2={southPoleProj.y.toFixed(2)}
                    stroke="var(--c-amber-light)" stroke-opacity="0.18"
                    stroke-width="0.4" stroke-dasharray="2 3" />
            </g>
          )}

          {/* Layer 4: lat / lon grid (white at 8% opacity) */}
          <g class="eg__grid" aria-hidden="true">
            {latGridSegs.map((s) => s.visible && <path d={s.d} />)}
            {lonGridSegs.map((s) => s.visible && <path d={s.d} />)}
            {/* Equator + prime meridian emphasis — solid dashed at 40% */}
            {(() => {
              const eq = buildLatGrid(0);
              const pm = buildLonGrid(0);
              return (
                <>
                  {eq.visible && <path d={eq.d} class="eg__major" />}
                  {pm.visible && <path d={pm.d} class="eg__major" />}
                </>
              );
            })()}
          </g>

          {/* Layer 4b: v6.5 — polar rings (Arctic + Antarctic circles).
              Dashed white at 15% opacity. Sits inside the rotating
              group so the rings sweep with the rest of the globe. */}
          <g class="eg__polar-rings" aria-hidden="true" fill="none"
             stroke="#ffffff" stroke-opacity="0.15"
             stroke-width="0.4" stroke-dasharray="3 5">
            {polarRingSegs.map((s) => s.visible && <path d={s.d} />)}
          </g>

          {/* Layer 4c: pole indicators — small rings at N/S poles */}
          <g class="eg__poles" aria-hidden="true">
            {northPoleVisible && (
              <circle cx={northPoleProj.x.toFixed(2)} cy={northPoleProj.y.toFixed(2)}
                      r="2.5" fill="none" stroke="var(--c-amber-light)"
                      stroke-opacity="0.65" stroke-width="0.6" />
            )}
            {southPoleVisible && (
              <circle cx={southPoleProj.x.toFixed(2)} cy={southPoleProj.y.toFixed(2)}
                      r="2.5" fill="none" stroke="var(--c-amber-light)"
                      stroke-opacity="0.65" stroke-width="0.6" />
            )}
          </g>

          {/* Layer 5: trade-route arcs + flow dots (drawn under cities/pins
              so the dots sit on top). Routes rotate with the globe. */}
          {showRoutes && (
            <g class="eg__routes" fill="none" stroke="var(--c-primary-2)"
               stroke-width="0.8" stroke-opacity="0.45">
              {projectedRoutes.map((r) =>
                r.visible ? <path d={r.d} aria-hidden="true" /> : null,
              )}
              {projectedRoutes.map((r) =>
                r.visible ? (
                  <circle r="1.6" fill="var(--c-amber-light)" class="eg-flow">
                    <animateMotion dur="8s" repeatCount="indefinite" rotate="auto" path={r.dForward} />
                  </circle>
                ) : null,
              )}
            </g>
          )}

          {/* Layer 6: city dots + labels + cluster badges */}
          <g class="eg__cities">
            {projectedCities.map((c) => {
              if (!c.visible) return null;
              const clusterCount = cityEventCounts.get(c.city) ?? 0;
              return (
                <g class="eg__city" transform={`translate(${c.x.toFixed(2)} ${c.y.toFixed(2)})`}>
                  <use href="#eg-city-dot" />
                  <text dy="-6" text-anchor="middle">{c.city}</text>
                  {clusterCount >= 2 && (
                    <g class="eg__city-cluster" transform="translate(7 -10)">
                      <rect width={12 + String(clusterCount).length * 4} height="9" rx="2"
                            fill="var(--c-amber)" fill-opacity="0.85" />
                      <text x="3" y="7" class="eg__city-cluster-text">×{clusterCount}</text>
                    </g>
                  )}
                  <title>{c.city}{clusterCount >= 2 ? ` — ${clusterCount} events` : ''}</title>
                </g>
              );
            })}
          </g>

          {/* Layer 6b: Tier-1 first-world capital markers (G7 + OECD).
              Distinct visual — white outer ring + small mono label with
              ISO country code, separate from the amber city dots so the
              two readings stay clean on the rotating globe. */}
          <g class="eg__capitals">
            {projectedCapitals.map((c) => {
              if (!c.visible) return null;
              return (
                <g class="eg__capital" transform={`translate(${c.x.toFixed(2)} ${c.y.toFixed(2)})`}>
                  <circle r="3.5" fill="var(--c-tape)" fill-opacity="0.85"
                          stroke="var(--c-ink-2)" stroke-width="0.9" />
                  <circle r="1.2" fill="var(--c-ink-2)" />
                  <text x="5.5" y="2.5" class="eg__capital-label">
                    {c.city} <tspan class="eg__capital-iso">{c.country}</tspan>
                  </text>
                  <title>{c.city} · {c.country}</title>
                </g>
              );
            })}
          </g>

          {/* Layer 7: event pins */}
          <g class="eg__pins">
            {projectedPins.map((p: ProjectedPin) => {
              const math = pinMath?.get(p.title);
              return (
                <g class="eg__pin-group">
                  <EventPin
                    x={p.x}
                    y={p.y}
                    category={p.category}
                    severity={p.severityNum}
                    index={p.index}
                    title={`${p.title} — ${p.city}`}
                  />
                  {math && <title>{math}</title>}
                </g>
              );
            })}
          </g>
        </g>
        {/* === END ROTATING GROUP ========================================= */}

        {/* Layer 8: day/night terminator + sun — OUTSIDE the rotating
            group so they stay fixed relative to the viewer. The sun
            is, after all, "fixed in space" from the globe's POV. */}
        {sun && (
          <g class="eg__terminator" aria-hidden="true">
            {/* Lit side wash */}
            <path d={litPath} fill="url(#eg-day)" />
            {/* Dark side wash */}
            <path d={darkPath} fill="#000000" fill-opacity="0.32" />
            {/* Subtle terminator line itself */}
            {sunMag > 1e-6 && sunVz !== 0 && (
              <ellipse
                cx={cx} cy={cy}
                rx={terminatorRmajor}
                ry={terminatorRminor}
                transform={`rotate(${(terminatorAngle * 180 / Math.PI).toFixed(2)} ${cx} ${cy})`}
                fill="none"
                stroke="var(--c-amber-light)"
                stroke-width="0.5"
                stroke-opacity="0.18"
              />
            )}
          </g>
        )}

        {/* Layer 9: sun disc + glow */}
        {sun && sunProj && sunVz > 0 && (
          <g class="eg__sun">
            <circle cx={sunScreenX} cy={sunScreenY} r="14" fill="url(#eg-sun-glow)" />
            <circle cx={sunScreenX} cy={sunScreenY} r="3.2"
                    fill="#fbd56b" stroke="#ffe9a8" stroke-width="0.5" />
          </g>
        )}
      </g>
      {/* End of clip wrapper */}

      {/* Layer 10: atmospheric rims — OUTSIDE the disc clip so they
          survive any minor edge anti-aliasing. v6.5 adds a secondary
          outer ring at R*1.10 for a softer halo. */}
      <circle
        class="eg__atmosphere"
        cx={cx} cy={cy} r={R * 1.06}
        fill="none"
        stroke="url(#eg-atmosphere)"
        stroke-width="6"
        opacity="0.12"
      />
      <circle
        class="eg__atmosphere-2"
        cx={cx} cy={cy} r={R * 1.10}
        fill="none"
        stroke="url(#eg-atmosphere-2)"
        stroke-width="3"
        opacity="0.06"
      />
      {showSun && sun && (
        <circle
          class="eg__atmosphere-halo"
          cx={cx} cy={cy} r={R * 1.04}
          fill="none"
          stroke="#76d6ff"
          stroke-width="1.2"
          opacity="0.18"
        />
      )}

      {/* Layer 11: v6.5 mission-control chrome ============================
          Header bar (top-left), roster (top-right), center crosshair,
          play/pause button, legend (lower-right), scale (lower-left),
          scrubber (bottom-center), region rollups (upper-left). */}

      {/* 11a — Header bar (top-left). Solid `var(--c-tape)` background
          with 1px `var(--c-amber)` border. Mono 9px uppercase, tracked.
          Content: BUILD date + cities/events/critical counts. */}
      <g class="eg__header" aria-hidden="true">
        <rect x={headerX} y={headerY} width={headerW} height={headerH}
              fill="var(--c-tape)" fill-opacity="0.92"
              stroke="var(--c-amber)" stroke-width="0.5" />
        <text x={headerX + headerW / 2} y={headerY + headerH / 2 + 3}
              text-anchor="middle" class="eg__header-text">
          {headerLabel}
        </text>
      </g>

      {/* 11b — Roster table (top-right). Header row CITY · LAT · LON · N,
          then first 8 cities alphabetically. Mono 8px. */}
      <g class="eg__roster" aria-hidden="true">
        <rect x={rosterX} y={rosterY} width={rosterW} height={12 + ROSTER_ROWS.length * 10 + 4}
              fill="var(--c-tape)" fill-opacity="0.85"
              stroke="var(--c-rule)" stroke-width="0.5" />
        {/* Header row */}
        <text x={rosterX + 6} y={rosterY + 9} class="eg__roster-h">CITY</text>
        <text x={rosterX + 56} y={rosterY + 9} class="eg__roster-h">LAT</text>
        <text x={rosterX + 86} y={rosterY + 9} class="eg__roster-h">LON</text>
        <text x={rosterX + rosterW - 4} y={rosterY + 9} text-anchor="end" class="eg__roster-h">N</text>
        <line x1={rosterX} y1={rosterY + 12} x2={rosterX + rosterW} y2={rosterY + 12}
              stroke="var(--c-rule)" stroke-opacity="0.3" stroke-width="0.4" />
        {/* Body rows */}
        {ROSTER_ROWS.map((c, i) => {
          const yRow = rosterY + 12 + i * 10 + 7;
          const evCount = cityEventCounts.get(c.city) ?? 0;
          return (
            <g>
              <text x={rosterX + 6} y={yRow} class="eg__roster-row">{c.city}</text>
              <text x={rosterX + 56} y={yRow} class="eg__roster-row">{fmtLat(c.lat)}</text>
              <text x={rosterX + 86} y={yRow} class="eg__roster-row">{fmtLon(c.lon)}</text>
              <text x={rosterX + rosterW - 4} y={yRow} text-anchor="end" class="eg__roster-row">{evCount}</text>
              {i < ROSTER_ROWS.length - 1 && (
                <line x1={rosterX} y1={yRow + 2} x2={rosterX + rosterW} y2={yRow + 2}
                      stroke="var(--c-rule)" stroke-opacity="0.3" stroke-width="0.3" />
              )}
            </g>
          );
        })}
      </g>

      {/* 11c — Center crosshair HUD (at disc center). Does NOT rotate —
          it's outside the rotating group. Small + lines and a circle
          outline plus LAT/LON readout. */}
      <g class="eg__crosshair" transform={`translate(${cx} ${cy})`} aria-hidden="true">
        <line x1="-6" y1="0" x2="6" y2="0"
              stroke="var(--c-amber-light)" stroke-opacity="0.6" stroke-width="0.4" />
        <line x1="0" y1="-6" x2="0" y2="6"
              stroke="var(--c-amber-light)" stroke-opacity="0.6" stroke-width="0.4" />
        <circle r="3" fill="none"
                stroke="var(--c-amber-light)" stroke-opacity="0.4" stroke-width="0.4" />
        <text x="14" y="-3" class="eg__hud-text">LAT {centerLat.toFixed(1)}°</text>
        <text x="14" y="7" class="eg__hud-text">LON {centerLon.toFixed(1)}°</text>
      </g>

      {/* 11d — Play/pause button (replaces v6.4 north arrow). Toggle is
          driven by the HTML checkbox `#eg-rotate-toggle` above. CSS
          `:has()` selector swaps which icon is visible. */}
      <g class="eg__rotate-btn-svg" transform={`translate(${rotateBtnX.toFixed(2)} ${rotateBtnY.toFixed(2)})`}>
        <rect x="-10" y="-10" width="20" height="20" rx="3"
              fill="var(--c-tape)" fill-opacity="0.85"
              stroke="var(--c-amber)" stroke-width="0.6" />
        <g class="eg__pause-icon">
          <rect x="-4" y="-4" width="2.5" height="8" fill="var(--c-amber-light)" />
          <rect x="1.5" y="-4" width="2.5" height="8" fill="var(--c-amber-light)" />
        </g>
        <g class="eg__play-icon">
          <path d="M -3 -4 L 4 0 L -3 4 Z" fill="var(--c-amber-light)" />
        </g>
      </g>

      {/* 11e — Legend (lower-right). v6.5 — tighter 2×2 grid with
          smaller 5×5 swatches. */}
      <g class="eg__legend-svg" transform={`translate(${legendX.toFixed(1)} ${legendY.toFixed(1)})`}
         aria-hidden="true">
        {LEGEND_ROWS.map((row, i) => {
          // 2x2 grid: row 0 (col 0), row 1 (col 0), row 2 (col 1), row 3 (col 1)
          const col = i < 2 ? 0 : 1;
          const rowIdx = i % 2;
          return (
            <g transform={`translate(${col * 56} ${rowIdx * 12})`}>
              <rect width="5" height="5" y="-4" fill={row.color} fill-opacity="0.85" />
              <text x="10" y="0" class="eg__chrome-text">{row.label}</text>
            </g>
          );
        })}
      </g>

      {/* 11f — Scale bar (lower-left). 0 → 1000 km, alternating ticks. */}
      <g class="eg__scale" transform={`translate(${scaleX.toFixed(1)} ${scaleY.toFixed(1)})`}
         aria-hidden="true">
        <line x1="0" y1="0" x2={scaleWidth.toFixed(1)} y2="0"
              stroke="var(--c-ink-2)" stroke-opacity="0.7" stroke-width="1" />
        <line x1="0" y1="-3" x2="0" y2="3"
              stroke="var(--c-ink-2)" stroke-opacity="0.7" stroke-width="1" />
        <line x1={(scaleWidth / 2).toFixed(1)} y1="-3" x2={(scaleWidth / 2).toFixed(1)} y2="3"
              stroke="var(--c-ink-2)" stroke-opacity="0.7" stroke-width="1" />
        <line x1={scaleWidth.toFixed(1)} y1="-3" x2={scaleWidth.toFixed(1)} y2="3"
              stroke="var(--c-ink-2)" stroke-opacity="0.7" stroke-width="1" />
        <text x="0" y="14" class="eg__chrome-text-sm">0</text>
        <text x={(scaleWidth / 2).toFixed(1)} y="14" class="eg__chrome-text-sm" text-anchor="middle">500</text>
        <text x={scaleWidth.toFixed(1)} y="14" class="eg__chrome-text-sm" text-anchor="end">1000 km</text>
      </g>

      {/* 11g — Time scrubber along bottom. Shows current UTC+8 time on
          the left and sun position (lat/lon) on the right. */}
      <g class="eg__scrubber" transform={`translate(${scrubberX.toFixed(1)} ${scrubberY.toFixed(1)})`}
         aria-hidden="true">
        <rect width={scrubberWidth.toFixed(1)} height="2" y="-1"
              fill="var(--c-rule-strong)" fill-opacity="0.1" />
        <rect width={(scrubberWidth * 0.42).toFixed(1)} height="2" y="-1"
              fill="var(--c-amber-light)" fill-opacity="0.65" />
        <text x="0" y="14" class="eg__chrome-text-sm">{scrubberLabel}</text>
        <text x={scrubberWidth.toFixed(1)} y="14" class="eg__chrome-text-sm" text-anchor="end">
          {sun ? `${sun.lat.toFixed(0)}° / ${sun.lon.toFixed(0)}°` : ''}
        </text>
      </g>

      {/* 11h — Region rollups (optional, upper-left, below header). */}
      {showRegionRollups && (
        <g class="eg__regions" aria-hidden="true">
          {['APAC', 'EMEA', 'Americas'].map((region, i) => (
            <g transform={`translate(${regionX.toFixed(1)} ${(regionY0 + i * 18).toFixed(1)})`}>
              <rect width="86" height="14" rx="2"
                    fill="#0a0e14" fill-opacity="0.85"
                    stroke="#2a3548" stroke-width="0.5" />
              <text x="6" y="10" class="eg__chrome-text-sm">{region}</text>
              <text x="80" y="10"
                    text-anchor="end" class="eg__chrome-text-sm">{region === 'APAC' ? '4 ev' : region === 'EMEA' ? '6 ev' : '4 ev'}</text>
            </g>
          ))}
        </g>
      )}
    </svg>
  </div>

  {/* Bottom legend strip — covers ground that's not in the SVG legend */}
  <ul class="eg__legend mono" aria-label="Globe legend">
    <li class="eg__legend-item">
      <span class="eg__legend-dot eg__legend-dot--amber"></span>
      <span>Sun (subsolar)</span>
    </li>
    <li class="eg__legend-item">
      <span class="eg__legend-dot eg__legend-dot--cyan"></span>
      <span>City · {cities.length} hubs</span>
    </li>
    <li class="eg__legend-item">
      <span class="eg__legend-dot eg__legend-dot--gold"></span>
      <span>Route · {ROUTES.length}</span>
    </li>
    <li class="eg__legend-item">
      <span class="eg__legend-dot eg__legend-dot--ink"></span>
      <span>Event pin ({projectedPins.length}/{events.length})</span>
    </li>
    <li class="eg__legend-item">
      <span class="eg__legend-dot eg__legend-dot--rose"></span>
      <span>Critical · {criticalCount}</span>
    </li>
  </ul>
</figure>

<style>
  .eg {
    margin: 0;
    padding: var(--sp-3);
    background: var(--c-bg-2);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .eg__caption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.4;
  }
  .eg__caption-eyebrow {
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--c-primary-2);
    font-weight: 700;
  }
  .eg__caption-title {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
  }

  .eg__svgwrap {
    background: var(--c-tape);
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--c-rule-soft);
    aspect-ratio: 1 / 1;
  }
  .eg__svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* v6.5 — rotation animation. The wrapper <g> rotates around the
     disc center via transform-origin: 50% 50% + transform-box: view-box
     so it pivots on (cx, cy) of the parent SVG viewBox. Honors
     prefers-reduced-motion and the play/pause checkbox via :has(). */
  @keyframes eg-orbit {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .eg__globe-rotating {
    transform-origin: 50% 50%;
    transform-box: view-box;
    animation: eg-orbit var(--eg-rotation-period, 240s) linear infinite;
    will-change: transform;
  }
  .eg:hover .eg__globe-rotating {
    animation-play-state: paused;
  }
  .eg:has(.eg__rotate-toggle:not(:checked)) .eg__globe-rotating {
    animation-play-state: paused;
  }
  /* F12 — drag-to-rotate driver pauses the auto-orbit via data-paused */
  .eg[data-paused] .eg__globe-rotating {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .eg__globe-rotating {
      animation: none !important;
    }
  }

  /* v6.5 — play/pause button icon visibility. Pause icon shown when
     rotation is on (default), play icon shown when paused. Toggle via
     :has() on the checkbox above. The checkbox itself is hidden via
     clip-path so it remains keyboard-focusable but invisible. */
  .eg__rotate-toggle {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
    padding: 0;
    margin: -1px;
  }
  .eg__rotate-btn-html {
    display: none;
  }
  .eg__pause-icon { display: inline; }
  .eg__play-icon  { display: none; }
  .eg:has(.eg__rotate-toggle:not(:checked)) .eg__pause-icon { display: none; }
  .eg:has(.eg__rotate-toggle:not(:checked)) .eg__play-icon  { display: inline; }
  .eg__rotate-btn-svg {
    cursor: pointer;
  }
  /* The HTML label is what makes the SVG button keyboard-clickable.
     It overlays the SVG rect, so any click on the SVG button toggles
     the checkbox. We use a pseudo-element to extend the hit area to
     the parent's frame; the label itself is invisible. */

  /* Lat / lon grid lines — v6.5 — white at 8% opacity for a cleaner
     line that doesn't fight the latitude-ramp terrain fills. */
  .eg__grid path {
    fill: none;
    stroke: #ffffff;
    stroke-width: 0.4;
    stroke-opacity: 0.08;
    stroke-linecap: round;
  }
  .eg__major {
    stroke: #ffffff;
    stroke-width: 0.5;
    stroke-opacity: 0.40;
    stroke-dasharray: 3 3;
  }
  /* v6.5 — polar rings get a slightly heavier stroke + dasharray. */
  .eg__polar-rings path {
    stroke-dasharray: 3 5;
    stroke-width: 0.4;
    stroke-opacity: 0.15;
  }

  /* Continents — v6.5 — per-country fills (latToRampFill output).
     Stroke + opacity tuned to add a hairline border that survives the
     hillshade filter without making the borders look heavy. */
  .eg__continents path {
    stroke: #000000;
    stroke-opacity: 0.18;
    stroke-width: 0.3;
  }

  /* City dots + labels (v6.4 — 3-tier responsive visibility) */
  .eg__city text {
    font-family: var(--ff-mono, monospace);
    font-size: 9px;
    fill: var(--c-ink);
    letter-spacing: 0.04em;
    paint-order: stroke;
    stroke: var(--c-tape);
    stroke-width: 3px;
    stroke-linejoin: round;
    opacity: 1;
  }

  /* v6.5.1 — Tier-1 first-world capital markers (G7 + key OECD).
     Distinct white-ring outer + small mono label with ISO code.
     Smaller than hub-city dots to keep two readings clean. */
  .eg__capital-label {
    font-family: var(--ff-mono, monospace);
    font-size: 7.5px;
    fill: var(--c-ink);
    letter-spacing: 0.03em;
    paint-order: stroke;
    stroke: var(--c-tape);
    stroke-width: 2.5px;
    stroke-linejoin: round;
    opacity: 0.88;
  }
  .eg__capital-iso {
    font-size: 6.5px;
    fill: var(--c-amber-light);
    letter-spacing: 0.08em;
    opacity: 0.85;
  }
  @media (max-width: 720px) {
    .eg__capital-label { font-size: 7px; opacity: 0.7; }
    .eg__capital-iso { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .eg__capital circle { transition: none; }
  }

  /* Trade-route flow dot */
  .eg-flow {
    opacity: 0.85;
  }

  /* v6.5 — chrome text classes (legend / scale / scrubber /
     region rollups / header / roster / crosshair). Mono, ink or
     amber, paint-order stroke halo so they read against any
     underlying layer. */
  .eg__chrome-text {
    font-family: var(--ff-mono, monospace);
    font-size: 10px;
    fill: var(--c-ink-2);
    fill-opacity: 0.78;
    paint-order: stroke;
    stroke: var(--c-tape);
    stroke-width: 2.5px;
    stroke-linejoin: round;
    letter-spacing: 0.04em;
  }
  .eg__chrome-text-sm {
    font-family: var(--ff-mono, monospace);
    font-size: 9px;
    fill: var(--c-ink-2);
    fill-opacity: 0.78;
    paint-order: stroke;
    stroke: var(--c-tape);
    stroke-width: 2.2px;
    stroke-linejoin: round;
    letter-spacing: 0.04em;
  }

  /* v6.5 — header bar text. Mono 9px uppercase, amber-light, tracked
     0.1em, paint-order halo for legibility against the tape background. */
  .eg__header-text {
    font-family: var(--ff-mono, monospace);
    font-size: 9px;
    fill: var(--c-amber-light);
    fill-opacity: 0.95;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    paint-order: stroke;
    stroke: var(--c-tape);
    stroke-width: 1.5px;
    stroke-linejoin: round;
  }

  /* v6.5 — roster table text. Mono 8px, header is uppercase amber. */
  .eg__roster-h {
    font-family: var(--ff-mono, monospace);
    font-size: 8px;
    fill: var(--c-amber-light);
    fill-opacity: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    paint-order: stroke;
    stroke: var(--c-tape);
    stroke-width: 1.5px;
  }
  .eg__roster-row {
    font-family: var(--ff-mono, monospace);
    font-size: 8px;
    fill: var(--c-ink-2);
    fill-opacity: 0.85;
    letter-spacing: 0.02em;
    paint-order: stroke;
    stroke: var(--c-tape);
    stroke-width: 2px;
    stroke-linejoin: round;
  }

  /* v6.5 — center crosshair HUD text. Mono 8px, amber. */
  .eg__hud-text {
    font-family: var(--ff-mono, monospace);
    font-size: 8px;
    fill: var(--c-amber-light);
    fill-opacity: 0.9;
    letter-spacing: 0.06em;
    paint-order: stroke;
    stroke: var(--c-tape);
    stroke-width: 2px;
    stroke-linejoin: round;
  }

  /* v6.4 — country borders (white hairlines, 6% opacity). */
  .eg__borders path {
    stroke-width: 0.5;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  /* v6.4 — pole indicators (small amber rings). */
  .eg__poles circle {
    pointer-events: none;
  }

  /* v6.4 — earth axis (dotted amber line). */
  .eg__axis line {
    pointer-events: none;
  }

  /* v6.4 — city cluster badge (×N events at a city). */
  .eg__city-cluster {
    pointer-events: none;
  }
  .eg__city-cluster-text {
    font-family: var(--ff-mono, monospace);
    font-size: 8px;
    font-weight: 700;
    fill: var(--c-tape);
    letter-spacing: 0;
  }

  /* v6.5 — star field. 3 tiers; tier 3 (large anchor stars) gets a
     faint white halo for visual punch against the dark tape. */
  .eg__stars circle {
    pointer-events: none;
  }
  .eg__star--t3 {
    filter: drop-shadow(0 0 1px rgba(230, 237, 243, 0.4));
  }
  /* v6.5 — secondary outer atmosphere ring */
  .eg__atmosphere-2 {
    pointer-events: none;
  }

  /* Legend */
  .eg__legend {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-5);
    font-size: 0.7rem;
    color: var(--c-ink-2);
  }
  .eg__legend-item {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .eg__legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }
  .eg__legend-dot--amber { background: var(--c-amber-light); }
  .eg__legend-dot--gold  { background: var(--c-primary-2); }
  .eg__legend-dot--cyan  { background: var(--c-accent-cyan, #76d6ff); }
  .eg__legend-dot--ink   { background: var(--c-ink-2); }
  .eg__legend-dot--rose  { background: var(--c-fail); }

  @media (max-width: 1080px) and (min-width: 600px) {
    .eg__city text {
      font-size: 8px;
      opacity: 0.7;
      stroke-width: 2.5px;
    }
  }

  @media (max-width: 600px) {
    .eg__city text { display: none; }
    .eg__caption-title { font-size: var(--fs-xs); }
    .eg__legend { gap: var(--sp-2) var(--sp-3); font-size: 0.65rem; }
    .eg__chrome-text, .eg__chrome-text-sm { font-size: 8px; }
    .eg__header-text { font-size: 7px; letter-spacing: 0.06em; }
    .eg__roster-h, .eg__roster-row, .eg__hud-text { font-size: 7px; }
    .eg__regions { display: none; }
    .eg__roster { display: none; }
  }

  /* Reduced-motion — kill the flow-dot animation and pin pulse, and
     the rotation animation. */
  @media (prefers-reduced-motion: reduce) {
    .eg-flow animateMotion,
    .eg-flow { animation: none !important; opacity: 0.7 !important; }
    .eg__pin-group :global(.evp--pulse .evp__ring) { display: none !important; }
    .eg__globe-rotating { animation: none !important; }
  }
</style>

<script define:vars={{ flowAmber }}>
  // Set the flow-dot hue deterministically from buildSeed so the amber
  // tones mix consistently across builds. No timers, no randomness —
  // just a CSS custom property for the route-color tint.
  const sheet = document.createElement('style');
  sheet.textContent = `:root { --eg-flow-tint: hsla(43, ${Math.round(78 + flowAmber * 14)}%, ${Math.round(60 + flowAmber * 4)}%, 0.9); }`;
  document.head.appendChild(sheet);
</script>
