---
/**
 * HeroVideo.astro — background video overlay for the workspace section.
 *
 * v6.2 Mission Q — "Trader Workspace / Iron Man Desk".
 *
 * Two-layer approach (records, in order, back to front):
 *   1. Outer layer: <video autoplay muted loop playsinline> IF a static
 *      file exists at `public/ambient/workspace-loop.mp4`. Otherwise an
 *      inline-rendered SVG fallback (orbital grid + price-line + city
 *      markers).
 *   2. Inner layer: a dark gradient overlay so hero text stays readable.
 *      On top of the SVG fallback we also apply a 2px blur + 0.7
 *      brightness — the ambient layer should *whisper*, not shout.
 *
 * Performance:
 *   - Video pauses under prefers-reduced-motion (muted, no audio).
 *   - If the video file is missing, we serve the SVG only — no network
 *     fetch, no 404, no layout shift.
 *
 * Positioning: sits behind `.hero`, anchored full-bleed. The parent
 * `.workspace` section controls its own height (single-row band, 280px
 * desktop / 200px mobile). Color palette is amber on tape-dark.
 *
 * NDA-positive: zero platform names, zero employer names. Pure numbers
 * + abstract shapes.
 *
 * Built server-rendered; the only inline `<script>` toggles the
 * reduced-motion pause on the video element (CSS owns the SVG
 * animation).
 */

// Server-side check for the video asset. import.meta.glob lets us probe
// `public/ambient/*` without ever making a request — if a build ever
// ships a real .mp4 here, the component promotes itself to the video
// branch automatically. Today (Mission Q) no file exists, so the SVG
// fallback always wins.
const ambientFiles = import.meta.glob('/public/ambient/*', { eager: true });
const videoSrc = Object.keys(ambientFiles).find((p) => p.endsWith('workspace-loop.mp4'));
const hasVideo = Boolean(videoSrc);
const publicVideoUrl = videoSrc ? videoSrc.replace('/public', '') : null;

// Build a deterministic set of orbital markers + city dots seeded from
// the build date. Same pattern as `notes/v61-patterns.md` Pattern 1 —
// every visitor to the same build sees the same ambient, which is the
// whole point of "deterministic live-feel".
import { seedFromString, buildSeed } from '@utils/prng';
const rng = seedFromString(buildSeed() + '::herovideo');

// 6 amber orbital "stations" — positions on a 1600x800 canvas.
const orbits = Array.from({ length: 6 }, (_, i) => ({
  id: `orb-${i}`,
  cx: 120 + i * 240 + Math.floor(rng() * 80),
  cy: 320 + Math.floor(rng() * 200),
  r: 3 + Math.floor(rng() * 3),
  // delay so the pulses feel alive instead of all firing together
  delay: +(rng() * 4).toFixed(2),
  // 4 of 6 are amber, 2 are the cyan accent — gives the eye two color
  // anchors as the panel scrolls past
  tone: i % 3 === 1 ? 'cyan' : 'amber',
}));

// 8 city dots, scattered to suggest a coverage map behind the panel.
// Coordinates are placed within a 1600x800 frame but normalized to
// thirds so the eye reads "global" rather than "asteroid belt".
const cityDots = Array.from({ length: 8 }, (_, i) => {
  const band = i < 3 ? 0.7 : i < 6 ? 0.55 : 0.4;
  return {
    id: `city-${i}`,
    cx: 200 + i * 160 + Math.floor(rng() * 60),
    cy: Math.floor(800 * band) + Math.floor(rng() * 60),
    r: 2 + Math.floor(rng() * 2),
    delay: +(rng() * 3).toFixed(2),
  };
});

// Price-line polyline — 24 sample points drawn from a tight random
// walk around y=420. Reads as a tape line on a chart.
const PRICE_N = 24;
const pricePoints: Array<{ x: number; y: number }> = [];
let yLevel = 420;
for (let i = 0; i < PRICE_N; i++) {
  const x = 60 + (i / (PRICE_N - 1)) * 1480;
  yLevel = yLevel + (rng() - 0.5) * 18;
  // mild mean reversion to keep the line on screen
  yLevel = yLevel + (420 - yLevel) * 0.04;
  pricePoints.push({ x: Math.round(x), y: Math.round(yLevel) });
}
const pricePath = pricePoints.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`).join(' ');
// Off-screen companion used for the seamless loop (we draw two stacks
// of 24 with a small overlap; CSS pans the group across the canvas).
const pricePath2 = pricePoints
  .map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x + 1540} ${p.y}`)
  .join(' ');

// Underlying perspective grid — diagonal hairlines so the panel
// reads as a floor plan rather than wallpaper.
const gridRows = 16;
const gridCols = 32;
interface GridLine {
  x1: number;
  y1: number;
  x2: number;
  y2: number;
}
const gridLines: GridLine[] = [];
for (let r = 0; r <= gridRows; r++) {
  // perspective: x grows non-uniformly toward the horizon
  const t = r / gridRows;
  const y = 800 - t * t * 720; // quadratic ease to vanishing point
  gridLines.push({ x1: 0, y1: y, x2: 1600, y2: y });
}
for (let c = 0; c <= gridCols; c++) {
  const x = (c / gridCols) * 1600;
  gridLines.push({ x1: x, y1: 80, x2: x, y2: 800 });
}

// Vignette stops are baked in CSS, not here.
---

<div class="hero-video" aria-hidden="true">
  <div class="hero-video__media">
    {
      hasVideo ? (
        <video
          class="hero-video__video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster=""
        >
          <source src={publicVideoUrl!} type="video/mp4" />
        </video>
      ) : (
        <svg
          class="hero-video__svg"
          viewBox="0 0 1600 800"
          preserveAspectRatio="xMidYMid slice"
          role="presentation"
        >
          {/* === perspective floor grid ===
              Hairline grid in muted ink so the canvas reads as a
              vanishing-point floor plan under the panel. */}
          <g class="hero-video__grid" stroke="var(--c-ink-haze)" stroke-width="0.5">
            {gridLines.map((l, _i) => (
              <line x1={l.x1} y1={l.y1} x2={l.x2} y2={l.y2} />
            ))}
          </g>

          {/* === dot lattice (was 50×30, v6.10.14 → 25×15) ===
              Sparse amber dots anchored to the foreground band. Gives
              the panel a "data plane" texture without competing with
              the price-line. Density cut 4× to ship ~30KB less HTML
              per render; visually identical at the 1600×800 viewBox
              scale the panel uses.
           */}
          <g class="hero-video__dots">
            {Array.from({ length: 25 * 15 }, (_, i) => {
              const col = i % 25;
              const row = Math.floor(i / 25);
              const x = 30 + col * 62 + (row % 2) * 8;
              const y = 600 + row * 14;
              return <circle cx={x} cy={y} r="1.4" />;
            })}
          </g>

          {/* === price-line tape ===
              Two concatenated polylines so the CSS pan loops
              seamlessly. Stroke is amber-light at ~80% so it reads
              as a "tape", not a star chart. */}
          <g class="hero-video__price">
            <path
              d={pricePath}
              fill="none"
              stroke="var(--c-amberl-mid)"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path
              d={pricePath2}
              fill="none"
              stroke="var(--c-amberl-mid)"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </g>

          {/* === amber orbit stations + cyan accents ===
              6 dots, slow pulse, two colored (cyan) for accent. */}
          <g class="hero-video__orbits">
            {orbits.map((o) => (
              <circle
                cx={o.cx}
                cy={o.cy}
                r={o.r}
                fill={o.tone === 'cyan' ? 'var(--c-accent-cyan)' : 'var(--c-amberl-mid)'}
                style={`--pulse-delay: ${o.delay}s;`}
              />
            ))}
          </g>

          {/* === pulsing city markers (8) ===
              Reads as a coverage map at low density. Staggered
              delays so the band "breathes".
              v6.10.30 — hoist fill to <g> (SVG presentation attr
              inheritance): 8 inline fill="rgba(...)" → 1 parent fill. */}
          <g class="hero-video__cities" fill="rgba(63, 185, 80, 0.55)">
            {cityDots.map((c) => (
              <circle cx={c.cx} cy={c.cy} r={c.r} style={`--pulse-delay: ${c.delay}s;`} />
            ))}
          </g>
        </svg>
      )
    }
  </div>

  {
    /* === gradient overlay === keeps hero text readable above the
      ambient layer. fades from dense at top, lifts in the band,
      dense again at the bottom. */
  }
  <div class="hero-video__overlay"></div>
  <div class="hero-video__noise"></div>
</div>

<style>
  /* ============================================================
     hero-video — full-bleed ambient band.
     Position: relative on the parent; this element is absolute
     inset:0 so it bleeds to the section edges. The parent <section>
     controls its own min-height.
     ============================================================ */
  .hero-video {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
    background: var(--c-tape);
  }
  .hero-video__media {
    position: absolute;
    inset: 0;
    filter: blur(2px) brightness(0.7) saturate(1.1);
    transform: translateZ(0); /* promote for GPU compositing */
    will-change: filter;
  }
  .hero-video__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-video__svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  /* v6.11.6 — price-tape stroke moved from --c-amberl-mid to
     color-mix of --c-amber so future palette lifts propagate. */
  .hero-video__price {
    stroke: color-mix(in oklab, var(--c-amber) 85%, transparent);
  }
  /* v6.10.41 — amber dots tint now derives from --c-amber via color-mix
     so future palette tweaks (e.g. F14 → F15) propagate without grepping
     every <g> literal. Was inline rgba(201,138,22,0.22) on the <g>. */
  .hero-video__dots {
    fill: color-mix(in oklab, var(--c-amber) 22%, transparent);
  }
  .hero-video__overlay {
    position: absolute;
    inset: 0;
    /* v6.11.6 — was rgba(13,17,23,*) literals; now color-mix of
       --c-tape so future palette lifts propagate. */
    background: linear-gradient(
      180deg,
      color-mix(in oklab, var(--c-tape) 85%, transparent) 0%,
      color-mix(in oklab, var(--c-tape) 62%, transparent) 50%,
      color-mix(in oklab, var(--c-tape) 95%, transparent) 100%
    );
  }
  /* subtle static grain so the panel doesn't read as flat fill.
     v6.11.6 — opacity 0.35 → 0.18 (was borderline AI-vibe grain).
     Still adds texture but reads as institutional ambient rather
     than as a gradient overlay. */
  .hero-video__noise {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(var(--c-white-mist) 1px, transparent 1px);
    background-size: 3px 3px;
    mix-blend-mode: overlay;
    opacity: 0.18;
  }

  /* === SVG-only: price-line tape pans left at one cycle per minute. ===
     Two concatenated polylines + the parent .hero-video__price group,
     translated by exactly one screen-width. When the right copy reaches
     the left edge the loop snaps back invisibly. */
  .hero-video__price {
    animation: hero-video-pan 60s linear infinite;
    transform-origin: 0 0;
    will-change: transform;
  }
  @keyframes hero-video-pan {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-1540px);
    }
  }

  /* === pulse — amber/cyan/green dots fade-in/out at staggered === */
  .hero-video__orbits circle,
  .hero-video__cities circle {
    transform-origin: center;
    animation: hero-video-pulse 4.8s var(--ease-out) infinite;
    animation-delay: var(--pulse-delay, 0s);
  }
  /* v6.9.16 — drop the decorative scale(1.18) pulse. Opacity 0.55→0.9
     keeps the "data-marker alive" signal; scale-change reads as Tron
     lab chrome. */
  @keyframes hero-video-pulse {
    0%,
    100% {
      opacity: 0.55;
    }
    50% {
      opacity: 0.9;
    }
  }

  /* === motion-budget — every keyframed motion pauses under reduced === */
  @media (prefers-reduced-motion: reduce) {
    .hero-video__price,
    .hero-video__orbits circle,
    .hero-video__cities circle {
      animation: none;
    }
  }
</style>

{
  /* The reduce-motion pause-on-video behavior lives in
     src/scripts/hero-video.ts (imported by BaseLayout). The SVG
     fallback branch — what every build today takes — needs no
     client-side handler at all; CSS owns the entire animation. The
     driver only fires when an actual <video class="hero-video__video">
     exists in the DOM (a build that ships a real .mp4). */
}
