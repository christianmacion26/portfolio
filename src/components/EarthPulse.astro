---
/**
 * EarthPulse.astro — v6.4 "Earth Mission Control" CSS-driven pulse rings
 * emanating from cities when a severity-3 (critical) event is firing in
 * the build's worldEvent fixture set.
 *
 * Architecture:
 *   - Pure server-rendered overlay — absolutely positioned over an
 *     EarthGlobe parent.
 *   - Filters `getCollection('worldEvent')` to severity === 'critical'
 *     at build time. If zero critical events are firing, the component
 *     renders no rings (decoration-not-information guard, per the plan
 *     Risk register).
 *   - Projection is inlined as a local copy of the EarthGlobe helper.
 *     Astro .astro files cannot export runtime functions to other .astro
 *     consumers, so each component that needs orthographic projection
 *     inlines its own helper. The two implementations are byte-identical
 *     at projection time and only differ in which `centerLat` /
 *     `centerLon` / `cx/cy/R` they use.
 *
 * Honored constraints:
 *   - No `client:*` directives, no `Math.random()`, no `Date.now()`.
 *   - Palette tokens only.
 *   - `prefers-reduced-motion: reduce` honored both via the universal
 *     block in `src/styles/tokens.css` and via the per-component
 *     `@media (prefers-reduced-motion: reduce)` override below.
 *
 * Props:
 *   centerLat, centerLon — view center (default 20 / 80, APAC view,
 *     matches EarthGlobe default).
 *   width, height — overlay dimensions (default 800×800). The parent
 *     positions this absolutely over a same-sized EarthGlobe.
 */
import { getCollection } from 'astro:content';

interface Props {
  centerLat?: number;
  centerLon?: number;
  width?: number;
  height?: number;
}

const { centerLat = 20, centerLon = 80, width = 800, height = 800 } = Astro.props;

const cx = width / 2;
const cy = height / 2;
const R = Math.min(width, height) * 0.46;

// === Orthographic projection (inlined — see header) ===================
function project(lat: number, lon: number) {
  const latRad = (lat * Math.PI) / 180;
  const lonRad = ((lon - centerLon) * Math.PI) / 180;
  const cosLat = Math.cos(latRad);
  const sinLat = Math.sin(latRad);
  const cosLon = Math.cos(lonRad);
  const sinLon = Math.sin(lonRad);
  const cosC = Math.cos((centerLat * Math.PI) / 180);
  const sinC = Math.sin((centerLat * Math.PI) / 180);
  // Standard orthographic rotation + projection.
  const x = cosLat * sinLon;
  const y = sinC * sinLat + cosC * cosLat * cosLon;
  const z = cosC * sinLat - sinC * cosLat * cosLon;
  return {
    x: cx + R * x,
    y: cy - R * y,
    visible: z > 0,
  };
}

// === Build-time: project all severity-3 firing events =================
interface RawWorldEvent {
  id: string;
  data: {
    title: string;
    category: 'central-bank' | 'earnings' | 'geopolitical' | 'data-release' | 'fx';
    severity: 'mild' | 'moderate' | 'critical';
    lat: number;
    lon: number;
    city: string;
    order: number;
    source: string;
  };
}

const allEvents = await getCollection('worldEvent');
const firing = allEvents
  .filter((e: RawWorldEvent) => e.data.severity === 'critical')
  .sort((a: RawWorldEvent, b: RawWorldEvent) => a.data.order - b.data.order);

interface RingOut {
  x: number;
  y: number;
  delay: number;
  color: string;
  slug: string;
  city: string;
  title: string;
}

const rings: RingOut[] = firing
  .map((e: RawWorldEvent, i: number): RingOut | null => {
    const p = project(e.data.lat, e.data.lon);
    if (!p.visible) return null;
    return {
      x: p.x,
      y: p.y,
      delay: i * 600, // stagger so consecutive criticals don't sync up
      color:
        e.data.category === 'central-bank'
          ? 'var(--c-amber-light)'
          : e.data.category === 'earnings'
            ? 'var(--c-amber-deep)'
            : e.data.category === 'data-release'
              ? 'var(--c-accent-cyan)'
              : 'var(--c-amber)',
      slug: e.id ?? e.data.city.toLowerCase().replace(/\s+/g, '-'),
      city: e.data.city,
      title: e.data.title,
    };
  })
  .filter((r: RingOut | null): r is RingOut => r !== null);
---

<div
  class="earth-pulse"
  role="presentation"
  aria-hidden="true"
  style={`width:${width}px;height:${height}px;`}
>
  {
    rings.map((r) => (
      <span
        class="earth-pulse__ring"
        style={`left:${r.x.toFixed(2)}px;top:${r.y.toFixed(2)}px;background:${r.color};--pulse-delay:${r.delay}ms;`}
      />
    ))
  }
</div>

<style>
  .earth-pulse {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .earth-pulse__ring {
    position: absolute;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    animation: earth-pulse 3s var(--ease-out, ease) infinite;
    animation-delay: var(--pulse-delay, 0ms);
    opacity: 0;
    /* Foundation-guarantee: the universal `* { animation: none }` at
       tokens.css:174-198 already covers reduced-motion users. Belt-
       and-suspenders override below for the rare build where that
       universal rule is overriden. */
  }
  @keyframes earth-pulse {
    0% {
      transform: translate(-50%, -50%) scale(0.3);
      opacity: 0.55;
    }
    100% {
      transform: translate(-50%, -50%) scale(1.3);
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .earth-pulse__ring {
      animation: none;
      display: none;
    }
  }
</style>
