---
/**
 * PredictionCard.astro — single binary-event-market card.
 *
 * Layout (top → bottom):
 *   - Category pill (mono, uppercase)
 *   - Title (h3)
 *   - Big implied probability (e.g. "18¢") + secondary fair value
 *   - Edge badge (positive = green, negative = red)
 *   - Per-card probability walk SVG (24 points, deterministic seed)
 *   - Footer: methodology link + tenor
 *
 * NDA-positive: no platform names appear in any field. Generic
 * language: "implied", "fair", "edge".
 *
 * Usage:
 *   <PredictionCard event={ev} />
 */
interface Event {
  id: string;
  data: {
    title: string;
    category: 'macro' | 'crypto' | 'rates' | 'political' | 'equity' | 'volatility';
    tenor: string;
    impliedPx: number;
    edge: number;
    evidence: string;
    methodology: string;
    source: string;
    order: number;
  };
  body?: string;
}
interface Props {
  event: Event;
  buildDate?: string;
}
const { event, buildDate = '2026-07-10' } = Astro.props;
const e = event.data;
const impliedCents = Math.round(e.impliedPx * 100);
const fairCents = Math.round((e.impliedPx + e.edge) * 100);
const edgeSign = e.edge >= 0 ? '+' : '−';
const edgeCents = `${edgeSign}${Math.abs(e.edge * 100).toFixed(0)}¢`;
const edgeClass = e.edge >= 0 ? 'card__edge--pos' : 'card__edge--neg';
const categoryClass = `card__pill--${e.category}`;

// Per-card SVG: a deterministic probability walk from implied to fair,
// 24 points, seeded from the slug.
function slugSeed(slug: string): number {
  let h = 0x811c9dc5;
  for (let i = 0; i < slug.length; i++) {
    h ^= slug.charCodeAt(i);
    h = Math.imul(h, 0x01000193);
  }
  return (h >>> 0) / 4294967296;
}

const W = 320,
  H = 84;
const PADL = 4,
  PADR = 4,
  PADT = 6,
  PADB = 6;
const innerW = W - PADL - PADR;
const innerH = H - PADT - PADB;

const seed = slugSeed(event.id);
const steps = 24;
const pts: { x: number; y: number }[] = [];
let cur = e.impliedPx;
const target = Math.max(0.005, Math.min(0.995, e.impliedPx + e.edge));
// y at impliedPx / fairProb endpoints (the curve should fill 50%-130% of vertical range)
const yLow = Math.min(e.impliedPx, target) - 0.04;
const yHigh = Math.max(e.impliedPx, target) + 0.04;
const range = yHigh - yLow || 0.1;

for (let i = 0; i <= steps; i++) {
  const t = i / steps;
  const pull = (target - cur) * 0.22;
  const phase = seed * Math.PI * 2;
  const noise = Math.sin(phase + t * Math.PI * 5) * 0.015;
  cur = Math.max(0.005, Math.min(0.995, cur + pull + noise));
  const px = PADL + t * innerW;
  const py = PADT + innerH * (1 - (cur - yLow) / range);
  pts.push({ x: px, y: py });
}
// Force final point exactly at fair value for clean terminal anchor.
pts[pts.length - 1] = {
  x: PADL + innerW,
  y: PADT + innerH * (1 - (target - yLow) / range),
};

const pathD = pts
  .map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(2)} ${p.y.toFixed(2)}`)
  .join(' ');
const areaD = `${pathD} L ${(PADL + innerW).toFixed(2)} ${(PADT + innerH).toFixed(2)} L ${PADL} ${(PADT + innerH).toFixed(2)} Z`;
const gradId = `card-grad-${event.id.replace(/[^a-z0-9]/gi, '')}`;
---

<article class="card">
  <div class="card__top">
    <span class:list={['card__pill', 'mono', categoryClass]}>{e.category}</span>
    <span class="card__tenor mono">{e.tenor}</span>
  </div>

  <h3 class="card__title">{e.title}</h3>

  <div class="card__numbers">
    <div class="card__price">
      <div class="card__cents mono">{impliedCents}¢</div>
      <div class="card__cents-lbl mono">implied</div>
    </div>
    <div class="card__divider" aria-hidden="true"></div>
    <div class="card__price card__price--fair">
      <div class="card__cents mono">{fairCents}¢</div>
      <div class="card__cents-lbl mono">fair</div>
    </div>
    <div class:list={['card__edge', 'mono', edgeClass]} aria-label={`Edge ${edgeCents}`}>
      {edgeCents}
    </div>
  </div>

  <svg
    class="card__svg"
    viewBox={`0 0 ${W} ${H}`}
    role="img"
    aria-label={`Probability walk from ${impliedCents}¢ to ${fairCents}¢`}
    preserveAspectRatio="none"
  >
    <defs>
      <linearGradient id={gradId} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--c-primary-2)" stop-opacity="0.30" />
        <stop offset="100%" stop-color="var(--c-primary-2)" stop-opacity="0" />
      </linearGradient>
    </defs>
    <path d={areaD} fill={`url(#${gradId})`} />
    <path
      d={pathD}
      fill="none"
      stroke="var(--c-primary-2)"
      stroke-width="1.4"
      stroke-linejoin="round"
      stroke-linecap="round"
    />
    {/* terminal fair-value anchor */}
    <circle
      cx={PADL + innerW}
      cy={PADT + innerH * (1 - (target - yLow) / range)}
      r="2.4"
      fill="var(--c-primary-2-light)"
    />
  </svg>

  <p class="card__evidence">{e.evidence}</p>

  <div class="card__foot">
    <span class="card__method">{e.methodology}</span>
    <span class="card__source mono">{e.source}</span>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    background: var(--c-tape-2);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    color: var(--c-ink);
    min-width: 0;
    transition: border-color var(--transition);
  }
  .card:hover {
    border-color: var(--c-primary-2);
  }
  .card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-2);
  }
  .card__pill {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 2px 8px;
    border-radius: 3px;
    border: 1px solid currentColor;
  }
  .card__pill--macro {
    color: var(--c-primary-2);
  }
  .card__pill--crypto {
    color: var(--c-primary-2-light);
  }
  .card__pill--rates {
    color: var(--c-accent-cyan);
  }
  .card__pill--political {
    color: var(--c-ink-2);
  }
  .card__pill--equity {
    color: var(--c-gold);
  }
  .card__pill--volatility {
    color: var(--c-fail);
  }
  .card__tenor {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    letter-spacing: 0.04em;
  }
  .card__title {
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--c-ink);
    line-height: 1.3;
    margin: 0;
    letter-spacing: -0.012em;
    min-height: 2.6em;
  }
  .card__numbers {
    display: grid;
    grid-template-columns: 1fr 1px 1fr auto;
    gap: var(--sp-3);
    align-items: center;
    padding: var(--sp-3) 0;
    border-top: 1px solid var(--c-rule-soft);
    border-bottom: 1px solid var(--c-rule-soft);
  }
  .card__price {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .card__cents {
    font-size: 1.7rem;
    font-weight: 700;
    line-height: 1;
    color: var(--c-ink);
    font-variant-numeric: tabular-nums;
  }
  .card__price--fair .card__cents {
    color: var(--c-primary-2);
  }
  .card__cents-lbl {
    font-size: 0.62rem;
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .card__divider {
    width: 1px;
    align-self: stretch;
    background: var(--c-rule);
  }
  .card__edge {
    font-size: 0.78rem;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 3px;
    white-space: nowrap;
  }
  .card__edge--pos {
    color: var(--c-pass);
    background: var(--c-pass-soft);
  }
  .card__edge--neg {
    color: var(--c-fail);
    background: var(--c-fail-soft);
  }
  .card__svg {
    width: 100%;
    height: 84px;
    display: block;
    background: var(--c-bg);
    border-radius: var(--radius-sm);
  }
  .card__evidence {
    margin: 0;
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-2);
    padding-top: var(--sp-2);
    border-top: 1px solid var(--c-rule-soft);
    flex-wrap: wrap;
  }
  .card__method {
    font-size: 0.65rem;
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .card__source {
    font-size: 0.62rem;
    color: var(--c-ink-3);
    letter-spacing: 0.04em;
  }

  @media (max-width: 540px) {
    .card__title {
      font-size: 0.95rem;
      min-height: 2.4em;
    }
    .card__cents {
      font-size: 1.45rem;
    }
  }
</style>