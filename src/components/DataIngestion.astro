---
/**
 * DataIngestion.astro — v6.6 (Mission S, part 2)
 *
 * Replaces the v6.2 prose event feed with a server-rendered pipeline diagram:
 *
 *   SOURCE (4 venues) → NORMALIZE (3 ops) → ENRICH (3 ops) →
 *   INDEX (3 ops) → STREAM (3 ops)
 *
 * Each stage is one SVG `<g>` of small mono nodes (12px square + 11px mono
 * label + 4-char tps rate). Adjacent stages are connected by 1px bezier
 * arrows with `<marker>` arrowheads. A compact 180×40 bar chart in the
 * header shows per-venue throughput; a 5-cell lag strip below the
 * diagram shows per-stage budget burn.
 *
 * All numerics are deterministic from two PRNG closures:
 *   - `seedFromString(buildSeed() + '::ingest')` for the venue chart
 *   - `seedFromString(buildSeed() + '::ingest-lag')` for the lag strip
 *
 * No `Math.random()`, no `Date.now()` — Standing Order §9 compliant.
 * `prefers-reduced-motion` zeros all transitions on the lag fill + node hover.
 */
import { seedFromString, buildSeed } from '@utils/prng';

const rand = seedFromString(buildSeed() + '::ingest');
const lagRand = seedFromString(buildSeed() + '::ingest-lag');

// --- Stage configuration ---
// Node `tps` strings are exactly 4 chars (X.Yk) — required by the spec.
type StageNode = { label: string; tps: string };
type Stage = { name: string; nodes: StageNode[] };

const STAGES: Stage[] = [
  {
    name: 'SOURCE',
    nodes: [
      { label: 'NYSE',    tps: '1.2k' },
      { label: 'NASDAQ',  tps: '2.4k' },
      { label: 'CME',     tps: '0.8k' },
      { label: 'BINANCE', tps: '4.1k' },
    ],
  },
  {
    name: 'NORMALIZE',
    nodes: [
      { label: 'DEDUP',     tps: '8.5k' },
      { label: 'TIMESTAMP', tps: '8.5k' },
      { label: 'CLEAN',     tps: '8.4k' },
    ],
  },
  {
    name: 'ENRICH',
    nodes: [
      { label: 'TAG',      tps: '8.3k' },
      { label: 'FX-CONV',  tps: '8.2k' },
      { label: 'HOLIDAY',  tps: '8.2k' },
    ],
  },
  {
    name: 'INDEX',
    nodes: [
      { label: 'COLUMNAR',   tps: '8.0k' },
      { label: 'PARTITIONS', tps: '8.0k' },
      { label: 'SNAPSHOT',   tps: '0.5k' },
    ],
  },
  {
    name: 'STREAM',
    nodes: [
      { label: 'ZERO-COPY', tps: '8.0k' },
      { label: 'ZMQ-SUB',   tps: '8.0k' },
      { label: 'KAFKA-PUB', tps: '7.9k' },
    ],
  },
];

// --- Top-right per-venue throughput chart (5 vertical bars) ---
const VENUES = ['NYSE', 'NASDAQ', 'CME', 'BINANCE', 'CBOE'] as const;
const venueBars = VENUES.map((venue) => {
  // Deterministic [0.35, 1.0] ratio per venue
  const ratio = 0.35 + rand() * 0.65;
  const tpsNum = (ratio * 4.8).toFixed(1); // 1.7..4.8
  return { venue, ratio, tps: `${tpsNum}k` };
});

// --- Lag strip data: %-of-budget per stage, colored green/amber/red ---
type LagCell = { name: string; pct: number; state: 'green' | 'amber' | 'red' };
const lagCells: LagCell[] = STAGES.map((stage) => {
  const pct = Math.round(20 + lagRand() * 70); // 20..90
  const state: LagCell['state'] =
    pct < 50 ? 'green' : pct < 75 ? 'amber' : 'red';
  return { name: stage.name, pct, state };
});

// --- SVG layout constants ---
const SVG_W = 1080;
const SVG_H = 220;
const STAGE_X = [110, 320, 530, 740, 950]; // x-centers for each stage column
const NODE_SPACING = 38;
const NODE_CENTER_Y = 130;

// Compute node positions per stage, vertically centered around NODE_CENTER_Y.
const stageNodes = STAGES.map((stage, sIdx) => {
  const x = STAGE_X[sIdx]!;
  const n = stage.nodes.length;
  const startY = NODE_CENTER_Y - ((n - 1) * NODE_SPACING) / 2;
  return stage.nodes.map((node, nIdx) => ({
    ...node,
    x,
    y: startY + nIdx * NODE_SPACING,
  }));
});

// Edges: one bezier per (stage, lane) pair across adjacent stages.
// For 4→3 transitions, the 4th source lane merges into the 3rd normalize lane.
type Edge = { d: string };
const edges: Edge[] = [];
for (let s = 0; s < STAGES.length - 1; s++) {
  const fromNodes = stageNodes[s]!;
  const toNodes = stageNodes[s + 1]!;
  const laneCount = Math.max(fromNodes.length, toNodes.length);
  for (let i = 0; i < laneCount; i++) {
    const fromIdx = Math.min(i, fromNodes.length - 1);
    const toIdx = Math.min(i, toNodes.length - 1);
    const from = fromNodes[fromIdx]!;
    const to = toNodes[toIdx]!;
    const x1 = from.x + 8;
    const y1 = from.y;
    const x2 = to.x - 8;
    const y2 = to.y;
    const cx = (x1 + x2) / 2;
    // Cubic bezier with horizontal tangents — smooth horizontal flow.
    const d = `M ${x1} ${y1} C ${cx} ${y1}, ${cx} ${y2}, ${x2} ${y2}`;
    edges.push({ d });
  }
}
---

<section class="ingest" aria-labelledby="ingest-title">
  <div class="ingest__container">
    {/* --- Header: title + caption left, throughput chart right --- */}
    <header class="ingest__head">
      <div class="ingest__head-left">
        <span class="ingest__eyebrow mono">Data ingestion</span>
        <h2 id="ingest-title" class="ingest__title">
          Pipeline <span class="ingest__title-em">live</span>.
          <span class="ingest__cursor" aria-hidden="true">▍</span>
        </h2>
        <p class="ingest__caption">
          Five-stage fan-in from venue to subscribers — server-rendered, seeded from a single deterministic PRNG.
        </p>
      </div>
      <div class="ingest__head-right" aria-label="Per-venue throughput (events / sec)">
        <span class="ingest__chart-label mono">throughput · events / s</span>
        <svg
          class="ingest__chart"
          viewBox="0 0 180 40"
          role="img"
          aria-label="Bar chart of throughput by venue"
          preserveAspectRatio="xMidYMid meet"
        >
          {/* 5 vertical bars + numeric labels in 11px mono tabular-nums */}
          {venueBars.map((bar, i) => {
            const slot = 180 / 5;        // 36px per slot
            const barW = 22;
            const x = i * slot + (slot - barW) / 2;
            const h = Math.max(3, bar.ratio * 26);
            const y = 38 - h;
            const labelY = Math.max(y - 2, 9);
            return (
              <g class="ingest__chart-bar">
                <rect
                  class="ingest__chart-rect"
                  x={x}
                  y={y}
                  width={barW}
                  height={h}
                  rx="1"
                />
                <text
                  class="ingest__chart-num mono tnum"
                  x={x + barW / 2}
                  y={labelY}
                  text-anchor="middle"
                >
                  {bar.tps}
                </text>
              </g>
            );
          })}
        </svg>
        <div class="ingest__chart-axis mono" aria-hidden="true">
          {venueBars.map((bar) => (
            <span class="ingest__chart-tick">{bar.venue.slice(0, 3)}</span>
          ))}
        </div>
      </div>
    </header>

    {/* --- Pipeline diagram --- */}
    <div
      class="ingest__diagram"
      role="img"
      aria-label={`Data ingestion pipeline: ${STAGES.map((s) => s.name).join(' → ')}`}
    >
      <svg
        class="ingest__svg"
        viewBox={`0 0 ${SVG_W} ${SVG_H}`}
        preserveAspectRatio="xMidYMid meet"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <marker
            id="ing-arrow"
            viewBox="0 0 10 10"
            refX="9"
            refY="5"
            markerWidth="6"
            markerHeight="6"
            orient="auto-start-reverse"
            markerUnits="userSpaceOnUse"
          >
            <path d="M0,0 L10,5 L0,10 Z" class="ing-arrow-head" />
          </marker>
        </defs>

        {/* stage column labels */}
        {STAGES.map((stage, sIdx) => (
          <g class="ingest__stage-header">
            <text
              x={STAGE_X[sIdx]}
              y="22"
              text-anchor="middle"
              class="ingest__stage-name mono"
            >
              {stage.name}
            </text>
            <line
              class="ingest__stage-rule"
              x1={STAGE_X[sIdx] - 50}
              y1="32"
              x2={STAGE_X[sIdx] + 50}
              y2="32"
            />
          </g>
        ))}

        {/* edges (drawn before nodes so squares overlay arrowheads cleanly) */}
        {edges.map((e) => (
          <path
            class="ingest__edge"
            d={e.d}
            stroke-width="1"
            fill="none"
            marker-end="url(#ing-arrow)"
          />
        ))}

        {/* nodes */}
        {stageNodes.map((nodes) => (
          <g class="ingest__stage-group">
            {nodes.map((node) => (
              <g
                class="ingest__node"
                transform={`translate(${node.x} ${node.y})`}
              >
                <rect
                  class="ingest__node-sq"
                  x="-6"
                  y="-6"
                  width="12"
                  height="12"
                  rx="1"
                />
                <text
                  class="ingest__node-label mono"
                  x="0"
                  y="22"
                  text-anchor="middle"
                >
                  {node.label}
                </text>
                <text
                  class="ingest__node-tps mono tnum"
                  x="0"
                  y="36"
                  text-anchor="middle"
                >
                  {node.tps}
                </text>
              </g>
            ))}
          </g>
        ))}
      </svg>
    </div>

    {/* --- Lag strip: 5 cells × %-of-budget --- */}
    <div
      class="ingest__lag-strip"
      role="group"
      aria-label="Per-stage lag as percent of budget"
    >
      {lagCells.map((cell) => (
        <div class:list={['ingest__lag-cell', `ingest__lag-cell--${cell.state}`]}>
          <span class="ingest__lag-name mono">{cell.name}</span>
          <div class="ingest__lag-bar" aria-hidden="true">
            <div
              class="ingest__lag-fill"
              style={`--pct:${cell.pct}%`}
            ></div>
          </div>
          <span class="ingest__lag-pct mono tnum">{cell.pct}%</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ingest {
    background: var(--c-tape);
    color: var(--ink-on-tape);
    border-block: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: var(--sp-6);
  }
  .ingest__container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 var(--sp-5);
  }

  /* --- Header --- */
  .ingest__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--sp-5);
    margin-bottom: var(--sp-5);
    flex-wrap: wrap;
  }
  .ingest__head-left {
    flex: 1 1 320px;
    min-width: 0;
  }
  .ingest__head-right {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .ingest__eyebrow {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-amber-light);
    font-weight: 600;
  }
  .ingest__title {
    font-size: clamp(1.4rem, 3vw, 1.85rem);
    color: var(--ink-on-tape);
    font-weight: 600;
    letter-spacing: -0.014em;
    margin: 0.4rem 0 0.5rem;
    line-height: 1.2;
  }
  .ingest__title-em { color: var(--c-amber-light); }
  .ingest__cursor {
    display: inline-block;
    color: var(--c-amber-light);
    margin-left: 0.18em;
    animation: ingest-blink 1.05s steps(2, jump-none) infinite;
  }
  @keyframes ingest-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  .ingest__caption {
    color: rgba(250, 250, 250, 0.62);
    font-size: var(--fs-sm);
    margin: 0;
    line-height: 1.5;
    max-width: 60ch;
  }

  /* --- Per-venue chart --- */
  .ingest__chart-label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(250, 250, 250, 0.5);
  }
  .ingest__chart {
    width: 180px;
    height: 40px;
    display: block;
    overflow: visible;
  }
  .ingest__chart-rect {
    fill: var(--c-amber);
    transition: filter 240ms ease;
  }
  .ingest__chart-bar:hover .ingest__chart-rect {
    filter: brightness(1.25);
  }
  .ingest__chart-num {
    fill: rgba(250, 250, 250, 0.85);
    font-size: 11px;
  }
  .ingest__chart-axis {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    width: 180px;
    font-size: 9px;
    color: rgba(250, 250, 250, 0.45);
    letter-spacing: 0.06em;
  }
  .ingest__chart-tick {
    text-align: center;
  }

  /* --- Pipeline SVG --- */
  .ingest__diagram {
    margin-block: var(--sp-4);
    background: var(--c-bg-2);
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.04);
    padding: var(--sp-3);
  }
  .ingest__svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }
  .ingest__stage-name {
    fill: var(--c-amber-light);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
  }
  .ingest__stage-rule {
    stroke: var(--c-grid-line);
    stroke-width: 1;
  }
  .ingest__edge {
    stroke: var(--c-amber);
    opacity: 0.55;
  }
  .ing-arrow-head {
    fill: var(--c-amber-light);
  }
  .ingest__node-sq {
    fill: var(--c-amber);
    stroke: var(--c-amber-light);
    stroke-width: 0.5;
    transition: filter 240ms ease, transform 240ms ease;
  }
  .ingest__node:hover .ingest__node-sq {
    filter: brightness(1.3);
  }
  .ingest__node-label {
    fill: var(--ink-on-tape);
    font-size: 11px;
    font-weight: 500;
  }
  .ingest__node-tps {
    fill: var(--c-amber-light);
    font-size: 11px;
  }

  /* --- Lag strip --- */
  .ingest__lag-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--sp-3);
    margin-top: var(--sp-4);
    padding: var(--sp-3);
    background: var(--c-bg-2);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: var(--radius-md);
  }
  .ingest__lag-cell {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 8px;
    align-items: center;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    background: var(--c-tape-2);
    border-left: 3px solid transparent;
  }
  .ingest__lag-cell--green { border-left-color: var(--c-data-positive); }
  .ingest__lag-cell--amber { border-left-color: var(--c-amber); }
  .ingest__lag-cell--red   { border-left-color: var(--c-data-negative); }

  .ingest__lag-name {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(250, 250, 250, 0.65);
    font-weight: 600;
  }
  .ingest__lag-bar {
    height: 8px;
    background: var(--c-grid-line);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }
  .ingest__lag-fill {
    height: 100%;
    width: var(--pct, 0%);
    transition: width 320ms ease;
    border-radius: 4px;
  }
  /* F18 — institutional: pipeline lag bars are status indicators, but
     we remove the bright pass-green / fail-red. Status becomes a single
     amber channel: 3 alpha steps (full = on-time, half = amber, low =
     faint ink). Reads as "pipeline health" without the traffic light. */
  .ingest__lag-cell--green .ingest__lag-fill { background: rgba(232, 178, 32, 0.85); }
  .ingest__lag-cell--amber .ingest__lag-fill { background: rgba(232, 178, 32, 0.55); }
  .ingest__lag-cell--red   .ingest__lag-fill { background: rgba(232, 178, 32, 0.25); }
  .ingest__lag-pct {
    font-size: 11px;
    color: var(--ink-on-tape);
    font-weight: 700;
    min-width: 32px;
    text-align: right;
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    .ingest__cursor { animation: none; opacity: 1; }
    .ingest__lag-fill,
    .ingest__node-sq,
    .ingest__chart-rect { transition: none; }
  }

  /* --- Responsive --- */
  @media (max-width: 760px) {
    .ingest__head { flex-direction: column; align-items: flex-start; }
    .ingest__head-right { align-items: flex-start; }
    .ingest__lag-strip { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 460px) {
    .ingest__lag-strip { grid-template-columns: 1fr; }
  }
</style>