---
/**
 * MetricPill.astro — single headline-metric pill.
 *
 * Tone maps to a numeric color token so the value's hue carries semantic
 * weight (e.g. amber accent for quant metrics, near-black for AI/structural).
 */
interface Props {
  label: string;
  value: string;
  sub?: string;
  tone?: 'brand' | 'accent' | 'gold' | 'pass';
}
const { label, value, sub, tone = 'brand' } = Astro.props;
const valueColor =
  tone === 'accent'
    ? 'var(--c-primary-2-deep)'
    : tone === 'gold'
      ? 'var(--c-gold)'
      : tone === 'pass'
        ? 'var(--c-pass)'
        : 'var(--c-primary)';
---

<div class="metric">
  <div class="metric__value mono" style={`color: ${valueColor}`}>{value}</div>
  <div class="metric__label">{label}</div>
  {sub && <div class="metric__sub faint text-xs">{sub}</div>}
</div>

<style>
  .metric {
    padding: var(--sp-4);
    background: var(--c-bg);
    border: var(--border);
    border-radius: var(--radius-sm);
    text-align: center;
  }
  .metric__value {
    font-size: var(--fs-2xl);
    font-weight: 600;
    line-height: 1;
    margin-bottom: var(--sp-2);
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum' 1;
  }
  .metric__label {
    font-size: var(--fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-ink-2);
  }
  .metric__sub {
    margin-top: var(--sp-2);
  }
</style>
