---
/**
 * VideoEmbed.astro — pure HTML5 <video> wrapper for proof recordings.
 *
 * Two modes:
 *   - 'inline'  (default): click-to-play with native controls. Used in /experience.
 *   - 'gallery': autoplay + muted + loop. Used in /proof gallery. Mobile Safari-safe
 *                via `playsinline`; audio is already stripped at the source.
 *
 * No client-side JS — `<video controls>` is HTML5 native.
 */
interface Props {
  src: string;
  poster: string;
  title: string;
  duration?: number;
  caption?: string;
  mode?: 'inline' | 'gallery';
  tone?: 'paper' | 'tape';
}

const { src, poster, title, duration, caption, mode = 'inline', tone = 'paper' } = Astro.props;

const isGallery = mode === 'gallery';
---

<figure class={`video-embed video-embed--${tone}`}>
  <div class="video-embed__frame">
    <video
      src={src}
      poster={poster}
      title={title}
      controls={!isGallery}
      autoplay={isGallery}
      muted={isGallery}
      loop={isGallery}
      playsinline
      preload={isGallery ? 'metadata' : 'none'}
      aria-label={title}
      class="video-embed__video"></video>
    {
      !isGallery && duration && (
        <span class="video-embed__duration mono" aria-hidden="true">
          {duration}s
        </span>
      )
    }
  </div>
  {caption && <figcaption class="video-embed__cap">{caption}</figcaption>}
</figure>

<style>
  .video-embed {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .video-embed--paper {
    background: var(--c-paper);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    padding: var(--sp-3);
  }
  .video-embed--tape {
    background: var(--c-tape);
    border: 1px solid var(--c-tape-2);
    border-radius: var(--radius);
    padding: var(--sp-3);
  }
  .video-embed__frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--c-tape);
  }
  .video-embed__video {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    display: block;
    background: var(--c-tape);
  }
  .video-embed__duration {
    position: absolute;
    top: var(--sp-2);
    right: var(--sp-2);
    padding: 2px 8px;
    background: rgba(13, 17, 23, 0.78);
    color: var(--c-primary-2-deep);
    font-size: var(--fs-xs);
    border-radius: 3px;
    letter-spacing: 0.06em;
  }
  .video-embed__cap {
    padding: 0 var(--sp-1);
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-snug);
  }
  .video-embed--tape .video-embed__cap {
    color: rgba(230, 237, 243, 0.78);
  }
</style>
