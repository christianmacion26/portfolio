function signalPillColor(sig: string): string {
  switch (sig) {
    case 'long-vol':
      return 'fail';
    case 'short-vol':
      return 'pass';
    case 'flatten':
      return 'cyan';
    case 'steepen':
      return 'amber';
    case 'carry':
      return 'amber';
    default:
      return 'neutral';
  }
}
---

<aside
  class="earth-drawer"
  id="earth-drawer"
  aria-label="Earth event drawer — open a city panel to view its details"
>
  <header class="earth-drawer__head">
    <span class="earth-drawer__head-label">Event detail</span>
    <span class="earth-drawer__head-count">{events.length} fixtures</span>
  </header>
  <div class="earth-drawer__panels">
    {
      events.map((e) => (
        <details class="earth-drawer__panel" id={`event-${e.slug}`}>
          <summary class="earth-drawer__summary">
            <span class="earth-drawer__city">{e.city}</span>
            <span class="earth-drawer__head-text">{e.title}</span>
          </summary>
          <div class="earth-drawer__body">
            <span class="earth-drawer__ts">{e.timestamp}</span>
            <h3 class="earth-drawer__title">{e.title}</h3>
            <pre class="earth-drawer__formula">{e.formula}</pre>
            <dl class="earth-drawer__meta">
              <dt>Signal</dt>
              <dd>
                <span
                  class:list={[
                    'pill',
                    `pill--${signalPillColor(e.signal)}`,
                  ]}
                >
                  {e.signal}
                </span>
              </dd>
              <dt>Magnitude</dt>
              <dd class="earth-drawer__num">
                {e.magnitude} {e.unit}
              </dd>
              <dt>Desk action</dt>
              <dd>{e.deskAction}</dd>
              <dt>Source</dt>
              <dd class="earth-drawer__mono">{e.source}</dd>
              <dt>Research</dt>
              <dd>
                <a href={`/research#event-${e.slug}`} class="earth-drawer__deep">
                  backtest artifact →
                </a>
              </dd>
            </dl>
          </div>
        </details>
      ))
    }
  </div>
</aside>

<style>
  .earth-drawer {
    position: fixed;
    top: var(--nav-h, 56px);
    right: 0;
    bottom: 0;
    width: 360px;
    max-width: 100vw;
    background: var(--c-tape-2);
    border-left: 1px solid var(--c-rule);
    transform: translateX(100%);
    transition: transform 240ms var(--ease-out, ease);
    z-index: 60;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .earth-drawer:has(.earth-drawer__panel[open]) {
    transform: translateX(0);
  }

  .earth-drawer__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--sp-3) var(--sp-4);
    border-bottom: 1px solid var(--c-rule);
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
  }
  .earth-drawer__head-label {
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .earth-drawer__head-count {
    color: var(--c-ink-2);
    letter-spacing: 0.04em;
  }

  .earth-drawer__panels {
    overflow-y: auto;
    scrollbar-gutter: stable;
    flex: 1;
    min-height: 0;
  }

  .earth-drawer__panel {
    border-bottom: 1px solid var(--c-rule-soft);
  }
  .earth-drawer__panel summary {
    cursor: pointer;
    list-style: none;
    padding: var(--sp-3) var(--sp-4);
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: 44px;
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    position: relative;
  }
  .earth-drawer__panel summary::-webkit-details-marker {
    display: none;
  }
  .earth-drawer__panel summary::after {
    content: '+';
    margin-left: auto;
    color: var(--c-amber-light);
    font-family: var(--ff-mono, monospace);
    padding-left: var(--sp-2);
  }
  .earth-drawer__panel[open] summary::after {
    content: '−';
  }
  .earth-drawer__panel summary:hover {
    color: var(--c-amber-light);
  }
  .earth-drawer__city {
    color: var(--c-amber-light);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: var(--ff-mono, monospace);
    font-size: 0.7rem;
    flex-shrink: 0;
  }
  .earth-drawer__head-text {
    color: var(--c-ink);
  }

  .earth-drawer__body {
    padding: var(--sp-2) var(--sp-4) var(--sp-4);
    border-top: 1px solid var(--c-rule-soft);
  }
  .earth-drawer__ts {
    color: var(--c-ink-3);
    font-family: var(--ff-mono, monospace);
    font-size: var(--fs-xs);
    letter-spacing: 0.04em;
  }
  .earth-drawer__title {
    font-size: 1.1rem;
    margin: var(--sp-1) 0;
    color: var(--c-ink);
    font-weight: 600;
  }
  .earth-drawer__formula {
    background: var(--c-tape);
    border: 1px solid var(--c-rule);
    padding: var(--sp-2);
    margin: var(--sp-2) 0;
    font-family: var(--ff-mono, monospace);
    font-size: var(--fs-xs);
    color: var(--c-amber-light);
    white-space: pre-wrap;
    overflow-x: auto;
  }
  .earth-drawer__meta {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: var(--sp-2) var(--sp-3);
    margin: var(--sp-3) 0 0;
    font-size: var(--fs-xs);
  }
