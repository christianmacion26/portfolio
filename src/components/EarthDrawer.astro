---
/**
 * EarthDrawer.astro — v6.4 "Earth Mission Control" Bloomberg `<F1> Help`-
 * style right-side event drawer.
 *
 * Deviates from the plan's `:target` mechanism in favor of the native
 * `<details>` element. The two are functionally equivalent for an always-
 * mounted drawer-on-page-load scenario, but `<details>` wins on:
 *   - Accessibility: native keyboard semantics, ARIA state, focus.
 *   - Reduced-motion: no `transition: none` fight against the universal
 *     `tokens.css` override; the panel simply opens/closes without
 *     needing a position-based slide.
 *   - Multiple panels: a user can pin several events open at once.
 *
 * Architecture:
 *   - One `<details>` panel per news-burst event (36 total).
 *   - The whole drawer is hidden off-screen at `translateX(100%)`. When
 *     at least one panel is `open`, the `:has(details[open])` parent
 *     selector slides it into view at `translateX(0)`.
 *   - Each `summary` is a 44-px-tall tap target with the city, headline,
 *     and a +/- disclosure glyph.
 *   - Each panel body carries: timestamp, formula `<pre>`, signal pill,
 *     magnitude, desk-action 1-liner, source, research deep-link.
 *
 * Honored constraints:
 *   - No `client:*`, no `Math.random()`, no `Date.now()`. All timestamps
 *     are deterministic UTC strings baked into the corpus (the corpus
 *     came from Phase A research; no live data source touches this).
 *   - Palette tokens only.
 *   - `prefers-reduced-motion: reduce` honored (slide transition
 *     suppressed).
 */
interface DrawerEvent {
  slug: string;
  city: string;
  category: string;
  timestamp: string;
  title: string;
  formula: string;
  signal: string;
  magnitude: string;
  unit: string;
  deskAction: string;
  source: string;
}

