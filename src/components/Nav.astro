---
/**
 * Nav.astro — top navigation, responsive (collapses on mobile).
 * v3.5: split into primary (always-visible on desktop) and secondary
 * (Resources disclosure) to keep 1280px rows breathable.
 */
import { path } from '@utils/url';
import NavMore from '@components/NavMore.astro';
const { pathname } = Astro.url;
const isActive = (href: string) => {
  const suffix = href === '/' ? '/' : href;
  return pathname === suffix || pathname.startsWith(suffix + '/');
};

// Primary links — visible inline at every viewport >= 1024px.
// Mobile (<=980px) renders ALL links flat inside the burger menu.
const primary = [
  { href: path('/'), label: 'Home' },
  { href: path('/for-recruiters'), label: 'For recruiters' },
  { href: path('/proof'), label: 'Proof' },
  { href: path('/projects'), label: 'Projects' },
  { href: path('/solutions'), label: 'Solutions' },
  { href: path('/methodology'), label: 'Method' },
  { href: path('/now'), label: 'Now' },
];

// Secondary links - behind a "Resources" details disclosure on desktop,
// flat list on mobile.
const secondary = [
  { href: path('/positions'), label: 'Live book' },
  { href: path('/experience'), label: 'Experience' },
  { href: path('/publications'), label: 'Pubs' },
  { href: path('/papers'), label: 'Papers' },
  { href: path('/talks'), label: 'Talks' },
  { href: path('/contact'), label: 'Contact' },
  { href: path('/glossary'), label: 'Glossary' },
  { href: path('/uses'), label: 'Uses' },
  { href: path('/reading'), label: 'Reading' },
  { href: path('/about-this-site'), label: 'About this site' },
  { href: path('/colophon'), label: 'Colophon' },
];
---

<header class="nav">
  <div class="container nav__inner">
    <a href={path('/')} class="nav__brand" aria-label="Christian Macion - home">
      <picture class="nav__brand-mark" aria-hidden="true">
        <source media="(prefers-color-scheme: dark)" srcset={path('/cm-mark-amber-dark.svg')} />
        <img
          src={path('/cm-mark-amber-light.svg')}
          alt=""
          width="36"
          height="36"
        />
      </picture>
      <span class="nav__brand-text">
        <span class="nav__brand-name">Christian T. Macion, CTA<sup>®</sup></span>
        <span class="nav__brand-sub">Quant Researcher · AI Engineer</span>
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav__toggle-input" aria-hidden="true" />
    <label for="nav-toggle" class="nav__toggle" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav__links" aria-label="Primary">
      <div class="nav__primary">
        {
          primary.map(({ href, label }) => (
            <a href={href} class:list={['nav__link', { 'nav__link--active': isActive(href) }]}>
              {label}
            </a>
          ))
        }
        <NavMore items={secondary} mode="dropdown" class="nav__more" />
      </div>

      <div class="nav__secondary-row">
        <NavMore items={secondary} mode="inline" class="nav__more-flat" />
        <a
          href={path('/resume')}
          class="btn btn--primary btn--sm nav__cta nav__cta--mobile">Resume ↓</a
        >
      </div>

      <a
        href={path('/search?focus=1')}
        class="nav-search"
        aria-label="Search the site"
        title="Search (Pagefind)"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>
      {/* v6.1.0 — theme toggle REMOVED. The site is one consistent palette. */}
      <a href={path('/resume')} class="btn btn--primary btn--sm nav__cta nav__cta--desktop">Resume ↓</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    /* v6.1.0 — always institutional-tape (single palette, no light/dark flip) */
    background: rgba(13, 17, 23, 0.92);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--ink-on-tape);
  }
  /* v6.1.0 — light/dark mode removed. Background is always tape (set above
     on `.nav`); prefers-color-scheme and [data-theme] overrides are dead. */
  .nav__inner {
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
  }
  .nav__brand {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    text-decoration: none;
    color: #fff;        /* v6.1.0 — always tape nav, light text */
    flex-shrink: 0;
  }
  .nav__brand-mark {    display: block;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
  }
  .nav__brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .nav__brand-name {
    font-weight: 600;
    font-size: var(--fs-sm);
  }
  .nav__brand-name sup {
    font-size: 0.65em;
    color: var(--c-primary-2-light);
  }
  .nav__brand-sub {
    font-size: var(--fs-xs);
    color: rgba(255, 255, 255, 0.6);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .nav__primary {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .nav__secondary-row {
    display: none;
  }
  .nav__link {
    color: rgba(230, 237, 243, 0.7);  /* v6.1.0 — light text on dark nav */
    font-size: var(--fs-sm);
    font-weight: 500;
    padding: 0.5rem 0;
    border-bottom: 2px solid transparent;
    transition:
      color var(--transition),
      border-color var(--transition);
  }
  .nav__link:hover {
    color: var(--c-primary-2-light);
  }
  .nav__link--active {
    color: var(--c-primary-2-light);
    border-bottom-color: var(--c-primary-2);
  }
  .nav__cta--mobile {
    display: none;
  }

  /* === v6.x · Force amber on the Resume CTA (P0-4) ===
     .btn--primary uses var(--c-primary), which flips to a pale ink in
     dark mode → invisible against the dark navbar. Always amber. */
  .nav__cta {
    background: var(--c-amber-deep);
    color: #ffffff;
    border: 1px solid var(--c-amber);
  }
  .nav__cta:hover {
    background: var(--c-amber);
    color: #0a0d12;
  }

  /* === v6.1.0 — theme toggle CSS removed (the button is gone) === */

  /* === Search shortcut === */
  .nav-search {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-sm);
    color: rgba(230, 237, 243, 0.7);
    text-decoration: none;
    transition:
      color var(--transition),
      border-color var(--transition),
      background var(--transition);
  }
  .nav-search:hover {
    color: var(--c-primary-2-deep);
    border-color: var(--c-primary-2-deep);
  }
  .theme-toggle__sun,
  .theme-toggle__moon {
    transition: opacity var(--transition);
  }
  /* Default (light): show moon (suggest switching to dark) */
  .theme-toggle__sun {
    display: none;
  }
  .theme-toggle__moon {
    display: block;
  }
  /* Dark mode: show sun (suggest switching to light) */
  :root[data-theme='dark'] .theme-toggle__sun {
    display: block;
  }
  :root[data-theme='dark'] .theme-toggle__moon {
    display: none;
  }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .theme-toggle__sun {
      display: block;
    }
    :root:not([data-theme='light']) .theme-toggle__moon {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .theme-toggle__sun,
    .theme-toggle__moon {
      transition: none;
    }
  }

  .nav__toggle-input {
    display: none;
  }
  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 22px;    cursor: pointer;
  }
  .nav__toggle span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--c-ink);
    border-radius: 1px;
    transition: all 200ms ease;
  }

  @media (max-width: 1080px) {
    .nav__brand-sub {
      display: none;
    }
  }
  @media (max-width: 600px) {
    .nav__brand-name {
      font-size: 0.78rem;
      letter-spacing: -0.01em;
    }
    .nav__inner {
      gap: var(--sp-2);
    }
  }
  @media (max-width: 420px) {
    .nav__brand-name {
      font-size: 0.7rem;
    }
  }
  @media (max-width: 980px) {
    .nav__toggle {
      display: flex;
    }
    .nav__links {
      position: absolute;
      top: var(--nav-h);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: var(--c-bg);
      border-bottom: var(--border);
      padding: var(--sp-4) var(--sp-5);
      gap: var(--sp-2);
      transform: translateY(-200%);
      transition: transform 200ms ease;
      box-shadow: var(--shadow-md);
    }
    .nav__toggle-input:checked ~ .nav__links {
      transform: translateY(0);
    }
    /* On mobile: collapse primary row into the flat list, hide the dropdown */
    .nav__primary {
      display: none;
    }
    .nav__secondary-row {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .nav__link {
      padding: 0.625rem 0;
      border-bottom: 1px solid var(--c-rule-soft);
    }
    .nav__link--active {
      border-bottom-color: var(--c-primary);
    }
    .nav__cta--desktop {
      display: none;
    }
    .nav__cta--mobile {
      display: inline-flex;
      align-self: flex-start;
      margin-top: var(--sp-3);
    }
    .theme-toggle {
      align-self: flex-start;
      margin-top: var(--sp-3);
    }
    .nav-search {
      align-self: flex-start;
      margin-top: var(--sp-3);
    }
  }
</style>
