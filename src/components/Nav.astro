---
/**
 * Nav.astro — top navigation, responsive (collapses on mobile).
 * v3.5: split into primary (always-visible on desktop) and secondary
 * (Resources disclosure) to keep 1280px rows breathable.
 */
import { path } from '@utils/url';
import { profile } from '@utils/profile';
import NavMore from '@components/NavMore.astro';
const { pathname } = Astro.url;
const isActive = (href: string) => {
  const suffix = href === '/' ? '/' : href;
  return pathname === suffix || pathname.startsWith(suffix + '/');
};

// Primary links — visible inline at every viewport >= 1024px.
// Mobile (<=980px) renders ALL links flat inside the burger menu.
const primary = [
  { href: path('/'), label: 'Home' },
  { href: path('/for-recruiters'), label: 'For recruiters' },
  { href: path('/proof'), label: 'Proof' },
  { href: path('/projects'), label: 'Projects' },
  { href: path('/solutions'), label: 'Solutions' },
  { href: path('/methodology'), label: 'Method' },
  { href: path('/now'), label: 'Now' },
];

// v6.1.0 (Mission G) — Markets dropdown sits between Proof and Projects
// on desktop (as a <details><summary> disclosure), flat with a heading
// inside the burger menu on mobile. /ai is a sub-route of /research for
// nav IA but is its own page.
const markets = [
  { href: path('/markets'), label: 'Markets' },
  { href: path('/prediction-markets'), label: 'Prediction' },
  { href: path('/research'), label: 'Research' },
];

// Secondary links - behind a "Resources" details disclosure on desktop,
// flat list on mobile.
const secondary = [
  { href: path('/positions'), label: 'Live book' },
  { href: path('/experience'), label: 'Experience' },
  { href: path('/publications'), label: 'Pubs' },
  { href: path('/papers'), label: 'Papers' },
  { href: path('/talks'), label: 'Talks' },
  { href: path('/contact'), label: 'Contact' },
  { href: path('/glossary'), label: 'Glossary' },
  { href: path('/uses'), label: 'Uses' },
  { href: path('/reading'), label: 'Reading' },
  { href: path('/about-this-site'), label: 'About this site' },
  { href: path('/colophon'), label: 'Colophon' },
];
---

<header class="nav">
  <div class="container nav__inner">
    <a href={path('/')} class="nav__brand" aria-label="Christian Macion - home">
      <picture class="nav__brand-mark" aria-hidden="true">
        <source media="(prefers-color-scheme: dark)" srcset={path('/cm-mark-amber-dark.svg')} />
        <img src={path('/cm-mark-amber-light.svg')} alt="" width="36" height="36" />
      </picture>
      <span class="nav__brand-text">
        {
          /* v6.10.47 — derive the brand name from profile.fullName. The ®
            glyph is wrapped in <sup> so the existing `.nav__brand-name sup`
            rule (font-size 0.65em + amber tint) renders it as a proper
            typographic superscript instead of inline text. */
        }
        <span class="nav__brand-name" set:html={profile.fullName.replace('®', '<sup>®</sup>')} />
        <span class="nav__brand-sub">{profile.titles.short}</span>
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav__toggle-input" aria-hidden="true" />
    <label for="nav-toggle" class="nav__toggle" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav__links" aria-label="Primary">
      <div class="nav__primary">
        {
          /* v6.1.0 (Mission G) — Markets dropdown sits BETWEEN Proof and Projects.
            Split the loop into 3 chunks so the dropdown interrupts the linear
            flow at the spec'd position. */
        }
        {
          primary.slice(0, 3).map(({ href, label }) => (
            <a href={href} class:list={['nav__link', { 'nav__link--active': isActive(href) }]}>
              {label}
            </a>
          ))
        }
        <NavMore items={markets} mode="dropdown" label="Markets" class="nav__more" />
        {
          primary.slice(3).map(({ href, label }) => (
            <a href={href} class:list={['nav__link', { 'nav__link--active': isActive(href) }]}>
              {label}
            </a>
          ))
        }
        <NavMore items={secondary} mode="dropdown" class="nav__more" />
      </div>

      <div class="nav__secondary-row">
        <NavMore items={markets} mode="inline" label="Markets" class="nav__more-flat" />
        <NavMore items={secondary} mode="inline" class="nav__more-flat" />
        <a href={path('/resume')} class="btn btn--primary btn--sm nav__cta nav__cta--mobile"
          >Resume ↓</a
        >
      </div>

      <a
        href={path('/search?focus=1')}
        class="nav-search"
        aria-label="Search the site"
        title="Search (Pagefind)"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>
      {/* v6.1.0 — theme toggle REMOVED. The site is one consistent palette. */}
      <a href={path('/resume')} class="btn btn--primary btn--sm nav__cta nav__cta--desktop"
        >Resume ↓</a
      >
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    /* v6.1.0 — always institutional-tape (single palette, no light/dark flip).
       v6.11.6 — was rgba(13,17,23,1); use --c-tape token so future
       palette shifts propagate. */
    background: var(--c-tape);
    border-bottom: 1px solid var(--c-white-haze);
    color: var(--ink-on-tape);
  }
  /* v6.1.0 — light/dark mode removed. Background is always tape (set above
     on `.nav`); prefers-color-scheme and [data-theme] overrides are dead. */
  .nav__inner {
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
  }
  .nav__brand {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    text-decoration: none;
    color: var(--c-primary); /* v6.1.0 — always tape nav, light text */
    flex-shrink: 0;
    /* v6.3 polish — enforce ≥ 44 px tap target on the brand link.
       The audit flagged "Christian T. Macion, CTA®" at 184×36 px.
       min-height:44 lifts the rect without shifting visible content
       because the brand is centered in a 56 px nav row. */
    min-height: 44px;
    padding: 0.25rem 0;
  }
  .nav__brand-mark {
    display: block;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
  }
  .nav__brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .nav__brand-name {
    font-weight: 600;
    font-size: var(--fs-sm);
  }
  .nav__brand-name sup {
    font-size: 0.65em;
    color: var(--c-primary-2-light);
  }
  .nav__brand-sub {
    font-size: var(--fs-xs);
    color: var(--c-white-faint);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .nav__primary {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .nav__secondary-row {
    display: none;
  }
  .nav__link {
    color: var(--c-ink-mute); /* v6.1.0 — light text on dark nav */
    font-size: var(--fs-sm);
    font-weight: 500;
    padding: 0.5rem 0;
    /* v6.1 polish — enforce ≥ 44 px tap target on every nav link.
       The nav itself is 56 px tall; previous padding (0.5rem top/bot)
       rendered ~30 px high. min-height doesn't shift layout because
       the parent flex container centers content vertically. */
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    border-bottom: 2px solid transparent;
    transition:
      color var(--transition),
      border-color var(--transition);
  }
  .nav__link:hover {
    color: var(--c-primary-2-light);
  }
  .nav__link--active {
    color: var(--c-primary-2-light);
    border-bottom-color: var(--c-primary-2);
  }
  /* v6.1.0 — Match .nav__link color treatment when NavMore is nested
     in the primary row (Markets dropdown + Resources dropdown).
     NavMore's default styles are tuned for `--c-ink-2` against light bg;
     here the nav is institutional-tape, so re-color and remove the
     pill-shaped hover background that no longer fits the row layout. */
  .nav__primary .nav-more__summary {
    color: var(--c-ink-mute);
    font-size: var(--fs-sm);
    font-weight: 500;
    padding: 0.5rem 0;
    border-radius: 0;
    /* v6.1 polish — min-height + flex centering so the dropdown summary
       matches the .nav__link touch target. */
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .nav__primary .nav-more__summary:hover,
  .nav__primary .nav-more[open] .nav-more__summary {
    color: var(--c-primary-2-light);
    background: transparent;
  }
  .nav__primary .nav-more[open] .nav-more__summary {
    border-bottom: 2px solid var(--c-primary-2);
  }
  /* Highlight the Markets summary when any of its children is the
     current page. We can't use NavMore's built-in isActive on the
     summary because that helper is scoped to a single href; mark
     the summary manually via data-active on the <details>. */
  .nav__primary .nav-more[data-active] .nav-more__summary {
    color: var(--c-primary-2-light);
    border-bottom: 2px solid var(--c-primary-2);
  }
  .nav__cta--mobile {
    display: none;
  }

  /* === v6.x · Force amber on the Resume CTA (P0-4) ===
     .btn--primary uses var(--c-primary), which flips to a pale ink in
     dark mode → invisible against the dark navbar. Always amber. */
  .nav__cta {
    background: var(--c-amber-deep);
    color: var(--c-primary);
    border: 1px solid var(--c-amber);
  }
  .nav__cta:hover {
    background: var(--c-amber);
    color: var(--c-primary-deep);
  }

  /* === v6.1.0 — theme toggle CSS removed (the button is gone) === */

  /* === Search shortcut ===
   * v6.1.1 polish — the 32×32 icon button failed WCAG 2.5.5 (44×44).
   * The visual stays 32×32; an invisible `::after` pseudo-element
   * expands the hit target by 6px on every side (32 + 12 = 44×44),
   * without shifting the layout or changing the visible button box. */
  .nav-search {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--c-white-wisp);
    border-radius: var(--radius-sm);
    color: var(--c-ink-mute);
    text-decoration: none;
    transition:
      color var(--transition),
      border-color var(--transition),
      background var(--transition);
  }
  .nav-search::after {
    content: '';
    position: absolute;
    inset: -6px;
  }
  .nav-search:hover {
    color: var(--c-primary-2-light);
    border-color: var(--c-primary-2-light);
  }
  /* v6.11.6 — removed dead .theme-toggle__sun / .theme-toggle__moon /
     [data-theme='dark'] / prefers-color-scheme CSS. The theme toggle
     was removed (single palette, no light/dark flip) but the CSS
     survived. Aspirational bloat. */

  .nav__toggle-input {
    display: none;
  }
  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 22px;
    cursor: pointer;
  }
  .nav__toggle span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--c-ink);
    border-radius: 1px;
    transition: all 200ms ease;
  }

  @media (max-width: 1080px) {
    .nav__brand-sub {
      display: none;
    }
  }
  @media (max-width: 600px) {
    .nav__brand-name {
      font-size: 0.78rem;
      letter-spacing: -0.01em;
    }
    .nav__inner {
      gap: var(--sp-2);
    }
  }
  @media (max-width: 420px) {
    .nav__brand-name {
      font-size: 0.7rem;
    }
  }
  @media (max-width: 980px) {
    .nav__toggle {
      display: flex;
    }
    .nav__links {
      position: absolute;
      top: var(--nav-h);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: var(--c-bg);
      border-bottom: var(--border);
      padding: var(--sp-4) var(--sp-5);
      gap: var(--sp-2);
      transform: translateY(-200%);
      transition: transform 200ms ease;
      box-shadow: var(--shadow-md);
    }
    .nav__toggle-input:checked ~ .nav__links {
      transform: translateY(0);
    }
    /* On mobile: collapse primary row into the flat list, hide the dropdown */
    .nav__primary {
      display: none;
    }
    .nav__secondary-row {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .nav__link {
      padding: 0.625rem 0;
      border-bottom: 1px solid var(--c-rule-soft);
    }
    .nav__link--active {
      border-bottom-color: var(--c-primary);
    }
    .nav__cta--desktop {
      display: none;
    }
    .nav__cta--mobile {
      display: inline-flex;
      align-self: flex-start;
      margin-top: var(--sp-3);
    }
    /* v6.11.6 — removed dead .theme-toggle block from mobile MQ. */
    .nav-search {
      align-self: flex-start;
      margin-top: var(--sp-3);
    }
  }
</style>
