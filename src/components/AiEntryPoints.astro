---
/**
 * AiEntryPoints.astro — v6.5 "Graphic Visual Dynamic" AI-improved
 * entry-points chip row.
 *
 * Three server-rendered library-style tiles:
 *   - READ METHOD      → /methodology/                       (31-gate framework)
 *   - FIND PATTERN     → /research/#math-corpus              (26-pair corpus)
 *   - OPEN NOTEBOOKS   → /projects/?tag=quant                (15 projects)
 *
 * v6.5 visual upgrade (replaces the v6.4 wordy chip row):
 *   - 280×160 tile instead of an inline chip
 *   - Top-right animated radial-gradient sphere at 0.4 opacity
 *   - Center text: 14px tracked mono caps
 *   - Bottom 24px progress bar, full-width, 1px stroke + 4px amber fill at center
 *   - Bottom-right 10px mono count chip (31 GATES / 26 PAIRS / 15 PROJECTS)
 *   - Hover: 4px-wide amber bar slides in from the left (220ms, CSS-only)
 *   - Reduced-motion block honored
 *
 * Discipline (carried from plan §D.2):
 *   - Server-rendered. Zero runtime LLM cost.
 *   - "Library-style imperative-mono labels" — no chat widget.
 *   - All three URLs are deterministic pages in this Astro site.
 *
 * Honored constraints:
 *   - No `client:*`, no `Math.random()`, no `Date.now()`.
 *   - Palette tokens only.
 *   - `prefers-reduced-motion: reduce` honored (the radial pulse is
 *     suppressed via `@media (prefers-reduced-motion: reduce)`).
 */
type ChipIcon = 'book' | 'search' | 'box';

interface Chip {
  label: string;
  href: string;
  icon: ChipIcon;
  count: number;
  countLabel: string;
}

const chips: Chip[] = [
  {
    label: 'READ METHOD',
    href: '/methodology/',
    icon: 'book',
    count: 31,
    countLabel: 'GATES',
  },
  {
    label: 'FIND PATTERN',
    href: '/research/#math-corpus',
    icon: 'search',
    count: 26,
    countLabel: 'PAIRS',
  },
  {
    label: 'OPEN NOTEBOOKS',
    href: '/projects/?tag=quant',
    icon: 'box',
    count: 15,
    countLabel: 'PROJECTS',
  },
];

const ICONS: Record<ChipIcon, string> = {
  // Tiny inline SVGs — keep markup terse.
  book:
    '<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 2.5h6a2 2 0 0 1 2 2v7"/><path d="M2.5 2.5v7a2 2 0 0 0 2 2h6"/><path d="M2.5 11.5V13"/></svg>',
  search:
    '<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="6" r="3.5"/><path d="m9 9 3 3"/></svg>',
  box:
    '<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 1.5 2.5 4v6L7 12.5l4.5-2.5V4L7 1.5Z"/><path d="M2.5 4 7 6.5 11.5 4"/><path d="M7 6.5v6"/></svg>',
};
---

<section
  class="section section--tight ai-entry-points"
  aria-labelledby="ai-entry-title"
>
  <div class="container">
    <header class="ai-entry-points__head">
      <p class="section__eyebrow">Entry points</p>
      <h2 id="ai-entry-title" class="section__title">
        What would you like to see first?
      </h2>
    </header>

    <ul class="ai-entry-points__chips" role="list">
      {
        chips.map((c) => (
          <li>
            <a class="epip-tile" href={c.href} aria-label={`${c.label} — ${c.count} ${c.countLabel}`}>
              <span class="epip-tile__orb" set:html={ICONS[c.icon]} aria-hidden="true" />
              <span class="epip-tile__label">{c.label}</span>
              <div class="epip-tile__bar" aria-hidden="true">
                <span class="epip-tile__bar-fill" />
              </div>
              <span class="epip-tile__count mono">{c.count} {c.countLabel}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .ai-entry-points__head {
    text-align: center;
    margin-bottom: var(--sp-5);
  }

  .ai-entry-points__chips {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* 280 × 160 tile. Position-relative so the hover-rail can
     slide in from the left edge and the orb can sit top-right. */
  .epip-tile {
    position: relative;
    display: grid;
    grid-template-rows: 1fr auto;
    width: 280px;
    height: 160px;
    padding: var(--sp-3);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    background: var(--c-bg-2);
    color: var(--c-ink);
    text-decoration: none;
    overflow: hidden;
    /* Universal `a { min-height: 44px }` global rule is the safety net;
       this chip-level baseline keeps the visible hit-test stable. */
    min-height: 44px;
    transition:
      border-color var(--transition),
      background var(--transition),
      transform var(--transition);
  }

  /* v6.7 — Animated radial-gradient orb top-right. v6.6 had it
     positioned outside the tile (top:-38, right:-38) which made it
     render as a half-circle smudge. Pulled fully inside the tile
     and trimmed the size so it reads as decoration, not bleed. */
  .epip-tile__orb {
    position: absolute;
    top: -16px;
    right: -16px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 30%,
      var(--c-amber-light),
      var(--c-tape) 70%
    );
    opacity: 0.55;
    animation: epip-orb-pulse 6s ease-in-out infinite;
    pointer-events: none;
    filter: blur(0.5px);
  }

  @keyframes epip-orb-pulse {
    0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.50; }
    50%      { transform: scale(1.08) rotate(8deg); opacity: 0.62; }
  }

  /* Center text — 14px tracked mono caps. Icon glyph sits over the orb. */
  .epip-tile__label {
    align-self: center;
    justify-self: center;
    font-family: var(--ff-mono);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    color: var(--c-ink);
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .epip-tile__label svg {
    color: var(--c-primary-2-light);
  }

  /* Bottom 24px-tall progress bar at full-width.
     1px stroke + 4px amber fill at center.
     Fill width = a tasteful, palette-faithful 38% so the bar reads as
     "loaded, not full" without needing per-chip data. */
  .epip-tile__bar {
    height: 24px;
    width: 100%;
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--c-tape);
    align-self: end;
  }
  .epip-tile__bar-fill {
    display: block;
    width: 38%;
    height: 4px;
    background: var(--c-primary-2);
    border-radius: 2px;
  }

  /* Bottom-right 10px mono count chip. */
  .epip-tile__count {
    position: absolute;
    right: var(--sp-2);
    bottom: 30px;        /* sits above the progress bar */
    font-size: 10px;
    color: var(--c-ink-3);
    letter-spacing: 0.04em;
    background: rgba(13, 17, 23, 0.65);
    border: 1px solid var(--c-rule);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  /* Hover: 4px-wide amber bar slides in from the left, 220ms CSS-only. */
  .epip-tile::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0;            /* animated open on hover */
    background: var(--c-primary-2);
    transition: width 220ms ease;
    pointer-events: none;
  }
  .epip-tile:hover {
    border-color: var(--c-primary-2);
  }
  .epip-tile:hover::before {
    width: 4px;
  }
  .epip-tile:focus-visible {
    outline: 2px solid var(--c-primary-2);
    outline-offset: 2px;
  }

  @media (max-width: 720px) {
    .ai-entry-points__chips {
      flex-direction: column;
      align-items: center;
    }
    .epip-tile {
      width: 100%;
      max-width: 320px;
    }
  }

  /* Reduced motion: kill the orb pulse + hover slide. */
  @media (prefers-reduced-motion: reduce) {
    .epip-tile__orb {
      animation: none;
    }
    .epip-tile::before,
    .epip-tile:hover::before {
      transition: none;
    }
  }
</style>
