---
/**
 * StatementCarousel.astro — single-line rotating statement carousel.
 *
 * Per UI/UX research synthesis (v6.0.7), the institutional "rotating
 * statement" pattern is the HRT signature ("innovators. engineers.
 * technologists. mathematicians."). It demonstrates a firm's discipline
 * by rotating through complete sentences — not just vocabulary.
 *
 * Auto-advances every 5s. Pauses on hover or keyboard focus. Dots
 * indicator below for manual navigation. Respects prefers-reduced-motion
 * (no auto-advance, no fade).
 *
 * v6.0.13 — Cross-fade bug fix:
 *   The previous CSS+JS had two slides at non-zero opacity for the full
 *   320 ms transition window (outgoing at 1→0, incoming at 0→1) because
 *   both `is-active` toggles ran synchronously in `show()` and both had
 *   the same CSS transition. The result was stacked glyphs bisecting each
 *   other, clipped to the viewport's overflow.
 *
 *   Fix: only the INCOMING slide animates. Outgoing snaps via 0 ms
 *   transition (`transition: opacity 0ms` outside `.is-active`).
 *   This eliminates the 320 ms visual overlap.
 *
 *   v6.0.13 also: track width set to 100% so the 0-wide-content bug
 *   (parent flex item with absolute-only children) is fixed; dots shrunk
 *   slightly; dot row centered via flex justify-content.
 *
 * Usage:
 *   <StatementCarousel />
 *   <StatementCarousel
 *     statements={[
 *       'Eval-first. ↦ Ship-ready.',
 *       'NDA-clean. ↦ Reproducible.',
 *     ]}
 *   />
 */

interface Props {
  /** Statements to rotate through. Defaults match the canonical site-wide set. */
  statements?: string[];
  /** Auto-advance interval in milliseconds. Default 5000ms. */
  intervalMs?: number;
  /** Optional label for screen readers. */
  label?: string;
}

const {
  statements = [
    'Eval-first. ↦ Ship-ready.',
    'NDA-clean. ↦ Public-data reproducible.',
    '31 gates. ↦ Zero rollbacks.',
    'PBO-tested. ↦ OOS-validated.',
    '11 agents. ↦ One method.',
    '102 certs. ↦ One discipline.',
  ] as string[],
  intervalMs = 5000,
  label = 'Discipline statements — rotating',
} = Astro.props;
---

<div class="stmt-carousel" data-stmt-carousel data-interval={String(intervalMs)} aria-roledescription="carousel" aria-label={label}>
  <div class="stmt-carousel__viewport">
    <ol class="stmt-carousel__track">
      {statements.map((s, i) => (
        <li
          class:list={['stmt-carousel__slide', { 'is-active': i === 0 }]}
          aria-hidden={i === 0 ? 'false' : 'true'}
          data-stmt-index={i}
        >
          {/* Inner span gives us a real block child so `text-wrap: balance`
              and `padding-inline` work — bare text inside a flex item
              becomes an anonymous flex item with `min-width: auto` and
              refuses to wrap properly. */}
          <span class="stmt-carousel__text">{s}</span>
        </li>
      ))}
    </ol>
  </div>
  <ol class="stmt-carousel__dots" role="tablist" aria-label="Choose statement">
    {statements.map((_s, i) => (
      <li>
        <button
          type="button"
          class:list={['stmt-carousel__dot', { 'is-active': i === 0 }]}
          data-stmt-dot={i}
          aria-label={`Show statement ${i + 1}`}
          aria-pressed={i === 0 ? 'true' : 'false'}
        ></button>
      </li>
    ))}
  </ol>
</div>

<!-- Driver is in src/scripts/carousel.ts, imported via BaseLayout.
     Astro 7 was dropping per-component <script> blocks during the build
     (the chunk never materialised in dist/_astro/), so the carousel
     silently rendered as static HTML with no behavior. Routing the
     driver through the BaseLayout bundle — alongside reveal-on-scroll,
     odometer, active-nav, copy-button, scroll-progress — guarantees it
     ships on every page that includes the carousel. -->

<style>
  .stmt-carousel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4) 0;
    border-top: 1px solid var(--c-rule-soft);
    border-bottom: 1px solid var(--c-rule-soft);
    background: var(--c-bg);
  }

  .stmt-carousel__viewport {
    width: 100%;
    max-width: 760px;
    overflow: hidden;
    /* Reserve ~2 lines of vertical space so a 2-line wrap doesn't shift
       the dots down on each slide. */
    min-height: 3.4em;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .stmt-carousel__track {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    /* v6.0.13 — width:100% is critical. Without it, the track (a flex
       item whose only children are `position: absolute`) collapses to
       its content size, which is 0, and the slides render as a 0-wide
       column overflowing the viewport's overflow-hidden — clipped to
       a narrow center slice that looks like "...ugeni." / "O...". */
    width: 100%;
    height: 3.4em;
  }

  .stmt-carousel__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif-display);
    font-style: italic;
    font-size: clamp(1.05rem, 2.2vw, 1.4rem);
    line-height: 1.4;
    color: var(--c-ink);
    letter-spacing: -0.005em;
    padding: 0;
    opacity: 0;
    /* v6.0.13 — outgoing slide gets a 0 ms transition (instant hide)
       so the active slide's 280 ms fade-in never overlaps a fading-out
       slide. The single `is-active` class flip then produces a clean
       cross-fade without stacked glyphs. */
    transition: opacity 0ms;
    pointer-events: none;
    z-index: 1;
  }
  .stmt-carousel__slide.is-active {
    opacity: 1;
    transition: opacity 280ms var(--ease-out);
    z-index: 2;
  }
  .stmt-carousel__text {
    display: block;
    text-align: center;
    text-wrap: balance;
    padding-inline: var(--sp-4);
  }

  .stmt-carousel__dots {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    gap: var(--sp-2);
  }
  .stmt-carousel__dots li {
    display: flex;
  }
  .stmt-carousel__dot {
    width: 44px;
    height: 44px;
    padding: 0;
    border-radius: 50%;
    border: 0;
    background: transparent;
    cursor: pointer;
    transition:
      background var(--transition),
      border-color var(--transition),
      transform var(--transition);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* Inner visible 6 px dot; outer 44 px is the hit target. */
  .stmt-carousel__dot::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 1px solid var(--c-ink-3);
    background: transparent;
    transition:
      background var(--transition),
      border-color var(--transition),
      transform var(--transition);
  }
  .stmt-carousel__dot:hover::before {
    border-color: var(--c-primary-2);
  }
  .stmt-carousel__dot.is-active::before {
    background: var(--c-primary-2);
    border-color: var(--c-primary-2);
    transform: scale(1.4);
  }

  /* Small viewport: shrink dots so 6 × 32 + 5 × 4 = 212 px fits in 320 px. */
  @media (max-width: 480px) {
    .stmt-carousel__dot {
      width: 32px;
      height: 32px;
    }
    .stmt-carousel__dots {
      gap: var(--sp-1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stmt-carousel__slide {
      transition: none;
    }
  }
</style>
