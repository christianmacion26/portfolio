---
/**
 * TrustStrip.astro — narrow horizontal strip of "trust anchors" rendered
 * below the hero on the home page. Each chip points at a verifiable proof
 * surface elsewhere on the site.
 *
 * Trust anchors surfaced here:
 *   - Tested against           → numerical-faithfulness eval harness
 *   - Reproducible builds       → public repos + Pages deploys
 *   - NDA-safe by construction  → disclosure + Ferioli reference
 *   - Public RSS / Atom feed    → /feed.xml
 *   - Open-source first         → 6+ repos
 *
 * Why a strip (and not just a sentence): each anchor is a *pointer* to
 * evidence. Hiring managers skim — make the pointers skimmable.
 *
 * Build SHA: derived from `import.meta.env.PUBLIC_BUILD_SHA` if the build
 * pipeline wired it. If missing, the build pill is hidden entirely — we
 * never show "sha-loc" or "sha-unk" placeholders, which read as dishonest.
 *
 * Icons: inline SVG, currentColor, 12px. No Unicode glyphs, no emoji — those
 * render as tofu or in unrelated platform colors on recruiter machines.
 */
import { buildStampUtc8 as _bs } from '@utils/build-stamp';
import { path } from '@utils/url';

interface Props {
  variant?: 'paper' | 'tape';
  buildSha?: string;
}
const { variant = 'paper', buildSha = import.meta.env.PUBLIC_BUILD_SHA as string | undefined } =
  Astro.props;
// Deterministic per build (Standing Order §9: no `new Date()` in
// deterministic outputs). The prop can still be passed from an external
// caller (e.g., a future CI step that overrides the stamp), but the
// default is the build-time UTC+8 stamp.
const lastVerified = _bs();
const shortSha = buildSha ? buildSha.replace(/^.*?([0-9a-f]{7,})$/, '$1').slice(0, 7) : null;
---

<aside class:list={['trust-strip', `trust-strip--${variant}`]} aria-label="Portfolio trust signals">
  <div class="trust-strip__inner">
    <span class="trust-strip__title mono">trust/</span>

    <a
      class="trust-pill"
      href={`${path('/proof')}/#code-artifacts`}
      title="All metrics evaluated by a separate harness"
    >
      <svg
        class="trust-pill__icon"
        viewBox="0 0 16 16"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M6 3h4l3 3v7a1 1 0 0 1-1 1H6a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3Z"></path><path
          d="m6 9 1.8 1.8L11 7"></path></svg
      >
      <span class="trust-pill__label">tested</span>
      <span class="trust-pill__detail">numerical-eval</span>
    </a>

    <a
      class="trust-pill"
      href={path('/projects')}
      title="Every project ships with a public repo + pages deploy"
    >
      <svg
        class="trust-pill__icon"
        viewBox="0 0 16 16"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="4" cy="4" r="1.5"></circle><circle cx="12" cy="4" r="1.5"></circle><circle
          cx="4"
          cy="12"
          r="1.5"></circle><circle cx="12" cy="12" r="1.5"></circle><circle cx="8" cy="8" r="1.5"
        ></circle><path d="M4 4 8 8M12 4 8 8M4 12 8 8M12 12 8 8"></path></svg
      >
      <span class="trust-pill__label">reproducible</span>
      <span class="trust-pill__detail">public repos</span>
    </a>

    <a
      class="trust-pill"
      href={`${path('/experience')}/#nda-safe`}
      title="Past engagement disclosed at /experience; PM-verified, NDA-clean by construction"
    >
      <svg
        class="trust-pill__icon"
        viewBox="0 0 16 16"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M8 1.5 2.5 4v4.2c0 3 2.4 5.5 5.5 6.3 3.1-.8 5.5-3.3 5.5-6.3V4L8 1.5Z"></path><path
          d="m5.8 8 1.6 1.6L10.4 6.6"></path></svg
      >
      <span class="trust-pill__label">NDA-clean</span>
      <span class="trust-pill__detail">by construction</span>
    </a>

    <a
      class="trust-pill"
      href={path('/feed.xml')}
      rel="alternate"
      type="application/atom+xml"
      title="Atom feed of new projects"
    >
      <svg
        class="trust-pill__icon"
        viewBox="0 0 16 16"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M3 4.5a8.5 8.5 0 0 1 8.5 8.5"></path><path d="M3 8.5a4.5 4.5 0 0 1 4.5 4.5"
        ></path><circle cx="3.8" cy="12.2" r="1.1" fill="currentColor"></circle></svg
      >
      <span class="trust-pill__label">RSS</span>
      <span class="trust-pill__detail">/feed.xml</span>
    </a>

    {
      shortSha && (
        <span class="trust-pill trust-pill--static" title={`Site build ${shortSha}`}>
          <svg
            class="trust-pill__icon"
            viewBox="0 0 16 16"
            aria-hidden="true"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <>
              <path d="M2 4 8 1.5 14 4v8L8 14.5 2 12V4Z" />
              <path d="M2 4 8 6.5 14 4M8 6.5V14.5" />
            </>
          </svg>
          <span class="trust-pill__label">build</span>
          <span class="trust-pill__detail mono">{shortSha}</span>
        </span>
      )
    }

    <span class="trust-pill trust-pill--static" title={`All claims re-verified on ${lastVerified}`}>
      <svg
        class="trust-pill__icon"
        viewBox="0 0 16 16"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M2.5 8a5.5 5.5 0 0 1 9.4-3.9M13.5 8a5.5 5.5 0 0 1-9.4 3.9"></path><path
          d="m11.5 1.5 1 2.5-2.5.5M4.5 14.5l-1-2.5 2.5-.5"></path></svg
      >
      <span class="trust-pill__dot" aria-hidden="true"></span>
      <span class="trust-pill__label">verified</span>
      <span class="trust-pill__detail mono">{lastVerified}</span>
    </span>
  </div>
</aside>

<style>
  .trust-strip {
    border-block: var(--border);
    background: var(--c-bg);
  }
  .trust-strip--paper {
    background: var(--c-paper);
  }
  .trust-strip--tape {
    background: var(--c-bg-2);
    color: var(--c-ink);
  }
  .trust-strip__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: var(--sp-3) var(--sp-4);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-2) var(--sp-3);
  }
  .trust-strip__title {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    margin-right: var(--sp-2);
  }

  .trust-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-sm);
    font-size: var(--fs-xs);
    background: var(--c-bg);
    color: var(--c-ink);
    text-decoration: none;
    /* v6.3 polish — audit flagged 4 pills at 176-208×30 px on mobile
       ("tested numerical-eval", "reproducible public repos",
       "NDA-clean by construction", "RSS /feed.xml"). The visible
       pill is fine but the touch rect was only 30 px tall;
       min-height:44 lifts the rect without enlarging the visible
       capsule (the border + padding absorb the extra 14 px inside
       the hit area). */
    min-height: 44px;
    transition:
      border-color var(--transition),
      background var(--transition),
      transform var(--transition);
  }
  a.trust-pill:hover {
    border-color: var(--c-amber-deep);
    /* v6.10.41 — derive hover tint from --c-amber via color-mix so
       palette tweaks propagate. Was rgba(196,138,22,0.06). */
    background: color-mix(in oklab, var(--c-amber) 6%, transparent);
  }
  .trust-pill--static {
    cursor: default;
    background: var(--c-bg-2);
  }
  .trust-pill__icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: var(--c-amber-deep);
  }
  .trust-strip--tape .trust-pill__icon {
    color: var(--c-amber);
  }
  .trust-pill__label {
    font-weight: 600;
    color: var(--c-ink);
  }
  .trust-pill__detail {
    color: var(--c-ink-2);
  }

  /* === Phase D-9 · verified-dot pulse ===
     Subtle 2.4s breathing on the green dot before "verified" — the lone
     "live" affordance in the TrustStrip. Disables under reduced-motion. */
  .trust-pill__dot {
    display: inline-block;
    width: 6px;
    /* F21 — institutional: kill the halo-pulse. Subtle opacity pulse
       remains (it's a status semantics, not a glow ring). */
    height: 6px;
    border-radius: 50%;
    background: var(--c-primary-2); /* single amber accent, not pass-green */
    animation: trust-pulse 2.4s var(--ease-snappy) infinite;
    flex-shrink: 0;
  }
  @keyframes trust-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.6;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .trust-pill__dot {
      animation: none;
    }
  }

  @media (max-width: 720px) {
    .trust-strip__inner {
      justify-content: flex-start;
    }
  }
</style>
