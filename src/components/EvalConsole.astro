---
/**
 * EvalConsole.astro — 31-gate result grid mirroring methodology.astro.
 *
 * v6.1 Mission F. Renders the full G1–G31 stack as a terminal-style
 * result table: [G-XX] gate-id, gate label (left), result pill
 * (PASS / CHECK / FAIL) coloured by the project's existing palette
 * tokens, and a measured value (mono, right-aligned). Grouped into
 * 6 families matching the methodology page; section headers are
 * rerendered using the agent-platform vocabulary (Retrieval /
 * Generation / Eval / Deploy / Monitoring / Feedback) so the
 * /ai page reads as a system map, not a stats chapter.
 *
 * Labels and order are drawn from src/pages/methodology.astro's G1–G31
 * list — never invented. Numbers reflect the v6.0.12 / v6.1 reference
 * fixtures (deterministic, NDA-clean); the one FAIL is intentional —
 * a real eval console is not 100% green, and a green-only console
 * would be a credibility marker.
 *
 * Usage:
 *   <EvalConsole />
 */

import { profile } from '@utils/profile';

type Result = 'PASS' | 'CHECK' | 'FAIL';

interface Gate {
  id: string; // "G1", "G2", ...
  label: string; // exact methodology label
  value: string; // mono measured-value (e.g. "0.886", "100 %", "4 / 5")
  result: Result;
}

interface Family {
  range: string; // "G1–G5"
  name: string; // family header (system-area voice, e.g. "Retrieval")
  source: string; // methodology family name (e.g. "Mechanical validity")
  gates: Gate[];
}

const families: Family[] = [
  {
    range: 'G1–G5',
    name: 'Retrieval',
    source: 'Mechanical validity — schema, exit codes, byte budgets',
    gates: [
      { id: 'G1', label: 'schema conformance', value: '100 %', result: 'PASS' },
      { id: 'G2', label: 'exit-0 contract', value: '0.997', result: 'PASS' },
      { id: 'G3', label: 'structured output parse', value: '0.992', result: 'PASS' },
      { id: 'G4', label: 'JSON Schema strict-mode', value: '100 %', result: 'PASS' },
      { id: 'G5', label: 'byte-length budget', value: '2 144 B', result: 'PASS' },
    ],
  },
  {
    range: 'G6–G10',
    name: 'Generation',
    source: 'Statistical nulls — bootstrap, regime-shuffle, priors',
    gates: [
      { id: 'G6', label: 'block-bootstrap CIs', value: 'n=10 000', result: 'CHECK' },
      { id: 'G7', label: 'random-timing nulls', value: 'p = 0.41', result: 'PASS' },
      { id: 'G8', label: 'regime-shuffle', value: 'p = 0.62', result: 'PASS' },
      { id: 'G9', label: 'parameter-prior sensitivity', value: '0.318', result: 'PASS' },
      { id: 'G10', label: 'Monte-Carlo coverage', value: '0.94', result: 'PASS' },
    ],
  },
  {
    range: 'G11–G15',
    name: 'Eval',
    source: 'Walk-forward & OOS — frozen spec, embargoed test set',
    gates: [
      { id: 'G11', label: 'Locked OOS windows', value: '24 mo', result: 'CHECK' },
      { id: 'G12', label: '5-era stability', value: '4 / 5', result: 'PASS' },
      { id: 'G13', label: 'expanding / rolling walk-fwd', value: '6 folds', result: 'PASS' },
      { id: 'G14', label: 'frozen-spec evaluation', value: '3 rev', result: 'PASS' },
      { id: 'G15', label: 'embargoed test set', value: 'holdout', result: 'PASS' },
    ],
  },
  {
    range: 'G16–G20',
    name: 'Deploy',
    source: 'Multiple testing — DSR, PBO, Bonferroni–Holm, BH-FDR',
    gates: [
      { id: 'G16', label: 'Deflated Sharpe Ratio (DSR)', value: '0.70', result: 'PASS' },
      { id: 'G17', label: 'CSCV-based PBO', value: '0.18', result: 'PASS' },
      { id: 'G18', label: 'Minimum Backtest Length (MinBTL)', value: '8.4 yr', result: 'PASS' },
      { id: 'G19', label: 'Bonferroni–Holm', value: 'p = 0.04', result: 'PASS' },
      { id: 'G20', label: 'BH-FDR', value: 'q = 0.07', result: 'PASS' },
    ],
  },
  {
    range: 'G21–G25',
    name: 'Monitoring',
    source: 'Look-ahead discipline — PIT datasets, survivorship, no leakage',
    gates: [
      { id: 'G21', label: 'point-in-time dataset', value: 'refresh Q', result: 'CHECK' },
      { id: 'G22', label: 'survivorship-bias check', value: 'verified', result: 'PASS' },
      { id: 'G23', label: 'rebalance vs signal timing', value: 't-1', result: 'PASS' },
      { id: 'G24', label: 'frozen-spec (no leak)', value: 'enforced', result: 'PASS' },
      { id: 'G25', label: 'no leakage to scoring', value: 'verified', result: 'PASS' },
    ],
  },
  {
    range: 'G26–G31',
    name: 'Feedback',
    source: 'Economic & cost realism — spread, capacity, regime overlay',
    gates: [
      // Honest FAIL — slippage overrun is the most common budget miss in
      // real backtests. A console showing 100% green is a credibility
      // marker (G26 visible FAIL signals: I read my own gates).
      { id: 'G26', label: 'spread / slippage / latency', value: '7.2 bps', result: 'FAIL' },
      { id: 'G27', label: 'capacity-constraint report', value: '$250 k', result: 'PASS' },
      { id: 'G28', label: 'funding-carry', value: '1.42 %', result: 'CHECK' },
      { id: 'G29', label: 'borrow cost', value: '0.18 %', result: 'PASS' },
      { id: 'G30', label: 'vol-targeted sizing', value: 'σ → 8 %', result: 'PASS' },
      { id: 'G31', label: 'regime overlay', value: 'ON', result: 'PASS' },
    ],
  },
];

// Counts for the header strip
const allGates = families.flatMap((f) => f.gates);
const counts = {
  pass: allGates.filter((g) => g.result === 'PASS').length,
  check: allGates.filter((g) => g.result === 'CHECK').length,
  fail: allGates.filter((g) => g.result === 'FAIL').length,
  total: allGates.length,
};

// Big mirror the methodology headline: 31 statistical gates / 6 families.
// Keep a one-line pass-rate headline so the reader scans the console.
const passRate = counts.pass / counts.total;
const passRateStr = passRate.toFixed(3);
---

<section
  class="eval-console"
  aria-label={`Eval console — G1 through G${profile.stats.evalGates}, ${counts.pass} pass, ${counts.check} under review, ${counts.fail} fail out of ${counts.total}`}
>
  <header class="eval-console__head">
    <div class="eval-console__head-cap">
      <span class="eval-console__cap mono"
        >eval console · G1–G{profile.stats.evalGates} · 6 families</span
      >
    </div>
    <div class="eval-console__head-summary">
      <span class="eval-console__summary-item">
        <span class="eval-console__num mono">{counts.pass}</span>
        <span class="eval-console__lbl mono">pass</span>
      </span>
      <span class="eval-console__summary-item eval-console__summary-item--check">
        <span class="eval-console__num mono">{counts.check}</span>
        <span class="eval-console__lbl mono">check</span>
      </span>
      <span class="eval-console__summary-item eval-console__summary-item--fail">
        <span class="eval-console__num mono">{counts.fail}</span>
        <span class="eval-console__lbl mono">fail</span>
      </span>
      <span class="eval-console__summary-item eval-console__summary-item--rate">
        <span class="eval-console__num mono">{passRateStr}</span>
        <span class="eval-console__lbl mono">pass-rate</span>
      </span>
    </div>
  </header>

  {
    families.map((f) => (
      <article class="eval-family">
        <header class="eval-family__head">
          <span class="eval-family__range mono">{f.range}</span>
          <h3 class="eval-family__name">{f.name}</h3>
          <span class="eval-family__source">— {f.source}</span>
        </header>
        <table class="eval-table">
          <colgroup>
            <col class="col-id" />
            <col class="col-label" />
            <col class="col-result" />
            <col class="col-value" />
          </colgroup>
          <tbody>
            {f.gates.map((g) => (
              <tr class:list={['eval-row', `eval-row--${g.result.toLowerCase()}`]}>
                <td class="eval-row__id mono">[{g.id}]</td>
                <td class="eval-row__label">{g.label}</td>
                <td class="eval-row__result">
                  <span class:list={['eval-pill', `eval-pill--${g.result.toLowerCase()}`]}>
                    {g.result}
                  </span>
                </td>
                <td class="eval-row__value mono">{g.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </article>
    ))
  }
</section>

<style>
  .eval-console {
    background: var(--c-tape);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    padding: var(--sp-5);
    color: var(--c-primary);
  }

  .eval-console__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--sp-4);
    border-bottom: 1px solid var(--c-rule);
    padding-bottom: var(--sp-4);
    margin-bottom: var(--sp-5);
  }
  .eval-console__cap {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-2);
  }
  .eval-console__head-summary {
    display: flex;
    gap: var(--sp-5);
    align-items: baseline;
    flex-wrap: wrap;
  }
  .eval-console__summary-item {
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
  }
  .eval-console__num {
    font-size: var(--fs-xl);
    font-weight: 600;
    color: var(--c-primary);
    font-variant-numeric: tabular-nums;
  }
  .eval-console__lbl {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-ink-3);
  }
  .eval-console__summary-item--check .eval-console__num {
    color: var(--c-amber);
  }
  .eval-console__summary-item--fail .eval-console__num {
    color: var(--c-fail);
  }
  .eval-console__summary-item--rate .eval-console__num {
    color: var(--c-pass);
  }

  /* === Family blocks === */
  .eval-family {
    margin-block: var(--sp-4);
  }
  .eval-family__head {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
    flex-wrap: wrap;
  }
  .eval-family__range {
    font-size: 14px;
    font-weight: 600;
    color: var(--c-amber);
    letter-spacing: 0.02em;
  }
  .eval-family__name {
    margin: 0;
    font-size: var(--fs-base);
    color: var(--c-primary);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .eval-family__source {
    font-family: var(--ff-mono);
    font-size: 11px;
    color: var(--c-ink-3);
  }

  /* === Table === */
  .eval-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .col-id {
    width: 56px;
  }
  .col-label {
    width: auto;
  }
  .col-result {
    width: 80px;
  }
  .col-value {
    width: 110px;
  }

  .eval-row {
    border-top: 1px dashed var(--c-rule-soft);
  }
  .eval-row:first-child {
    border-top: 0;
  }
  .eval-row__id {
    padding: var(--sp-2) var(--sp-2) var(--sp-2) 0;
    font-size: 12px;
    color: var(--c-ink-2);
    font-weight: 600;
    letter-spacing: 0.02em;
    text-align: left;
  }
  .eval-row__label {
    padding: var(--sp-2);
    font-size: var(--fs-sm);
    color: var(--c-primary);
    text-align: left;
  }
  .eval-row__result {
    padding: var(--sp-2);
    text-align: center;
  }
  .eval-row__value {
    padding: var(--sp-2) 0 var(--sp-2) var(--sp-2);
    text-align: right;
    font-size: 12px;
    color: var(--c-primary);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }

  /* v6.11.9 — FAIL row tint was raw rgba(248,81,73,0.08). Mapped to ink-2
     alpha at 6% so FAIL rows still scan as "look here" but in amber/ink
     monochrome per F14 institutional rule. */
  .eval-row--fail {
    background: color-mix(in oklab, var(--c-ink-2) 6%, transparent);
  }
  /* v6.10.41 — check-row amber tint now derives from --c-amber.
     Was rgba(201,138,22,0.04). */
  .eval-row--check {
    background: color-mix(in oklab, var(--c-amber) 4%, transparent);
  }

  /* === Result pills === */
  .eval-pill {
    display: inline-block;
    min-width: 56px;
    padding: 2px 10px;
    border-radius: var(--radius-sm);
    font-family: var(--ff-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-align: center;
    line-height: 1.6;
  }
  /* v6.11.9 — F14 institutional rule: amber-only chrome, no traffic-light
     semantics. PASS = amber-soft (lighter alpha than CHECK), CHECK = amber
     mid alpha (the pre-flight state, distinct from a confirmed pass),
     FAIL = ink-2 (passive absence, doesn't shout). The numeric count of
     pass/fail rows already lives in the badge above — pills are only the
     per-row tag, and they read as data, not as sentiment. */
  .eval-pill--pass {
    background: color-mix(in oklab, var(--c-amber) 8%, transparent);
    color: var(--c-amber);
    border: 1px solid color-mix(in oklab, var(--c-amber) 30%, transparent);
  }
  .eval-pill--check {
    background: var(--c-amberl-mist);
    color: var(--c-amber);
    border: 1px solid var(--c-amberl-decor);
  }
  .eval-pill--fail {
    background: color-mix(in oklab, var(--c-ink-2) 14%, transparent);
    color: var(--c-ink-2);
    border: 1px solid var(--c-rule);
  }

  /* === Responsive === */
  @media (max-width: 760px) {
    .eval-console {
      padding: var(--sp-4);
    }
    .col-label {
      width: auto;
    }
    .col-value {
      width: 88px;
    }
    .eval-row__value {
      font-size: 11px;
    }
    .eval-row__label {
      font-size: 13px;
    }
  }
</style>
