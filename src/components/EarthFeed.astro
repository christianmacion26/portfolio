---

<aside class="earth-feed" aria-label="News from Earth, last 24 hours">
  <header class="earth-feed__head">
    <span class="earth-feed__title">news/</span>
    <span class="earth-feed__count">{events.length} events · last 24h</span>
  </header>
  <div class="earth-feed__viewport">
    <ol class="earth-feed__track">
      {
        events.concat(events).map((e) => (
          <li class="earth-feed__chip">
            <a href={`${path('/research')}#event-${e.slug}`}>
              <span class="earth-feed__city">{e.city} ·</span>
              <span class="earth-feed__head-text">{e.title}</span>
              <span class:list={['earth-feed__signal', `earth-feed__signal--${e.signal}`]}>
                {e.signal}
              </span>
            </a>
          </li>
        ))
      }
    </ol>
  </div>
</aside>

<style>
  .earth-feed {
    border-block: 1px solid var(--c-rule);
    background: var(--c-tape);
    overflow: hidden;
  }
  .earth-feed__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-2) var(--sp-4);
    border-bottom: 1px solid var(--c-rule-soft);
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
  }
  .earth-feed__title {
    color: var(--c-ink-3);
    letter-spacing: 0.06em;
    text-transform: lowercase;
  }
  .earth-feed__count {
    color: var(--c-ink-2);
    letter-spacing: 0.06em;
  }

  .earth-feed__viewport {
    width: 100%;
    overflow: hidden;
    height: 2.4em;
  }
  .earth-feed__track {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    height: 100%;
    animation: earth-feed-scroll 96s linear infinite;
    width: max-content;
  }
  .earth-feed__viewport:hover .earth-feed__track,
  .earth-feed__viewport:focus-within .earth-feed__track {
    animation-play-state: paused;
  }
  .earth-feed__chip {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 var(--sp-4);
    border-right: 1px solid var(--c-rule-soft);
    flex-shrink: 0;
  }
  .earth-feed__chip a {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--ff-mono);
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    text-decoration: none;
    min-height: 44px;
  }
  .earth-feed__chip a:hover {
    color: var(--c-amber-light);
  }
  .earth-feed__city {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.7rem;
    color: var(--c-amber-light);
  }
  .earth-feed__head-text {
    color: var(--c-ink);
  }
  .earth-feed__signal {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.65rem;
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
  }
  /* v6.11.10 — F14 amber-only. Long-vol = ink-2 (no red); short-vol
     = amber. Sign carried by semantic word + label, not hue. */
  .earth-feed__signal--long-vol {
    background: color-mix(in oklab, var(--c-ink-2) 12%, transparent);
    color: var(--c-ink-2);
  }
  .earth-feed__signal--short-vol {
    background: color-mix(in oklab, var(--c-amber) 12%, transparent);
    color: var(--c-amber);
  }
  .earth-feed__signal--flatten {
    background: rgba(34, 211, 238, 0.12);
    color: var(--c-accent-cyan);
  }
  .earth-feed__signal--steepen {
    background: var(--c-amberl-mist);
    color: var(--c-amber-light);
  }
  .earth-feed__signal--carry {
    background: var(--c-amberl-soft);
    color: var(--c-amber-light);
  }
  .earth-feed__signal--breakeven-watch,
  .earth-feed__signal--regime-shift {
    background: rgba(173, 186, 199, 0.12);
    color: var(--c-ink-2);
  }

  @keyframes earth-feed-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .earth-feed__track {
      animation: none;
    }
  }

  @media (max-width: 720px) {
    .earth-feed__viewport {
      height: 4em;
    }
    .earth-feed__chip a {
      flex-wrap: wrap;
      align-content: center;
    }
  }
</style>
