---
/**
 * EventPin.astro — v6.2 single event-pin primitive for WorldEventMap.
 *
 * Pure server-rendered SVG, no JS. Renders a 12px circle in the
 * category color, with an optional outer pulse ring for severity-3
 * (critical) pins. Coordinates are pre-projected (the caller passes
 * x/y in the parent's viewBox space, not raw lat/lon).
 *
 * Visual conventions:
 *   - central-bank  -> var(--c-amber-light)   amber
 *   - earnings      -> var(--c-pass)          green
 *   - geopolitical  -> var(--c-fail)          red
 *   - data-release  -> var(--c-accent-cyan)   cyan
 *   - fx            -> var(--c-primary-3)     purple
 *
 * Severity drives radius and ring count:
 *   - 1 (mild)    r = 3
 *   - 2 (moderate) r = 4
 *   - 3 (critical) r = 5 + outer pulse ring (CSS @keyframes pulse-ring)
 *
 * Honors `prefers-reduced-motion: reduce` — pulse animation is disabled.
 *
 * Props are spread into the <g> via Astro's class:list for a stable,
 * easy-to-target DOM; styling is in the companion <style> block.
 */
interface Props {
  /** Pre-projected x in the parent SVG's viewBox. */
  x: number;
  /** Pre-projected y in the parent SVG's viewBox. */
  y: number;
  /** Event category — drives fill color. */
  category: 'central-bank' | 'earnings' | 'geopolitical' | 'data-release' | 'fx';
  /** Severity 1=mild, 2=moderate, 3=critical (pulse ring only on 3). */
  severity: 1 | 2 | 3;
  /** 0-based index, used to stagger the fade-in via nth-child delays. */
  index?: number;
  /** Optional title for a11y (rendered as <title> child). */
  title?: string;
}

const { x, y, category, severity, index = 0, title } = Astro.props;

const radius = severity === 3 ? 5 : severity === 2 ? 4 : 3;
const showPulse = severity === 3;
const catClass = `evp-cat--${category}`;
const sevClass = `evp-sev--${severity}`;
---

<g
  class:list={['evp', catClass, sevClass, showPulse && 'evp--pulse']}
  style={`--evp-delay: ${(index * 50).toFixed(0)}ms;`}
  transform={`translate(${x.toFixed(2)} ${y.toFixed(2)})`}
>
  {showPulse && <circle r={radius + 5} class="evp__ring" />}
  <circle r={radius} class="evp__dot" />
  {title && <title>{title}</title>}
</g>

<style>
  .evp {
    opacity: 0;
    animation: evp-fade-in 320ms var(--ease-out, ease) forwards;
    animation-delay: var(--evp-delay, 0ms);
  }

  .evp__dot {
    stroke-width: 1;
    stroke: rgba(13, 17, 23, 0.85);
  }

  .evp__ring {
    fill: none;
    stroke-width: 1.2;
    opacity: 0;
    transform-origin: center;
    transform-box: fill-box;
    animation: evp-pulse-ring 2400ms ease-out infinite;
  }

  /* Category colors — palette tokens only. */
  .evp-cat--central-bank .evp__dot { fill: var(--c-amber-light); }
  .evp-cat--earnings .evp__dot { fill: var(--c-pass); }
  .evp-cat--geopolitical .evp__dot { fill: var(--c-fail); }
  .evp-cat--data-release .evp__dot { fill: var(--c-accent-cyan); }
  .evp-cat--fx .evp__dot { fill: var(--c-primary-3); }

  .evp-cat--central-bank .evp__ring { stroke: var(--c-amber-light); }
  .evp-cat--earnings .evp__ring { stroke: var(--c-pass); }
  .evp-cat--geopolitical .evp__ring { stroke: var(--c-fail); }
  .evp-cat--data-release .evp__ring { stroke: var(--c-accent-cyan); }
  .evp-cat--fx .evp__ring { stroke: var(--c-primary-3); }

  @keyframes evp-fade-in {
    from { opacity: 0; transform: scale(0.8); }
    to   { opacity: 1; transform: scale(1); }
  }
  /* When the <g> has its own translate transform, animating its inner
     scale fights the inline transform. So we animate opacity only
     on the wrapping <g> and a subtle scale on the .evp__dot itself. */
  .evp__dot {
    transform-origin: center;
    transform-box: fill-box;
    animation: evp-pop 320ms var(--ease-out, ease) backwards;
  }
  @keyframes evp-pop {
    from { transform: scale(0.4); }
    to   { transform: scale(1); }
  }

  @keyframes evp-pulse-ring {
    0%   { transform: scale(0.7); opacity: 0.7; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .evp,
    .evp__dot,
    .evp__ring {
      animation: none !important;
      opacity: 1 !important;
    }
    .evp__ring { display: none !important; }
  }
</style>
