---
/**
 * ProcessStrip.astro — horizontal process visualization for the AI lane.
 *
 * Each step = number + title + short description. Used on the home page
 * after the stat-row to communicate "how AI engineering work is shipped
 * here" at a glance.
 *
 * Renders as horizontal flex on desktop, vertical on mobile.
 */
interface Props {
  steps: { num: string; title: string; desc: string }[];
  title?: string;
  subtitle?: string;
  tone?: 'paper' | 'tape';
}
const { steps, title, subtitle, tone = 'paper' } = Astro.props;
---

<section class={`process process--${tone}`}>
  {
    title && (
      <header class="process__head">
        <p class="section__eyebrow mono">process/</p>
        <h2 class="process__title">{title}</h2>
        {subtitle && <p class="process__sub">{subtitle}</p>}
      </header>
    )
  }
  <ol class="process__steps">
    {
      steps.map((s) => (
        <li class="step">
          <div class="step__num mono">{s.num}</div>
          <div class="step__body">
            <div class="step__title">{s.title}</div>
            <p class="step__desc">{s.desc}</p>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .process {
    padding-block: var(--sp-8);
    background: var(--c-bg-2);
    border-block: 1px solid var(--c-rule);
  }
  .process--tape {
    background: var(--c-tape);
    color: var(--ink-on-tape);
    border-color: var(--c-tape-2);
  }
  .process__head {
    max-width: var(--container-narrow);
    margin: 0 auto var(--sp-7);
    padding-inline: var(--sp-4);
  }
  .process__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-block: var(--sp-3) var(--sp-3);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .process__sub {
    font-size: var(--fs-base);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 60ch;
  }
  .process--tape .process__sub {
    color: rgba(230, 237, 243, 0.7);
  }
  .process__steps {
    display: grid;
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: var(--container-max);
    counter-reset: step;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
  }
  .step {
    counter-increment: step;
    position: relative;
    padding: var(--sp-5) var(--sp-4);
    background: var(--c-bg);
    border-right: 1px dashed var(--c-rule);
    min-height: 180px;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .process--tape .step {
    background: var(--c-tape-2);
    border-right-color: var(--c-tape-2);
    color: var(--ink-on-tape);
  }
  .step:last-child {
    border-right: none;
  }
  .step__num {
    font-size: var(--fs-2xl);
    font-weight: 800;
    color: var(--c-primary-2-deep);
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .process--tape .step__num {
    color: #d4a017;
  }
  .step__title {
    font-size: var(--fs-base);
    font-weight: 700;
    color: var(--c-primary);
    letter-spacing: -0.01em;
  }
  .process--tape .step__title {
    color: #fff;
  }
  .step__desc {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    line-height: var(--lh-snug);
    margin: 0;
  }
  .process--tape .step__desc {
    color: rgba(230, 237, 243, 0.78);
  }

  @media (max-width: 880px) {
    .process__steps {
      grid-template-columns: 1fr;
    }
    .step {
      border-right: none;
      border-bottom: 1px dashed var(--c-rule);
      min-height: 0;
    }
    .step:last-child {
      border-bottom: none;
    }
  }
</style>
