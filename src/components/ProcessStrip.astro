---
/**
 * ProcessStrip.astro — process visualization for the AI lane.
 *
 * v3.5: switched from a flat grid of bars to PipelineDiagram.astro,
 * an inline SVG flowchart with a feedback loop. Same public API:
 * `steps`, `title`, `subtitle`, `tone`. Callers (index.astro) don't
 * change.
 */
import PipelineDiagram from '@components/PipelineDiagram.astro';
interface Props {
  steps: { num: string; title: string; desc: string }[];
  title?: string;
  subtitle?: string;
  tone?: 'paper' | 'tape';
}
const { steps, title, subtitle, tone = 'paper' } = Astro.props;
---

<section class={`process process--${tone}`}>
  {
    title && (
      <header class="process__head">
        <p class="section__eyebrow mono">process/</p>
        <h2 class="process__title">{title}</h2>
        {subtitle && <p class="process__sub">{subtitle}</p>}
      </header>
    )
  }
  <div class="process__diagram">
    <PipelineDiagram steps={steps} tone={tone} />
  </div>
</section>

<style>
  .process {
    padding-block: var(--sp-8);
    background: var(--c-bg-2);
    border-block: 1px solid var(--c-rule);
  }
  .process--tape {
    background: var(--c-tape);
    color: var(--ink-on-tape);
    border-color: var(--c-tape-2);
  }
  .process__head {
    max-width: var(--container-narrow);
    margin: 0 auto var(--sp-7);
    padding-inline: var(--sp-4);
  }
  .process__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-block: var(--sp-3) var(--sp-3);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .process__sub {
    font-size: var(--fs-base);
    color: var(--c-ink-2);
    line-height: var(--lh-loose);
    max-width: 60ch;
  }
  .process--tape .process__sub {
    color: rgba(230, 237, 243, 0.7);
  }
  .process__diagram {
    max-width: var(--container-max);
    margin: 0 auto;
    padding-inline: var(--sp-4);
  }
</style>

