---
/**
 * KeyHintPanel.astro — v6.6 (Mission 6.6, Graphic Visual Dynamic)
 * Floating keyboard-shortcut hints. Toggle with `?`.
 *
 * v6.6 — Converted from a wordy list to a graphic-visual-dynamic panel.
 * Each shortcut is now a 240×96 tile with three stacked elements:
 *   1. Top: a 56×28 SVG keyboard-key visualization — a 1px-stroked
 *      square with a 4×5 grid of 4×4 amber cells and a centered
 *      bracket-label like `[?]`, `[G]`, `[j]`, `[k]`, `[b]`, `[/]`.
 *   2. Middle: an 11px mono label naming the action.
 *   3. Bottom: a 60×6 wave-pattern SVG showing 4 rounded humps; the
 *      per-hump opacity encodes shortcut-coverage density
 *      (deterministic from `seedFromString(buildSeed())`).
 *
 * Behavior:
 *   - Initially hidden (no `.is-open` class).
 *   - `?` toggles `.is-open`. `Esc` closes.
 *   - `j` scrolls page down a viewport-height; `k` up. `g` top, `b` bottom.
 *   - `/` focuses the first `[data-search]` element on the page.
 *
 * Wired by `src/scripts/keyboard-shortcuts.ts` (imported via BaseLayout).
 * Honors `prefers-reduced-motion` (opacity transition only — no slide).
 */
import { seedFromString, buildSeed } from '@utils/prng';

interface Shortcut {
  key: string;
  desc: string;
  humps: boolean[];
}

const shortcuts: Shortcut[] = [
  { key: '?',  desc: 'Toggle keyboard map' },
  { key: 'j',  desc: 'Jump down a viewport' },
  { key: 'k',  desc: 'Jump up a viewport' },
  { key: 'g',  desc: 'Go to top' },
  { key: 'b',  desc: 'Go to bottom' },
  { key: '/',  desc: 'Focus search' },
];

// === Per-tile deterministic hump-coverage =========================
// Each tile gets 4 humps; the seeded PRNG picks which humps are
// "covered" (full opacity) vs "outline" (low opacity). Deterministic
// per build, so the same build always renders the same density map.
const humpRng = seedFromString(buildSeed() + '::keyhint-waves');
for (const s of shortcuts) {
  s.humps = [0, 1, 2, 3].map(() => humpRng() > 0.5);
}
---

<aside
  id="keyhint-panel"
  class="keyhint"
  role="dialog"
  aria-modal="false"
  aria-label="Keyboard shortcuts"
  hidden
>
  <header class="keyhint__head">
    <span class="keyhint__eyebrow mono">Keyboard</span>
    <h3 class="keyhint__title">Shortcuts</h3>
    <p class="keyhint__press">Press <kbd class="keyhint__kbd mono">?</kbd> again to close</p>
  </header>

  <div class="keyhint__grid">
    {shortcuts.map((s) => (
      <div class="keyhint__tile">
        {/* === Keyboard-key visualization (56×28) ===
            4×5 grid of 4×4 SVG cells (texture) + centered bracket-label. */}
        <div class="keyhint__key">
          <svg viewBox="0 0 56 28" class="keyhint__keysvg" aria-hidden="true">
            <rect
              x="0.5"
              y="0.5"
              width="55"
              height="27"
              rx="2"
              fill="none"
              stroke="var(--c-amber)"
              stroke-width="1"
              stroke-opacity="0.85"
            />
            {/* v6.10.17 — hoist fill/fill-opacity to <g> (was on each of
                20 rects × 6 shortcuts = 120 attrs ≈ 3KB). */}
            <g fill="var(--c-amber)" fill-opacity="0.32">
              {Array.from({ length: 5 }).map((_, row) =>
                Array.from({ length: 4 }).map((__, col) => (
                  <rect
                    x={20 + col * 4}
                    y={4 + row * 4}
                    width="3"
                    height="3"
                  />
                )),
              )}
            </g>
            <text
              x="28"
              y="17.5"
              class="keyhint__keylabel"
              text-anchor="middle"
              dominant-baseline="middle"
            >{`[${s.key}]`}</text>
          </svg>
        </div>

        {/* === Action label (11px mono) === */}
        <p class="keyhint__label mono">{s.desc}</p>

        {/* === Wave-pattern coverage (60×6, 4 humps) === */}
        <svg viewBox="0 0 60 6" class="keyhint__wave" aria-hidden="true">
          {s.humps.map((filled, i) => (
            <path
              d={`M ${i * 15} 3 Q ${i * 15 + 7.5} ${i % 2 === 0 ? 0 : 6} ${(i + 1) * 15} 3`}
              fill="none"
              stroke="var(--c-amber)"
              stroke-width="1"
              stroke-linecap="round"
              stroke-opacity={filled ? 1 : 0.25}
            />
          ))}
        </svg>
      </div>
    ))}
  </div>
</aside>

<style>
  /* ============================================================
     PANEL SHELL — fixed bottom-right, tape-dark, 1px amber rule.
     ============================================================ */
  .keyhint {
    position: fixed;
    right: var(--sp-5);
    bottom: var(--sp-5);
    width: 528px; /* 240 × 2 tiles + 16 gap + 32 padding */
    max-width: calc(100vw - var(--sp-7));
    background: var(--c-tape);
    color: var(--ink-on-tape);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    padding: var(--sp-4);
    box-shadow: var(--shadow-lg);
    z-index: var(--z-toast);
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition:
      opacity 220ms var(--ease-out, ease-out),
      transform 220ms var(--ease-out, ease-out);
  }
  .keyhint:not([hidden]).is-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .keyhint {
      transition: opacity 120ms linear;
      transform: none !important;
    }
    .keyhint__wave path {
      transition: stroke-opacity 120ms linear !important;
    }
  }

  /* ============================================================
     HEADER — eyebrow + title + "press ? to close" hint.
     ============================================================ */
  .keyhint__head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--sp-1);
    margin-bottom: var(--sp-3);
    padding-bottom: var(--sp-2);
    border-bottom: 1px solid var(--c-rule);
  }
  .keyhint__eyebrow {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-amber);
    font-weight: 600;
    grid-column: 1 / 2;
  }
  .keyhint__title {
    font-size: var(--fs-base);
    color: var(--c-ink);
    font-weight: 600;
    margin: 0;
    grid-column: 1 / 2;
    line-height: 1.2;
  }
  .keyhint__press {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
    align-self: end;
    justify-self: end;
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    margin: 0;
    white-space: nowrap;
  }
  .keyhint__kbd {
    display: inline-block;
    min-width: 1.4em;
    padding: 0.18em 0.45em;
    font-size: 0.72rem;
    text-align: center;
    background: var(--c-tape);
    color: var(--c-amber);
    border: 1px solid var(--c-amber);
    border-radius: 4px;
    line-height: 1;
  }

  /* ============================================================
     TILE GRID — 2 columns × 3 rows of 240×96 tiles.
     On narrow viewports, fall back to 1 column with horizontal scroll.
     ============================================================ */
  .keyhint__grid {
    display: grid;
    grid-template-columns: repeat(2, 240px);
    gap: var(--sp-3);
    justify-content: center;
  }
  @media (max-width: 560px) {
    .keyhint__grid {
      grid-template-columns: 240px;
    }
  }

  /* ============================================================
     TILE — fixed 240×96, three stacked elements (key / label / wave).
     ============================================================ */
  .keyhint__tile {
    width: 240px;
    height: 96px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: rgba(230, 237, 243, 0.02);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-sm);
    transition: border-color 200ms ease, background 200ms ease;
  }
  .keyhint__tile:hover {
    border-color: var(--c-amber);
    background: rgba(232, 178, 32, 0.04);
  }
  .keyhint__tile:hover .keyhint__wave path {
    stroke-opacity: 1;
  }

  /* ============================================================
     KEYBOARD-KEY SVG (56×28)
     ============================================================ */
  .keyhint__key {
    width: 56px;
    height: 28px;
    flex-shrink: 0;
  }
  .keyhint__keysvg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .keyhint__keylabel {
    font-size: 9px;
    font-family: var(--ff-mono);
    fill: var(--c-amber);
    font-weight: 600;
    letter-spacing: 0;
  }

  /* ============================================================
     ACTION LABEL (11px mono)
     ============================================================ */
  .keyhint__label {
    font-size: 11px;
    color: var(--c-ink-2);
    text-align: center;
    line-height: 1.2;
    margin: 0;
    letter-spacing: 0.02em;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ============================================================
     WAVE-PATTERN COVERAGE (60×6)
     ============================================================ */
  .keyhint__wave {
    width: 60px;
    height: 6px;
    display: block;
    flex-shrink: 0;
  }
  .keyhint__wave path {
    transition: stroke-opacity 240ms ease;
  }
</style>
