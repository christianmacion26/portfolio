---
/**
 * TimelineEntry.astro — one experience entry, NDA-safe.
 */
interface Props {
  title: string;
  company: string;
  location: string;
  startDate: string;
  endDate: string;
  isCurrent?: boolean;
  summary?: string;
}
const { title, company, location, startDate, endDate, isCurrent, summary } = Astro.props;

function formatDate(iso: string): string {
  if (iso.toLowerCase() === 'present') return 'Present';
  const [y, m] = iso.split('-');
  const date = new Date(Number(y), Number(m) - 1, 1);
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
const dateRange = `${formatDate(startDate)} — ${formatDate(endDate)}`;
---
<article class="tl">
  <div class="tl__rail" aria-hidden="true">
    <span class="tl__dot"></span>
    <span class="tl__line"></span>
  </div>
  <div class="tl__body">
    <header class="tl__head">
      <div>
        <h3 class="tl__role">{title}</h3>
        <p class="tl__meta">
          <span class="tl__company">{company}</span>
          <span class="tl__sep" aria-hidden="true">·</span>
          <span class="tl__loc">{location}</span>
          {isCurrent && <span class="pill pill--brand tl__current">Current</span>}
        </p>
      </div>
      <div class="tl__date mono">{dateRange}</div>
    </header>
    {summary && <p class="tl__summary">{summary}</p>}
    <div class="tl__content"><slot /></div>
  </div>
</article>

<style>
  .tl {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: var(--sp-5);
    padding-block: var(--sp-5);
    border-bottom: 1px solid var(--c-rule-soft);
  }
  .tl:last-child { border-bottom: none; }
  .tl__rail {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.5rem;
  }
  .tl__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--c-primary);
    box-shadow: 0 0 0 4px rgba(11, 61, 92, 0.10);
  }
  .tl__line {
    width: 2px;
    flex: 1;
    background: var(--c-rule-soft);
    margin-top: var(--sp-2);
  }
  .tl__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .tl__role { font-size: var(--fs-lg); margin: 0; }
  .tl__meta {
    margin-top: 0.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    align-items: center;
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
  }
  .tl__company { font-weight: 500; color: var(--c-ink); }
  .tl__sep { color: var(--c-ink-3); }
  .tl__current { margin-left: var(--sp-2); }
  .tl__date {
    font-size: var(--fs-sm);
    color: var(--c-ink-2);
    white-space: nowrap;
  }
  .tl__summary {
    margin-top: var(--sp-3);
    color: var(--c-ink-2);
    font-size: var(--fs-base);
    line-height: var(--lh-loose);
  }
  .tl__content {
    margin-top: var(--sp-4);
  }
  .tl__content :global(ul) {
    list-style: none;
    padding: 0;
  }
  .tl__content :global(li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: var(--sp-3);
    line-height: var(--lh-loose);
    font-size: var(--fs-base);
    color: var(--c-ink);
  }
  .tl__content :global(li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c-primary-2);
  }
  .tl__content :global(strong) { color: var(--c-primary); font-weight: 600; }
</style>