---
/**
 * CoverageGlobe.astro — v6.1 institutional coverage dot map.
 *
 * Server-rendered SVG (no JS). Renders a sparse world dot-map using
 * the Equirectangular projection (lat/lon → x/y directly) and plots a
 * city for each entry in `points`. Cities without a back-link just
 * render as dots; the default 6 cities are linked to relevant pages.
 *
 * Visual conventions:
 *   - Equirectangular 0–360 lon, 0–180 lat, viewBox 720×360.
 *   - Background landmass dots: a small grid (8° spacing) of faint
 *     amber dots — gives the "we cover the world" impression without
 *     shipping a real basemap (heavy, IP-encumbered).
 *   - City dots: weighted by `weight` (0–1), colored amber with a
 *     faint pulse-ring around the larger cities.
 *   - Hover reveals the city name + lat/lon via <title> (a11y) +
 *     underline-on-hover (visual).
 *
 * Usage:
 *   <CoverageGlobe points={[
 *     {city:'Digos', lat:6.74, lon:125.36, weight:1.0},
 *     ...
 *   ]} />
 */
interface Point {
  city: string;
  lat: number;
  lon: number;
  weight: number; // 0..1, drives dot radius
  /** Optional href to make the city a link. */
  href?: string;
  /** Optional 1-line label rendered under the dot. */
  caption?: string;
}
interface Props {
  points?: Point[];
  /** ViewBox width (default 720). */
  width?: number;
  /** ViewBox height (default 360 — Equirectangular 2:1). */
  height?: number;
  /** Spacing in degrees between background landmass dots (default 20). */
  bgStep?: number;
}
const { points, width = 720, height = 360, bgStep = 20 } = Astro.props;

// === Default cities ===
// Six representative locations spanning research, client, and
// exchange timezones. `href` cross-links where a page exists; otherwise
// the dot is informational only. Coordinates are public-domain facts.
const defaultPoints: Point[] = [
  { city: 'Digos City', lat: 6.74, lon: 125.36, weight: 1.0, caption: 'home base', href: '/about' },
  { city: 'Singapore', lat: 1.35, lon: 103.82, weight: 0.8, caption: 'APAC ops' },
  { city: 'Tokyo', lat: 35.68, lon: 139.69, weight: 0.7, caption: 'JPX' },
  { city: 'Zurich', lat: 47.38, lon: 8.54, weight: 0.85, caption: 'CTA' },
  { city: 'London', lat: 51.51, lon: -0.13, weight: 0.95, caption: 'LSE' },
  { city: 'New York', lat: 40.71, lon: -74.01, weight: 0.9, caption: 'NYSE / Nasdaq' },
];
const cities = points ?? defaultPoints;

// === Equirectangular projection ===
// x = (lon + 180) / 360 * width
// y = (90 - lat) / 180 * height
function project(lat: number, lon: number): { x: number; y: number } {
  const x = ((lon + 180) / 360) * width;
  const y = ((90 - lat) / 180) * height;
  return { x, y };
}

// === Background landmass dot grid ===
// We don't ship a basemap — render a sparse grid of faint dots. For a
// more "institutional" feel we'd mask them to land, but the dot grid
// reads as "we are everywhere" without that work, and keeps the file
// small + IP-clean. Step is in degrees.
interface BgDot {
  x: number;
  y: number;
  visible: boolean;
}
const bgDots: BgDot[] = [];
for (let lat = -60; lat <= 75; lat += bgStep) {
  for (let lon = -180; lon <= 180; lon += bgStep) {
    const { x, y } = project(lat, lon);
    // Crude land mask: keep dots that fall in a coarse continent outline.
    // The exact borders don't matter — we just want denser coverage in
    // northern-hemisphere continents and sparser in the southern oceans.
    // North America + Europe + Asia band
    const nhContinent =
      lat > 5 &&
      lat < 75 &&
      ((lon > -130 && lon < -55) || // North America
        (lon > -10 && lon < 60) || // Europe + W. Asia
        (lon > 60 && lon < 145)); // E. Asia
    // Africa + South America band
    const shContinent =
      lat > -55 &&
      lat < 35 &&
      ((lon > -85 && lon < -30) || // S. America
        (lon > -15 && lon < 50)); // Africa
    // Australia
    const au = lat > -40 && lat < -10 && lon > 110 && lon < 155;
    const visible = nhContinent || shContinent || au;
    bgDots.push({ x, y, visible });
  }
}

// === Project cities ===
const cityPositions = cities.map((c) => {
  const { x, y } = project(c.lat, c.lon);
  // Dot radius scales 4..9 with weight 0..1.
  const r = 4 + c.weight * 5;
  return { ...c, x, y, r };
});

// === Reference grid lines (equator + prime meridian) ===
const equatorY = project(0, 0).y;
const primeX = project(0, 0).x;
---

<figure class="globe">
  {
    cityPositions.length > 0 && (
      <figcaption class="globe__caption">
        {cityPositions.length} research & ops nodes · equirectangular projection
      </figcaption>
    )
  }
  <svg
    class="globe__svg"
    viewBox={`0 0 ${width} ${height}`}
    role="img"
    aria-label="Coverage map: research and operations nodes"
    preserveAspectRatio="xMidYMid meet"
  >
    <title>Coverage map — equirectangular world dot map with city markers</title>

    {/* Background grid lines (equator, prime meridian) — very faint. */}
    <line x1="0" y1={equatorY} x2={width} y2={equatorY} class="globe__eq"></line>
    <line x1={primeX} y1="0" x2={primeX} y2={height} class="globe__pm"></line>

    {/* Background landmass dots */}
    {bgDots.map((d) => (d.visible ? <circle cx={d.x} cy={d.y} r="0.9" class="globe__bg" /> : null))}

    {/* City dots + pulse ring for the high-weight ones */}
    {
      cityPositions.map((c) => (
        <g>
          {c.weight >= 0.7 && <circle cx={c.x} cy={c.y} r={c.r + 5} class="globe__pulse" />}
          {c.href ? (
            // v6.3 polish — single home-base city dot is rendered as a
            // <circle> with a <title> tooltip instead of a clickable
            // anchor. The audit was flagging the only href-bearing dot
            // (Digos City) as 9×9 / 21×21 px undersized on /markets;
            // SVG hit-targets scale with the viewBox so the smallest
            // honest fix is to drop the link and keep the tooltip.
            // The /about page is reachable via the global nav.
            <circle cx={c.x} cy={c.y} r={c.r} class="globe__dot">
              <title>
                {c.city} ({c.lat.toFixed(2)}°, {c.lon.toFixed(2)}°)
                {c.caption ? ` — ${c.caption}` : ''}
              </title>
            </circle>
          ) : (
            <circle cx={c.x} cy={c.y} r={c.r} class="globe__dot">
              <title>
                {c.city} ({c.lat.toFixed(2)}°, {c.lon.toFixed(2)}°)
                {c.caption ? ` — ${c.caption}` : ''}
              </title>
            </circle>
          )}
          <text x={c.x} y={c.y - c.r - 4} text-anchor="middle" class="globe__label">
            {c.city}
          </text>
        </g>
      ))
    }
  </svg>

  <ul class="globe__legend mono" aria-label="City list">
    {
      cityPositions.map((c) => (
        <li>
          <span class="globe__legend-dot" style={`--w: ${c.weight.toFixed(2)}`} />
          <span class="globe__legend-city">{c.city}</span>
          {c.caption && <span class="globe__legend-cap">{c.caption}</span>}
        </li>
      ))
    }
  </ul>
</figure>

<style>
  .globe {
    margin: 0;
    padding: var(--sp-3);
    background: var(--c-bg-2);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .globe__caption {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    line-height: 1.4;
  }
  .globe__svg {
    width: 100%;
    height: auto;
    display: block;
    background: var(--c-tape);
    border-radius: var(--radius-sm);
  }
  .globe__eq,
  .globe__pm {
    stroke: var(--c-rule);
    stroke-width: 0.5;
    stroke-dasharray: 2, 4;
    opacity: 0.6;
  }
  .globe__bg {
    fill: var(--c-ink-3);
    opacity: 0.18;
  }
  .globe__dot {
    fill: var(--c-primary-2);
    stroke: var(--c-primary-2-light);
    stroke-width: 1;
    cursor: default;
  }
  a .globe__dot {
    cursor: pointer;
  }
  a:hover .globe__dot,
  a:focus-visible .globe__dot {
    fill: var(--c-primary-2-light);
    stroke: var(--c-primary-2);
  }
  .globe__pulse {
    fill: none;
    stroke: var(--c-primary-2);
    stroke-width: 1;
    opacity: 0.4;
  }
  .globe__label {
    font-size: 10px;
    fill: var(--c-ink);
    font-weight: 600;
    letter-spacing: 0.04em;
    /* no text-shadow — institutional: read on background alone */
  }
  .globe__legend {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-4);
    font-size: 0.7rem;
    color: var(--c-ink-2);
  }
  .globe__legend li {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .globe__legend-dot {
    width: calc(6px + var(--w, 0.5) * 6px);
    height: calc(6px + var(--w, 0.5) * 6px);
    border-radius: 50%;
    background: var(--c-primary-2);
    display: inline-block;
    flex-shrink: 0;
  }
  .globe__legend-city {
    color: var(--c-ink);
    font-weight: 600;
  }
  .globe__legend-cap {
    color: var(--c-ink-3);
  }
</style>
