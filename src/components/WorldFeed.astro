---
/**
 * WorldFeed.astro — four-lane categorized news-caster ticker.
 *
 * v6.2 Mission R — "Trader Workspace / Iron Man Desk".
 *
 * Lanes (vertical auto-scroll, each holding 4 visible rows):
 *   1. MARKETS — equity / macro headlines.        amber.
 *   2. POLICY  — central bank / regulatory.       green.
 *   3. QUANT   — research / methodology.          cyan/info.
 *   4. AI      — AI engineering / evals.          monochrome.
 *
 * Each lane: 20 fixtures, sorted by timestamp descending; one per
 * 8-second tick; seamless CSS-only infinite scroll. Duplicated tracks
 * (20 + 20) + a translateY animation that snaps invisibly from -50% to
 * 0% creates a true infinite pan without any client JS. The 40-second
 * total cycle (5 rotations × 8s) is the rate a recruiter's eye can
 * sustain without the panel reading as "TV noise."
 *
 * Determinism — every visitor to the same build sees identical rows.
 * The pool of fixtures is fixed; the order is the input order; the
 * timestamp cycle is fixed. No Math.random / Date.now / argless Date
 * anywhere — Standing Order §9 hard rule.
 *
 * palette: existing tokens only.
 *   MARKETS  → var(--c-primary-2) amber
 *   POLICY   → var(--c-pass)      green
 *   QUANT    → var(--c-info)      cyan
 *   AI       → monochrome (F14 institutional: 1 amber accent only)
 *
 * NDA-positive:
 *   - Generic category language only ("Fed minutes", "S&P 500",
 *     "30-year Treasury"). No employer or platform names.
 *   - Categories are designed to be instantly decodable by an HR
 *     recruiter (markets = finance, quant = research, AI = LLMs) and
 *     by a quant-savvy scanner (PSR, DSR, PBO, OOS).
 *
 * Accessibility:
 *   - Each item is a real <article> with timestamp + visible category
 *     badge + headline. Screen-readers receive the data without the
 *     animation.
 *   - prefers-reduced-motion: every lane falls back to a static,
 *     stacked column where ALL items are visible.
 */

import { seedFromString, buildSeed } from '@utils/prng';
import { profile } from '@utils/profile';

// === FIXTURE POOLS — NDA-clean, category language only ===
const MARKETS_POOL = [
  'S&P 500 closes +1.4% on cooling inflation print',
  '30-year Treasury yield slips 6bp on dovish Fed minutes',
  'Russell 2000 leads small-cap rotation; breadth +0.8 sigma',
  'Brent crude settles +2.1% on supply-discipline headline',
  'VIX term structure in mild contango; front-month at 14.2',
  'Copper-to-gold ratio extends 3-day rally; cyclical bid',
  'DXY softens on softer services PMI print',
  'Gold settles near cycle high on real-yield compression',
  'IG credit spreads tighten 4bp; CDX-IG at 52bps',
  '10Y TIPS breakeven lifts to 2.42% on hotter core PCE',
  'Nikkei +2.3% on weak yen; TOPIX at 32-year high',
  'DAX breaks out of 6-month range; Bund yields steady',
  'EM FX carry basket widens; BRL outperforms',
  'WTI curve flattens on prompt-month tightness',
  'HY index OAS compresses 8bp; CCC down 27bp',
  'Yen rallies as policy board signals taper continuity',
  'Baltic Dry index posts third weekly gain',
  'EUR/USD technical breakout above 1.0940 resistance',
  'Silver-to-gold ratio at 11-year low; deficit flagged',
  'US 2s10s curve steepens 5bp; bull-steepener extends',
];

const POLICY_POOL = [
  'Policy-board minutes signal patient stance; 25-bp path narrows',
  'ECB minutes reveal divided council on September cut',
  'BoJ reaffirms yield-band guidance; JGB order-book quiet',
  'Headline CPI prints 2.0% YoY; in line with consensus',
  'Daily fix at 7.18; steady against USD basket',
  'Voting minutes scheduled for Wednesday 14:00 local',
  'Council member: data-dependent, not calendar-driven',
  'ETF-purchase guidance review scheduled for October meeting',
  'Minutes: services inflation still sticky into Q3',
  'Statement cites weak productivity; rate held',
  'Balance-sheet runoff pace to continue at $60bn / month',
  'Repo facility usage falls to 12-month low',
  'Supervisory letter to pensions on LDI leverage thresholds',
  'MLF rollover at unchanged 2.30% policy rate',
  'Regional president speech: policy now well-calibrated',
  'Policy rate held; trade-weighted FX firming',
  'Minutes: more transmission evidence needed before next move',
  'Budget committee testimony scheduled for next month',
  'Working paper published on fiscal-monetary interaction',
  'Quarterly refunding plan announced; coupon mix steady',
];

const QUANT_POOL = [
  'Deflated-Sharpe discipline cuts false-positive rate 60% in walk-forward',
  'PBO of cross-sectional momentum at 42%; selection bias dominates',
  'PSR vs DSR gap of 0.18 alerts to multiple-testing risk',
  'Combinatorially-purged CV PBO at 38%; statistically marginal',
  'Out-of-sample Sharpe degrades 0.42 to 0.18 across frozen-spec windows',
  'Block-bootstrap on 1440-bar blocks passes serial-dependence test',
  'Variance-risk-premium harvest: vol-targeted Sharpe 1.62',
  'Cointegration half-life estimate 32 days; mean-reversion quality good',
  'Funding-carry basis annualized 8.4%; vol-adjusted 5.1%',
  'Lookahead audit flags 2 of 9 strategies; both repaired',
  'Regime overlay adds 220bps of risk-adj alpha; turnover 1.4x',
  'Cross-sectional vs time-series momentum blend to lowest drawdown',
  'Frozen-spec walk-forward: 9 strategies survive in-sample to out-of-sample',
  'PIT enforcement yields 4 fewer fills and 12 fewer survivors',
  'Cost-adjusted backtest adds 3.2bps round-trip drag assumption',
  'HV-RV spread at 4-sigma; variance risk premium compressed',
  'PSR-based hypothesis count: 31 trials; DSR haircut applied',
  'Survivorship-bias adjustment lowers total return by 380bps',
  'Cash-futures basis annualized; ladder to 5 tenors, all positive',
  'Regime classifier AUC 0.71 on out-of-sample macro prints',
];

const AI_POOL = [
  `${profile.stats.evalGates}-gate eval harness catches regression in MCP round-trip parity`,
  'Agent roster revision: 11 nodes; orchestrator plus 4 inputs plus 3 middle plus 3 outputs',
  'RAG recall@10 lifted 4pp via query-rewrite plus hybrid retrieval',
  'Structured-output JSON-schema validation: 100% pass across 200 traces',
  'MCP tool-call failure rate 0.8% over 1200 sample sessions',
  `Eval harness gates G1 to G${profile.stats.evalGates} mechanical; no manual override`,
  'LLM judge scoring: 88% agreement with rubric-graded holdout',
  'Prompt-injection probe: 9 attack variants; all refused by charter',
  'Token-budget per trace: median 4.1k; p95 7.8k',
  'Refusal quality score: 0.97 against policy v3.0 holdout',
  'Tool-call latency p50 220ms p95 480ms over MCP stdio transport',
  'Agent-system bootstrapped in 4.1s; deterministic per BUILD_DATE',
  'Embedding model swap: recall parity plus or minus 2pp at iso-cost',
  'Reranker on long context: NDCG@10 plus 3.4pp over base retriever',
  'Hallucination probe: factual recall 96% on 1000 closed-domain questions',
  `Agent-fleet harness regression suite: 12 of ${profile.stats.evalGates} gates auto-triggered`,
  'Eval traceability: every gate cross-links to source artifact',
  'JSON-schema coverage: 41 contracts; lint pass at 100%',
  'MCP server health-check: 0 missed heartbeats over 7-day window',
  'Eval-driven prompt iteration: 6 prompts to 4 wins, 2 holds',
];

const LANES = [
  { id: 'markets', label: 'MARKETS', pool: MARKETS_POOL, tone: 'amber' as const, channel: '01' },
  { id: 'policy', label: 'POLICY', pool: POLICY_POOL, tone: 'pass' as const, channel: '02' },
  { id: 'quant', label: 'QUANT', pool: QUANT_POOL, tone: 'info' as const, channel: '03' },
  { id: 'ai', label: 'AI', pool: AI_POOL, tone: 'ai' as const, channel: '04' },
] as const;

// Pad shorter pools to 20 with the longer ones' tail items so every
// lane has exactly 20 rows regardless of input length. Every Visitor
// gets the same 20 because the same seeds drive the same indexing.
const TGT = 20;
function pad20(pool: string[], seedKey: string): string[] {
  const r = seedFromString(buildSeed() + '::pad::' + seedKey);
  const out = pool.slice();
  while (out.length < TGT) {
    const idx = Math.floor(r() * pool.length);
    out.push(pool[idx]);
  }
  return out.slice(0, TGT);
}

interface FeedItem {
  time: string;
  headline: string;
}

function buildLanes(): Array<{
  id: string;
  label: string;
  tone: 'amber' | 'pass' | 'info' | 'ai';
  channel: string;
  items: FeedItem[];
}> {
  return LANES.map((ln) => {
    const items20 = pad20([...ln.pool], ln.id);
    // Stable timestamp sweep: start at 14:32:00, step -1m28s for each
    // row so the timestamps read as a coherent tape descending. The
    // exact sweep is deterministic from row count — no PRNG needed.
    const items = items20.map<FeedItem>((headline, i) => {
      const startSec = 14 * 3600 + 32 * 60; // 14:32:00
      const stepSec = 88; // 1m28s per row
      const t = startSec - i * stepSec;
      const h = Math.floor(t / 3600);
      const m = Math.floor((t % 3600) / 60);
      const s = t % 60;
      const pad = (n: number) => String(n).padStart(2, '0');
      return { time: `${pad(h)}:${pad(m)}:${pad(s)}`, headline };
    });
    return {
      id: ln.id,
      label: ln.label,
      tone: ln.tone,
      channel: ln.channel,
      items,
    };
  });
}

const lanes = buildLanes();

// ITEM_HEIGHT (px) and VISIBLE_ROWS drive the keyframes math. Keep them
// in JS so the cycle math and the CSS stay in sync.
const ITEM_HEIGHT = 56;
const VISIBLE_ROWS = 4;
const ROTATE_SECONDS = 8;
// Total cycle: 20 items / 4 visible per row = 5 rotations × 8s = 40s.
// Duplicate the items list inside the track so a -50% translate lands
// on the second copy and the loop is truly seamless.
const CYCLE_SECONDS = (20 / VISIBLE_ROWS) * ROTATE_SECONDS;
---

<section class="worldfeed" aria-label="World news wire">
  <header class="worldfeed__head container">
    <p class="worldfeed__eyebrow mono">World wire — 4 channels, 80 fixtures</p>
    <p class="worldfeed__sub">
      Build-stamp seeded. Four lanes scroll in parallel, one headline per channel every 8 seconds.
      NDA-clean by construction.
    </p>
  </header>

  <div class="worldfeed__grid">
    {
      lanes.map((lane) => (
        <article class={`worldfeed__lane worldfeed__lane--${lane.tone}`} data-lane-id={lane.id}>
          <header class="worldfeed__lane-head">
            <span class="worldfeed__lane-channel mono">{lane.channel}</span>
            <span class="worldfeed__lane-label mono">{lane.label}</span>
            <span class="worldfeed__lane-dot" aria-hidden="true">
              <span class="worldfeed__lane-dot-pulse" />
            </span>
          </header>

          <div class="worldfeed__viewport" style={`--item-h: ${ITEM_HEIGHT}px;`}>
            <div
              class="worldfeed__track"
              style={`--item-h: ${ITEM_HEIGHT}px; --lane-cycle: ${CYCLE_SECONDS}s;`}
            >
              {[...lane.items, ...lane.items].map((it, i) => (
                <article class="worldfeed__item" data-idx={i % lane.items.length}>
                  <span class="worldfeed__time mono">{it.time}</span>
                  <span class="worldfeed__chip mono">{lane.label}</span>
                  <p class="worldfeed__headline">{it.headline}</p>
                </article>
              ))}
            </div>

            {/* static mirror under reduced motion: a non-animated copy
                that holds all 20 rows in a scrollable column. Hidden
                by default; revealed only when prefers-reduced-motion
                is on. */}
            <div class="worldfeed__static" aria-hidden="true">
              {lane.items.map((it, i) => (
                <article class="worldfeed__item" data-idx={i}>
                  <span class="worldfeed__time mono">{it.time}</span>
                  <span class="worldfeed__chip mono">{lane.label}</span>
                  <p class="worldfeed__headline">{it.headline}</p>
                </article>
              ))}
            </div>
          </div>

          <footer class="worldfeed__lane-foot mono">
            <span>channel {lane.channel}</span>
            <span aria-hidden="true">·</span>
            <span>{lane.items.length} fixtures</span>
          </footer>
        </article>
      ))
    }
  </div>
</section>

<style>
  /* ============================================================
     WorldFeed — institutional-tape dark panel, four lane columns.
     Each lane rotates 4-item windows every 8s via CSS-only pan.
     On prefers-reduced-motion the animated track is hidden and
     every row is visible in the static mirror column.
     ============================================================ */
  .worldfeed {
    background: var(--c-tape);
    color: var(--ink-on-tape);
    border-block: 1px solid var(--c-white-mist);
    padding-block: var(--sp-6) var(--sp-7);
    position: relative;
  }
  .worldfeed__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-5);
    margin-bottom: var(--sp-5);
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--c-white-mist);
    max-width: var(--container-max);
    margin-left: auto;
    margin-right: auto;
    padding-inline: var(--sp-4);
  }
  .worldfeed__eyebrow {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--c-primary-2);
    font-weight: 600;
    margin: 0;
  }
  .worldfeed__sub {
    font-size: var(--fs-xs);
    color: var(--c-ink-ghost);
    font-family: var(--ff-mono);
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* === 4 lanes desktop, 2x2 tablet, 1x4 mobile === */
  .worldfeed__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-3);
    max-width: var(--container-max);
    margin: 0 auto;
    padding-inline: var(--sp-4);
  }

  .worldfeed__lane {
    display: flex;
    flex-direction: column;
    background: var(--c-tape-2);
    border: 1px solid var(--c-white-mist);
    border-radius: var(--radius-sm);
    overflow: hidden;
    min-width: 0;
  }

  /* === lane header (channel + label + dot) === */
  .worldfeed__lane-head {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border-bottom: 1px solid var(--c-white-mist);
    background: var(--c-tape);
  }
  .worldfeed__lane-channel {
    font-size: 0.62rem;
    color: var(--c-ink-veil);
    letter-spacing: 0.06em;
  }
  .worldfeed__lane-label {
    font-size: var(--fs-xs);
    letter-spacing: 0.18em;
    font-weight: 600;
    color: var(--ink-on-tape);
  }
  .worldfeed__lane-dot {
    margin-left: auto;
    position: relative;
    display: inline-block;
    width: 8px;
    height: 8px;
  }
  .worldfeed__lane-dot-pulse {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    animation: worldfeed-dot 2.4s var(--ease-out) infinite;
  }
  /* F14 — monochrome channel accent: only the active/highlighted lane
     gets amber; all other lanes render in ink-3 (subdued editorial).
     Per Man Group / Renaissance / AQR convention: data sections use
     ONE accent for emphasis, everything else is monochrome ink. */
  .worldfeed__lane--amber .worldfeed__lane-dot-pulse {
    background: var(--c-primary-2);
  }
  .worldfeed__lane--pass .worldfeed__lane-dot-pulse {
    background: var(--c-ink-ghost);
  }
  .worldfeed__lane--info .worldfeed__lane-dot-pulse {
    background: var(--c-ink-wisp);
  }
  .worldfeed__lane--ai .worldfeed__lane-dot-pulse {
    background: var(--c-ink-haze);
  }
  @keyframes worldfeed-dot {
    0%,
    100% {
      opacity: 0.55;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.18);
    }
  }

  /* === animated viewport — 4 rows tall, overflowing track pans === */
  .worldfeed__viewport {
    position: relative;
    height: calc(var(--item-h) * 4);
    overflow: hidden;
  }
  .worldfeed__track {
    display: flex;
    flex-direction: column;
    will-change: transform;
    animation: worldfeed-pan var(--lane-cycle) linear infinite;
  }
  @keyframes worldfeed-pan {
    /* 20 items / 4 visible = 5 rotations; total anim height = 40 rows.
       Translate by 50% (= 20 rows = one full copy) for a seamless loop. */
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-50%);
    }
  }

  /* === static mirror — shown ONLY when prefers-reduced-motion is set.
     Inline by default with the animated track; the parent wrapper has
     no overflow rule of its own, so the mirror is collapsed until we
     reverse visibility. The mirror gets ALL 20 rows visible at once. */
  .worldfeed__static {
    display: none;
  }

  /* === single row — timestamp + chip + headline === */
  .worldfeed__item {
    display: grid;
    grid-template-columns: 56px auto minmax(0, 1fr);
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border-bottom: 1px solid var(--c-white-mist);
    min-height: var(--item-h);
    background: transparent;
  }
  .worldfeed__time {
    font-size: 0.7rem;
    color: var(--c-ink-ghost);
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
  }
  .worldfeed__chip {
    display: inline-block;
    padding: 1px 6px;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    border-radius: 2px;
    text-align: center;
    border: 1px solid currentColor;
    line-height: 1.5;
  }
  .worldfeed__headline {
    margin: 0;
    font-size: var(--fs-xs);
    color: var(--ink-on-tape);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  /* F14 — per-lane accent on the chip + headline: monochrome ink except
     the first/active lane (amber). Removes the traffic-light rainbow
     that read as "AI-generated status dashboard" and replaces it with
     the institutional pattern of one accent + ink variants. */
  .worldfeed__lane--amber .worldfeed__chip,
  .worldfeed__lane--amber .worldfeed__lane-label {
    color: var(--c-primary-2);
  }
  .worldfeed__lane--pass .worldfeed__chip,
  .worldfeed__lane--pass .worldfeed__lane-label {
    color: var(--c-ink-faint);
  }
  .worldfeed__lane--info .worldfeed__chip,
  .worldfeed__lane--info .worldfeed__lane-label {
    color: var(--c-ink-veil);
  }
  .worldfeed__lane--ai .worldfeed__chip,
  .worldfeed__lane--ai .worldfeed__lane-label {
    color: var(--c-ink-wisp);
  }

  /* === lane footer === */
  .worldfeed__lane-foot {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border-top: 1px solid var(--c-white-mist);
    font-size: 0.6rem;
    color: var(--c-ink-veil);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ============================================================
     prefers-reduced-motion — switch from animated pan to a
     static, fully-visible stacked column.
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .worldfeed__track {
      animation: none;
      transform: none;
    }
    .worldfeed__lane-dot-pulse {
      animation: none;
    }
    .worldfeed__viewport {
      height: auto;
      overflow: visible;
    }
    .worldfeed__track {
      display: none;
    }
    .worldfeed__static {
      display: flex;
      flex-direction: column;
    }
  }

  /* === responsive: 2x2 then 1x4 === */
  @media (max-width: 880px) {
    .worldfeed__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 540px) {
    .worldfeed__grid {
      grid-template-columns: 1fr;
    }
    .worldfeed__head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
