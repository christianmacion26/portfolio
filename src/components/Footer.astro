---
/**
 * Footer.astro — global footer with contact recaps + quick links.
 */
import { profile } from '@utils/profile';
import { path } from '@utils/url';

const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <div class="footer__name">{profile.fullName}</div>
      <div class="footer__role">{profile.titles.primary}</div>
      <div class="footer__loc">{profile.location.display}</div>
    </div>

    <div class="footer__cols">
      <div class="footer__col">
        <h4>Site</h4>
        <ul>
          <li><a href={path('/projects')}>Projects</a></li>
          <li><a href={path('/experience')}>Experience</a></li>
          <li><a href={path('/skills')}>Skills</a></li>
          <li><a href={path('/certifications')}>Certifications</a></li>
          <li><a href={path('/about')}>About</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Contact</h4>
        <ul>
          <li><a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a></li>
          <li><a href={`tel:${profile.contact.phone}`}>{profile.contact.phoneDisplay}</a></li>
          <li><a href={profile.contact.linkedin} target="_blank" rel="noopener">LinkedIn ↗</a></li>
          <li><a href={profile.contact.github} target="_blank" rel="noopener">GitHub ↗</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Availability</h4>
        <ul>
          <li>{profile.availability.mode}, {profile.availability.hours}</li>
          <li>UTC+8 · Philippines</li>
          <li>Open to AI Engineer & Quant roles</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer__base">
    <div class="container footer__base-inner">
      <small>© {year} {profile.shortName}. Built with Astro. No proprietary data sources referenced.</small>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--sp-9);
    background: var(--c-bg-2);
    border-top: var(--border);
    color: var(--c-ink-2);
  }
  .footer__inner {
    padding-block: var(--sp-7);
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--sp-7);
  }
  .footer__name { font-weight: 600; color: var(--c-ink); font-size: var(--fs-lg); }
  .footer__role { color: var(--c-primary); font-size: var(--fs-sm); margin-top: 0.25rem; }
  .footer__loc  { color: var(--c-ink-2); font-size: var(--fs-sm); margin-top: 0.25rem; }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }
  .footer__col h4 {
    font-size: var(--fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink);
    margin-bottom: var(--sp-3);
  }
  .footer__col ul { list-style: none; padding: 0; }
  .footer__col li { line-height: 1.9; font-size: var(--fs-sm); }
  .footer__col a { color: var(--c-ink-2); }
  .footer__col a:hover { color: var(--c-primary); }

  .footer__base {
    border-top: 1px solid var(--c-rule-soft);
    padding-block: var(--sp-4);
  }
  .footer__base-inner small { font-size: var(--fs-xs); color: var(--c-ink-3); }

  @media (max-width: 720px) {
    .footer__inner { grid-template-columns: 1fr; }
    .footer__cols { grid-template-columns: 1fr 1fr; }
  }
</style>
