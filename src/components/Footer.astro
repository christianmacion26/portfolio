---
/**
 * Footer.astro — v2: full contact directory + 4 columns.
 */
import { profile } from '@utils/profile';
import { path } from '@utils/url';

const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <div class="footer__name">{profile.fullName}</div>
      <div class="footer__role">{profile.titles.primary}</div>
      <div class="footer__loc mono">{profile.location.display}</div>
      <div class="footer__hours mono">
        <span class="dot dot--pass"></span>
        {profile.availability.mode} · {profile.availability.hours}
      </div>
    </div>

    <div class="footer__cols">
      <div class="footer__col">
        <h4>Site</h4>
        <ul>
          <li><a href={path('/solutions')}>Solutions</a></li>
          <li><a href={path('/projects')}>Projects</a></li>
          <li><a href={path('/publications')}>Publications</a></li>
          <li><a href={path('/methodology')}>Methodology</a></li>
          <li><a href={path('/experience')}>Experience</a></li>
          <li><a href={path('/skills')}>Skills</a></li>
          <li><a href={path('/certifications')}>Certifications</a></li>
          <li><a href={path('/about')}>About</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Contact</h4>
        <ul>
          <li><a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a></li>
          <li><a href={`tel:${profile.contact.phone}`}>{profile.contact.phoneDisplay}</a></li>
          <li><a href={profile.contact.linkedin} target="_blank" rel="noopener">LinkedIn ↗</a></li>
          <li><a href={profile.contact.github} target="_blank" rel="noopener">GitHub ↗</a></li>
          <li><a href={profile.contact.ojp} target="_blank" rel="noopener">OnlineJobs.ph ↗</a></li>
          <li><a href={profile.contact.upwork} target="_blank" rel="noopener">Upwork ↗</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Method</h4>
        <ul class="mono">
          <li>eval-first discipline</li>
          <li>G1–G31 gate stack</li>
          <li>block-bootstrap CIs</li>
          <li>deflated Sharpe</li>
          <li>CSCV-based PBO</li>
          <li>walk-forward · 5-era stability</li>
          <li>frozen-spec evaluation</li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Availability</h4>
        <ul>
          <li>Remote · 20 hrs/wk</li>
          <li class="mono">UTC+8 · Philippines</li>
          <li>Open to QR / AI eng roles</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer__base">
    <div class="container footer__base-inner">
      <small>© {year} {profile.shortName}. Built with Astro. <span class="mono">No proprietary data sources referenced.</span></small>
      <small class="mono">last build · {new Date().toISOString().slice(0, 10)}</small>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--sp-9);
    background: var(--c-tape);
    color: rgba(230, 237, 243, 0.7);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .footer__inner {
    padding-block: var(--sp-7);
    display: grid;
    grid-template-columns: 1.1fr 3fr;
    gap: var(--sp-7);
  }
  .footer__name { font-weight: 600; color: #fff; font-size: var(--fs-lg); }
  .footer__role { color: #3fb950; font-size: var(--fs-sm); margin-top: 0.25rem; }
  .footer__loc  { color: rgba(255, 255, 255, 0.6); font-size: var(--fs-sm); margin-top: 0.25rem; }
  .footer__hours {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--fs-xs);
    margin-top: var(--sp-2);
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
  }
  .footer__col h4 {
    font-size: var(--fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: var(--sp-3);
  }
  .footer__col ul { list-style: none; padding: 0; }
  .footer__col li { line-height: 1.95; font-size: var(--fs-sm); }
  .footer__col a { color: rgba(230, 237, 243, 0.7); }
  .footer__col a:hover { color: #3fb950; }

  .footer__base {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: var(--sp-4);
  }
  .footer__base-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  .footer__base-inner small { font-size: var(--fs-xs); color: rgba(255, 255, 255, 0.45); }

  @media (max-width: 880px) {
    .footer__inner { grid-template-columns: 1fr; }
    .footer__cols { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 540px) {
    .footer__cols { grid-template-columns: 1fr; }
  }
</style>