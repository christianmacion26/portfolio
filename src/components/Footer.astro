---
/**
 * Footer.astro — v2: full contact directory + 4 columns.
 */
import { profile } from '@utils/profile';
import { path } from '@utils/url';
import { buildYear, buildStampUtc8 } from '@utils/build-stamp';
import BrandMotif from '@components/BrandMotif.astro';
import Avatar from '@components/Avatar.astro';
import pkg from '../../package.json';
const portfolioVersion = `v${pkg.version}`;

const year = buildYear();
const deployedStamp = buildStampUtc8();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <div class="footer__mark">
        <BrandMotif width={140} decorative={true} />
      </div>
      <div class="footer__identity">
        <div class="footer__avatar">
          <Avatar alt={profile.headshot.alt} size={48} loading="lazy" fetchpriority="auto" />
        </div>
        <div class="footer__id-text">
          <div class="footer__name">{profile.fullName}</div>
          <div class="footer__role">{profile.titles.primary}</div>
          <div class="footer__loc mono">{profile.location.display}</div>
          {
            /* F21 — institutional: dot for "online/available" should be amber,
              not bright pass-green. Single accent = institutional. */
          }
          <div class="footer__hours mono">
            <span class="dot dot--amber" aria-hidden="true"></span>
            {profile.availability.mode} · {profile.availability.hours}
          </div>
        </div>
      </div>
    </div>

    <div class="footer__cols">
      <div class="footer__col">
        <h4>Site</h4>
        <ul>
          <li><a href={path('/solutions')}>Solutions</a></li>
          <li><a href={path('/projects')}>Projects</a></li>
          <li><a href={path('/proof')}>Proof</a></li>
          <li><a href={path('/positions')}>Positions</a></li>
          <li><a href={path('/screening-call')}>Screening call</a></li>
          <li><a href={path('/publications')}>Publications</a></li>
          <li><a href={path('/methodology')}>Methodology</a></li>
          <li><a href={path('/experience')}>Experience</a></li>
          <li><a href={path('/skills')}>Skills</a></li>
          <li><a href={path('/certifications')}>Certifications</a></li>
          <li><a href={path('/uses')}>Uses</a></li>
          <li><a href={path('/about')}>About</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Contact</h4>
        <ul>
          <li><a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a></li>
          <li><a href={`tel:${profile.contact.phone}`}>{profile.contact.phoneDisplay}</a></li>
          <li>
            <a href={profile.contact.linkedin} target="_blank" rel="noopener noreferrer"
              >LinkedIn ↗</a
            >
          </li>
          <li>
            <a href={profile.contact.github} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
          </li>
          <li>
            <a href={profile.contact.medium} target="_blank" rel="noopener noreferrer">Medium ↗</a>
          </li>
          <li>
            <a href={profile.contact.ojp} target="_blank" rel="noopener noreferrer"
              >OnlineJobs.ph ↗</a
            >
          </li>
          <li>
            <a href={profile.contact.upwork} target="_blank" rel="noopener noreferrer">Upwork ↗</a>
          </li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Method</h4>
        <ul class="mono">
          <li><a href={path('/methodology')}>eval-first discipline</a></li>
          <li>
            <a href={path('/methodology')}
              ><strong>G1–G{profile.stats.evalGates} gate stack</strong> ↗</a
            >
          </li>
          <li>block-bootstrap CIs</li>
          <li>deflated Sharpe</li>
          <li>CSCV-based PBO</li>
          <li>walk-forward · 5-era stability</li>
          <li>frozen-spec evaluation</li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Availability</h4>
        <ul>
          <li>Remote · {profile.availability.hours}</li>
          <li class="mono">UTC+8 · Philippines</li>
          <li>Open to QR / AI eng roles</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer__base">
    <div class="container footer__base-inner">
      <small
        >© {year}
        {profile.shortName}. Built with Astro. <span class="mono"
          >No proprietary data sources referenced.</span
        ></small
      >
      <div class="footer__base-meta">
        <small class="mono">
          <a href={path('/humans.md')}>humans.md</a> · AI-agent identity document
        </small>
        <small class="mono">
          portfolio.os · {portfolioVersion} · last deployed {deployedStamp} · built with Astro
        </small>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--sp-9);
    background: var(--c-tape);
    color: var(--c-ink-mute);
    border-top: 1px solid var(--c-white-mist);
  }
  .footer__inner {
    padding-block: var(--sp-7);
    display: grid;
    grid-template-columns: 1.1fr 3fr;
    gap: var(--sp-7);
  }
  .footer__mark {
    margin-bottom: var(--sp-4);
    opacity: 0.92;
  }
  .footer__identity {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
  }
  .footer__avatar {
    flex-shrink: 0;
  }
  .footer__avatar :global(.avatar) {
    border-width: 1px;
  }
  .footer__id-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .footer__name {
    font-weight: 600;
    color: var(--c-ink);
    font-size: var(--fs-lg);
  }
  .footer__role {
    color: var(--c-ink-2);
    font-size: var(--fs-sm);
    margin-top: 0.25rem;
  }
  .footer__loc {
    color: var(--c-white-faint);
    font-size: var(--fs-sm);
    margin-top: 0.25rem;
  }
  .footer__hours {
    color: var(--c-white-faint);
    font-size: var(--fs-xs);
    margin-top: var(--sp-2);
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
  }
  .footer__col h4 {
    font-size: var(--fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-white-ghost);
    margin-bottom: var(--sp-3);
  }
  .footer__col ul {
    list-style: none;
    padding: 0;
  }
  .footer__col li {
    line-height: 1.95;
    font-size: var(--fs-sm);
  }
  .footer__col a {
    color: var(--c-ink-mute);
    /* v6.3 polish — every footer link gets ≥ 44×44 tap target.
       The audit flagged column links at 33-141×17-20 px on mobile
       (Proof, Skills, Uses, About, humans.md). min-height:44 +
       inline-flex + padding-inline:1rem lifts the click rect to
       WCAG 2.5.5 ≥ 44×44 without affecting the visible row rhythm
       (the parent column gap already provides visual breathing). */
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.25rem 0.75rem;
  }
  .footer__col a:hover {
    color: var(--c-amber-light);
  }

  .footer__base {
    border-top: 1px solid var(--c-white-mist);
    padding-block: var(--sp-4);
  }
  .footer__base-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  .footer__base-inner small {
    font-size: var(--fs-xs);
    color: var(--c-white-fade);
  }
  .footer__base-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .footer__base-meta a {
    color: var(--c-primary-2);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--c-amber-decor);
    /* v6.3 polish — humans.md link was 67×17 on mobile. Same
       min-height:44 + inline-flex treatment as the column links
       above so the audit clears every footer <a> on the page. */
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.25rem 0.5rem;
  }
  .footer__base-meta a:hover {
    color: var(--c-primary-2-light);
    text-decoration-color: var(--c-amber);
  }

  @media (max-width: 880px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
    .footer__cols {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 540px) {
    .footer__cols {
      grid-template-columns: 1fr;
    }
  }
</style>
