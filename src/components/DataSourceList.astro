---
/**
 * DataSourceList.astro — registry of public-domain data sources used
 * across the 9 quant research projects on /research.
 *
 * Standing Order: only sources that are verifiably public-domain, NDA-clean,
 * and known-licence are listed. No proprietary feeds, no employer scrapes,
 * no platform names. Each row carries {name, url_pattern, lastUpdated,
 * license} so a hiring manager can audit the data lineage with curl.
 *
 * Usage:
 *   <DataSourceList />
 */

interface Source {
  name: string;
  category: 'macro' | 'equity-deriv' | 'crypto-onchain' | 'funding' | 'rates' | 'commodities' | 'fx' | 'cftc';
  urlPattern: string;
  lastUpdated: string;
  license: string;
  note?: string;
}

const sources: Source[] = [
  {
    name: 'FRED-equivalent (public macro time-series)',
    category: 'macro',
    urlPattern: 'https://fred.stlouisfed.org/ — public CSV download per series',
    lastUpdated: '2026-07-08',
    license: 'Public domain (US Federal Reserve release)',
    note: 'US macro series, daily/quarterly frequency.',
  },
  {
    name: 'CBOE VIX Historical (free)',
    category: 'equity-deriv',
    urlPattern: 'https://cdn.cboe.com/api/global/us_indices/daily_prices/VIX_History.csv',
    lastUpdated: '2026-07-09',
    license: 'Free for non-commercial redistribution',
    note: 'Used by project 04 and 07 — variance risk premium + regime classifier.',
  },
  {
    name: 'Yahoo Finance (delayed quotes, free tier)',
    category: 'equity-deriv',
    urlPattern: 'https://query1.finance.yahoo.com/v7/finance/download/{ticker}',
    lastUpdated: '2026-07-09',
    license: 'Yahoo terms (delayed ≥15 min, non-commercial)',
    note: 'Daily OHLCV equity / ETF data for cross-sectional and pairs work.',
  },
  {
    name: 'CFTC Commitment of Traders (COT)',
    category: 'cftc',
    urlPattern: 'https://www.cftc.gov/dea/newdeacom.html — annual + weekly disaggregated reports',
    lastUpdated: '2026-06-28',
    license: 'Public domain (US Government publication)',
    note: 'Positioning baseline for any carry/liquidity signal.',
  },
  {
    name: 'CoinGecko free tier (no API key)',
    category: 'crypto-onchain',
    urlPattern: 'https://api.coingecko.com/api/v3/coins/{id}/market_chart',
    lastUpdated: '2026-07-09',
    license: 'Free tier, attribution required',
    note: 'Daily and intraday crypto price history across the 18-coin universe.',
  },
  {
    name: 'Public-domain academic datasets (Bailey, López de Prado, Chan)',
    category: 'macro',
    urlPattern: 'https://www.quantresearch.org/ — published companion data',
    lastUpdated: '2026-05-15',
    license: 'Academic use, attribution required',
    note: 'Replicated baselines for DSR / multiple-testing papers.',
  },
  {
    name: 'Treasury par-yield curve (US Treasury)',
    category: 'rates',
    urlPattern: 'https://home.treasury.gov/resource-center/data-chart-center/interest-rates/daily-treasury-rates.csv',
    lastUpdated: '2026-07-08',
    license: 'Public domain (US Treasury publication)',
    note: 'Term-structure ground truth for any rates / curve work.',
  },
  {
    name: 'EIA petroleum spot prices (weekly)',
    category: 'commodities',
    urlPattern: 'https://www.eia.gov/dnav/pet/pet_pri_spt_s1_d.htm',
    lastUpdated: '2026-07-07',
    license: 'Public domain (US EIA)',
    note: 'Commodity baseline for cross-asset regime overlays.',
  },
  {
    name: 'Binance public klines (delayed REST)',
    category: 'crypto-onchain',
    urlPattern: 'https://api.binance.com/api/v3/klines?symbol=BTCUSDT&interval=1d',
    lastUpdated: '2026-07-09',
    license: 'Public REST endpoint, no key required',
    note: 'Daily OHLCV on the BTC/ETH/SOL universe for project 02/03/05.',
  },
  {
    name: 'Binance public funding-rate history (read)',
    category: 'funding',
    urlPattern: 'https://fapi.binance.com/fapi/v1/fundingRate?symbol=BTCUSDT',
    lastUpdated: '2026-07-09',
    license: 'Public REST endpoint, no key required',
    note: 'Source for project 06 funding-carry study.',
  },
  {
    name: 'FRED-equivalent: World Bank open data (macro cross-country)',
    category: 'macro',
    urlPattern: 'https://data.worldbank.org/indicator — open data API',
    lastUpdated: '2026-06-30',
    license: 'Open licence (CC-BY 4.0)',
    note: 'Cross-country macro for sanity-checking single-country signals.',
  },
  {
    name: 'FRED-equivalent: BIS real-effective-exchange-rate',
    category: 'fx',
    urlPattern: 'https://data.bis.org/topics/RPP',
    lastUpdated: '2026-06-15',
    license: 'Public (Bank for International Settlements, re-use permitted)',
    note: 'FX basket reference for any carry / FX-overlay discussion.',
  },
];
---

<section class="datasrc" aria-labelledby="datasrc-heading">
  <header class="datasrc__head">
    <p class="datasrc__eyebrow mono">Data source registry</p>
    <h2 id="datasrc-heading" class="datasrc__title">
      Every dataset behind the 9 strategies.
    </h2>
    <p class="datasrc__sub">
      Twelve public-domain sources. Every strategy, every equity curve, every
      OOS Sharpe on this page reads from this list. No proprietary feeds, no
      employer scrapes, no platform API keys. Each line carries its URL
      pattern, last-pull timestamp, and licence — so a hiring manager can
      audit the data lineage with <span class="mono">curl</span>.
    </p>
  </header>

  <div class="datasrc__scroll" role="region" aria-label="Data sources table" tabindex="0">
    <table class="datasrc__table">
      <thead>
        <tr>
          <th class="datasrc__th" scope="col">Source</th>
          <th class="datasrc__th" scope="col">Category</th>
          <th class="datasrc__th" scope="col">URL pattern</th>
          <th class="datasrc__th mono" scope="col">Last pull</th>
          <th class="datasrc__th" scope="col">Licence</th>
        </tr>
      </thead>
      <tbody>
        {
          sources.map((s) => (
            <tr class="datasrc__row">
              <th scope="row" class="datasrc__name">
                <span class="datasrc__name-text">{s.name}</span>
                {s.note && <span class="datasrc__note">{s.note}</span>}
              </th>
              <td class="datasrc__cat">
                <span class:list={['datasrc__pill', `datasrc__pill--${s.category}`]}>{s.category}</span>
              </td>
              <td class="datasrc__url mono">{s.urlPattern}</td>
              <td class="datasrc__last mono">{s.lastUpdated}</td>
              <td class="datasrc__lic">{s.license}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>

<style>
  .datasrc {
    padding-block: var(--sp-9);
    background: var(--c-tape);
    border-block: var(--border-paper);
  }
  .datasrc__head {
    max-width: 880px;
    margin-inline: auto;
    margin-bottom: var(--sp-7);
    padding-inline: var(--sp-4);
  }
  .datasrc__eyebrow {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-primary-2);
    margin-bottom: var(--sp-3);
    font-weight: 600;
  }
  .datasrc__title {
    font-size: clamp(1.5rem, 3.5vw, var(--fs-2xl));
    color: var(--c-ink);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin-bottom: var(--sp-3);
    max-width: 22ch;
  }
  .datasrc__sub {
    color: var(--c-ink-2);
    font-size: var(--fs-base);
    line-height: 1.65;
    max-width: 64ch;
  }

  .datasrc__scroll {
    max-width: 1180px;
    margin-inline: auto;
    padding-inline: var(--sp-4);
    overflow-x: auto;
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    background: var(--c-tape-2);
  }
  .datasrc__table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: var(--fs-sm);
    min-width: 880px;
  }
  .datasrc__th {
    text-align: left;
    padding: var(--sp-3) var(--sp-4);
    background: var(--c-tape-3);
    color: var(--c-primary-2);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-xs);
    border-bottom: 1px solid var(--c-rule);
    position: sticky;
    top: 0;
  }
  .datasrc__row + .datasrc__row .datasrc__name,
  .datasrc__row + .datasrc__row .datasrc__cat,
  .datasrc__row + .datasrc__row .datasrc__url,
  .datasrc__row + .datasrc__row .datasrc__last,
  .datasrc__row + .datasrc__row .datasrc__lic {
    border-top: 1px solid var(--c-rule);
  }
  .datasrc__name {
    padding: var(--sp-3) var(--sp-4);
    color: var(--c-ink);
    vertical-align: top;
    background: var(--c-tape-3);
    font-weight: 600;
    max-width: 320px;
  }
  .datasrc__name-text {
    display: block;
    line-height: 1.3;
  }
  .datasrc__note {
    display: block;
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    margin-top: var(--sp-1);
    font-weight: 400;
    line-height: 1.4;
  }
  .datasrc__cat {
    padding: var(--sp-3) var(--sp-4);
    vertical-align: top;
  }
  .datasrc__pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    border: 1px solid var(--c-rule);
    color: var(--c-ink-2);
    background: var(--c-bg-3);
  }
  /* F16 — institutional: collapse 7 colored pills → monochrome ink-3.
     Only the macro category keeps amber (the primary work surface).
     All others (equity/crypto/funding/rates/commodities/fx/cftc) read
     as ink-3 hairline-bordered labels — no rainbow. */
  .datasrc__pill--macro { color: var(--c-primary-2); border-color: rgba(232, 178, 32, 0.4); }
  .datasrc__pill--equity-deriv { color: var(--c-ink-3); border-color: var(--c-rule); }
  .datasrc__pill--crypto-onchain { color: var(--c-ink-3); border-color: var(--c-rule); }
  .datasrc__pill--funding { color: var(--c-ink-3); border-color: var(--c-rule); }
  .datasrc__pill--rates { color: var(--c-ink-3); border-color: var(--c-rule); }
  .datasrc__pill--commodities { color: var(--c-ink-3); border-color: var(--c-rule); }
  .datasrc__pill--fx { color: var(--c-ink-3); border-color: var(--c-rule); }
  .datasrc__pill--cftc { color: var(--c-ink-2); border-color: var(--c-rule); }

  .datasrc__url {
    padding: var(--sp-3) var(--sp-4);
    color: var(--c-ink-2);
    vertical-align: top;
    font-size: var(--fs-xs);
    word-break: break-word;
    line-height: 1.4;
    max-width: 340px;
  }
  .datasrc__last {
    padding: var(--sp-3) var(--sp-4);
    color: var(--c-primary-2);
    vertical-align: top;
    font-size: var(--fs-xs);
    white-space: nowrap;
  }
  .datasrc__lic {
    padding: var(--sp-3) var(--sp-4);
    color: var(--c-ink-3);
    vertical-align: top;
    font-size: var(--fs-xs);
    font-style: italic;
    line-height: 1.4;
  }

  @media (max-width: 720px) {
    .datasrc__scroll {
      margin-inline: 0;
      border-radius: 0;
      border-inline: none;
    }
  }
</style>
