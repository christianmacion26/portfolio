---
/**
 * DataSourceList.astro — registry of public-domain data sources used
 * across the 9 quant research projects on /research.
 *
 * Standing Order: only sources that are verifiably public-domain, NDA-clean,
 * and known-licence are listed. No proprietary feeds, no employer scrapes,
 * no platform names. Each row carries {name, url_pattern, license, note}
 * so a hiring manager can audit the data lineage with curl.
 *
 * v6.11.7 — removed per-row `lastUpdated` dates. Those literals were
 * stale (5+ days behind today) and presented as if they were live audit
 * signal. Replaced with a single `last verified` stamp at the table top
 * that derives from `buildStampUtc8()` — honest signal that the registry
 * itself was re-checked at the current deploy, not that every source
 * was pulled today. The repository's data-pipeline commits are the real
 * lineage record.
 *
 * Usage:
 *   <DataSourceList />
 */
import { buildStampUtc8 } from '@utils/build-stamp';
import { profile } from '@utils/profile';
// v6.11.16 — extracted registry to @utils/data-sources so /research can
// derive "12 sources" chrome from dataSources.length instead of a hardcoded
// literal. Single writer, multiple readers.
import { dataSources, type DataSource } from '@utils/data-sources';

void (0 as unknown as DataSource); // type-only import for downstream tooling

const lastVerified = buildStampUtc8();
---

<section class="datasrc" aria-labelledby="datasrc-heading">
  <header class="datasrc__head">
    <p class="datasrc__eyebrow mono">Data source registry</p>
    <h2 id="datasrc-heading" class="datasrc__title">
      Every dataset behind the {profile.stats.strategyCount} strategies.
    </h2>
    <p class="datasrc__sub">
      {dataSources.length} public-domain sources. Every strategy, every equity curve, every OOS Sharpe
      on this page reads from this list. No proprietary feeds, no employer scrapes, no platform API keys.
      Each line carries its URL pattern and licence — so a hiring manager can audit the data lineage with
      <span class="mono">curl</span>.
    </p>
    <p class="datasrc__verified mono">
      Registry last verified <time datetime={lastVerified}>{lastVerified}</time> · per-source pull dates
      tracked in the repository data-pipeline commits.
    </p>
  </header>

  <div class="datasrc__scroll" role="region" aria-label="Data sources table" tabindex="0">
    <table class="datasrc__table">
      <thead>
        <tr>
          <th class="datasrc__th" scope="col">Source</th>
          <th class="datasrc__th" scope="col">Category</th>
          <th class="datasrc__th" scope="col">URL pattern</th>
          <th class="datasrc__th" scope="col">Licence</th>
        </tr>
      </thead>
      <tbody>
        {
          dataSources.map((s) => (
            <tr class="datasrc__row">
              <th scope="row" class="datasrc__name">
                <span class="datasrc__name-text">{s.name}</span>
                {s.note && <span class="datasrc__note">{s.note}</span>}
              </th>
              <td class="datasrc__cat">
                <span class:list={['datasrc__pill', `datasrc__pill--${s.category}`]}>
                  {s.category}
                </span>
              </td>
              <td class="datasrc__url mono">{s.urlPattern}</td>
              <td class="datasrc__lic">{s.license}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>

<style>
  .datasrc {
    padding-block: var(--sp-9);
    background: var(--c-tape);
    border-block: var(--border-paper);
  }
  .datasrc__head {
    max-width: 880px;
    margin-inline: auto;
    margin-bottom: var(--sp-7);
    padding-inline: var(--sp-4);
  }
  .datasrc__eyebrow {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-primary-2);
    margin-bottom: var(--sp-3);
    font-weight: 600;
  }
  .datasrc__title {
    font-size: clamp(1.5rem, 3.5vw, var(--fs-2xl));
    color: var(--c-ink);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin-bottom: var(--sp-3);
    max-width: 22ch;
  }
  .datasrc__sub {
    color: var(--c-ink-2);
    font-size: var(--fs-base);
    line-height: 1.65;
    max-width: 64ch;
    margin-bottom: var(--sp-3);
  }
  .datasrc__verified {
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    letter-spacing: 0.02em;
    margin: 0;
  }
  .datasrc__verified time {
    color: var(--c-primary-2);
  }

  .datasrc__scroll {
    max-width: 1180px;
    margin-inline: auto;
    padding-inline: var(--sp-4);
    overflow-x: auto;
    border: 1px solid var(--c-rule);
    border-radius: var(--radius);
    background: var(--c-tape-2);
  }
  .datasrc__table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: var(--fs-sm);
    min-width: 880px;
  }
  .datasrc__th {
    text-align: left;
    padding: var(--sp-3) var(--sp-4);
    background: var(--c-tape-3);
    color: var(--c-primary-2);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-xs);
    border-bottom: 1px solid var(--c-rule);
    position: sticky;
    top: 0;
  }
  .datasrc__row + .datasrc__row .datasrc__name,
  .datasrc__row + .datasrc__row .datasrc__cat,
  .datasrc__row + .datasrc__row .datasrc__url,
  .datasrc__row + .datasrc__row .datasrc__lic {
    border-top: 1px solid var(--c-rule);
  }
  .datasrc__name {
    padding: var(--sp-3) var(--sp-4);
    color: var(--c-ink);
    vertical-align: top;
    background: var(--c-tape-3);
    font-weight: 600;
    max-width: 320px;
  }
  .datasrc__name-text {
    display: block;
    line-height: 1.3;
  }
  .datasrc__note {
    display: block;
    font-size: var(--fs-xs);
    color: var(--c-ink-3);
    margin-top: var(--sp-1);
    font-weight: 400;
    line-height: 1.4;
  }
  .datasrc__cat {
    padding: var(--sp-3) var(--sp-4);
    vertical-align: top;
  }
  .datasrc__pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    border: 1px solid var(--c-rule);
    color: var(--c-ink-2);
    background: var(--c-bg-3);
  }
  /* F16 — institutional: collapse 7 colored pills → monochrome ink-3.
     Only the macro category keeps amber (the primary work surface).
     All others (equity/crypto/funding/rates/commodities/fx/cftc) read
     as ink-3 hairline-bordered labels — no rainbow. */
  .datasrc__pill--macro {
    color: var(--c-primary-2);
    border-color: var(--c-amberl-decor);
  }
  .datasrc__pill--equity-deriv {
    color: var(--c-ink-3);
    border-color: var(--c-rule);
  }
  .datasrc__pill--crypto-onchain {
    color: var(--c-ink-3);
    border-color: var(--c-rule);
  }
  .datasrc__pill--funding {
    color: var(--c-ink-3);
    border-color: var(--c-rule);
  }
  .datasrc__pill--rates {
    color: var(--c-ink-3);
    border-color: var(--c-rule);
  }
  .datasrc__pill--commodities {
    color: var(--c-ink-3);
    border-color: var(--c-rule);
  }
  .datasrc__pill--fx {
    color: var(--c-ink-3);
    border-color: var(--c-rule);
  }
  .datasrc__pill--cftc {
    color: var(--c-ink-2);
    border-color: var(--c-rule);
  }

  .datasrc__url {
    padding: var(--sp-3) var(--sp-4);
    color: var(--c-ink-2);
    vertical-align: top;
    font-size: var(--fs-xs);
    word-break: break-word;
    line-height: 1.4;
    max-width: 340px;
  }
  .datasrc__lic {
    padding: var(--sp-3) var(--sp-4);
    color: var(--c-ink-3);
    vertical-align: top;
    font-size: var(--fs-xs);
    font-style: italic;
    line-height: 1.4;
  }

  @media (max-width: 720px) {
    .datasrc__scroll {
      margin-inline: 0;
      border-radius: 0;
      border-inline: none;
    }
  }
</style>
