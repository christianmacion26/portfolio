---
/**
 * TraderDesk.astro — v6.5 (graphic institutional command panel)
 *
 * Semantic intent of the v6.2 panel (positions · orders · calendar · alerts)
 * preserved but now compressed into numeric headlines + 1-line captions + 4
 * server-rendered SVG visualizations:
 *
 *   1. P&L EQUITY CURVE  — 60-bar sparkline, 280×48, max-DD shaded zone
 *   2. ORDER-FLOW TAPE   — 8 rows × 4 cols BID/ASK heat grid (size-graded)
 *   3. RISK GAUGE        — semicircle 0–100 with needle at current 1-day VaR
 *   4. SIGNAL MATRIX     — 4×4 grid of mini-sparklines (MOM · MR · CRY · VRP)
 *
 * No paragraph prose, no per-cell prose tables. Every fixture is derived from
 * `seedFromString(buildSeed() + '::traderdesk')` so the build is deterministic;
 * no `Math.random()` / `Date.now()` / argless `new Date()` (Standing Order §9).
 *
 * Reduced-motion: nothing animates by itself; pulse uses pure CSS opacity,
 * stopped under `prefers-reduced-motion: reduce` at the panel root.
 *
 * Palette: tokens only — `--c-tape`, `--c-bg-2`, `--c-ink`, `--c-ink-2`,
 * `--c-amber`, `--c-amber-light`, `--c-pass`, `--c-fail`, `--c-data-positive`,
 * `--c-data-negative`, `--c-grid-line`. Tints composed via CSS `opacity`
 * (no raw hex anywhere).
 */
import { seedFromString, buildSeed, formatPct } from '@utils/prng';

// ============================================================================
// 0. Single seeded PRNG for the whole panel — deterministic across builds.
// ============================================================================
const rng = seedFromString(buildSeed() + '::traderdesk');
const u = () => rng(); // uniform [0,1)
const z = () => {
  // Box-Muller N(0,1); consumes 2 uniforms, identical every build.
  const u1 = u() || 1e-12;
  const u2 = u();
  return Math.sqrt(-2 * Math.log(u1)) * Math.cos(2 * Math.PI * u2);
};

// ============================================================================
// 1. P&L EQUITY CURVE — 60 daily returns, normalized to sparkline coords.
// ============================================================================
const PNl_BARS = 60;
const SPARK_W = 280;
const SPARK_H = 48;
const BASELINE_Y = SPARK_H * 0.62; // bars hang from a lower baseline (intuition: price)
const MAX_BAR = SPARK_H * 0.42; // max half-height of a single bar

const dailyReturns: number[] = Array.from({ length: PNl_BARS }, () => z() * 1.05);
// Build the equity curve (cumulative sum from 100).
const equityCurve: number[] = (() => {
  const out = new Array<number>(PNl_BARS);
  out[0] = 100;
  for (let i = 1; i < PNl_BARS; i++) out[i] = out[i - 1] + dailyReturns[i]!;
  return out;
})();
const maxAbs = Math.max(...dailyReturns.map((r) => Math.abs(r))) || 1;
const barW = (SPARK_W - (PNl_BARS - 1) * 0.7) / PNl_BARS;

// Headline stats
const pnlTotal = +(equityCurve[equityCurve.length - 1]! - 100).toFixed(2); // %
const meanRet = dailyReturns.reduce((a, b) => a + b, 0) / dailyReturns.length;
const stdRet = Math.sqrt(
  dailyReturns.reduce((acc, r) => acc + (r - meanRet) ** 2, 0) /
    Math.max(1, dailyReturns.length - 1),
);
const pnlSharpe = +((meanRet / Math.max(stdRet, 0.05)) * Math.sqrt(252)).toFixed(2);
// Max drawdown (signed negative %)
const ddStat = (() => {
  let peak = -Infinity,
    maxDd = 0,
    ddStart = 0,
    ddEnd = 0,
    curPeakIdx = 0;
  for (let i = 0; i < equityCurve.length; i++) {
    if (equityCurve[i]! > peak) {
      peak = equityCurve[i]!;
      curPeakIdx = i;
    }
    const dd = (equityCurve[i]! - peak) / peak;
    if (dd < maxDd) {
      maxDd = dd;
      ddStart = curPeakIdx;
      ddEnd = i;
    }
  }
  return { pct: +(maxDd * 100).toFixed(2), start: ddStart, end: ddEnd };
})();

// ============================================================================
// 2. ORDER-FLOW TAPE — 8 rows × 4 cols of BID/ASK sizes (heat-graded).
// ============================================================================
const TAPE_ROWS = 8;
const TAPE_COLS = 4;
const tapeCells: Array<{
  row: number;
  col: number;
  size: number;
  isBid: boolean;
  intensity: number;
}> = [];
for (let r = 0; r < TAPE_ROWS; r++) {
  for (let c = 0; c < TAPE_COLS; c++) {
    const size = Math.round(u() * 280) + 12; // 12–292
    tapeCells.push({ row: r, col: c, size, isBid: r % 2 === 0, intensity: 0 });
  }
}
const tapeMax = Math.max(...tapeCells.map((c) => c.size));
const tapeMin = Math.min(...tapeCells.map((c) => c.size));
for (const c of tapeCells) {
  c.intensity = (c.size - tapeMin) / Math.max(1, tapeMax - tapeMin);
}
// Aggregate: biggest bid / biggest ask / total flow
const tapeBids = tapeCells.filter((c) => c.isBid).sort((a, b) => b.size - a.size);
const tapeAsks = tapeCells.filter((c) => !c.isBid).sort((a, b) => b.size - a.size);
const tapeTopBid = tapeBids[0]!.size;
const tapeTopAsk = tapeAsks[0]!.size;
const tapeTotalBid = tapeBids.reduce((a, b) => a + b.size, 0);
const tapeTotalAsk = tapeAsks.reduce((a, b) => a + b.size, 0);
const tapeImbalance = +(
  ((tapeTotalBid - tapeTotalAsk) / (tapeTotalBid + tapeTotalAsk)) *
  100
).toFixed(1);

// ============================================================================
// 3. RISK GAUGE — semicircle 0–100 with needle at current 1-day VaR.
// ============================================================================
const varPct = +(u() * 56 + 18).toFixed(1); // 18.0 – 74.0
const GAUGE_W = 200;
const GAUGE_H = 110;
const gCx = GAUGE_W / 2;
const gCy = GAUGE_H - 8;
const gR = GAUGE_H - 18;

// pct → angle: 0% = 180° (left), 100% = 0° (right). Sweep clockwise over top.
const pctToAngle = (p: number) => 180 - (p / 100) * 180; // degrees, standard math frame
const polarXY = (pct: number, rScale: number) => {
  const a = (pctToAngle(pct) * Math.PI) / 180;
  return { x: gCx + gR * rScale * Math.cos(a), y: gCy - gR * rScale * Math.sin(a) };
};
// Needle endpoint (note y-flipped for SVG).
const needleTip = (() => {
  const a = (pctToAngle(varPct) * Math.PI) / 180;
  return { x: gCx + gR * 0.92 * Math.cos(a), y: gCy - gR * 0.92 * Math.sin(a) };
})();
// Arc path generator, radius scale 1.0, drawn stroke at thickness.
function arcStroke(fromPct: number, toPct: number, rScale: number): string {
  const a = (pctToAngle(fromPct) * Math.PI) / 180;
  const b = (pctToAngle(toPct) * Math.PI) / 180;
  const r = gR * rScale;
  const x0 = gCx + r * Math.cos(a);
  const y0 = gCy - r * Math.sin(a);
  const x1 = gCx + r * Math.cos(b);
  const y1 = gCy - r * Math.sin(b);
  const large = Math.abs(toPct - fromPct) > 50 ? 1 : 0;
  return `M ${x0.toFixed(2)} ${y0.toFixed(2)} A ${r.toFixed(2)} ${r.toFixed(2)} 0 ${large} 1 ${x1.toFixed(2)} ${y1.toFixed(2)}`;
}
const gaugeTicks: Array<{ pct: number; label: string }> = [
  { pct: 0, label: '0' },
  { pct: 25, label: '25' },
  { pct: 50, label: '50' },
  { pct: 75, label: '75' },
  { pct: 100, label: '100' },
];

// v6.7.1 — minor ticks at the quarter marks (12.5 / 37.5 / 62.5 / 87.5)
// for finer-grained read. 0.75px ink-3 hairline, no label.
const gaugeMinorTicks: Array<{ pct: number }> = [
  { pct: 12.5 },
  { pct: 37.5 },
  { pct: 62.5 },
  { pct: 87.5 },
];

// ============================================================================
// 4. SIGNAL MATRIX — 4 rows × 4 cols of mini-sparklines.
//    Rows = signals (MOM · MR · CRY · VRP); cols = windows (1D · 5D · 10D · 30D).
//    Each cell is 5 mini-bars; color by last-bar sign.
// ============================================================================
type MatCell = { bars: number[]; lastSign: 1 | -1 | 0; label: string };
type MatRow = { signal: string; cells: MatCell[] };
const MAT_ROWS = 4;
const MAT_COLS = 4;
const BARS_PER_CELL = 5;
const signalLabels = ['MOM', 'MR', 'CRY', 'VRP'];
const windowLabels = ['1D', '5D', '10D', '30D'];

const matrix: MatRow[] = signalLabels.map((sig) => {
  const cells: MatCell[] = windowLabels.map((win) => {
    const bars: number[] = [];
    for (let i = 0; i < BARS_PER_CELL; i++) {
      // mean-reverting walk clipped to [-1, 1]; seeded so it builds deterministically
      const prev = bars[i - 1] ?? 0;
      const next = prev + z() * 0.5 + -prev * 0.18;
      bars.push(Math.max(-1, Math.min(1, next)));
    }
    const last = bars[bars.length - 1]!;
    const lastSign = last > 0.05 ? 1 : last < -0.05 ? -1 : 0;
    return { bars, lastSign, label: win };
  });
  return { signal: sig, cells };
});

// Matrix geometry
const MAT_W = 280;
const MAT_H = 90;
const matPadL = 36; // signal labels
const matPadT = 14; // window labels
const matGridW = MAT_W - matPadL - 4;
const matGridH = MAT_H - matPadT - 14; // leave space for legend strip
const cellW = matGridW / MAT_COLS;
const cellH = matGridH / MAT_ROWS;
const matBarGap = 0.6;
const matBarW = (cellW - 4 - (BARS_PER_CELL - 1) * matBarGap) / BARS_PER_CELL;
const matBarMaxHalf = (cellH - 6) / 2;
const matBaselineAt = (r: number) => matPadT + (r + 0.5) * cellH;

// ============================================================================
// 5. KPI TILES — compressed headline recap (semantic intent preserved).
// ============================================================================
// Positions
const posCount = 5;
const posNetPnl = +(pnlTotal * 38).toFixed(0); // synthetic: NAV-normalized net
const posTopSymbol = (() => {
  const syms = ['GLOBAL-1', 'MACRO-3', 'EQUITY-7', 'RATES-12', 'FX-44', 'COMMOD-2', 'CREDIT-9'];
  return syms[Math.floor(u() * syms.length)]!;
})();
// Orders
const ordCount = 5;
const ordOpen = Math.round(u() * 3) + 1; // 1–3
const ordPartial = Math.round(u() * 2); // 0–1
const ordAck = Math.round(u() * 2) + 1; // 1–2
const ordRej = Math.round(u() * 2); // 0–1
// Calendar
const calCount = 3;
const nextCalHrs = Math.round(u() * 6 + 1); // 1–6 hrs
const nextCalImpact = (() => {
  const w = u() * 5;
  return w >= 4.5 ? 'HIGH' : w >= 3.0 ? 'MED' : 'LOW';
})();
// Alerts
const alertCount = 3;
const alertCrit = Math.round(u() * 2) + 1; // 1–2
const alertWarn = Math.round(u() * 3); // 0–2
const alertInfo = Math.max(0, alertCount - alertCrit - alertWarn);

// ============================================================================
// 6. Latency — φ displayed top-right (deterministic from the seeded u()).
// ============================================================================
const latencyMs = (Math.floor(u() * 900) + 100).toString().padStart(3, '0');

// Helper: pct → decimal string for compact KPIs, e.g. +12.40%
const fmtPct = (n: number) => formatPct(n);
---

<section class="desk" aria-labelledby="desk-title">
  <header class="desk__head">
    <div class="desk__head-left">
      <p class="desk__eyebrow mono">Trader desk</p>
      <h2 id="desk-title" class="desk__title">
        P&amp;L · order flow · risk · signals
        <span class="desk__title-em mono">live</span>
      </h2>
    </div>
    <div class="desk__head-right mono" aria-hidden="true">
      <span class="desk__pulse"></span>
      <span class="desk__latency">φ 0.{latencyMs}ms</span>
    </div>
  </header>

  <div class="desk__panel">
    {
      /* =============================================================
         ROW A — P&L EQUITY CURVE · 60-bar sparkline, 280×48
         ============================================================= */
    }
    <section class="desk__row desk__row--pnl" aria-label="Book equity curve, 60 trading bars">
      <div class="desk__pnl-meta">
        <p class="desk__viz-cap mono">Book equity · 60 bars · today</p>
        <p
          class:list={[
            'desk__pnl-headline',
            'tnum',
            pnlTotal >= 0 ? 'desk__pnl-headline--pos' : 'desk__pnl-headline--neg',
          ]}
        >
          {pnlTotal >= 0 ? '+' : ''}{pnlTotal.toFixed(2)}%
          <span class="desk__pnl-cap mono desk__pnl-cap--inline">60d</span>
        </p>
        <p class="desk__pnl-sub mono">
          <span class="desk__pnl-stat">
            <span class="tnum desk__pnl-stat-num">{pnlSharpe.toFixed(2)}</span>
            <span class="desk__pnl-stat-cap">Sharpe</span>
          </span>
          <span class="desk__pnl-stat desk__pnl-stat--neg">
            <span class="tnum desk__pnl-stat-num">{ddStat.pct.toFixed(2)}%</span>
            <span class="desk__pnl-stat-cap">Max DD</span>
          </span>
          <span class="desk__pnl-stat">
            <span class="tnum desk__pnl-stat-num">{fmtPct(tapeImbalance)}</span>
            <span class="desk__pnl-stat-cap">Book skew</span>
          </span>
        </p>
      </div>

      <svg
        class="desk__spark"
        viewBox={`0 0 ${SPARK_W} ${SPARK_H}`}
        role="img"
        aria-label={`Sixty trading-bar P&L equity curve; total ${pnlTotal.toFixed(2)} percent, max drawdown ${ddStat.pct.toFixed(2)} percent`}
        preserveAspectRatio="none"
      >
        {/* Max-DD shaded zone (underlay, full-height translucent band) */}
        {
          (() => {
            const x = (ddStat.start * (SPARK_W - 0.7)) / PNl_BARS + ddStat.start * 0.7;
            const w =
              ((ddStat.end - ddStat.start) * (SPARK_W - 0.7)) / PNl_BARS +
              (ddStat.end - ddStat.start - 1) * 0.7 +
              0.7;
            return (
              <rect
                x={x.toFixed(2)}
                y={0}
                width={Math.max(0.5, w).toFixed(2)}
                height={SPARK_H}
                class="desk__spark-dd"
              />
            );
          })()
        }
        {/* Mid baseline (zero return reference line) */}
        <line
          x1={0}
          y1={BASELINE_Y.toFixed(2)}
          x2={SPARK_W}
          y2={BASELINE_Y.toFixed(2)}
          class="desk__spark-base"></line>
        {/* 60 bars */}
        {
          dailyReturns.map((r, i) => {
            const h = Math.max(0.5, (Math.abs(r) / maxAbs) * MAX_BAR);
            const x = i * (barW + 0.7);
            const y = r >= 0 ? BASELINE_Y - h : BASELINE_Y;
            return (
              <rect
                x={x.toFixed(2)}
                y={y.toFixed(2)}
                width={barW.toFixed(2)}
                height={h.toFixed(2)}
                class:list={[
                  'desk__spark-bar',
                  r >= 0 ? 'desk__spark-bar--pos' : 'desk__spark-bar--neg',
                  Math.abs(r) > 1.4 ? 'desk__spark-bar--strong' : '',
                ]}
              />
            );
          })
        }
      </svg>
    </section>

    {
      /* =============================================================
         ROW B — THREE VISUAL PANELS · order-flow · risk · signal matrix
         ============================================================= */
    }
    <section
      class="desk__row desk__row--visuals"
      aria-label="Order flow, risk, and signal visualizations"
    >
      {/* --- 2.1 ORDER-FLOW TAPE --- */}
      <article class="desk__viz" aria-label="Order flow tape, 8 rows by 4 columns">
        <header class="desk__viz-head">
          <p class="desk__viz-cap mono">Order flow · 8 × 4 heat</p>
          <p class="desk__viz-num tnum">
            <span class="desk__viz-num-pos">+{tapeTotalBid.toLocaleString()}</span>
            <span class="desk__viz-num-sep mono">/</span>
            <span class="desk__viz-num-neg">−{tapeTotalAsk.toLocaleString()}</span>
          </p>
        </header>
        <div class="desk__tape">
          {
            tapeCells.map((c) => (
              <span
                class:list={[
                  'desk__tape-cell',
                  'tnum',
                  c.isBid ? 'desk__tape-cell--bid' : 'desk__tape-cell--ask',
                ]}
                style={`--t: ${(0.18 + 0.65 * c.intensity).toFixed(3)}`}
                title={`${c.isBid ? 'BID' : 'ASK'} · ${c.size}`}
              >
                <span class="desk__tape-side mono">{c.isBid ? 'B' : 'A'}</span>
                <span class="desk__tape-size">{c.size}</span>
              </span>
            ))
          }
        </div>
        <footer class="desk__viz-foot">
          <span class="desk__viz-pill mono">top bid <span class="tnum">{tapeTopBid}</span></span>
          <span class="desk__viz-pill mono">top ask <span class="tnum">{tapeTopAsk}</span></span>
        </footer>
      </article>

      {/* --- 2.2 RISK GAUGE --- */}
      <article class="desk__viz" aria-label={`Risk gauge, current one-day VaR ${varPct} percent`}>
        <header class="desk__viz-head">
          <p class="desk__viz-cap mono">Risk · 1-day VaR</p>
          <p class="desk__viz-cap mono desk__viz-cap--mute">NAV-normalized</p>
        </header>
        <svg
          class="desk__gauge"
          viewBox={`0 0 ${GAUGE_W} ${GAUGE_H}`}
          role="img"
          aria-label={`Semicircle gauge, 0 to 100, needle at ${varPct}`}
          preserveAspectRatio="xMidYMid meet"
        >
          {/* Zone arcs (drawn first, lowest layer) */}
          <path d={arcStroke(0, 50, 1)} class="desk__gauge-arc desk__gauge-arc--safe" fill="none"
          ></path>
          <path d={arcStroke(50, 75, 1)} class="desk__gauge-arc desk__gauge-arc--warn" fill="none"
          ></path>
          <path d={arcStroke(75, 100, 1)} class="desk__gauge-arc desk__gauge-arc--alert" fill="none"
          ></path>
          {/* Minor quarter-marks (no labels) */}
          {
            gaugeMinorTicks.map((t) => {
              const inner = polarXY(t.pct, 0.9);
              const outer = polarXY(t.pct, 1.0);
              return (
                <line
                  x1={inner.x.toFixed(2)}
                  y1={inner.y.toFixed(2)}
                  x2={outer.x.toFixed(2)}
                  y2={outer.y.toFixed(2)}
                  class="desk__gauge-tick desk__gauge-tick--minor"
                />
              );
            })
          }
          {/* Tick marks + labels */}
          {
            gaugeTicks.map((t) => {
              const inner = polarXY(t.pct, 0.86);
              const outer = polarXY(t.pct, 1.02);
              const lbl = polarXY(t.pct, 0.74);
              return (
                <g>
                  <line
                    x1={inner.x.toFixed(2)}
                    y1={inner.y.toFixed(2)}
                    x2={outer.x.toFixed(2)}
                    y2={outer.y.toFixed(2)}
                    class="desk__gauge-tick"
                  />
                  <text
                    x={lbl.x.toFixed(2)}
                    y={(lbl.y + 3).toFixed(2)}
                    text-anchor="middle"
                    class="desk__gauge-ticklbl mono"
                  >
                    {t.label}
                  </text>
                </g>
              );
            })
          }
          {/* Needle */}
          <line
            x1={gCx}
            y1={gCy}
            x2={needleTip.x.toFixed(2)}
            y2={needleTip.y.toFixed(2)}
            class="desk__gauge-needle"></line>
          {/* Hub */}
          <circle cx={gCx} cy={gCy} r={4.5} class="desk__gauge-hub"></circle>
          <text
            x={gCx}
            y={gCy + 26}
            text-anchor="middle"
            class:list={[
              'desk__gauge-readout',
              'tnum',
              varPct < 50
                ? 'desk__gauge-readout--safe'
                : varPct < 75
                  ? 'desk__gauge-readout--warn'
                  : 'desk__gauge-readout--alert',
            ]}
          >
            {varPct.toFixed(1)}
          </text>
          <text x={gCx} y={gCy + 38} text-anchor="middle" class="desk__gauge-readout-cap mono">
            % NAV
          </text>
        </svg>
      </article>

      {/* --- 2.3 SIGNAL MATRIX --- */}
      <article
        class="desk__viz desk__viz--matrix"
        aria-label="Signal matrix, 4 by 4 mini-sparklines"
      >
        <header class="desk__viz-head">
          <p class="desk__viz-cap mono">Signals · 4 × 4 sparklines</p>
          <p class="desk__viz-cap mono desk__viz-cap--mute">last Δ color</p>
        </header>
        <svg
          class="desk__matrix"
          viewBox={`0 0 ${MAT_W} ${MAT_H}`}
          role="img"
          aria-label="Signal matrix: four quant signals (momentum, mean-revert, carry, variance-risk-premium) across four windows"
          preserveAspectRatio="xMidYMid meet"
        >
          {/* Window labels (top) */}
          {
            windowLabels.map((w, c) => (
              <text
                x={(matPadL + (c + 0.5) * cellW).toFixed(2)}
                y={(matPadT - 3).toFixed(2)}
                text-anchor="middle"
                class="desk__matrix-axis mono"
              >
                {w}
              </text>
            ))
          }
          {/* Signal row labels (left) */}
          {
            matrix.map((row, r) => (
              <text
                x={matPadL - 6}
                y={(matBaselineAt(r) + 3).toFixed(2)}
                text-anchor="end"
                class="desk__matrix-axis desk__matrix-axis--sig mono"
              >
                {row.signal}
              </text>
            ))
          }
          {/* Grid lines */}
          {
            Array.from({ length: MAT_COLS + 1 }, (_, c) => (
              <line
                x1={(matPadL + c * cellW).toFixed(2)}
                y1={matPadT}
                x2={(matPadL + c * cellW).toFixed(2)}
                y2={(matPadT + MAT_ROWS * cellH).toFixed(2)}
                class="desk__matrix-grid"
              />
            ))
          }
          {
            Array.from({ length: MAT_ROWS + 1 }, (_, r) => (
              <line
                x1={matPadL}
                y1={(matPadT + r * cellH).toFixed(2)}
                x2={MAT_W}
                y2={(matPadT + r * cellH).toFixed(2)}
                class="desk__matrix-grid"
              />
            ))
          }
          {/* Mini-bars per cell */}
          {
            matrix.map((row, r) =>
              row.cells.map((cell, c) => {
                const baseY = matBaselineAt(r);
                return cell.bars.map((b, k) => {
                  const h = Math.max(0.4, Math.abs(b) * matBarMaxHalf);
                  const x = matPadL + c * cellW + 2 + k * (matBarW + matBarGap);
                  const y = b >= 0 ? baseY - h : baseY;
                  const isLast = k === cell.bars.length - 1;
                  const signCls = isLast
                    ? b >= 0
                      ? 'desk__matrix-bar--pos'
                      : 'desk__matrix-bar--neg'
                    : 'desk__matrix-bar--mute';
                  return (
                    <rect
                      x={x.toFixed(2)}
                      y={y.toFixed(2)}
                      width={matBarW.toFixed(2)}
                      height={h.toFixed(2)}
                      class:list={['desk__matrix-bar', signCls]}
                    />
                  );
                });
              }),
            )
          }
          {/* Legend strip (below grid) */}
          <text x={matPadL} y={(MAT_H - 6).toFixed(2)} class="desk__matrix-legend mono">
            <tspan class="desk__matrix-legend-dot desk__matrix-legend-dot--pos">●</tspan>
            <tspan dx="4">+Δ</tspan>
            <tspan dx="12" class="desk__matrix-legend-dot desk__matrix-legend-dot--neg">●</tspan>
            <tspan dx="4">−Δ</tspan>
            <tspan dx="12" class="desk__matrix-legend-dot desk__matrix-legend-dot--mute">●</tspan>
            <tspan dx="4">flat</tspan>
          </text>
        </svg>
      </article>
    </section>

    {
      /* =============================================================
         ROW C — COMPRESSED KPI TILES · semantic recap of the v6.2 cells
         ============================================================= */
    }
    <section class="desk__row desk__row--kpis" aria-label="Book, orders, calendar, alerts summary">
      <article class="desk__kpi" aria-label={`${posCount} positions, net P&L ${posNetPnl} USD`}>
        <p class="desk__kpi-cap mono">Positions</p>
        <p class="desk__kpi-num tnum">{posCount}</p>
        <p class="desk__kpi-sub mono tnum">
          net <span class:list={[posNetPnl >= 0 ? 'desk__kpi-sub--pos' : 'desk__kpi-sub--neg']}>
            {posNetPnl >= 0 ? '+' : '−'}${Math.abs(posNetPnl).toLocaleString()}
          </span>
        </p>
        <p class="desk__kpi-note mono">top · {posTopSymbol}</p>
      </article>
      <article
        class="desk__kpi"
        aria-label={`${ordCount} orders: ${ordOpen} open, ${ordPartial} partial, ${ordAck} ack, ${ordRej} rejected`}
      >
        <p class="desk__kpi-cap mono">Orders</p>
        <p class="desk__kpi-num tnum">{ordCount}</p>
        <p class="desk__kpi-sub mono tnum">
          <span class="desk__kpi-sub--pos">+{ordOpen}</span>
          <span class="desk__kpi-sub-sep">·</span>
          <span>{ordPartial}</span>
          <span class="desk__kpi-sub-sep">·</span>
          <span class="desk__kpi-sub--pos">{ordAck}</span>
          <span class="desk__kpi-sub-sep">·</span>
          <span class="desk__kpi-sub--neg">{ordRej}</span>
        </p>
        <p class="desk__kpi-note mono">open · partial · ack · rej</p>
      </article>
      <article
        class="desk__kpi"
        aria-label={`${calCount} upcoming events, next in ${nextCalHrs} hours, impact ${nextCalImpact}`}
      >
        <p class="desk__kpi-cap mono">Calendar</p>
        <p class="desk__kpi-num tnum">{calCount}</p>
        <p class="desk__kpi-sub mono tnum">next +{nextCalHrs}h</p>
        <p class="desk__kpi-note mono">
          impact <span
            class:list={['desk__kpi-pill', `desk__kpi-pill--${nextCalImpact.toLowerCase()}`]}
            >{nextCalImpact}</span
          >
        </p>
      </article>
      <article
        class="desk__kpi"
        aria-label={`${alertCount} alerts: ${alertCrit} critical, ${alertWarn} warning, ${alertInfo} info`}
      >
        <p class="desk__kpi-cap mono">Alerts</p>
        <p class="desk__kpi-num tnum">{alertCount}</p>
        <p class="desk__kpi-sub mono tnum">
          <span class="desk__kpi-sub--neg">{alertCrit}</span>
          <span class="desk__kpi-sub-sep">·</span>
          <span class="desk__kpi-sub--warn">{alertWarn}</span>
          <span class="desk__kpi-sub-sep">·</span>
          <span>{alertInfo}</span>
        </p>
        <p class="desk__kpi-note mono">crit · warn · info</p>
      </article>
    </section>
  </div>
</section>

<style>
  /* ===== Section shell ===== */
  .desk {
    background: var(--c-bg-2);
    color: var(--c-ink);
    padding-block: var(--sp-6) var(--sp-7);
    border-bottom: 1px solid var(--c-grid-line);
  }
  .desk__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-4);
    max-width: 1180px;
    margin: 0 auto var(--sp-5);
    padding: 0 var(--sp-5);
  }
  .desk__head-left {
    display: flex;
    align-items: baseline;
    gap: var(--sp-4);
    flex-wrap: wrap;
    min-width: 0;
  }
  .desk__head-right {
    font-size: var(--fs-xs);
    color: var(--c-ink-2);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-variant-numeric: tabular-nums;
  }
  .desk__eyebrow {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-amber);
    font-weight: 600;
    margin: 0;
  }
  .desk__title {
    font-size: clamp(1.3rem, 2.6vw, 1.7rem);
    color: var(--c-ink);
    font-weight: 600;
    letter-spacing: -0.014em;
    margin: 0;
    line-height: 1.2;
  }
  .desk__title-em {
    color: var(--c-amber-light);
    margin-left: 0.5em;
    font-size: 0.55em;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.18em 0.5em;
    border: 1px solid var(--c-amber);
    border-radius: 3px;
    vertical-align: middle;
    font-weight: 600;
  }
  .desk__pulse {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--c-amber);
    opacity: 0.85;
  }
  .desk__latency {
    color: var(--c-amber-light);
  }

  /* ===== Panel ===== */
  .desk__panel {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 var(--sp-5);
    display: grid;
    gap: var(--sp-3);
  }

  /* All rows share a dark tape-style container */
  .desk__row {
    background: var(--c-tape);
    border: 1px solid var(--c-grid-line);
    border-radius: var(--radius-sm);
    padding: var(--sp-3) var(--sp-4);
  }
  .desk__row--pnl {
    display: grid;
    grid-template-columns: 1fr minmax(280px, 320px);
    gap: var(--sp-5);
    align-items: center;
  }
  .desk__row--visuals {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-3);
  }
  .desk__row--kpis {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--sp-3);
  }

  @media (max-width: 1024px) {
    .desk__row--pnl {
      grid-template-columns: 1fr;
    }
    .desk__row--visuals {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .desk__row--kpis {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 600px) {
    .desk__row--visuals {
      grid-template-columns: 1fr;
    }
    .desk__row--kpis {
      grid-template-columns: 1fr;
    }
  }

  /* ===== Row A — P&L sparkline ===== */
  .desk__pnl-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }
  .desk__viz-cap {
    color: var(--c-amber);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
    margin: 0;
  }
  .desk__viz-cap--mute {
    color: var(--c-ink-2);
    font-weight: 500;
  }
  .desk__pnl-headline {
    color: var(--c-ink);
    font-size: clamp(1.6rem, 3.4vw, 2.2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1;
  }
  .desk__pnl-headline--pos {
    color: var(--c-pass);
  }
  .desk__pnl-headline--neg {
    color: var(--c-fail);
  }
  .desk__pnl-cap--inline {
    color: var(--c-ink-2);
    font-size: 0.7rem;
    margin-left: 0.5rem;
    letter-spacing: 0.08em;
  }
  .desk__pnl-sub {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin: 0;
    color: var(--c-ink-2);
    font-size: 0.78rem;
  }
  .desk__pnl-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .desk__pnl-stat-num {
    color: var(--c-ink);
    font-size: 0.95rem;
    font-weight: 600;
  }
  .desk__pnl-stat-cap {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink-2);
  }
  .desk__pnl-stat--neg .desk__pnl-stat-num {
    color: var(--c-fail);
  }

  .desk__spark {
    width: 100%;
    height: 48px;
    display: block;
  }
  .desk__spark-dd {
    fill: var(--c-fail);
    opacity: 0.12;
  }
  .desk__spark-base {
    stroke: var(--c-grid-line);
    stroke-width: 0.6;
    stroke-dasharray: 1.5 1.5;
  }
  .desk__spark-bar {
    shape-rendering: crispEdges;
  }
  .desk__spark-bar--pos {
    fill: var(--c-data-positive);
  }
  .desk__spark-bar--neg {
    fill: var(--c-data-negative);
  }
  .desk__spark-bar--strong {
    opacity: 1;
  }

  /* ===== Row B — visual panels ===== */
  .desk__viz {
    background: var(--c-bg-2);
    border: 1px solid var(--c-grid-line);
    border-radius: var(--radius-sm);
    padding: var(--sp-3);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
  }
  .desk__viz-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-2);
    border-bottom: 1px solid var(--c-grid-line);
    padding-bottom: var(--sp-2);
  }
  .desk__viz-num {
    font-size: 0.85rem;
    font-weight: 600;
  }
  .desk__viz-num-pos {
    color: var(--c-pass);
  }
  .desk__viz-num-neg {
    color: var(--c-fail);
  }
  .desk__viz-num-sep {
    color: var(--c-ink-2);
    margin: 0 0.3em;
  }
  .desk__viz-foot {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: auto;
  }
  .desk__viz-pill {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-2);
    padding: 0.18em 0.5em;
    border: 1px solid var(--c-grid-line);
    border-radius: 3px;
  }

  /* Order-flow tape */
  .desk__tape {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    grid-auto-rows: 1fr;
    gap: 2px;
    aspect-ratio: 16 / 5;
    width: 100%;
  }
  .desk__tape-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    padding: 2px;
    border-radius: 2px;
    color: var(--c-ink);
    background: color-mix(in oklab, var(--c-grid-line) calc(var(--t) * 100%), transparent);
    border: 1px solid var(--c-grid-line);
    font-family: var(--ff-mono);
    line-height: 1;
    min-height: 22px;
  }
  .desk__tape-cell--bid {
    background: color-mix(in oklab, var(--c-data-positive) calc(var(--t) * 100%), transparent);
    border-color: color-mix(
      in oklab,
      var(--c-data-positive) calc((var(--t) + 0.3) * 100%),
      transparent
    );
  }
  .desk__tape-cell--ask {
    background: color-mix(in oklab, var(--c-data-negative) calc(var(--t) * 100%), transparent);
    border-color: color-mix(
      in oklab,
      var(--c-data-negative) calc((var(--t) + 0.3) * 100%),
      transparent
    );
  }
  .desk__tape-side {
    font-size: 0.5rem;
    opacity: 0.85;
    letter-spacing: 0.08em;
  }
  .desk__tape-size {
    font-size: 0.78rem;
    font-weight: 600;
  }

  /* Risk gauge */
  .desk__gauge {
    width: 100%;
    height: auto;
    display: block;
    flex: 1 1 auto;
  }
  .desk__gauge-arc {
    stroke-width: 6;
    stroke-linecap: butt;
  }
  .desk__gauge-arc--safe {
    stroke: var(--c-pass);
    stroke-opacity: 0.45;
  }
  .desk__gauge-arc--warn {
    stroke: var(--c-amber);
    stroke-opacity: 0.55;
  }
  .desk__gauge-arc--alert {
    stroke: var(--c-fail);
    stroke-opacity: 0.55;
  }
  /* v6.7.1 — gauge ticks made more visible. v6.6 had them at ink-2
     8px which read as ghostly hairline. Bumped to ink + 9px + amber
     sub-ticks at quarter marks (12.5 / 37.5 / 62.5 / 87.5) for
     finer-grained read. */
  .desk__gauge-tick {
    stroke: var(--c-amber);
    stroke-width: 1.25;
  }
  .desk__gauge-ticklbl {
    font-size: var(--fs-3xs);
    fill: var(--c-ink);
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .desk__gauge-tick--minor {
    stroke: var(--c-ink-3);
    stroke-width: 0.75;
  }
  .desk__gauge-needle {
    stroke: var(--c-amber);
    stroke-width: 1.8;
    stroke-linecap: round;
  }
  .desk__gauge-hub {
    fill: var(--c-amber-light);
  }
  .desk__gauge-readout {
    font-size: 18px;
    font-weight: 600;
  }
  .desk__gauge-readout--safe {
    fill: var(--c-pass);
  }
  .desk__gauge-readout--warn {
    fill: var(--c-amber-light);
  }
  .desk__gauge-readout--alert {
    fill: var(--c-fail);
  }
  .desk__gauge-readout-cap {
    font-size: var(--fs-3xs); font-size: 7px;
    fill: var(--c-ink-2);
    letter-spacing: 0.08em;
  }

  /* Signal matrix */
  .desk__matrix {
    width: 100%;
    height: 90px;
    display: block;
  }
  .desk__matrix-axis {
    font-size: var(--fs-3xs); font-size: 7px;
    fill: var(--c-ink-2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .desk__matrix-axis--sig {
    fill: var(--c-amber);
    font-weight: 600;
  }
  .desk__matrix-grid {
    stroke: var(--c-grid-line);
    stroke-width: 0.5;
  }
  .desk__matrix-bar {
    shape-rendering: crispEdges;
  }
  .desk__matrix-bar--mute {
    fill: var(--c-ink-2);
    opacity: 0.45;
  }
  .desk__matrix-bar--pos {
    fill: var(--c-data-positive);
  }
  .desk__matrix-bar--neg {
    fill: var(--c-data-negative);
  }
  .desk__matrix-legend {
    font-size: var(--fs-3xs); font-size: 7px;
    fill: var(--c-ink-2);
    letter-spacing: 0.04em;
  }
  .desk__matrix-legend-dot--pos {
    fill: var(--c-data-positive);
  }
  .desk__matrix-legend-dot--neg {
    fill: var(--c-data-negative);
  }
  .desk__matrix-legend-dot--mute {
    fill: var(--c-ink-2);
    opacity: 0.5;
  }

  /* ===== Row C — KPI tiles ===== */
  .desk__kpi {
    background: var(--c-bg-2);
    border: 1px solid var(--c-grid-line);
    border-radius: var(--radius-sm);
    padding: var(--sp-3) var(--sp-3) var(--sp-3);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .desk__kpi-cap {
    color: var(--c-amber);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
    margin: 0;
  }
  .desk__kpi-num {
    color: var(--c-ink);
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1;
    margin: 0;
  }
  .desk__kpi-sub {
    color: var(--c-ink-2);
    font-size: 0.78rem;
    margin: 0;
    font-weight: 500;
  }
  .desk__kpi-sub--pos {
    color: var(--c-pass);
  }
  .desk__kpi-sub--neg {
    color: var(--c-fail);
  }
  .desk__kpi-sub--warn {
    color: var(--c-amber-light);
  }
  .desk__kpi-sub-sep {
    color: var(--c-ink-2);
    margin: 0 0.25rem;
  }
  .desk__kpi-note {
    color: var(--c-ink-2);
    font-size: 0.62rem;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .desk__kpi-pill {
    display: inline-block;
    font-size: 0.6rem;
    padding: 0.1em 0.5em;
    border-radius: 3px;
    border: 1px solid currentColor;
    font-weight: 600;
    letter-spacing: 0.08em;
    margin-left: 0.4rem;
  }
  .desk__kpi-pill--high {
    color: var(--c-fail);
  }
  .desk__kpi-pill--med {
    color: var(--c-amber-light);
  }
  .desk__kpi-pill--low {
    color: var(--c-ink-2);
  }
</style>
