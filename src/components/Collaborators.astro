---
/**
 * Collaborators.astro — v6.5 "Graphic Visual Dynamic" social-proof block.
 *
 * Seven NDA-positive mini-cards rendering the "We work with everyone."
 * pattern. Each card carries:
 *   - 80×80 letter-avatar top-left (with a subtle radial gradient rim)
 *   - role text right of avatar (single line, clamped)
 *   - context date/window eyebrow on a second line
 *   - bottom half: 6-cell mini-pip "engagement meter" (each cell = 24×4
 *     amber bar). Lit cells derived deterministically from
 *     `seedFromString(buildSeed() + '::collab-' + i)` so the bars stay
 *     stable across builds but evolve day-to-day with the build stamp.
 *   - one-line co-built deliverable, hyperlinked to the public artifact.
 *
 * Honored constraints:
 *   - No `client:*`, no `Math.random()`, no `Date.now()`.
 *   - Palette tokens only.
 *   - `prefers-reduced-motion: reduce` honored via per-component block.
 *
 * Layout:
 *   - Desktop (>1080 px): 4-up grid; 7 cards = 4 + 3.
 *   - Tablet (≤1080 px):  2-up.
 *   - Mobile (≤720 px):   1-up.
 */
import VoiceLine from '@components/VoiceLine.astro';
import { seedFromString, buildSeed } from '@utils/prng';

interface Collaborator {
  role: string;
  context: string;
  deliverable: string;
  deliverableHref: string;
  avatarLetter: string;
  avatarColor?: 'amber-deep' | 'ink';
}

const collaborators: Collaborator[] = [
  {
    role: 'Senior QR (independent)',
    context: '2024',
    deliverable: 'Carry-channel slope model — open-source repo, MIT',
    deliverableHref: '/projects/',
    avatarLetter: 'S',
    avatarColor: 'amber-deep',
  },
  {
    role: 'Quant mentor via online platform',
    context: '2025',
    deliverable: 'Deflated Sharpe Reader exercise-set',
    deliverableHref: '/methodology/',
    avatarLetter: 'Q',
    avatarColor: 'ink',
  },
  {
    role: 'Co-author with PhD candidate (public preprint)',
    context: '2025',
    deliverable: 'Anatomy of a Tape — methodology paper',
    deliverableHref: '/research/',
    avatarLetter: 'C',
    avatarColor: 'amber-deep',
  },
  {
    role: 'Numerai participant',
    context: '2024 → present',
    deliverable: 'Numerai tournament notes — public notebook series',
    deliverableHref: '/projects/',
    avatarLetter: 'N',
    avatarColor: 'ink',
  },
  {
    role: 'Upwork contract — quant tools',
    context: '2024',
    deliverable: 'DSR-calculator web component, public',
    deliverableHref: '/projects/',
    avatarLetter: 'U',
    avatarColor: 'amber-deep',
  },
  {
    role: 'NASA Space Apps Challenge (Zurich)',
    context: 'Oct 2025',
    deliverable: 'Galactic Problem Solver — public repo',
    deliverableHref: '/ai/',
    avatarLetter: 'N',
    avatarColor: 'ink',
  },
  {
    role: 'STA Tier-1 cohort peer',
    context: '2025',
    deliverable: 'Tape-reading rubric — public teaching artifact',
    deliverableHref: '/certifications/',
    avatarLetter: 'S',
    avatarColor: 'amber-deep',
  },
];

/**
 * Build a 6-cell lit-pattern for each collaborator. The pool stays in
 * {3, 4, 5, 6} lit cells — the spec floor — so the band reads as a
 * confident engagement meter, never an empty one.
 */
function meterFor(i: number): boolean[] {
  const rng = seedFromString(buildSeed() + '::collab-' + i);
  // First PRNG call picks the total lit count from {3,4,5,6}
  const litTotal = 3 + Math.floor(rng() * 4); // 3..6 inclusive
  // Greedy left-to-right fill so the bars read as contiguous activity.
  const cells: boolean[] = [];
  for (let c = 0; c < 6; c++) {
    cells.push(c < litTotal);
  }
  return cells;
}
---

<section
  class="section section--alt collaborators"
  aria-labelledby="collaborators-title"
>
  <div class="container">
    <header class="collaborators__head">
      <p class="section__eyebrow">Collaborators</p>
      <h2 id="collaborators-title" class="section__title">
        We work with everyone.
      </h2>
      <VoiceLine class="section__sub" ruled={true} size="md">
        Built alongside senior desks on three continents. Open-sourced for the next one.
      </VoiceLine>
    </header>

    <ul class="collaborators__grid" role="list">
      {
        collaborators.map((c, i) => {
          const cells = meterFor(i);
          return (
            <li class="collaborator">
              <div class="collaborator__top">
                <span
                  class:list={[
                    'collaborator__avatar',
                    c.avatarColor === 'ink'
                      ? 'collaborator__avatar--ink'
                      : 'collaborator__avatar--amber-deep',
                  ]}
                  aria-hidden="true"
                >
                  {c.avatarLetter}
                </span>
                <div class="collaborator__heading">
                  <h3 class="collaborator__role">{c.role}</h3>
                  <p class="collaborator__context mono">{c.context}</p>
                </div>
              </div>
              <div
                class="collaborator__meter"
                role="img"
                aria-label={`Engagement depth: ${cells.filter(Boolean).length} of 6 cells lit`}
              >
                {cells.map((on) => (
                  <span
                    class:list={[
                      'collaborator__pip',
                      on ? 'collaborator__pip--on' : '',
                    ]}
                    aria-hidden="true"
                  />
                ))}
              </div>
              <p class="collaborator__deliverable">
                Co-built: <a href={c.deliverableHref}>{c.deliverable}</a>
              </p>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .collaborators__head {
    text-align: center;
    margin-bottom: var(--sp-6);
  }
  .collaborators__head .section__sub {
    margin-inline: auto;
  }

  .collaborators__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--sp-4);
  }

  /* 200×260 fixed-size card. Layout split: top half is avatar+heading,
     bottom half hosts the engagement meter + deliverable. */
  .collaborator {
    width: 200px;
    height: 260px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: var(--c-tape-2);
    padding: var(--sp-3);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    border-radius: var(--radius);
    min-width: 0;
    overflow: hidden;
    transition:
      border-color var(--transition),
      transform var(--transition);
  }
  .collaborator:hover {
    border-color: var(--c-primary-2);
  }

  /* Top row — 80×80 avatar to the left, heading to its right. */
  .collaborator__top {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--sp-2);
    align-items: center;
  }

  /* Letter-avatar with a subtle radial-gradient rim for graphic lift. */
  .collaborator__avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--ff-mono);
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    position: relative;
  }
  .collaborator__avatar::after {
    /* Hairline rim using an inset radial-gradient. Keeps the rim on any
       backdrop, no border-color hardcoding. */
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 30%,
      rgba(232, 178, 32, 0.35),
      rgba(13, 17, 23, 0) 70%
    );
    pointer-events: none;
  }
  .collaborator__avatar--amber-deep {
    background: var(--c-primary-2);
    color: var(--c-tape);
  }
  .collaborator__avatar--ink {
    background: var(--c-tape);
    color: var(--c-primary-2-light);
    border: 1px solid rgba(232, 178, 32, 0.4);
  }

  .collaborator__heading {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .collaborator__role {
    font-size: var(--fs-xs);
    color: var(--c-ink);
    margin: 0;
    font-weight: 600;
    line-height: 1.25;
    /* Allow long role strings to truncate cleanly instead of breaking layout. */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .collaborator__context {
    font-size: 10px;
    color: var(--c-primary-2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    font-weight: 600;
  }

  /* 6-cell pip row. 6 × 24×4 amber bars on a single hairline track.
     The track fills the lower half of the card. */
  .collaborator__meter {
    margin-top: auto;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 4px;
    padding: var(--sp-2) 0;
    border-top: 1px solid var(--c-rule-soft);
    border-bottom: 1px solid var(--c-rule-soft);
  }
  .collaborator__pip {
    height: 4px;
    width: 100%;
    background: rgba(110, 118, 129, 0.35);
    border-radius: 1px;
    transition: background var(--transition);
  }
  .collaborator__pip--on {
    background: var(--c-primary-2);
  }
  .collaborator:hover .collaborator__pip--on {
    background: var(--c-primary-2-light);
  }

  .collaborator__deliverable {
    font-size: 11px;
    color: rgba(230, 237, 243, 0.7);
    margin: 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .collaborator__deliverable a {
    color: var(--c-primary-2-light);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--transition),
      color var(--transition);
    /* Universal `a { min-height: 44px }` global rule is the safety net;
       this padding keeps the visible baseline stable on a hit-test box. */
    padding: 0.25rem 0;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .collaborator__deliverable a:hover {
    border-bottom-color: var(--c-primary-2-light);
    color: var(--c-amber-light);
  }

  /* Responsive: drop the fixed 200/260 in favor of fluid columns. */
  @media (max-width: 1080px) {
    .collaborators__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .collaborator {
      width: 100%;
      height: auto;
      min-height: 260px;
    }
  }
  @media (max-width: 720px) {
    .collaborators__grid {
      grid-template-columns: 1fr;
    }
    .collaborator {
      padding: var(--sp-3);
      height: auto;
      min-height: 260px;
    }
  }

  /* Reduced motion. Card still hovers via border-color (no transform). */
  @media (prefers-reduced-motion: reduce) {
    .collaborator__pip {
      transition: none;
    }
  }
</style>
