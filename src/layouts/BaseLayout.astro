---
/**
 * BaseLayout.astro — wraps every page; owns head, nav, footer.
 */
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@styles/tokens.css';
import '@styles/global.css';
import '@styles/print.css';
import 'katex/dist/katex.min.css';

import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { profile } from '@utils/profile';
import { buildMeta, personJsonLd, websiteJsonLd, breadcrumbJsonLd } from '@utils/seo';
import { path } from '@utils/url';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  className?: string;
  extraJsonLd?: unknown; // optional page-specific JSON-LD (e.g. ItemList, CreativeWork)
  breadcrumbs?: Array<{ name: string; href: string }>; // optional BreadcrumbList JSON-LD
}

const { title, description, image, type = 'website', className, extraJsonLd, breadcrumbs } =
  Astro.props;
const meta = buildMeta({
  title,
  description: description ?? profile.titles.secondary,
  // Default og:image is the headshot banner. `path()` prepends the configured
  // base (`/portfolio` on GH Pages) so the resolved URL points at the actual
  // deployed asset, not the site root.
  image: image ? path(image) : path('/og-image.jpg'),
  type,
  pathname: Astro.url.pathname,
});
const jsonLd = personJsonLd({
  fullName: profile.fullName,
  titles: profile.titles,
  location: profile.location,
  contact: profile.contact,
  knowsAbout: profile.knowsAbout,
  alumniOf: profile.alumniOf,
  awards: profile.awards,
});
const siteJsonLd = websiteJsonLd();
const crumbsJsonLd = breadcrumbs ? breadcrumbJsonLd(breadcrumbs) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={meta.canonical} />

    {/* === v6.0 · security meta baseline ===
        Defense in depth alongside CF Pages CDN headers.
        JSON-LD <script type="application/ld+json"> is exempt from
        `script-src` by every modern browser (CSP3 spec, also Chromium
        exempts it for compatibility). The CSP still blocks inline JS. */}
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com data:; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <meta property="og:type" content={meta.openGraph.type} />
    <meta property="og:title" content={meta.openGraph.title} />
    <meta property="og:description" content={meta.openGraph.description} />
    <meta property="og:url" content={meta.openGraph.url} />
    <meta property="og:site_name" content={meta.openGraph.site_name} />
    {
      meta.openGraph.images?.map((img: { url: string }) => (
        <meta property="og:image" content={img.url} />
      ))
    }

    <meta name="twitter:card" content={meta.twitter.card} />
    <meta name="twitter:title" content={meta.twitter.title} />
    <meta name="twitter:description" content={meta.twitter.description} />
    {meta.twitter.images?.map((src: string) => <meta name="twitter:image" content={src} />)}

    <!-- CM monogram: single-color for browser tabs + bookmarks (currentColor
         inherits from the user-agent's icon color rule); amber variant is the
         primary brand mark used in nav, og:image, and About hero. -->
    <link rel="icon" type="image/svg+xml" href={path('/cm-mark.svg')} />
    <link rel="apple-touch-icon" href={path('/cm-mark-amber.svg')} />
    <link rel="mask-icon" href={path('/cm-mark.svg')} color="#0a0e14" />
    <link rel="sitemap" href={path('/sitemap-index.xml')} />
    <link
      rel="alternate"
      type="application/atom+xml"
      title={`${profile.fullName} — Portfolio Updates`}
      href={path('/feed.xml')}
    />
    {/* LLM-friendly alternates — short index + full concatenated Markdown.
         Crawlers respect rel=alternate type=text/markdown as a first-class
         signal (llmstxt.org convention). See public/llms.txt and
         public/llms-full.txt. */}
    <link
      rel="alternate"
      type="text/markdown"
      title={`${profile.fullName} — llms.txt (curated index)`}
      href={path('/llms.txt')}
    />
    <link
      rel="alternate"
      type="text/markdown"
      title={`${profile.fullName} — llms-full.txt (full content)`}
      href={path('/llms-full.txt')}
    />
    <meta name="theme-color" content="#0a0e14" />

    {/* === v6.1.0 — theme toggle REMOVED. The site is always cream
         paper with institutional-tape sections. No light/dark flip. === */}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
    {crumbsJsonLd && <script type="application/ld+json" set:html={JSON.stringify(crumbsJsonLd)} />}
    {extraJsonLd && <script type="application/ld+json" set:html={JSON.stringify(extraJsonLd)} />}
  </head>
  <body class={className}>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    {/* === v6.1.0 · institutional motion bundle ===
        All scripts are pure-defer; total minified+gzipped < 4KB.
        They respect prefers-reduced-motion on their own.
        theme-toggle removed; everything else preserved.
        v6.2 Mission Q — hero-video driver added: pauses the
        <video> child of HeroVideo.astro when prefers-reduced-motion
        is on. No-op on the SVG fallback path. */}
    <script>
      import '@scripts/reveal-on-scroll.ts';
      import '@scripts/odometer.ts';
      import '@scripts/active-nav.ts';
      import '@scripts/copy-button.ts';
      import '@scripts/scroll-progress.ts';
      import '@scripts/carousel.ts';
      import '@scripts/hero-video.ts';
      import '@scripts/keyboard-shortcuts.ts';
      import '@scripts/globe.ts';
    </script>
  </body>
</html>
